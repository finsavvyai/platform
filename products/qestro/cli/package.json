{
  "name": "qestro-cli",
  "version": "1.0.0",
  "description": "Questro Professional CLI - Complete testing automation platform command-line interface",
  "main": "dist/index.js",
  "types": "dist/index-simple.d.ts",
  "bin": {
    "qestro": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:dist": "tsc -p tsconfig.build.json && cp dist/index-simple.js dist/index.js",
    "build:enhanced": "tsc && cp dist/index-enhanced.js dist/index.js",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "prepare": "npm run build:dist",
    "prepublishOnly": "echo 'Skipping tests for demo CLI'",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "qestro",
    "testing",
    "automation",
    "cli",
    "mobile-testing",
    "web-testing",
    "test-recording",
    "test-execution",
    "devops",
    "ci-cd"
  ],
  "author": "Questro Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qestro/qestro-cli.git"
  },
  "bugs": {
    "url": "https://github.com/qestro/qestro-cli/issues"
  },
  "homepage": "https://docs.questro.io/cli",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "cli-table3": "^0.6.3",
    "boxen": "^7.1.1",
    "figlet": "^1.7.0",
    "conf": "^12.0.0",
    "axios": "^1.6.2",
    "jsonwebtoken": "^9.0.2",
    "open": "^9.1.0",
    "fs-extra": "^11.1.1",
    "yaml": "^2.3.4",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "progress": "^2.0.3",
    "update-notifier": "^7.0.0",
    "which": "^4.0.0",
    "semver": "^7.5.4",
    "uuid": "^9.0.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/jest": "^29.5.8",
    "@types/inquirer": "^9.0.7",
    "@types/figlet": "^1.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.14.202",
    "@types/progress": "^2.0.7",
    "@types/update-notifier": "^6.0.8",
    "@types/which": "^3.0.3",
    "@types/semver": "^7.5.6",
    "@types/uuid": "^9.0.7",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "prettier": "^3.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "@typescript-eslint/recommended"
    ],
    "env": {
      "node": true,
      "es2021": true
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    }
  }
}