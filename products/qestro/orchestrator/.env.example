# Qestro AI Orchestrator Environment Variables

# Required: OpenAI API Key (for CrewAI and code generation)
OPENAI_API_KEY=sk-your-key-here

# Optional: Anthropic API Key (for Claude-based agents)
ANTHROPIC_API_KEY=

# OpenHands AI Engine URL (your deployed Cloudflare Worker)
OPENHANDS_API_URL=https://openhands-ai-engine.workers.dev
OPENHANDS_API_KEY=

# Bolt.new automation (optional - for full automation)
# Session token from browser cookies
BOLT_SESSION_TOKEN=

# Git configuration
GIT_AUTHOR_NAME=Qestro AI
GIT_AUTHOR_EMAIL=ai@qestro.dev

# Model configuration
DEFAULT_LLM_MODEL=gpt-4-turbo
FAST_LLM_MODEL=gpt-3.5-turbo

# Feature flags
ENABLE_BOLT_AUTOMATION=false
ENABLE_AUTO_COMMIT=false
VERBOSE_MODE=true
