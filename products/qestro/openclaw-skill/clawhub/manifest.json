{
    "name": "qestro",
    "version": "1.0.0",
    "displayName": "Qestro QA Agent",
    "description": "AI-Powered Test Automation — run tests, view failures, generate test cases, get AI analysis, and manage your QA pipeline directly from any messaging app.",
    "author": {
        "name": "Qestro Engineering",
        "email": "skills@qestro.com",
        "url": "https://qestro.com"
    },
    "license": "MIT",
    "repository": "https://github.com/finsavvyai/qestro-openclaw-skill",
    "homepage": "https://qestro.com/integrations/openclaw",
    "categories": [
        "Developer Tools",
        "Testing & QA",
        "AI & Automation",
        "DevOps"
    ],
    "tags": [
        "qa",
        "testing",
        "automation",
        "playwright",
        "cypress",
        "ai",
        "test-generation",
        "self-healing",
        "ci-cd",
        "devops",
        "quality-assurance"
    ],
    "icon": "🧪",
    "color": "#6C63FF",
    "commands": [
        {
            "name": "dashboard",
            "description": "View real-time QA metrics and system health",
            "usage": "qestro dashboard",
            "examples": [
                "Show me the QA dashboard",
                "What's the current test status?"
            ]
        },
        {
            "name": "run-suite",
            "description": "Trigger a test suite execution",
            "usage": "qestro run-suite [suite-name]",
            "parameters": [
                {
                    "name": "suite-name",
                    "description": "Name of the test suite to run",
                    "required": false,
                    "default": "default",
                    "examples": [
                        "login-regression",
                        "checkout-e2e",
                        "api-smoke"
                    ]
                }
            ],
            "examples": [
                "Run the login regression suite",
                "Execute checkout tests"
            ]
        },
        {
            "name": "failures",
            "description": "View recent test failures with error details",
            "usage": "qestro failures",
            "examples": [
                "Show me recent failures",
                "What tests are failing?"
            ]
        },
        {
            "name": "analyze",
            "description": "Get AI-powered analysis of a test failure",
            "usage": "qestro analyze [test-id]",
            "parameters": [
                {
                    "name": "test-id",
                    "description": "The test case ID to analyze",
                    "required": true,
                    "examples": [
                        "TC-PAY-001",
                        "TC-AUTH-003"
                    ]
                }
            ],
            "examples": [
                "Analyze why TC-PAY-001 is failing",
                "What's wrong with the payment test?"
            ]
        },
        {
            "name": "generate",
            "description": "Generate test cases from natural language descriptions",
            "usage": "qestro generate [description]",
            "parameters": [
                {
                    "name": "description",
                    "description": "Natural language description of the test scenario",
                    "required": true,
                    "examples": [
                        "Test login with Google OAuth",
                        "Verify checkout with expired coupon",
                        "Test API rate limiting on /api/users"
                    ]
                }
            ],
            "examples": [
                "Generate a test for the login page with 2FA",
                "Create tests for the payment API"
            ]
        },
        {
            "name": "self-healing",
            "description": "Trigger AI self-healing for broken tests",
            "usage": "qestro self-healing",
            "examples": [
                "Run self-healing on failing tests",
                "Fix broken selectors"
            ]
        },
        {
            "name": "daily-summary",
            "description": "Get the daily QA digest with trends",
            "usage": "qestro daily-summary",
            "examples": [
                "Give me today's QA summary",
                "What happened with tests today?"
            ]
        }
    ],
    "requirements": {
        "openclaw": ">=0.1.0",
        "python": ">=3.9",
        "dependencies": [
            "requests",
            "rich"
        ]
    },
    "configuration": {
        "required": [
            {
                "key": "QESTRO_API_URL",
                "description": "URL of your Qestro backend API",
                "default": "http://localhost:8000"
            }
        ],
        "optional": [
            {
                "key": "QESTRO_API_KEY",
                "description": "API key for authenticated access"
            },
            {
                "key": "QESTRO_PROJECT_ID",
                "description": "Default project ID",
                "default": "default"
            }
        ]
    },
    "files": {
        "skill": "SKILL.md",
        "client": "scripts/qestro_client.py",
        "installer": "install.sh"
    },
    "capabilities": {
        "browser_control": true,
        "messaging": true,
        "webhooks": true,
        "realtime_notifications": true
    },
    "pricing": {
        "model": "free",
        "note": "Requires Qestro account (free tier available)"
    }
}