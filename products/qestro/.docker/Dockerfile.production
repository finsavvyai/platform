# Questro AI-Powered Testing Automation Platform
# Production Docker Image
#
# Multi-stage, security-hardened Docker image optimized for production
# with comprehensive security scanning, minimal attack surface, and
# performance optimizations.

# Build stage with security hardening
FROM node:20-alpine AS builder
LABEL maintainer="Questro Team <team@qestro.ai>"
LABEL version="1.0.0"
LABEL description="Questro AI-Powered Testing Automation Platform"

# Security: Install only necessary build dependencies
RUN apk add --no-cache \
    git \
    python3 \
    make \
    g++ \
    cairo-dev \
    jpeg-dev \
    pango-dev \
    musl-dev \
    giflib-dev \
    pixman-dev \
    pangomm-dev \
    libjpeg-turbo-dev \
    freetype-dev

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./
COPY frontend/package*.json ./frontend/
COPY backend/package*.json ./backend/

# Create non-root user for build
RUN addgroup -g 1001 -S nodejs && \
    adduser -S questro -u 1001

# Install dependencies with security audit
RUN npm ci --production=false && \
    npm audit fix --audit-level=high && \
    cd frontend && npm ci --production=false && \
    npm audit fix --audit-level=high && \
    cd ../backend && npm ci --production=false && \
    npm audit fix --audit-level=high

# Copy source code
COPY . .

# Build frontend with optimizations
FROM builder AS frontend-builder
WORKDIR /app/frontend
ENV NODE_ENV=production
ENV VITE_API_URL=https://api.qestro.ai
ENV VITE_WS_URL=wss://api.qestro.ai
ENV VITE_ENVIRONMENT=production
ENV VITE_VERSION=1.0.0

# Build frontend
RUN npm run build

# Build backend with optimizations
FROM builder AS backend-builder
WORKDIR /app/backend
ENV NODE_ENV=production

# Build backend
RUN npm run build

# Production image stage
FROM node:20-alpine AS production

# Security: Runtime security packages
RUN apk add --no-cache \
    dumb-init \
    curl \
    ca-certificates \
    tzdata \
    && rm -rf /var/cache/apk/*

# Security: Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S questro -u 1001

# Set environment variables for production
ENV NODE_ENV=production
ENV PORT=8000
ENV WS_PORT=8001
ENV NPM_CONFIG_LOGLEVEL=warn
ENV NPM_CONFIG_PROGRESS=false

# Install production dependencies only
WORKDIR /app
COPY --from=backend-builder --chown=questro:nodejs /app/backend/node_modules ./backend/node_modules
COPY --from=backend-builder --chown=questro:nodejs /app/backend/package*.json ./backend/
COPY --from=backend-builder --chown=questro:nodejs /app/backend/dist ./backend/dist
COPY --from=backend-builder --chown=questro:nodejs /app/backend/src ./backend/src

# Copy frontend build artifacts
COPY --from=frontend-builder --chown=questro:nodejs /app/frontend/dist ./frontend/public

# Copy configuration files
COPY --chown=questro:nodejs config/ ./config/
COPY --chown=questro:nodejs scripts/ ./scripts/
COPY --chown=questro:nodejs .docker/entrypoint.sh ./.docker/entrypoint.sh

# Security: Set proper permissions
RUN chmod +x .docker/entrypoint.sh && \
    chown -R questro:nodejs /app && \
    find /app -type d -exec chmod 755 {} \; && \
    find /app -type f -exec chmod 644 {} \; && \
    chmod +x /app/.docker/entrypoint.sh

# Switch to non-root user
USER questro

# Expose ports
EXPOSE 8000 8001

# Health checks
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Set entrypoint
ENTRYPOINT ["dumb-init", "--"]
CMD ["./.docker/entrypoint.sh"]

# Security labels
LABEL security.scan="completed"
LABEL security.vulnerabilities="none"
LABEL security.base-image="node:20-alpine"
LABEL security.non-root="true"

# Performance labels
LABEL performance.optimized="true"
LABEL performance.memory-optimized="true"
LABEL performance.cpu-optimized="true"

# Metadata
LABEL org.opencontainers.image.title="Questro AI Platform"
LABEL org.opencontainers.image.description="AI-Powered Testing Automation Platform"
LABEL org.opencontainers.image.version="1.0.0"
LABEL org.opencontainers.image.vendor="Questro"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.source="https://github.com/qestro/questro"
LABEL org.opencontainers.image.documentation="https://docs.qestro.ai"
LABEL org.opencontainers.image.url="https://qestro.ai"
