# Qestro Deployment Environment Variables
# Copy this file to .env and fill in actual values
# DO NOT commit actual secrets to version control

# Application Configuration
NODE_ENV=production
APP_NAME=Qestro
APP_VERSION=1.0.0
ENVIRONMENT=production

# API Configuration
API_URL=https://api.qestro.app
FRONTEND_URL=https://qestro.app
BACKEND_AUTH_URL=https://backend.qestro.app
CORS_ALLOWED_ORIGINS=https://qestro.app,https://preview.qestro.app

# Security & JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-required
JWT_EXPIRATION=7d

# AI Provider - OpenAI for test generation and analysis
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
AI_CACHE_TTL=86400

# Payment Processing - LemonSqueezy
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_WEBHOOK_SECRET=your-lemonsqueezy-webhook-secret
LEMONSQUEEZY_STORE_ID=your-store-id

# OAuth Configuration - GitHub
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_OAUTH_REDIRECT_URI=https://api.qestro.app/oauth/github/callback

# OAuth Configuration - Azure AD
AZURE_OAUTH_CLIENT_ID=your-azure-client-id
AZURE_OAUTH_CLIENT_SECRET=your-azure-client-secret
AZURE_OAUTH_TENANT=your-tenant-id

# OAuth Configuration - Google
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Email Service - Resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@qestro.app

# Database Configuration (managed by Cloudflare D1)
DATABASE_URL=file:./db.sqlite

# Logging
LOG_LEVEL=warn
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Feature Flags
FEATURE_VISUAL_REGRESSION=true
FEATURE_MOBILE_TESTING=true
FEATURE_CI_CD_INTEGRATION=true
FEATURE_AI_OPTIMIZATION=true

# Timeouts & Limits
TEST_EXECUTION_TIMEOUT=300000
SCREENSHOT_MAX_SIZE=10485760
RECORDING_MAX_SIZE=104857600
MAX_CONCURRENT_TESTS=10

# Browser Configuration
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_NAVIGATION_TIMEOUT=30000
CHROMIUM_LAUNCH_ARGS=--no-sandbox,--disable-setuid-sandbox

# Mobile Testing - Maestro Configuration
MAESTRO_CLOUD_API_KEY=your-maestro-cloud-api-key
MAESTRO_TIMEOUT=120000

# CDN & Storage (Cloudflare R2)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key

# Monitoring & Analytics
ANALYTICS_ENABLED=true
PERFORMANCE_MONITORING_ENABLED=true
ERROR_TRACKING_ENABLED=true

# Development Only
DEBUG=qestro:*
MOCK_EXTERNAL_SERVICES=false
