{
  "extends": "../../../backend/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmitOnError": false,
    "allowImportingTsExtensions": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../../backend/src/*"],
      "@tests/*": ["./*"],
      "@fixtures/*": ["./fixtures/*"],
      "@utils/*": ["./utils/*"],
      "@mocks/*": ["./mocks/*"]
    },
    "types": [
      "jest",
      "node",
      "@types/supertest"
    ]
  },
  "include": [
    "./**/*.ts",
    "./**/*.js",
    "../../../backend/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../../../backend/dist"
  ]
}
