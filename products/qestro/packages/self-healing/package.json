{
  "name": "@qestro/self-healing",
  "version": "0.1.0",
  "description": "AI-powered self-healing selectors for Playwright tests. Auto-fix broken tests when your UI changes.",
  "keywords": [
    "playwright",
    "testing",
    "self-healing",
    "qa",
    "test-automation",
    "ai-testing",
    "selectors",
    "e2e",
    "qestro"
  ],
  "homepage": "https://qestro.app",
  "bugs": {
    "url": "https://github.com/finsavvyai/questro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finsavvyai/questro.git",
    "directory": "packages/self-healing"
  },
  "license": "MIT",
  "author": "Qestro <info@qestro.app> (https://qestro.app)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/cjs-rename.mjs",
    "clean": "rm -rf dist dist-cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "publish:dry": "npm publish --dry-run --access public"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
