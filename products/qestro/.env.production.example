# ============================================
# QESTRO PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# This is a template for production environment variables.
# Copy this file to .env.production and fill in all required values.
#
# CRITICAL: Never commit .env.production to version control!
# CRITICAL: All secrets marked with [REQUIRED] must be set!
#
# Generation helpers:
#   JWT Secrets:     openssl rand -base64 32
#   Passwords:       openssl rand -hex 16
#   API Keys:        See provider documentation

# ============================================
# 1. CORE SERVER CONFIGURATION [REQUIRED]
# ============================================

# Application environment (production, staging, development)
NODE_ENV=production

# Server port (exposed through reverse proxy, not directly)
PORT=8000

# Server host (0.0.0.0 = all interfaces, localhost = only local)
HOST=0.0.0.0

# ============================================
# 2. DATABASE CONFIGURATION [REQUIRED]
# ============================================

# PostgreSQL connection string (takes precedence if provided)
# Format: postgresql://user:password@host:port/database?sslmode=require
# REQUIRED: Must be set for production
DATABASE_URL=postgresql://qestro_user:CHANGE_ME_DB_PASSWORD@postgres:5432/qestro_production

# Individual connection parameters (used if DATABASE_URL not provided)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=qestro_production
DB_USER=qestro_user
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Connection pooling tuning
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_IN_TRANSACTION_TIMEOUT=60000

# PostgreSQL SSL mode for production
# Recommend: require (for cloud databases like Supabase, RDS)
DB_SSL=true

# ============================================
# 3. REDIS CONFIGURATION [REQUIRED]
# ============================================

# Redis connection string
# Format: redis://:password@host:port
# REQUIRED: Must be set for production
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# Individual Redis parameters
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# Redis TLS for production (enable if using cloud Redis like Upstash)
REDIS_TLS=true

# Retry configuration
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# ============================================
# 4. JWT/AUTHENTICATION [REQUIRED]
# ============================================

# JWT secret for signing access tokens
# REQUIRED: Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# JWT secret for signing refresh tokens
# REQUIRED: Generate with: openssl rand -base64 32
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# JWT expiration times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt rounds for password hashing (10-12 recommended)
BCRYPT_ROUNDS=12

# ============================================
# 5. CORS CONFIGURATION [REQUIRED]
# ============================================

# Comma-separated list of allowed origins
# REQUIRED for production to prevent CSRF attacks
CORS_ORIGINS=https://qestro.app,https://qestro.io,https://app.qestro.app

# Allow credentials (cookies, authorization headers)
CORS_CREDENTIALS=true

# Max age for CORS preflight cache (seconds)
CORS_MAX_AGE=86400

# ============================================
# 6. FRONTEND CONFIGURATION [REQUIRED]
# ============================================

# Frontend URL used by backend for redirects and CORS
# REQUIRED: Must match your frontend domain
FRONTEND_URL=https://qestro.app

# Backend API base URL for frontend to call
API_BASE_URL=https://api.qestro.app

# ============================================
# 7. EMAIL CONFIGURATION [OPTIONAL]
# ============================================

# Email provider (sendgrid, resend, smtp, etc.)
EMAIL_PROVIDER=sendgrid

# SendGrid API key (for SendGrid provider)
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.CHANGE_ME_YOUR_SENDGRID_API_KEY

# Resend API key (alternative email provider)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_CHANGE_ME_YOUR_RESEND_API_KEY

# SMTP configuration (for custom SMTP server)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.CHANGE_ME_YOUR_SENDGRID_API_KEY

# Email sender information
EMAIL_FROM=noreply@qestro.app
EMAIL_FROM_NAME=Qestro
SUPPORT_EMAIL=support@qestro.app
SALES_EMAIL=sales@qestro.app

# ============================================
# 8. PAYMENT/BILLING CONFIGURATION [OPTIONAL]
# ============================================

# Stripe secret key (for payment processing)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME_YOUR_STRIPE_SECRET_KEY

# Stripe webhook secret (for webhook verification)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME_YOUR_WEBHOOK_SECRET

# Stripe price IDs for subscription tiers
# Get from: https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER=price_CHANGE_ME_STARTER
STRIPE_PRICE_PRO=price_CHANGE_ME_PRO
STRIPE_PRICE_ENTERPRISE=price_CHANGE_ME_ENTERPRISE

# ============================================
# 9. OAUTH CONFIGURATION [OPTIONAL]
# ============================================

# Google OAuth credentials
# Get from: https://console.developers.google.com/
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_OAUTH_CALLBACK_URL=https://api.qestro.app/auth/google/callback

# GitHub OAuth credentials
# Get from: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=CHANGE_ME_GITHUB_CLIENT_ID
GITHUB_OAUTH_CLIENT_SECRET=CHANGE_ME_GITHUB_CLIENT_SECRET
GITHUB_OAUTH_CALLBACK_URL=https://api.qestro.app/auth/github/callback

# ============================================
# 10. AI SERVICES CONFIGURATION [OPTIONAL]
# ============================================

# OpenAI API key (for test generation and self-healing)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-CHANGE_ME_YOUR_OPENAI_API_KEY

# OpenAI model to use (gpt-4, gpt-4-turbo, gpt-3.5-turbo, etc.)
OPENAI_MODEL=gpt-4

# Max tokens per API call (higher = slower but more detailed)
OPENAI_MAX_TOKENS=4000

# Temperature for AI responses (0.0-2.0, lower = deterministic, higher = creative)
OPENAI_TEMPERATURE=0.3

# ============================================
# 11. FILE STORAGE CONFIGURATION [OPTIONAL]
# ============================================

# AWS S3 configuration (for file uploads, screenshots, etc.)
# Get from: https://console.aws.amazon.com/
AWS_S3_BUCKET=qestro-storage-prod
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=CHANGE_ME_YOUR_AWS_SECRET_KEY

# Alternative: Cloudflare R2 (recommended with Cloudflare domains)
# Get from: https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=CHANGE_ME_ACCOUNT_ID
CLOUDFLARE_R2_BUCKET=qestro-storage
CLOUDFLARE_R2_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY
CLOUDFLARE_R2_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET_KEY

# Storage type to use (s3 or r2)
STORAGE_TYPE=s3

# ============================================
# 12. FEATURE FLAGS [OPTIONAL]
# ============================================

# Enable/disable features (true/false)
ENABLE_RECORDING=true
ENABLE_MOBILE_TESTING=true
ENABLE_AI_GENERATION=true
ENABLE_BILLING=true
ENABLE_METRICS=true
ENABLE_WEBSOCKETS=true

# ============================================
# 13. LOGGING & MONITORING [OPTIONAL]
# ============================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable application metrics collection
ENABLE_METRICS=true

# Metrics port (Prometheus format)
METRICS_PORT=9090

# Health check interval (milliseconds)
HEALTH_CHECK_INTERVAL=60000

# Enable performance monitoring
PERFORMANCE_MONITORING=true

# ============================================
# 14. RATE LIMITING [OPTIONAL]
# ============================================

# Rate limit window in minutes
RATE_LIMIT_WINDOW=15

# Max requests per window per IP
RATE_LIMIT_MAX=1000

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# Max body size for requests
BODY_LIMIT=50mb

# ============================================
# 15. TESTING & BROWSER AUTOMATION [OPTIONAL]
# ============================================

# Playwright browsers cache directory
PLAYWRIGHT_BROWSERS_PATH=/var/cache/playwright

# Enable browser automation for test execution
ENABLE_BROWSER_AUTOMATION=true

# Max concurrent tests running at once
MAX_CONCURRENT_TESTS=5

# Timeout for single test execution (milliseconds)
TEST_TIMEOUT=300000

# ============================================
# 16. INTEGRATIONS [OPTIONAL]
# ============================================

# GitHub integration
GITHUB_API_TOKEN=ghp_CHANGE_ME_YOUR_GITHUB_TOKEN

# GitLab integration
GITLAB_API_TOKEN=glpat-CHANGE_ME_YOUR_GITLAB_TOKEN

# Slack notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME/SLACK/WEBHOOK
SLACK_BOT_TOKEN=xoxb-CHANGE_ME_SLACK_BOT_TOKEN

# Discord notifications (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/CHANGE_ME/DISCORD/WEBHOOK

# ============================================
# 17. CLOUDFLARE CONFIGURATION [OPTIONAL]
# ============================================

# Cloudflare API token (for DNS, CDN, etc.)
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=CHANGE_ME_YOUR_CLOUDFLARE_API_TOKEN

# Cloudflare Zone ID (domain)
# Get from: https://dash.cloudflare.com/
CLOUDFLARE_ZONE_ID=CHANGE_ME_ZONE_ID_FOR_QESTRO_APP

# ============================================
# 18. DEPLOYMENT METADATA [OPTIONAL]
# ============================================

# Application version (semantic versioning)
APP_VERSION=1.0.0

# Build date (ISO 8601 format)
BUILD_DATE=2026-04-07

# Deployment platform (render, heroku, aws, gke, aks, etc.)
DEPLOYMENT_PLATFORM=docker

# ============================================
# 19. SETUP INSTRUCTIONS
# ============================================
#
# 1. Generate secrets:
#    JWT_SECRET:       openssl rand -base64 32
#    JWT_REFRESH_SECRET: openssl rand -base64 32
#    REDIS_PASSWORD:   openssl rand -hex 16
#    DB_PASSWORD:      openssl rand -hex 16
#
# 2. Database setup:
#    - Create PostgreSQL database (or use Supabase)
#    - Set DATABASE_URL (or individual DB_* variables)
#    - Run migrations: npm run migrate:prod
#
# 3. Redis setup:
#    - Create Redis instance (or use Upstash)
#    - Set REDIS_URL (or individual REDIS_* variables)
#
# 4. Email setup:
#    - Choose provider (SendGrid, Resend, or custom SMTP)
#    - Get API keys/credentials
#    - Set EMAIL_FROM, EMAIL_FROM_NAME
#
# 5. Frontend/CORS:
#    - Set FRONTEND_URL to your domain
#    - Set CORS_ORIGINS to allowed domains
#    - Set API_BASE_URL to backend API domain
#
# 6. Optional services:
#    - OpenAI API key (for AI features)
#    - Stripe keys (for billing)
#    - AWS S3 or Cloudflare R2 (for file storage)
#    - OAuth credentials (Google, GitHub)
#
# 7. Verify before deployment:
#    - Test database connection
#    - Test Redis connection
#    - Test email sending
#    - Test all third-party integrations
#
# 8. Start services:
#    docker-compose -f docker-compose.prod.yml up -d
#
# 9. Monitor:
#    docker-compose -f docker-compose.prod.yml logs -f backend
#    docker-compose -f docker-compose.prod.yml logs -f postgres
#    docker-compose -f docker-compose.prod.yml logs -f redis
#
# ============================================
# SECURITY CHECKLIST
# ============================================
#
# - [ ] All CHANGE_ME values replaced with actual secrets
# - [ ] .env.production not committed to version control
# - [ ] Secrets stored in secure vault (AWS Secrets Manager, HashiCorp Vault, etc.)
# - [ ] Database credentials rotated regularly
# - [ ] API keys have minimum required permissions
# - [ ] Redis password set and TLS enabled
# - [ ] JWT secrets are strong and unique
# - [ ] CORS_ORIGINS whitelist is restrictive
# - [ ] All third-party integrations verified and tested
# - [ ] Logging does not expose sensitive data
# - [ ] SSL/TLS certificates valid and up-to-date
# - [ ] Regular backups configured and tested
#
