# Questro Backend - Production Environment Template
# Copy this to .env.production and fill in actual values

NODE_ENV=production
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://questro_user:SECURE_PASSWORD@localhost:5432/questro_production

# Redis (optional - for sessions and caching)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-super-secure-jwt-secret-at-least-32-characters-long

# CORS and Frontend
FRONTEND_URL=https://questro.app
CORS_ORIGIN=https://questro.app

# AI Services
OPENAI_API_KEY=sk-your-openai-api-key-here

# Payment Processing
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key

# Email Service (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Monitoring & Logging
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=info

# File Storage (AWS S3 - optional)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=questro-recordings

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your-session-secret
SESSION_TIMEOUT=3600000