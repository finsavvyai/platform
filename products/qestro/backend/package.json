{
  "name": "questro-backend",
  "version": "1.0.0",
  "description": "Questro SaaS Backend - Node.js API with recording capabilities",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.cjs",
    "build:cloudflare": "node build.isolated.cjs",
    "start": "node dist/index.js",
    "dev:cloudflare": "wrangler dev",
    "deploy:cloudflare": "wrangler deploy",
    "deploy:cloudflare:preview": "wrangler deploy --env preview",
    "start:tsx": "tsx src/index.ts",
    "test": "node ../node_modules/jest/bin/jest.js --testPathPattern=../tests/backend",
    "test:smoke": "node ../node_modules/jest/bin/jest.js ../tests/backend/__tests__/jest-basic.test.ts ../tests/backend/__tests__/examples/jest-setup.test.ts --no-coverage",
    "test:watch": "node ../node_modules/jest/bin/jest.js --watch --testPathPattern=../tests/backend",
    "test:coverage": "node ../node_modules/jest/bin/jest.js --coverage --testPathPattern=../tests/backend",
    "test:coverage:nyc": "node ../node_modules/nyc/bin/nyc.js --reporter=lcov --reporter=text --reporter=html --reporter=json --reporter=json-summary --reporter=cobertura --reporter=teamcity node ../node_modules/jest/bin/jest.js --testPathPattern=../tests/backend",
    "test:integration": "node ../node_modules/jest/bin/jest.js --testPathPattern=../tests/backend/__tests__/integration",
    "test:unit": "node ../node_modules/jest/bin/jest.js --testPathPattern=../tests/backend/__tests__/services",
    "test:controllers": "node ../node_modules/jest/bin/jest.js --testPathPattern=../tests/backend/__tests__/controllers",
    "test:middleware": "node ../node_modules/jest/bin/jest.js --testPathPattern=../tests/backend/__tests__/middleware",
    "test:utils": "node ../node_modules/jest/bin/jest.js --testPathPattern=../tests/backend/__tests__/utils",
    "test:ci": "node ../node_modules/jest/bin/jest.js --ci --coverage --watchAll=false --maxWorkers=2",
    "test:ci:nyc": "node ../node_modules/nyc/bin/nyc.js --reporter=lcov --reporter=text --reporter=html --reporter=json --reporter=json-summary --reporter=cobertura --reporter=teamcity node ../node_modules/jest/bin/jest.js --ci --testPathPattern=../tests/backend --watchAll=false --maxWorkers=2",
    "coverage:report": "nyc report --reporter=html --reporter=text --reporter=lcov --reporter=json --reporter=json-summary",
    "coverage:check": "nyc check-coverage --lines 85 --functions 85 --branches 85 --statements 85",
    "coverage:check:strict": "nyc check-coverage --lines 90 --functions 90 --branches 90 --statements 90",
    "lint": "node ../node_modules/eslint/bin/eslint.js src --ext .ts --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "node ../node_modules/eslint/bin/eslint.js src --ext .ts --fix",
    "type-check": "node ../node_modules/typescript/lib/_tsc.js --noEmit -p tsconfig.typecheck.json",
    "db:migrate": "drizzle-kit up",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-database.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "validate:deployment": "tsx src/scripts/validateDeployment.ts",
    "worker:test-executor": "tsx src/workers/testExecutor.ts",
    "worker:ai-processor": "tsx src/workers/aiProcessor.ts",
    "job:cleanup": "tsx src/jobs/cleanup.ts",
    "job:health-monitor": "tsx src/jobs/healthMonitor.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/zod-validator": "^0.7.6",
    "@huggingface/inference": "^2.7.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/ws": "^8.18.1",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "drizzle-kit": "^0.20.6",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "hono": "^4.12.0",
    "joi": "^17.11.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "openai": "^4.20.1",
    "pg": "^8.11.3",
    "postgres": "^3.4.3",
    "puppeteer": "^24.17.0",
    "qrcode": "^1.5.4",
    "redis": "^4.6.10",
    "socket.io": "^4.7.4",
    "speakeasy": "^2.0.0",
    "stripe": "^14.9.0",
    "tsx": "^4.20.5",
    "twilio": "^4.19.0",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@playwright/test": "^1.55.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/joi": "^17.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mongodb": "^4.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "esbuild": "^0.19.12",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nyc": "^17.1.0",
    "playwright": "^1.55.1",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  }
}
