# ═══════════════════════════════════════════════════════════
# Qestro Authentication Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── JWT Configuration ────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Google OAuth ─────────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Callback: https://api.qestro.app/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── GitHub OAuth ─────────────────────────────────────────
# Console: https://github.com/settings/developers
# Callback: https://api.qestro.app/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ─── Microsoft / Azure AD ────────────────────────────────
# Console: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Callback: https://api.qestro.app/api/auth/microsoft/callback
AZURE_OAUTH_CLIENT_ID=
AZURE_OAUTH_CLIENT_SECRET=
AZURE_TENANT_ID=common

# ─── LinkedIn ────────────────────────────────────────────
# Console: https://www.linkedin.com/developers/apps
# Callback: https://api.qestro.app/api/auth/linkedin/callback
# Product: "Sign In with LinkedIn using OpenID Connect"
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=

# ─── Apple Sign-In ───────────────────────────────────────
# Console: https://developer.apple.com/account/resources/identifiers
# Callback: https://api.qestro.app/api/auth/apple/callback
# Note: Client secret is a signed JWT (see setup guide)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── Discord ─────────────────────────────────────────────
# Console: https://discord.com/developers/applications
# Callback: https://api.qestro.app/api/auth/discord/callback
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=

# ─── Twitter / X ─────────────────────────────────────────
# Console: https://developer.twitter.com/en/portal/projects-and-apps
# Callback: https://api.qestro.app/api/auth/twitter/callback
# OAuth 2.0 with PKCE, Web App (confidential client)
TWITTER_OAUTH_CLIENT_ID=
TWITTER_OAUTH_CLIENT_SECRET=

# ─── Frontend URL (for OAuth redirects) ──────────────────
FRONTEND_URL=http://localhost:3001
