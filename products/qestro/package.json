{
  "name": "questro-saas",
  "version": "1.0.0",
  "description": "Qestro — Copilot for testing AI vibe coding. Write tests once, run everywhere.",
  "private": true,
  "scripts": {
    "setup": "npm run setup:deps && npm run setup:db && npm run setup:workers",
    "setup:deps": "npm run setup:deps:frontend && npm run setup:deps:backend && npm run setup:deps:workers && npm run setup:deps:mobile && npm run setup:deps:extension",
    "setup:deps:frontend": "npm --prefix frontend install",
    "setup:deps:backend": "npm --prefix backend install",
    "setup:deps:workers": "npm install",
    "setup:deps:mobile": "cd mobile && npm install",
    "setup:deps:extension": "npm --prefix browser-extension install",
    "setup:db": "npm run db:generate && npm run db:migrate:local",
    "setup:workers": "npm run wrangler:auth",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "sh -c \"(lsof -ti tcp:8000 | xargs kill -9 >/dev/null 2>&1 || true) && npm --prefix backend run dev\"",
    "dev:workers": "wrangler dev",
    "dev:workers:watch": "node esbuild.config.mjs watch",
    "build": "npm run build:frontend && npm run build:backend && npm run build:extension && npm run build:workers",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "build:extension": "npm --prefix browser-extension run build",
    "build:workers": "node esbuild.config.mjs",
    "deploy": "npm run deploy:backend:prod && npm run deploy:frontend:prod",
    "deploy:workers": "npm run build:workers && wrangler deploy",
    "deploy:workers:dev": "npm run build:workers && wrangler deploy --env dev",
    "deploy:workers:staging": "npm run build:workers && wrangler deploy --env staging",
    "deploy:workers:prod": "echo \"Deprecated for production. Use npm run deploy:backend:prod\" && exit 1",
    "deploy:backend:prod": "npm --prefix backend run deploy:cloudflare",
    "deploy:frontend:dev": "npm --prefix frontend run build && wrangler pages deploy frontend/dist --project-name qestro-frontend-dev",
    "deploy:frontend:staging": "npm --prefix frontend run build && wrangler pages deploy frontend/dist --project-name qestro-frontend-staging",
    "deploy:frontend:prod": "npm --prefix frontend run build && wrangler pages deploy frontend/dist --project-name questro-frontend --branch production-deploy",
    "setup:cloudflare": "bash scripts/setup-cloudflare-infrastructure.sh",
    "test": "npm run test:frontend && npm run test:backend && npm run test:workers && npm run test:mobile && npm run test:extension",
    "test:smoke": "npm run test:frontend && npm run test:workers && npm run test:mobile && npm --prefix backend run test:smoke",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "node ./node_modules/jest/bin/jest.js tests/backend",
    "test:workers": "node ./node_modules/vitest/vitest.mjs run src/workers/ --environment=node",
    "test:mobile": "cd mobile && npm run test",
    "test:extension": "npm --prefix browser-extension run test",
    "test:maestro": "cd mobile && npm run test:maestro",
    "test:workers:watch": "node ./node_modules/vitest/vitest.mjs src/workers/ --environment=node",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
    "test:e2e:setup": "bash scripts/test-setup.sh",
    "test:e2e:diagnostic": "bash scripts/test-diagnostic.sh",
    "test:e2e:status": "bash scripts/test-results-dashboard.sh",
    "test:e2e:ui": "node ./node_modules/@playwright/test/cli.js test --ui",
    "test:e2e:headed": "node ./node_modules/@playwright/test/cli.js test --headed",
    "test:e2e:debug": "node ./node_modules/@playwright/test/cli.js test --debug",
    "test:e2e:report": "node ./node_modules/playwright/cli.js show-report",
    "test:e2e:auth": "node ./node_modules/@playwright/test/cli.js test tests/e2e/auth",
    "test:e2e:dashboard": "node ./node_modules/@playwright/test/cli.js test tests/e2e/dashboard",
    "test:e2e:projects": "node ./node_modules/@playwright/test/cli.js test tests/e2e/projects",
    "test:e2e:smoke": "node ./node_modules/@playwright/test/cli.js test tests/e2e/smoke --grep @smoke",
    "test:e2e:smoke:api": "node ./node_modules/@playwright/test/cli.js test tests/e2e/smoke-api --grep @api-smoke",
    "test:e2e:ci": "node ./node_modules/@playwright/test/cli.js test tests/e2e/smoke --grep @smoke --project=chromium && node ./node_modules/@playwright/test/cli.js test tests/e2e/smoke-api --grep @api-smoke --project=chromium",
    "test:e2e:chromium": "node ./node_modules/@playwright/test/cli.js test --project=chromium",
    "test:e2e:firefox": "node ./node_modules/@playwright/test/cli.js test --project=firefox",
    "test:e2e:webkit": "node ./node_modules/@playwright/test/cli.js test --project=webkit",
    "test:e2e:mobile": "node ./node_modules/@playwright/test/cli.js test --project=mobile",
    "test:e2e:prod": "PLAYWRIGHT_ENV=production node ./node_modules/@playwright/test/cli.js test tests/e2e/production",
    "test:e2e:prod:headed": "PLAYWRIGHT_ENV=production node ./node_modules/@playwright/test/cli.js test tests/e2e/production --headed",
    "test:playwright": "node ./node_modules/@playwright/test/cli.js test",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend && npm run test:coverage:workers",
    "test:coverage:backend": "npm --prefix backend run test:coverage",
    "test:coverage:frontend": "npm --prefix frontend run test:coverage",
    "test:coverage:workers": "node ./node_modules/vitest/vitest.mjs run --coverage src/workers/ --environment=node",
    "test:playwright:headed": "node ./node_modules/@playwright/test/cli.js test --headed",
    "test:playwright:debug": "node ./node_modules/@playwright/test/cli.js test --debug",
    "test:playwright:ui": "node ./node_modules/@playwright/test/cli.js test --ui",
    "test:playwright:report": "node ./node_modules/playwright/cli.js show-report",
    "lint": "npm run lint:frontend && npm run lint:backend && npm run lint:workers && npm run lint:mobile",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint:backend": "npm --prefix backend run lint",
    "lint:workers": "node ./node_modules/eslint/bin/eslint.js src/workers/ --ext .ts",
    "lint:mobile": "cd mobile && npm run lint",
    "lint:fix": "npm run lint:fix:frontend && npm run lint:fix:backend && npm run lint:fix:workers",
    "lint:fix:frontend": "npm --prefix frontend run lint:fix",
    "lint:fix:backend": "npm --prefix backend run lint:fix",
    "lint:fix:workers": "node ./node_modules/eslint/bin/eslint.js src/workers/ --ext .ts --fix",
    "clean": "npm run clean:frontend && npm run clean:backend && npm run clean:workers",
    "clean:frontend": "cd frontend && rm -rf node_modules dist",
    "clean:backend": "cd backend && rm -rf node_modules dist",
    "clean:workers": "rm -rf dist node_modules/.cache",
    "wrangler:auth": "wrangler whoami",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "wrangler d1 migrations apply qestro-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply qestro-production --remote",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:drop": "drizzle-kit drop",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "db:validate": "drizzle-kit introspect",
    "db:seed": "tsx scripts/seed-database.ts",
    "db:seed:clean": "tsx scripts/seed-database.ts clean",
    "db:seed:users": "tsx scripts/seed-database.ts users",
    "d1:create": "wrangler d1 create qestro-db",
    "d1:migrate": "wrangler d1 migrations apply qestro-production --remote",
    "d1:migrate:local": "wrangler d1 migrations apply qestro-production --local",
    "kv:create:sessions": "wrangler kv:namespace create SESSIONS",
    "kv:create:cache": "wrangler kv:namespace create CACHE",
    "kv:create:realtime": "wrangler kv:namespace create REALTIME",
    "r2:create": "wrangler r2 bucket create qestro-artifacts && wrangler r2 bucket create qestro-media && wrangler r2 bucket create qestro-backups",
    "backup:db": "scripts/backup-database.sh",
    "restore:db": "scripts/restore-database.sh",
    "security:scan": "npm audit && cd frontend && npm audit && cd ../backend && npm audit && cd ../mobile && npm audit && cd ../browser-extension && npm audit",
    "docs:build": "cd docs && npm run build",
    "docs:serve": "cd docs && npm run serve",
    "health-check": "npm run health-check:backend && npm run health-check:frontend && npm run health-check:extensions && npm run health-check:workers",
    "health-check:backend": "curl -f http://localhost:8000/api/health || exit 1",
    "health-check:frontend": "sh -c \"curl -f http://localhost:3000 || curl -f http://127.0.0.1:5173\"",
    "health-check:workers": "npm run build:workers",
    "health-check:extensions": "npm --prefix browser-extension run health-check",
    "health-check:mobile:ios": "npm --prefix mobile run health-check:ios",
    "integration-test": "npm run integration-test:api && npm run integration-test:websocket && npm run integration-test:auth && npm run integration-test:workers",
    "integration-test:api": "node scripts/integration/api-integration-test.js",
    "integration-test:websocket": "node scripts/integration/websocket-integration-test.js",
    "integration-test:auth": "node scripts/integration/auth-integration-test.js",
    "integration-test:workers": "node scripts/integration/workers-integration-test.js",
    "enterprise:onboard": "tsx scripts/enterprise-onboarding.ts",
    "deploy:production": "bash scripts/deploy-production.sh",
    "deploy:production:skip-tests": "bash scripts/deploy-production.sh --skip-tests"
  },
  "workspaces": [
    "frontend",
    "backend",
    "packages/finsavvyai-llm",
    "packages/finsavvyai-auth",
    "packages/finsavvyai-monitor",
    "packages/finsavvyai-pay",
    "packages/finsavvyai-test-config",
    "packages/finsavvyai-cf-stack",
    "packages/finsavvyai-db",
    "packages/finsavvyai-ui"
  ],
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "overrides": {
    "@hono/zod-validator": "0.7.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@faker-js/faker": "^10.3.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "c8": "^10.1.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.24.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "husky": "^8.0.3",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "lcov-result-merger": "^5.0.1",
    "lint-staged": "^15.2.0",
    "miniflare": "^3.20241022.0",
    "nyc": "^17.1.0",
    "prettier": "^3.1.1",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0",
    "wrangler": "^4.45.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/questro/questro-saas.git"
  },
  "keywords": [
    "testing",
    "automation",
    "mobile-testing",
    "web-testing",
    "saas",
    "maestro",
    "workflow-use",
    "ai-testing",
    "cross-platform",
    "enterprise"
  ],
  "author": "Questro Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/questro/questro-saas/issues"
  },
  "homepage": "https://qestro.io",
  "volta": {
    "node": "22.22.0"
  }
}
