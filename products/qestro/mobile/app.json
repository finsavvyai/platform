{
  "expo": {
    "name": "Qestro",
    "slug": "qestro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "qestro",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0b0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.qestro.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Qestro uses Face ID for secure authentication"
      }
    },
    "android": {
      "package": "io.qestro.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0b0f",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-image",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Qestro to use Face ID for authentication"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3b82f6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
