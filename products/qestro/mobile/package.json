{
  "name": "qestro-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "preios": "npm run health-check:ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "node ./node_modules/jest/bin/jest.js --runInBand",
    "test:coverage": "node ./node_modules/jest/bin/jest.js --runInBand --coverage",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch",
    "pretest:maestro": "npm run health-check:ios",
    "test:maestro": "maestro test .maestro/",
    "health-check:ios": "node scripts/check-ios-toolchain.mjs",
    "lint": "node ./node_modules/eslint/bin/eslint.js app src expo-env.d.ts --ext .ts,.tsx",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js app src expo-env.d.ts --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "typecheck": "node ./node_modules/typescript/lib/_tsc.js --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-community/netinfo": "11.5.2",
    "expo": "~55.0.4",
    "expo-blur": "~55.0.8",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.9",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.5",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-notifications": "~55.0.10",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-task-manager": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "lucide-react-native": "^0.575.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.1.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "^0.7.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
