# Environment Configuration for Questro Testing Platform
NODE_ENV=development
PORT=8000

# Database Configuration
# Set USE_SUPABASE=true to use Supabase, false for local PostgreSQL
USE_SUPABASE=false

# Supabase Database (Cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-database-password

# Local Database (Development)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=questro
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@finsavvyai.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=info@finsavvyai.com
FROM_NAME=Questro by FinsavvyAI

# LemonSqueezy Configuration (Payment Processing)
# Get these from your LemonSqueezy dashboard: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# LemonSqueezy Product Variant IDs (create products in LemonSqueezy dashboard first)
LEMONSQUEEZY_STARTER_VARIANT_ID=your-starter-variant-id
LEMONSQUEEZY_PRO_VARIANT_ID=your-professional-variant-id
LEMONSQUEEZY_ENTERPRISE_VARIANT_ID=your-enterprise-variant-id

# OpenAI Configuration (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=.png,.jpg,.jpeg,.gif,.mp4,.mov,.avi
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=testflow-pro-uploads

# External Tool Paths
MAESTRO_PATH=/usr/local/bin/maestro
WORKFLOW_USE_PATH=/usr/local/bin/workflow-use

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret

# Analytics
ANALYTICS_ENABLED=true
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_SEARCH_CONSOLE_ID=your-verification-code

# Monitoring
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# Feature Flags
ENABLE_RECORDING=true
ENABLE_MOBILE_TESTING=true
ENABLE_WEB_TESTING=true
ENABLE_API_ACCESS=true
ENABLE_VOICE_TESTING=true
ENABLE_SECURITY_TESTING=true
ENABLE_PERFORMANCE_TESTING=true
ENABLE_AI_GENERATION=true

# Company Information
COMPANY_NAME=FinsavvyAI
COMPANY_EMAIL=info@finsavvyai.com
SUPPORT_EMAIL=support@finsavvyai.com

# Notification Services Configuration
# Twilio (for SMS and Voice notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Slack Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Data Sources Configuration
# Encryption key for storing sensitive database credentials (32-character key)
DATASOURCE_ENCRYPTION_KEY=your-32-character-encryption-key-here

# Default database connection timeouts
DB_CONNECTION_TIMEOUT_MS=30000
API_REQUEST_TIMEOUT_MS=15000

# Scheduled Testing Configuration
ENABLE_SCHEDULED_TESTS=true
SCHEDULED_TESTS_CRON_INTERVAL=* * * * * # Every minute
MAX_CONCURRENT_SCHEDULED_TESTS=10

# Test Result Storage
TEST_RESULTS_RETENTION_DAYS=90
NOTIFICATION_LOGS_RETENTION_DAYS=30

# Report Generation
REPORTS_STORAGE_PATH=/tmp/reports
PDF_GENERATION_TIMEOUT_MS=60000
PDF_GENERATION_ENABLED=true

# Notification Rate Limiting
NOTIFICATION_RATE_LIMIT_PER_MINUTE=60
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_MS=5000

# Webhook Configuration for External Integrations
WEBHOOK_TIMEOUT_MS=15000
WEBHOOK_USER_AGENT=Questro-AI-Testing/1.0

# Alert Escalation Configuration
ALERT_ESCALATION_ENABLED=true
CRITICAL_ALERT_VOICE_CALLS_ENABLED=true

# Performance Testing Limits
PERFORMANCE_TEST_MAX_DURATION_SECONDS=600
PERFORMANCE_TEST_MAX_VIRTUAL_USERS=1000

# Security Testing Configuration
SECURITY_TESTING_ENABLED=true
SECURITY_SCAN_TIMEOUT_MS=600000

# AI-Powered Features
AI_ALERT_GENERATION_ENABLED=true
AI_INSIGHTS_GENERATION_ENABLED=true
AI_EMAIL_CONTENT_GENERATION_ENABLED=true

# Voice Features (OpenAI TTS)
VOICE_ALERTS_ENABLED=true
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=1.0

# Background Job Processing
BACKGROUND_JOBS_ENABLED=true
BACKGROUND_JOB_CONCURRENCY=5

# Cache Configuration
CACHE_QUERY_RESULTS=true
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE_MB=100

# Monitoring and Health Checks
HEALTH_CHECK_ENABLED=true
METRICS_COLLECTION_ENABLED=true
PERFORMANCE_MONITORING_ENABLED=true

# Data Source Templates
ENABLE_DATASOURCE_TEMPLATES=true
ENABLE_DATASOURCE_SCHEMA_DISCOVERY=true