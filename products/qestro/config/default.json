{
  "app": {
    "name": "Questro",
    "version": "1.0.0",
    "description": "AI-Powered Testing Platform",
    "environment": "development",
    "debug": true,
    "logLevel": "info"
  },
  "server": {
    "host": "localhost",
    "port": 8000,
    "cors": {
      "origin": ["http://localhost:3000", "http://localhost:3001"],
      "credentials": true
    },
    "rateLimit": {
      "windowMs": 900000,
      "max": 100
    }
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "questro_dev",
    "ssl": false,
    "pool": {
      "min": 2,
      "max": 10
    }
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "db": 0,
    "ttl": 3600
  },
  "auth": {
    "jwt": {
      "algorithm": "HS256",
      "expiresIn": "24h",
      "refreshExpiresIn": "7d"
    },
    "oauth": {
      "google": {
        "enabled": false,
        "clientId": ""
      },
      "github": {
        "enabled": false,
        "clientId": ""
      }
    }
  },
  "ai": {
    "openai": {
      "enabled": false,
      "model": "gpt-4",
      "maxTokens": 4000,
      "temperature": 0.7
    },
    "huggingface": {
      "enabled": false,
      "model": "distilbert-base-uncased"
    }
  },
  "testing": {
    "engines": {
      "playwright": {
        "enabled": true,
        "timeout": 30000,
        "retries": 3
      },
      "maestro": {
        "enabled": true,
        "timeout": 60000,
        "retries": 2
      }
    },
    "recording": {
      "enabled": true,
      "maxDuration": 1800,
      "autoSave": true
    }
  },
  "mobile": {
    "platforms": ["ios", "android"],
    "ios": {
      "minimumVersion": "13.0",
      "bundleId": "io.questro.mobile"
    },
    "android": {
      "minimumVersion": "7.0",
      "packageName": "io.questro.mobile"
    }
  },
  "extensions": {
    "vscode": {
      "enabled": true,
      "minimumVersion": "1.74.0",
      "commands": {
        "voiceCommands": true,
        "testGeneration": true,
        "securityScanning": true,
        "performanceTesting": true
      }
    },
    "browser": {
      "enabled": true,
      "supportedBrowsers": ["chrome", "firefox", "safari", "edge"],
      "permissions": ["activeTab", "storage", "scripting"]
    }
  },
  "notifications": {
    "email": {
      "enabled": false,
      "provider": "sendgrid",
      "from": "noreply@questro.io"
    },
    "slack": {
      "enabled": false,
      "webhookUrl": ""
    },
    "teams": {
      "enabled": false,
      "webhookUrl": ""
    }
  },
  "monitoring": {
    "telemetry": {
      "enabled": false,
      "provider": "mixpanel"
    },
    "analytics": {
      "enabled": false,
      "provider": "plausible"
    },
    "errorReporting": {
      "enabled": false,
      "provider": "sentry"
    },
    "logging": {
      "level": "info",
      "format": "json",
      "transport": "console"
    }
  },
  "security": {
    "encryption": {
      "algorithm": "aes-256-gcm",
      "keyLength": 32
    },
    "rateLimiting": {
      "enabled": true,
      "windowMs": 900000,
      "maxRequests": 100
    },
    "csp": {
      "enabled": true,
      "directives": {
        "defaultSrc": ["'self'"],
        "scriptSrc": ["'self'", "'unsafe-inline'"],
        "styleSrc": ["'self'", "'unsafe-inline'"],
        "imgSrc": ["'self'", "data:", "https:"]
      }
    }
  },
  "performance": {
    "caching": {
      "enabled": true,
      "ttl": 300,
      "strategy": "memory"
    },
    "compression": {
      "enabled": true,
      "algorithm": "gzip"
    },
    "optimization": {
      "bundleSplitting": true,
      "codeSplitting": true,
      "treeShaking": true
    }
  },
  "storage": {
    "local": {
      "enabled": true,
      "path": "./data"
    },
    "cloud": {
      "enabled": false,
      "provider": "aws",
      "bucket": "questro-storage"
    }
  },
  "api": {
    "version": "v1",
    "baseUrl": "http://localhost:8000/api/v1",
    "timeout": 10000,
    "retries": 3
  },
  "websocket": {
    "enabled": true,
    "port": 8001,
    "path": "/socket.io",
    "transports": ["websocket", "polling"]
  },
  "ci": {
    "enabled": false,
    "provider": "github",
    "pipelines": {
      "test": true,
      "build": true,
      "deploy": true
    }
  },
  "deployment": {
    "environment": "development",
    "provider": "local",
    "domains": {
      "api": "api.questro.dev",
      "app": "app.questro.dev",
      "docs": "docs.questro.dev"
    }
  }
}