{
  "app": {
    "environment": "production",
    "debug": false,
    "logLevel": "warn"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "cors": {
      "origin": ["https://app.questro.io", "https://questro.io"],
      "credentials": true
    },
    "rateLimit": {
      "windowMs": 900000,
      "max": 1000
    }
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "questro_prod",
    "ssl": {
      "rejectUnauthorized": true
    },
    "pool": {
      "min": 5,
      "max": 20
    }
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "db": 0,
    "ttl": 7200
  },
  "monitoring": {
    "telemetry": {
      "enabled": true,
      "provider": "mixpanel"
    },
    "analytics": {
      "enabled": true,
      "provider": "plausible"
    },
    "errorReporting": {
      "enabled": true,
      "provider": "sentry",
      "dsn": "${SENTRY_DSN}"
    },
    "logging": {
      "level": "warn",
      "format": "json",
      "transport": "file"
    }
  },
  "security": {
    "encryption": {
      "algorithm": "aes-256-gcm",
      "keyLength": 32
    },
    "rateLimiting": {
      "enabled": true,
      "windowMs": 900000,
      "maxRequests": 1000
    },
    "csp": {
      "enabled": true,
      "directives": {
        "defaultSrc": ["'self'", "https://cdn.questro.io"],
        "scriptSrc": ["'self'", "https://cdn.questro.io", "'unsafe-inline'"],
        "styleSrc": ["'self'", "https://cdn.questro.io", "'unsafe-inline'"],
        "imgSrc": ["'self'", "data:", "https:", "https://cdn.questro.io"]
      }
    },
    "helmet": {
      "enabled": true,
      "contentSecurityPolicy": true,
      "crossOriginEmbedderPolicy": true,
      "crossOriginOpenerPolicy": true,
      "crossOriginResourcePolicy": true
    }
  },
  "storage": {
    "local": {
      "enabled": false,
      "path": "./data"
    },
    "cloud": {
      "enabled": true,
      "provider": "aws",
      "bucket": "questro-prod-storage",
      "region": "us-east-1",
      "accessKey": "${AWS_ACCESS_KEY_ID}",
      "secretKey": "${AWS_SECRET_ACCESS_KEY}"
    }
  },
  "deployment": {
    "environment": "production",
    "provider": "render",
    "domains": {
      "api": "api.questro.io",
      "app": "app.questro.io",
      "docs": "docs.questro.io"
    }
  }
}