{
  "name": "opensyber-openagent",
  "displayName": "OpenAgent — AI Agent Activity Monitor",
  "description": "Monitor what AI coding agents (Cursor, Cline, Claude Code, Devin, Copilot) do to your filesystem and terminal in real time.",
  "version": "0.2.0",
  "publisher": "opensyber",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#0A0A0A",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/finsavvyai/opensyber"
  },
  "homepage": "https://opensyber.cloud/openagent",
  "bugs": {
    "url": "https://github.com/finsavvyai/opensyber/issues"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": ["Other", "Testing"],
  "keywords": ["security", "AI agent", "monitoring", "Cursor", "Cline", "Claude Code", "Devin", "audit", "compliance"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openagent",
          "title": "OpenAgent",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "openagent": [
        {
          "id": "openagent.activityView",
          "name": "Agent Activity",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "openagent.showReport",
        "title": "OpenAgent: Show Security Report"
      },
      {
        "command": "openagent.clearActivity",
        "title": "OpenAgent: Clear Activity Log"
      }
    ],
    "configuration": {
      "title": "OpenAgent",
      "properties": {
        "openagent.cloudSync.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Send anonymised activity metadata to OpenSyber dashboard (requires API key). File contents and secret values are never transmitted."
        },
        "openagent.cloudSync.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenSyber API key — get one at opensyber.cloud/settings"
        },
        "openagent.notifications.critical": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when a CRITICAL risk event is detected (e.g. agent reads .env or SSH key)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
