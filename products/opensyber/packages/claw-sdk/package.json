{
  "name": "@opensyber/claw-sdk",
  "version": "0.1.0",
  "description": "Claw AI gateway client — multi-provider LLM access (Anthropic, OpenAI, Workers AI) with session support for OpenSyber portfolio projects",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "homepage": "https://opensyber.cloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finsavvyai/opensyber.git",
    "directory": "packages/claw-sdk"
  },
  "keywords": [
    "ai",
    "llm",
    "claude",
    "anthropic",
    "openai",
    "opensyber",
    "claw",
    "gateway"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers.js",
      "types": "./dist/providers.d.ts"
    },
    "./clawpipe": {
      "import": "./dist/clawpipe-adapter.js",
      "types": "./dist/clawpipe-adapter.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "clawpipe-ai": "^3.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
