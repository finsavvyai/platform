{
  "name": "@opensyber/modal-adapter",
  "version": "0.1.0",
  "description": "OpenSyber sidecar adapter for Modal-based AI agent runtimes",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "homepage": "https://opensyber.cloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finsavvyai/opensyber.git",
    "directory": "packages/modal-adapter"
  },
  "keywords": [
    "opensyber",
    "modal",
    "agent-security",
    "runtime-attestation",
    "adapter"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet'",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}

