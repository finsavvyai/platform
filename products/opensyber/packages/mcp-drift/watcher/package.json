{
  "name": "@opensyber/mcp-drift-watcher",
  "version": "0.0.1",
  "private": true,
  "description": "Cross-session MCP drift watcher. Hono + Cloudflare D1 + Drizzle.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply mcp-drift --local",
    "db:migrate": "wrangler d1 migrations apply mcp-drift",
    "demo": "tsx scripts/demo.ts",
    "demo:stdio": "tsx scripts/demo-stdio.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250121.0",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "wrangler": "^3.100.0"
  }
}
