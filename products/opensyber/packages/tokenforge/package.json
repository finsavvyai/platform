{
  "name": "@opensyber/tokenforge",
  "version": "1.0.0",
  "description": "Device-bound session security — W3C DBSC + ECDSA P-256 signatures + AitM detection. Drop-in for Auth0 / Okta / Clerk / Entra ID.",
  "private": false,
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/opensyber/tokenforge"
  },
  "homepage": "https://tokenforge.opensyber.cloud",
  "author": "OpenSyber",
  "bugs": {
    "url": "https://github.com/opensyber/tokenforge/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "session-security",
    "tokenforge",
    "device-binding",
    "dbsc",
    "ecdsa",
    "trust-score",
    "session-management",
    "web-crypto",
    "anti-session-hijacking",
    "cookie-theft-protection",
    "cisco-duo-alternative"
  ],
  "sideEffects": false,
  "exports": {
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./server/internal": {
      "import": "./dist/server/internal.js",
      "types": "./dist/server/internal.d.ts"
    },
    "./server/storage": {
      "import": "./dist/server/storage/index.js",
      "types": "./dist/server/storage/index.d.ts"
    },
    "./storage/internal": {
      "import": "./dist/server/storage/internal.js",
      "types": "./dist/server/storage/internal.d.ts"
    },
    "./webhooks": {
      "import": "./dist/server/webhooks.js",
      "types": "./dist/server/webhooks.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./shared": {
      "import": "./dist/shared/types.js",
      "types": "./dist/shared/types.d.ts"
    },
    "./hono": {
      "import": "./dist/adapters/hono.js",
      "types": "./dist/adapters/hono.d.ts"
    },
    "./express": {
      "import": "./dist/adapters/express.js",
      "types": "./dist/adapters/express.d.ts"
    },
    "./nextjs": {
      "import": "./dist/adapters/nextjs.js",
      "types": "./dist/adapters/nextjs.d.ts"
    },
    "./fastify": {
      "import": "./dist/adapters/fastify.js",
      "types": "./dist/adapters/fastify.d.ts"
    },
    "./sveltekit": {
      "import": "./dist/adapters/sveltekit.js",
      "types": "./dist/adapters/sveltekit.d.ts"
    },
    "./astro": {
      "import": "./dist/adapters/astro.js",
      "types": "./dist/adapters/astro.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/server/storage/d1.*",
    "!dist/server/storage/postgres.*",
    "!dist/server/storage/redis.*",
    "!dist/server/storage/cloud.*",
    "!dist/server/storage/internal.*",
    "!dist/server/crypto.*",
    "!dist/server/trust-score.*",
    "!dist/server/verify.*",
    "!dist/server/binding.*",
    "!dist/server/step-up.*",
    "!dist/server/totp.*",
    "!dist/server/middleware-internal.*",
    "!dist/server/internal.*",
    "!dist/server/storage/**",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "hono": "^4.12.14"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.13",
    "@playwright/test": "^1.58.2",
    "tsx": "^4.20.6",
    "@cloudflare/workers-types": "^4.20250214.0",
    "@eslint/js": "^9.39.0",
    "@types/react": "^19.0.0",
    "eslint": "^9",
    "react": "^19.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
