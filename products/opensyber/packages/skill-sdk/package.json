{
  "name": "@opensyber/skill-sdk",
  "version": "0.1.0",
  "description": "SDK for building and testing OpenSyber marketplace skills — define skills, validate manifests, run test harness",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "homepage": "https://opensyber.cloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finsavvyai/opensyber.git",
    "directory": "packages/skill-sdk"
  },
  "keywords": [
    "opensyber",
    "skill",
    "marketplace",
    "sdk",
    "ai-agent"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
