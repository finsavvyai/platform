{
  "name": "@opensyber/cli",
  "version": "0.1.1",
  "description": "CLI tools for OpenSyber — scan AI agent activity logs and cloud posture",
  "type": "module",
  "license": "MIT",
  "homepage": "https://opensyber.cloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finsavvyai/opensyber.git",
    "directory": "packages/cli"
  },
  "bin": {
    "opensyber": "dist/bin/opensyber.js",
    "opensyber-scan": "dist/bin/agent-scan.js",
    "agent-scan": "dist/bin/agent-scan.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
