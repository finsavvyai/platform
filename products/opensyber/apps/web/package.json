{
  "name": "@opensyber/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "E2E_BASE_URL=http://localhost:3000 playwright test --project=visual",
    "test:visual:update": "E2E_BASE_URL=http://localhost:3000 playwright test --project=visual --update-snapshots",
    "test:visual:ui": "E2E_BASE_URL=http://localhost:3000 playwright test --project=visual --ui",
    "clean": "rm -rf .next .turbo out .open-next",
    "build:cf": "npx @opennextjs/cloudflare build",
    "deploy": "npm run build:cf && npx wrangler deploy"
  },
  "dependencies": {
    "@opensyber/auth": "workspace:*",
    "@opensyber/shared": "workspace:*",
    "@opensyber/tokenforge": "workspace:*",
    "@opensyber/ui": "workspace:*",
    "@sentry/nextjs": "^10.49.0",
    "clsx": "^2.1.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.487.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.9.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
