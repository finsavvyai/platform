    "k6:stress": "k6 run k6/stress.js"
  },
  "dependencies": {
    "@opensyber/auth": "workspace:*",
    "@opensyber/db": "workspace:*",
    "@opensyber/rbi-orchestrator": "workspace:*",
    "@opensyber/swg-orchestrator": "workspace:*",
    "@opensyber/wlp-orchestrator": "workspace:*",
    "@opensyber/shared": "workspace:*",
    "@opensyber/tokenforge": "workspace:*",
    "clawpipe-ai": "^3.5.1",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.5.9",
    "hono": "^4.12.14",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@vitest/ui": "^1.0.0",
    "typescript": "^5.7.0",
    "vitest": "^1.0.0",
    "wrangler": "^4.71.0"
