{
  "name": "@opensyber/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:load": "vitest run src/test/load-test.ts",
    "clean": "rm -rf dist .turbo .wrangler",
    "k6:smoke": "k6 run k6/smoke.js",
