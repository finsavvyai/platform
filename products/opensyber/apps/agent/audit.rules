# OpenSyber Agent — auditd rules for shell command monitoring
# Watch all execve syscalls
-a always,exit -F arch=b64 -S execve -k opensyber_exec

# Monitor critical binaries
-w /bin -p x -k opensyber_bin
-w /usr/bin -p x -k opensyber_usrbin
-w /sbin -p x -k opensyber_sbin

# Monitor sudo and su
-w /usr/bin/sudo -p x -k opensyber_sudo
-w /usr/bin/su -p x -k opensyber_su

# Monitor SSH access
-w /var/log/auth.log -p wa -k opensyber_auth
