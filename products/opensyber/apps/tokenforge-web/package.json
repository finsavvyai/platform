{
  "name": "@opensyber/tokenforge-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .next .turbo out .open-next",
    "build:cf": "npx @opennextjs/cloudflare build",
    "deploy": "npm run build:cf && npx wrangler deploy"
  },
  "dependencies": {
    "@opensyber/auth": "workspace:*",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.487.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
