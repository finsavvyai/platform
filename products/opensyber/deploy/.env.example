# Database Configuration
DB_USER=opensyber
DB_PASSWORD=your_secure_db_password_here
DB_NAME=opensyber
DB_HOST=postgres
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_HOST=redis
REDIS_PORT=6379

# Application
NODE_ENV=production
API_PORT=3001
NEXT_PUBLIC_API_URL=https://api.opensyber.com

# Clerk Authentication
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key_here

# LemonSqueezy (Payment Processing)
LEMON_SQUEEZY_API_KEY=your_lemon_squeezy_api_key_here
LEMON_SQUEEZY_STORE_ID=your_store_id_here
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# Cloudflare (Infrastructure & Agent Provisioning)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
API_BASE_URL=https://api.opensyber.cloud
AGENT_IMAGE=ghcr.io/finsavvyai/opensyber-agent:latest

# JWT & Security
JWT_SECRET=your_long_random_jwt_secret_here
JWT_EXPIRES_IN=7d
SESSION_SECRET=your_session_secret_here

# Cloudflare D1 (Workers Database)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
D1_DATABASE_ID=your_d1_database_id

# Email Configuration (Optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key

# Logging & Monitoring
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_here

# Feature Flags
FEATURE_BEHAVIORAL_MONITORING=true
FEATURE_CREDENTIAL_VAULTING=true
FEATURE_COMPLIANCE_ENFORCEMENT=true
FEATURE_TOKENFORGE=true
FEATURE_ANALYTICS=true

# Backup & Retention
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
DATA_RETENTION_DAYS=90
