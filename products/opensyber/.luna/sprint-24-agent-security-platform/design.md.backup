### FR-6: Proxy Routes

All proxy routes follow the established pattern from `apps/web/src/app/api/proxy/agents/route.ts`.

#### `apps/web/src/app/api/proxy/agents/team/[userId]/route.ts`

```typescript
import { auth } from '@clerk/nextjs/server';
import { NextResponse, type NextRequest } from 'next/server';

const API_URL = process.env.NEXT_PUBLIC_API_URL ?? 'https://api.opensyber.cloud';

export async function GET(
  req: NextRequest,
  { params }: { params: { userId: string } },
): Promise<NextResponse> {
  const { getToken } = await auth();
  const token = await getToken();
  if (!token) return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });

  const url = `${API_URL}/api/agents/team/${params.userId}/activity${req.nextUrl.search}`;
  const res = await fetch(url, {
    headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
  });
  const data = await res.json();
  return NextResponse.json(data, { status: res.status });
}
```

Similar pattern for all six new proxy routes listed in FR-6 requirements.

