#### FR-2: Plan Enforcement on Activity Sync

**Modified file**: `apps/api/src/routes/agent-monitor.ts`

Add `loadPlanConfig` to the middleware chain. Modify the `POST /activity/sync` handler:

```typescript
agentMonitorRoutes.post('/activity/sync', async (c) => {
  const db = c.get('db');
  const userId = c.get('userId');
  const config = c.get('planConfig')!;
  const orgId = c.get('orgId') ?? null;

  // 1. Check cloudSync feature gate
  if (!config.cloudSync) {
    return c.json({
      error: 'Forbidden',
      message: 'Cloud sync requires Pro plan or higher. Upgrade to sync agent activity.',
      upgradeRequired: true,
      feature: 'cloudSync',
    }, 403);
  }

  // 2. Parse and validate events (existing logic)
  const body = await c.req.json().catch(() => null);
  // ... validation ...

  // 3. Check agent limit (distinct agents within retention window)
  const retentionCutoff = new Date(
    Date.now() - config.agentHistoryDays * 24 * 60 * 60 * 1000
  ).toISOString();

  const existingAgents = await db
    .selectDistinct({ agent: agentActivity.agent })
    .from(agentActivity)
    .where(and(
      eq(agentActivity.userId, userId),
      gte(agentActivity.createdAt, retentionCutoff),
    ));

  const existingNames = new Set(existingAgents.map(a => a.agent));
  const newAgentNames = new Set(valid.map(e => e.agent));
  const combinedCount = new Set([...existingNames, ...newAgentNames]).size;

  if (combinedCount > config.agentLimit) {
    return c.json({
      error: 'Forbidden',
      message: `Agent limit reached (${existingNames.size}/${config.agentLimit}). Upgrade for more agents.`,
      upgradeRequired: true,
      limitKey: 'agentLimit',
      current: existingNames.size,
      limit: config.agentLimit,
    }, 403);
  }

  // 4. Check event timestamps against retention window
  const validInWindow = valid.filter(e => e.timestamp >= retentionCutoff);
  if (validInWindow.length === 0) {
    return c.json({
      error: 'Bad request',
      message: `Events older than ${config.agentHistoryDays} days are not accepted on your plan.`,
    }, 400);
  }

  // 5. Insert and evaluate (existing logic, but only validInWindow events)
  // ...

  // 6. Dispatch alerts asynchronously if violations found
  if (violations > 0 && orgId) {
    const ctx = c.executionCtx;
    ctx.waitUntil(dispatchViolationAlerts(db, c.env, orgId, newViolations));
  }

  return c.json({ synced: validInWindow.length, violations }, 201);
});
```

