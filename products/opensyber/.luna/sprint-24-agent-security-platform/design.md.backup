### FR-4: Activity-CSPM Cross-Linker

**File**: `apps/api/src/services/activity-cspm-linker.ts`

```typescript
import { eq, and, like, or } from 'drizzle-orm';
import { agentActivity, cspmFindings } from '@opensyber/db';
import type { DrizzleD1Database } from 'drizzle-orm/d1';

type Db = DrizzleD1Database<Record<string, unknown>>;

interface ActivityEvent {
  id: string;
  userId: string;
  orgId: string | null;
  type: string;
  path: string | null;
  summary: string;
  secretsCount: number;
}

const AWS_CRED_PATHS = [
  '.aws/credentials',
  '.aws/config',
  'aws-credentials',
];

const AWS_CLI_PATTERNS: Record<string, string> = {
  'aws s3': 's3-bucket',
  'aws ec2': 'security-group',
  'aws rds': 'rds-instance',
  'aws iam': 'iam-user',
};

export async function findRelatedFindings(
  db: Db,
  activity: ActivityEvent,
  limit = 5,
): Promise<Array<typeof cspmFindings.$inferSelect>> {
  if (!activity.orgId) return [];

  const conditions = [
    eq(cspmFindings.orgId, activity.orgId),
    eq(cspmFindings.status, 'open'),
  ];

  // Strategy 1: File reads matching AWS credential paths
  if (activity.type === 'file_read' && activity.path) {
    const isAwsCred = AWS_CRED_PATHS.some(p => activity.path!.includes(p));
    if (isAwsCred) {
      // Surface IAM-related findings
      return db.select().from(cspmFindings).where(
        and(
          ...conditions,
          or(
            like(cspmFindings.resourceType, '%iam%'),
            like(cspmFindings.checkId, '%CIS-1%'),
          ),
        ),
      ).limit(limit);
    }
  }

  // Strategy 2: Bash commands with AWS CLI invocations
  if (activity.type === 'bash_exec') {
    for (const [pattern, resourceType] of Object.entries(AWS_CLI_PATTERNS)) {
      if (activity.summary.includes(pattern)) {
        return db.select().from(cspmFindings).where(
          and(...conditions, eq(cspmFindings.resourceType, resourceType)),
        ).limit(limit);
      }
    }

    // Extract resource identifiers (s3 bucket names, sg-ids, etc.)
    const sgMatch = activity.summary.match(/sg-[a-f0-9]+/);
    if (sgMatch) {
      return db.select().from(cspmFindings).where(
        and(...conditions, like(cspmFindings.resourceId, `%${sgMatch[0]}%`)),
      ).limit(limit);
    }

    const s3Match = activity.summary.match(/s3:\/\/([a-z0-9.-]+)/);
    if (s3Match) {
      return db.select().from(cspmFindings).where(
        and(...conditions, like(cspmFindings.resourceId, `%${s3Match[1]}%`)),
      ).limit(limit);
    }
  }

  // Strategy 3: Secrets detected -> IAM access key findings
  if (activity.secretsCount > 0) {
    return db.select().from(cspmFindings).where(
      and(
        ...conditions,
        or(
          like(cspmFindings.checkId, '%IAM%'),
          like(cspmFindings.checkId, '%CIS-1%'),
        ),
      ),
    ).limit(limit);
  }

  return [];
}
```

