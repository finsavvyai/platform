## Middleware Design

### Plan Enforcement Middleware

**File**: `apps/api/src/middleware/plan-enforcement.ts`

This middleware factory provides two functions for plan-gating routes.

#### Interface

```typescript
import { createMiddleware } from 'hono/factory';
import { eq } from 'drizzle-orm';
import { users } from '@opensyber/db';
import { PLAN_CONFIGS } from '@opensyber/shared';
import type { PlanConfig } from '@opensyber/shared';
import type { Plan } from '@opensyber/shared';
import type { Env, Variables } from '../types.js';

type AppEnv = { Bindings: Env; Variables: Variables };

/**
 * Loads user plan config into context. Must run after authMiddleware.
 * Caches in c.set('planConfig', config) for the request lifetime.
 */
export const loadPlanConfig = createMiddleware<AppEnv>(async (c, next) => {
  const db = c.get('db');
  const userId = c.get('userId');

  const [user] = await db.select({ plan: users.plan })
    .from(users)
    .where(eq(users.id, userId))
    .limit(1);

  if (!user) {
    return c.json({ error: 'Unauthorized', message: 'User not found' }, 401);
  }

  const plan = user.plan as Plan;
  c.set('planConfig', PLAN_CONFIGS[plan]);
  c.set('userPlan', plan);
  return next();
});

/**
 * Requires a boolean plan feature to be enabled.
 *
 * Usage: requirePlanFeature('cloudSync')
 * Returns 403 with upgrade message if feature is disabled.
 */
export function requirePlanFeature(feature: keyof PlanConfig) {
  return createMiddleware<AppEnv>(async (c, next) => {
    const config = c.get('planConfig') as PlanConfig;
    if (!config) {
      return c.json({ error: 'Internal', message: 'Plan not loaded' }, 500);
    }
    if (!config[feature]) {
      return c.json({
        error: 'Forbidden',
        message: `This feature requires a plan upgrade. '${feature}' is not available on your current plan.`,
        upgradeRequired: true,
        feature,
      }, 403);
    }
    return next();
  });
}

/**
 * Checks a numeric plan limit against a current count.
 *
 * Usage: requirePlanLimit('cspmAccounts', async (c) => countAccounts(c))
 * Returns 403 if count >= limit.
 */
export function requirePlanLimit(
  limitKey: keyof PlanConfig,
  getCurrentCount: (c: Context) => Promise<number>,
) {
  return createMiddleware<AppEnv>(async (c, next) => {
    const config = c.get('planConfig') as PlanConfig;
    const limit = config[limitKey] as number;
    const current = await getCurrentCount(c);
    if (current >= limit) {
      return c.json({
        error: 'Forbidden',
        message: `Plan limit reached: ${limitKey} (${current}/${limit}). Upgrade for more.`,
        upgradeRequired: true,
        limitKey,
        current,
        limit,
      }, 403);
    }
    return next();
  });
}
```

#### Variables Extension

The `Variables` interface in `apps/api/src/types.ts` must be extended:

```typescript
export interface Variables {
  db: DrizzleD1Database<typeof schema>;
  userId: string;
  orgId: string | null;
  role: Role | null;
  orgMember: OrgMember | null;
  planConfig: PlanConfig | null;  // NEW
  userPlan: Plan | null;          // NEW
}
```

#### Usage Pattern

The plan enforcement middleware is applied per-route or per-route-group, **after** `authMiddleware` and `dbMiddleware` but **before** the route handler.

```typescript
// Example: activity sync with plan enforcement
agentMonitorRoutes.use('*', dbMiddleware, authMiddleware, resolveOrgContext, loadPlanConfig);

agentMonitorRoutes.post('/activity/sync', async (c) => {
  const config = c.get('planConfig')!;

  // Check cloud sync feature
  if (!config.cloudSync) {
    return c.json({
      error: 'Forbidden',
      message: 'Cloud sync requires Pro plan or higher',
      upgradeRequired: true,
    }, 403);
  }

  // Check agent limit
  const distinctAgents = await countDistinctAgents(db, userId, retentionWindow);
  if (distinctAgents >= config.agentLimit) {
    return c.json({
      error: 'Forbidden',
      message: `Agent limit reached (${distinctAgents}/${config.agentLimit})`,
      upgradeRequired: true,
    }, 403);
  }

  // ... rest of sync logic
});
```

### Middleware Chain Summary

The complete middleware chain for each route category:

| Route Group | Middleware Chain |
|---|---|
| `POST /agents/activity/sync` | db -> auth -> resolveOrg -> loadPlan -> [agent limit + cloud sync check] -> handler |
| `GET /agents/team/*` | db -> auth -> requirePermission('agent.policy.read') -> loadPlan -> requirePlanFeature('teamDashboard') -> handler |
| `* /agents/policies/*` | db -> auth -> resolveOrg -> loadPlan -> requirePlanFeature('policyEngine') -> handler |
| `* /agents/alert-channels/*` | db -> auth -> requirePermission('agent.policy.write') -> loadPlan -> requirePlanFeature('policyEngine') -> handler |
| `POST /cloud/accounts` | db -> auth -> resolveOrg -> loadPlan -> [cspmAccounts limit check] -> handler |
| `POST /agents/reports/generate` | db -> auth -> requirePermission -> loadPlan -> requirePlanFeature('pdfReports') -> handler |
| `GET /agents/risk-trend` | db -> auth -> resolveOrg -> loadPlan -> handler |
| `GET /agents/team/risk-trend` | db -> auth -> requirePermission('agent.policy.read') -> loadPlan -> requirePlanFeature('teamDashboard') -> handler |

