### FR-9: CSPM Scan Scheduler

**File**: `apps/api/src/services/cspm-scan-scheduler.ts`

```typescript
import { lte, and, eq, ne } from 'drizzle-orm';
import { cloudAccounts } from '@opensyber/db';
import type { Env } from '../types.js';
import { createDb } from '../lib/db.js';
import { runCspmScan } from './cspm-scanner.js';

const MAX_CONCURRENT = 5;

export async function processScheduledScans(env: Env): Promise<void> {
  const db = createDb(env.DB);
  const now = new Date().toISOString();

  // Find accounts due for scanning
  const dueAccounts = await db.select().from(cloudAccounts)
    .where(and(
      ne(cloudAccounts.scanSchedule, 'manual'),
      lte(cloudAccounts.nextScanAt, now),
      ne(cloudAccounts.status, 'scanning'),
    ))
    .limit(MAX_CONCURRENT);

  for (const account of dueAccounts) {
    try {
      // Mark as scanning
      await db.update(cloudAccounts)
        .set({ status: 'scanning' })
        .where(eq(cloudAccounts.id, account.id));

      // Run scan
      await runCspmScan(db, account.id, account.orgId, account.provider, env.ENCRYPTION_KEY);

      // Compute next scan time
      const interval = account.scanSchedule === 'daily'
        ? 24 * 60 * 60 * 1000
        : 7 * 24 * 60 * 60 * 1000;

      await db.update(cloudAccounts).set({
        nextScanAt: new Date(Date.now() + interval).toISOString(),
        status: 'active',
      }).where(eq(cloudAccounts.id, account.id));
    } catch (err) {
      console.error(`[ScheduledScan] Failed for account ${account.id}:`, err);
      await db.update(cloudAccounts).set({ status: 'error' })
        .where(eq(cloudAccounts.id, account.id));
    }
  }
}
```

### FR-2: Activity Retention Cron

**File**: `apps/api/src/services/activity-retention-cron.ts`

```typescript
import { lt, eq, and } from 'drizzle-orm';
import { agentActivity, users } from '@opensyber/db';
import { PLAN_CONFIGS } from '@opensyber/shared';
import type { Plan } from '@opensyber/shared';
import type { Env } from '../types.js';
import { createDb } from '../lib/db.js';

export async function purgeExpiredActivity(env: Env): Promise<void> {
  const db = createDb(env.DB);

  // Get all distinct users with activity
  const activeUsers = await db.selectDistinct({ userId: agentActivity.userId })
    .from(agentActivity).limit(1000);

  for (const { userId } of activeUsers) {
    // Fetch user plan
    const [user] = await db.select({ plan: users.plan })
      .from(users).where(eq(users.id, userId)).limit(1);

    if (!user) continue;

    const plan = user.plan as Plan;
    const config = PLAN_CONFIGS[plan];
    const cutoff = new Date(
      Date.now() - config.agentHistoryDays * 24 * 60 * 60 * 1000
    ).toISOString();

    // Delete expired activity in batches
    await db.delete(agentActivity).where(
      and(eq(agentActivity.userId, userId), lt(agentActivity.createdAt, cutoff)),
    );
  }
}
```

