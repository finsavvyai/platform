### FR-3: Alert Dispatch Service

**File**: `apps/api/src/services/alert-dispatch.ts`

```typescript
import { eq, and } from 'drizzle-orm';
import { alertChannels } from '@opensyber/db';
import type { DrizzleD1Database } from 'drizzle-orm/d1';
import { decrypt } from '../utils/encryption.js';
import { sendEmailAlert } from './alert-channels/email.js';
import { sendSlackAlert } from './alert-channels/slack.js';
import { sendPagerDutyAlert } from './alert-channels/pagerduty.js';
import { sendOpsGenieAlert } from './alert-channels/opsgenie.js';
import { sendTeamsAlert } from './alert-channels/teams.js';
import { sendDiscordAlert } from './alert-channels/discord.js';

type Db = DrizzleD1Database<Record<string, unknown>>;

interface Violation {
  id: string;
  policyId: string;
  policyName: string;
  severity: 'critical' | 'high' | 'medium' | 'low';
  summary: string;
  userId: string;
}

interface DispatchEnv {
  RESEND_API_KEY: string;
  ENCRYPTION_KEY: string;
  CACHE: KVNamespace; // for rate limiting
}

const SEVERITY_ORDER: Record<string, number> = {
  critical: 0, high: 1, medium: 2, low: 3,
};

export async function dispatchViolationAlerts(
  db: Db,
  env: DispatchEnv,
  orgId: string,
  violations: Violation[],
): Promise<void> {
  // Fetch active channels for this org
  const channels = await db.select().from(alertChannels)
    .where(and(eq(alertChannels.orgId, orgId), eq(alertChannels.isActive, true)));

  if (channels.length === 0) return;

  for (const violation of violations) {
    const violationSeverityOrder = SEVERITY_ORDER[violation.severity] ?? 3;

    for (const channel of channels) {
      const channelMinOrder = SEVERITY_ORDER[channel.minSeverity] ?? 1;

      // Only dispatch if violation severity >= channel min severity
      if (violationSeverityOrder > channelMinOrder) continue;

      // Rate limit: max 10 alerts per channel per minute
      const rateKey = `alert-rate:${channel.id}`;
      const currentCount = parseInt(await env.CACHE.get(rateKey) ?? '0', 10);
      if (currentCount >= 10) continue;
      await env.CACHE.put(rateKey, String(currentCount + 1), { expirationTtl: 60 });

      try {
        const config = JSON.parse(await decrypt(channel.config, env.ENCRYPTION_KEY));

        switch (channel.channelType) {
          case 'email':
            await sendEmailAlert(env.RESEND_API_KEY, config, violation);
            break;
          case 'slack':
            await sendSlackAlert(config, violation);
            break;
          case 'pagerduty':
            await sendPagerDutyAlert(config, violation);
            break;
          case 'opsgenie':
            await sendOpsGenieAlert(config, violation);
            break;
          case 'teams':
            await sendTeamsAlert(config, violation);
            break;
          case 'discord':
            await sendDiscordAlert(config, violation);
            break;
        }
      } catch (err) {
        console.error(`[AlertDispatch] Failed to send to ${channel.channelType} channel ${channel.id}:`, err);
      }
    }
  }
}
```

#### Example Channel: `alert-channels/slack.ts`

```typescript
interface SlackConfig {
  webhookUrl: string;
}

interface Violation {
  severity: string;
  summary: string;
  policyName: string;
  userId: string;
}

const SEVERITY_COLORS: Record<string, string> = {
  critical: '#dc2626',
  high: '#ea580c',
  medium: '#d97706',
  low: '#6b7280',
};

export async function sendSlackAlert(config: SlackConfig, violation: Violation): Promise<void> {
  const color = SEVERITY_COLORS[violation.severity] ?? '#6b7280';

  await fetch(config.webhookUrl, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      attachments: [{
        color,
        blocks: [
          {
            type: 'header',
            text: { type: 'plain_text', text: `[${violation.severity.toUpperCase()}] Policy Violation` },
          },
          {
            type: 'section',
            fields: [
              { type: 'mrkdwn', text: `*Policy:*\n${violation.policyName}` },
              { type: 'mrkdwn', text: `*Severity:*\n${violation.severity}` },
            ],
          },
          {
            type: 'section',
            text: { type: 'mrkdwn', text: `*Details:*\n${violation.summary}` },
          },
          {
            type: 'actions',
            elements: [{
              type: 'button',
              text: { type: 'plain_text', text: 'View in Dashboard' },
              url: 'https://opensyber.cloud/dashboard/agents/violations',
            }],
          },
        ],
      }],
    }),
  });
}
```

