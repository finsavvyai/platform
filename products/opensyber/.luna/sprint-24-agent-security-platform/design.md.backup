## Service Layer

### FR-1: Real AWS CSPM Scanner

The AWS scanner replaces the mock implementation in `cspm-scanner.ts`. It is organized as a directory of check modules for maintainability and the 200-line file limit.

#### Architecture

```
services/aws-scanner/
  index.ts          -- orchestrator: assume role, run all checks, aggregate findings
  sts-client.ts     -- STS AssumeRole wrapper
  s3-checks.ts      -- 4 checks: public access, public ACL, versioning, logging
  iam-checks.ts     -- 5 checks: root keys, root MFA, password policy, no-MFA users, admin policies
  ec2-checks.ts     -- 4 checks: SSH SGs, RDP SGs, unencrypted EBS, default encryption, default VPC
  rds-checks.ts     -- 2 checks: public RDS, unencrypted RDS
  cloudtrail-checks.ts -- 2 checks: multi-region, log validation
  guardduty-check.ts   -- 1 check: GuardDuty enabled
  types.ts          -- shared interfaces
```

#### `types.ts`

```typescript
export interface ScanContext {
  credentials: {
    accessKeyId: string;
    secretAccessKey: string;
    sessionToken: string;
  };
  region: string;
  accountId: string;
}

export interface CheckResult {
  checkId: string;
  severity: 'critical' | 'high' | 'medium' | 'low';
  resourceType: string;
  findings: CheckFinding[];
  error?: string;
}

export interface CheckFinding {
  resourceId: string;
  region: string;
  title: string;
  description: string;
  remediation: string;
  complianceFrameworks: string[];
}
```

#### `sts-client.ts`

```typescript
import { STSClient, AssumeRoleCommand } from '@aws-sdk/client-sts';
import type { ScanContext } from './types.js';

export async function assumeRole(
  roleArn: string,
  externalId: string,
): Promise<ScanContext> {
  const sts = new STSClient({ region: 'us-east-1' });

  const result = await sts.send(new AssumeRoleCommand({
    RoleArn: roleArn,
    RoleSessionName: `opensyber-scan-${Date.now()}`,
    ExternalId: externalId,
    DurationSeconds: 900, // 15 minutes, minimum
  }));

  const creds = result.Credentials;
  if (!creds?.AccessKeyId || !creds?.SecretAccessKey || !creds?.SessionToken) {
    throw new Error('STS AssumeRole returned incomplete credentials');
  }

  // Extract account ID from role ARN
  const accountId = roleArn.split(':')[4] ?? 'unknown';

  return {
    credentials: {
      accessKeyId: creds.AccessKeyId,
      secretAccessKey: creds.SecretAccessKey,
      sessionToken: creds.SessionToken,
    },
    region: 'us-east-1',
    accountId,
  };
}
```

#### `index.ts` (Orchestrator)

```typescript
import type { DrizzleD1Database } from 'drizzle-orm/d1';
import { eq } from 'drizzle-orm';
import { cloudAccounts, cspmScanRuns, cspmFindings } from '@opensyber/db';
import { decrypt } from '../../utils/encryption.js';
import { assumeRole } from './sts-client.js';
import { runS3Checks } from './s3-checks.js';
import { runIamChecks } from './iam-checks.js';
import { runEc2Checks } from './ec2-checks.js';
import { runRdsChecks } from './rds-checks.js';
import { runCloudTrailChecks } from './cloudtrail-checks.js';
import { runGuardDutyCheck } from './guardduty-check.js';
import type { CheckResult, ScanContext } from './types.js';

type Db = DrizzleD1Database<Record<string, unknown>>;

export interface AwsScanResult {
  scanRun: { id: string; status: string; findingCount: number; criticalCount: number; highCount: number };
  error?: string;
}

export async function runAwsScan(
  db: Db,
  cloudAccountId: string,
  orgId: string | null,
  roleArn: string,
  externalId: string,
  encryptionKey: string,
): Promise<AwsScanResult> {
  const scanId = crypto.randomUUID();
  const now = new Date().toISOString();

  // Insert scan run as "running"
  await db.insert(cspmScanRuns).values({
    id: scanId, cloudAccountId, orgId,
    startedAt: now, status: 'running',
    findingCount: 0, criticalCount: 0, highCount: 0,
  });

  try {
    // Assume role (temporary credentials, never stored)
    const ctx = await assumeRole(roleArn, externalId);

    // Run all checks concurrently with individual error handling
    const checkResults = await Promise.allSettled([
      runS3Checks(ctx),
      runIamChecks(ctx),
      runEc2Checks(ctx),
      runRdsChecks(ctx),
      runCloudTrailChecks(ctx),
      runGuardDutyCheck(ctx),
    ]);

    // Collect findings from successful checks
    const allFindings: typeof cspmFindings.$inferInsert[] = [];
    const errors: string[] = [];
    let criticalCount = 0;
    let highCount = 0;

    for (const result of checkResults) {
      if (result.status === 'rejected') {
        errors.push(String(result.reason));
        continue;
      }
      for (const check of result.value) {
        if (check.error) {
          errors.push(`${check.checkId}: ${check.error}`);
          continue;
        }
        for (const finding of check.findings) {
          if (check.severity === 'critical') criticalCount++;
          if (check.severity === 'high') highCount++;
          allFindings.push({
            id: crypto.randomUUID(),
            scanRunId: scanId,
            cloudAccountId,
            orgId,
            checkId: check.checkId,
            severity: check.severity,
            status: 'open',
            resourceId: finding.resourceId,
            resourceType: check.resourceType,
            region: finding.region,
            title: finding.title,
            description: finding.description,
            remediation: finding.remediation,
            complianceFrameworks: JSON.stringify(finding.complianceFrameworks),
            firstSeenAt: now,
          });
        }
      }
    }

    // Batch insert findings (max 100 per batch for D1)
    for (let i = 0; i < allFindings.length; i += 100) {
      const batch = allFindings.slice(i, i + 100);
      await db.insert(cspmFindings).values(batch);
    }

    // Update scan run
    const completedAt = new Date().toISOString();
    await db.update(cspmScanRuns).set({
      status: 'completed',
      completedAt,
      findingCount: allFindings.length,
      criticalCount,
      highCount,
    }).where(eq(cspmScanRuns.id, scanId));

    // Update cloud account
    await db.update(cloudAccounts).set({
      lastScanAt: completedAt,
      status: 'active',
    }).where(eq(cloudAccounts.id, cloudAccountId));

    return {
      scanRun: {
        id: scanId,
        status: 'completed',
        findingCount: allFindings.length,
        criticalCount,
        highCount,
      },
    };
  } catch (err) {
    // Mark scan as failed
    await db.update(cspmScanRuns).set({
      status: 'failed',
      completedAt: new Date().toISOString(),
    }).where(eq(cspmScanRuns.id, scanId));

    return {
      scanRun: { id: scanId, status: 'failed', findingCount: 0, criticalCount: 0, highCount: 0 },
      error: err instanceof Error ? err.message : 'Unknown scan error',
    };
  }
}
```

#### Example Check Module: `s3-checks.ts`

```typescript
import { S3Client, ListBucketsCommand, GetPublicAccessBlockCommand,
         GetBucketAclCommand, GetBucketVersioningCommand,
         GetBucketLoggingCommand } from '@aws-sdk/client-s3';
import type { ScanContext, CheckResult } from './types.js';

function createClient(ctx: ScanContext): S3Client {
  return new S3Client({
    region: ctx.region,
    credentials: ctx.credentials,
  });
}

export async function runS3Checks(ctx: ScanContext): Promise<CheckResult[]> {
  const client = createClient(ctx);
  const results: CheckResult[] = [];

  try {
    const buckets = await client.send(new ListBucketsCommand({}));
    const bucketList = buckets.Buckets ?? [];

    // Check 1: S3 Block Public Access
    for (const bucket of bucketList.slice(0, 100)) {
      try {
        const pab = await client.send(
          new GetPublicAccessBlockCommand({ Bucket: bucket.Name })
        );
        const config = pab.PublicAccessBlockConfiguration;
        if (!config?.BlockPublicAcls || !config?.BlockPublicPolicy ||
            !config?.IgnorePublicAcls || !config?.RestrictPublicBuckets) {
          // Finding: public access not fully blocked
          results.push({
            checkId: 'S3-PUB-BLOCK',
            severity: 'critical',
            resourceType: 's3-bucket',
            findings: [{
              resourceId: `arn:aws:s3:::${bucket.Name}`,
              region: ctx.region,
              title: 'S3 Block Public Access not fully enabled',
              description: `Bucket ${bucket.Name} does not have all Block Public Access settings enabled.`,
              remediation: 'Enable all four Block Public Access settings on this bucket.',
              complianceFrameworks: ['CIS AWS 2.1.5', 'SOC2 CC6.6'],
            }],
          });
        }
      } catch {
        // Public access block may not exist -- treat as finding
      }
    }

    // Check 2: S3 bucket with public ACL (similar pattern)
    // Check 3: S3 bucket versioning disabled
    // Check 4: S3 bucket access logging disabled
    // ... each follows the same pattern

  } catch (err) {
    return [{
      checkId: 'S3-ALL',
      severity: 'high',
      resourceType: 's3-bucket',
      findings: [],
      error: err instanceof Error ? err.message : 'S3 checks failed',
    }];
  }

  return results;
}
```

#### Modified `cspm-scanner.ts`

The existing file becomes a dispatcher:

```typescript
import type { DrizzleD1Database } from 'drizzle-orm/d1';
import { eq } from 'drizzle-orm';
import { cloudAccounts } from '@opensyber/db';
import { runAwsScan } from './aws-scanner/index.js';
import { decrypt } from '../utils/encryption.js';

type Db = DrizzleD1Database<Record<string, unknown>>;

export interface ScanResult {
  scanRun: { id: string; status: string; findingCount: number; criticalCount: number; highCount: number };
  error?: string;
}

export async function runCspmScan(
  db: Db,
  cloudAccountId: string,
  orgId: string | null,
  provider: string,
  encryptionKey: string,
): Promise<ScanResult> {
  if (provider !== 'aws') {
    return {
      scanRun: { id: '', status: 'failed', findingCount: 0, criticalCount: 0, highCount: 0 },
      error: `Provider '${provider}' not yet supported. Only AWS is available.`,
    };
  }

  // Fetch account credentials
  const [account] = await db.select().from(cloudAccounts)
    .where(eq(cloudAccounts.id, cloudAccountId));

  if (!account?.roleArn || !account?.externalId) {
    return {
      scanRun: { id: '', status: 'failed', findingCount: 0, criticalCount: 0, highCount: 0 },
      error: 'Cloud account missing roleArn or externalId',
    };
  }

  return runAwsScan(db, cloudAccountId, orgId, account.roleArn, account.externalId, encryptionKey);
}
```

