### FR-7: Risk Snapshot Cron

**File**: `apps/api/src/services/risk-snapshot-cron.ts`

```typescript
import { eq, and, gte, isNotNull } from 'drizzle-orm';
import { agentActivity, cspmFindings, agentRiskSnapshots, users } from '@opensyber/db';
import type { Env } from '../types.js';
import { createDb } from '../lib/db.js';
import {
  computeAgentScore, computeCspmScore, computeCombinedRiskScore,
  type AgentSummary, type CspmSummary,
} from './combined-risk-score.js';

export async function generateRiskSnapshots(env: Env): Promise<void> {
  const db = createDb(env.DB);
  const today = new Date().toISOString().split('T')[0]!;
  const yesterday = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString();

  // Find users with recent activity
  const activeUsers = await db
    .selectDistinct({ userId: agentActivity.userId })
    .from(agentActivity)
    .where(gte(agentActivity.createdAt, yesterday))
    .limit(500);

  // Process users in batches of 50
  for (let i = 0; i < activeUsers.length; i += 50) {
    const batch = activeUsers.slice(i, i + 50);

    for (const { userId } of batch) {
      // Compute agent summary
      const events = await db.select().from(agentActivity)
        .where(eq(agentActivity.userId, userId)).limit(1000);

      const agentSummary: AgentSummary = {
        total: events.length, critical: 0, high: 0, medium: 0, low: 0, secretsDetected: 0,
      };
      for (const e of events) {
        const k = e.risk as keyof Pick<AgentSummary, 'critical'|'high'|'medium'|'low'>;
        if (k in agentSummary) agentSummary[k]++;
        agentSummary.secretsDetected += e.secretsCount;
      }

      const agentScore = computeAgentScore(agentSummary);
      const cspmScore = 100; // Per-user CSPM not applicable without org
      const combined = Math.round(agentScore * 0.6 + cspmScore * 0.4);
      const grade = combined >= 90 ? 'A' : combined >= 70 ? 'B' : combined >= 50 ? 'C' : combined >= 30 ? 'D' : 'F';

      // Upsert (insert or ignore for idempotency)
      await db.insert(agentRiskSnapshots).values({
        id: crypto.randomUUID(),
        userId,
        orgId: null,
        agentScore,
        cspmScore,
        combinedScore: combined,
        grade,
        agentEventCount: events.length,
        cspmFindingCount: 0,
        snapshotDate: today,
        createdAt: new Date().toISOString(),
      }).onConflictDoNothing();
    }
  }

  // TODO: Org-level snapshots (similar pattern, grouped by orgId)
  // Deferred to keep within cron CPU budget
}
```

