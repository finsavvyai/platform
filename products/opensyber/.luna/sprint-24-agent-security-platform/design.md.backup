### FR-7: Risk Trend Chart

**File**: `apps/web/src/components/dashboard/RiskTrendChart.tsx`

```typescript
'use client';

import { useEffect, useState } from 'react';
import { LineChart, Line, XAxis, YAxis, Tooltip, ResponsiveContainer } from 'recharts';

interface TrendPoint {
  date: string;
  agentScore: number;
  cspmScore: number;
  combined: number;
  grade: string;
}

interface RiskTrendChartProps {
  endpoint: string; // e.g., '/api/proxy/agents/risk-trend'
  days?: '7' | '30' | '90';
}

export function RiskTrendChart({ endpoint, days = '30' }: RiskTrendChartProps) {
  const [data, setData] = useState<TrendPoint[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetch(`${endpoint}?days=${days}`)
      .then(r => r.json())
      .then(d => setData(d.data ?? []))
      .catch(() => setData([]))
      .finally(() => setLoading(false));
  }, [endpoint, days]);

  if (loading) return <div className="h-64 animate-pulse rounded-xl bg-neutral-800" />;
  if (data.length === 0) return null;

  return (
    <div className="rounded-xl border border-neutral-800 bg-neutral-900/30 p-6">
      <h3 className="mb-4 text-sm font-semibold uppercase tracking-wider text-neutral-500">
        Risk Score Trend
      </h3>
      <ResponsiveContainer width="100%" height={240}>
        <LineChart data={data}>
          <XAxis dataKey="date" stroke="#525252" fontSize={11} />
          <YAxis domain={[0, 100]} stroke="#525252" fontSize={11} />
          <Tooltip
            contentStyle={{ background: '#1a1a1a', border: '1px solid #333', borderRadius: 8 }}
            labelStyle={{ color: '#a3a3a3' }}
          />
          <Line type="monotone" dataKey="combined" stroke="#3b82f6" strokeWidth={2} dot={false} name="Combined" />
          <Line type="monotone" dataKey="agentScore" stroke="#22c55e" strokeWidth={1} dot={false} name="Agent" />
          <Line type="monotone" dataKey="cspmScore" stroke="#f59e0b" strokeWidth={1} dot={false} name="CSPM" />
        </LineChart>
      </ResponsiveContainer>
    </div>
  );
}
```

### FR-4: Related Findings Component

**File**: `apps/web/src/components/dashboard/RelatedFindings.tsx`

```typescript
'use client';

import { useState } from 'react';
import { ChevronDown, ShieldAlert } from 'lucide-react';

interface Finding {
  id: string;
  checkId: string;
  severity: string;
  title: string;
  resourceId: string;
  status: string;
}

interface RelatedFindingsProps {
  activityId: string;
}

const SEVERITY_COLORS: Record<string, string> = {
  critical: 'text-red-400',
  high: 'text-orange-400',
  medium: 'text-amber-400',
  low: 'text-neutral-500',
};

export function RelatedFindings({ activityId }: RelatedFindingsProps) {
  const [findings, setFindings] = useState<Finding[] | null>(null);
  const [loading, setLoading] = useState(false);
  const [expanded, setExpanded] = useState(false);

  async function loadFindings() {
    if (findings !== null) {
      setExpanded(!expanded);
      return;
    }
    setLoading(true);
    try {
      const res = await fetch(`/api/proxy/agents/activity/${activityId}/related-findings`);
      const data = await res.json();
      setFindings(data.data ?? []);
      setExpanded(true);
    } catch {
      setFindings([]);
    } finally {
      setLoading(false);
    }
  }

  return (
    <div>
      <button
        onClick={loadFindings}
        className="flex items-center gap-1 text-xs text-blue-400 hover:text-blue-300 transition"
      >
        <ShieldAlert className="h-3 w-3" />
        Related Findings
        <ChevronDown className={`h-3 w-3 transition ${expanded ? 'rotate-180' : ''}`} />
      </button>

      {expanded && findings && findings.length > 0 && (
        <div className="mt-2 space-y-1 rounded-lg border border-neutral-800 bg-neutral-900 p-3">
          {findings.map(f => (
            <div key={f.id} className="flex items-center gap-2 text-xs">
              <span className={`font-medium ${SEVERITY_COLORS[f.severity] ?? ''}`}>
                {f.severity.toUpperCase()}
              </span>
              <span className="text-neutral-300">{f.title}</span>
              <span className="text-neutral-600">{f.resourceId}</span>
            </div>
          ))}
        </div>
      )}

      {expanded && findings && findings.length === 0 && (
        <p className="mt-1 text-xs text-neutral-600">No related cloud findings</p>
      )}
    </div>
  );
}
```

