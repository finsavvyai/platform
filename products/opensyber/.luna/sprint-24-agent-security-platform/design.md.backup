### FR-8: PDF Report Generator

**File**: `apps/api/src/services/pdf-report-generator.ts`

```typescript
import { jsPDF } from 'jspdf';
import autoTable from 'jspdf-autotable';
import type { AgentSummary, CspmSummary, CombinedScore } from './combined-risk-score.js';

interface ReportData {
  orgName: string;
  score: CombinedScore;
  agentSummary: AgentSummary;
  cspmSummary: CspmSummary;
  violations: Array<{ summary: string; severity: string; createdAt: string }>;
}

const GRADE_COLORS: Record<string, [number, number, number]> = {
  A: [34, 197, 94],   // green
  B: [59, 130, 246],  // blue
  C: [245, 158, 11],  // amber
  D: [239, 68, 68],   // red
  F: [220, 38, 38],   // deep red
};

export function generatePdfReport(data: ReportData): ArrayBuffer {
  const doc = new jsPDF();
  const now = new Date().toISOString().split('T')[0];

  // Cover page
  doc.setFontSize(28);
  doc.setTextColor(255, 255, 255);
  doc.setFillColor(10, 10, 10);
  doc.rect(0, 0, 210, 297, 'F');

  doc.setTextColor(255, 255, 255);
  doc.text('OpenSyber', 20, 40);
  doc.setFontSize(20);
  doc.text('Security Report', 20, 55);

  doc.setFontSize(12);
  doc.setTextColor(160, 160, 160);
  doc.text(`Organization: ${data.orgName}`, 20, 80);
  doc.text(`Date: ${now}`, 20, 90);

  // Grade
  const gradeColor = GRADE_COLORS[data.score.grade] ?? [160, 160, 160];
  doc.setFontSize(72);
  doc.setTextColor(...gradeColor);
  doc.text(data.score.grade, 85, 160);
  doc.setFontSize(14);
  doc.text(`Combined Score: ${data.score.combined}/100`, 65, 180);

  // Page 2: Executive Summary
  doc.addPage();
  doc.setFillColor(10, 10, 10);
  doc.rect(0, 0, 210, 297, 'F');

  doc.setFontSize(18);
  doc.setTextColor(255, 255, 255);
  doc.text('Executive Summary', 20, 30);

  doc.setFontSize(11);
  doc.setTextColor(200, 200, 200);
  doc.text(`Agent Risk Score: ${data.score.agentScore}/100`, 20, 50);
  doc.text(`CSPM Score: ${data.score.cspmScore}/100`, 20, 60);
  doc.text(`Combined Score: ${data.score.combined}/100 (Grade: ${data.score.grade})`, 20, 70);

  // Agent risk table
  autoTable(doc, {
    startY: 85,
    head: [['Category', 'Count']],
    body: [
      ['Critical Events', String(data.agentSummary.critical)],
      ['High Events', String(data.agentSummary.high)],
      ['Medium Events', String(data.agentSummary.medium)],
      ['Low Events', String(data.agentSummary.low)],
      ['Secrets Detected', String(data.agentSummary.secretsDetected)],
    ],
    theme: 'grid',
    styles: { fillColor: [26, 26, 26], textColor: [200, 200, 200] },
    headStyles: { fillColor: [40, 40, 40], textColor: [255, 255, 255] },
  });

  // CSPM findings table
  const cspmY = (doc as any).lastAutoTable.finalY + 15;
  doc.setFontSize(14);
  doc.setTextColor(255, 255, 255);
  doc.text('CSPM Findings', 20, cspmY);

  autoTable(doc, {
    startY: cspmY + 10,
    head: [['Severity', 'Open Count']],
    body: [
      ['Critical', String(data.cspmSummary.critical)],
      ['High', String(data.cspmSummary.high)],
      ['Medium', String(data.cspmSummary.medium)],
      ['Low', String(data.cspmSummary.low)],
    ],
    theme: 'grid',
    styles: { fillColor: [26, 26, 26], textColor: [200, 200, 200] },
    headStyles: { fillColor: [40, 40, 40], textColor: [255, 255, 255] },
  });

  // Page 3: Top violations
  if (data.violations.length > 0) {
    doc.addPage();
    doc.setFillColor(10, 10, 10);
    doc.rect(0, 0, 210, 297, 'F');

    doc.setFontSize(18);
    doc.setTextColor(255, 255, 255);
    doc.text('Recent Policy Violations', 20, 30);

    autoTable(doc, {
      startY: 40,
      head: [['Severity', 'Summary', 'Date']],
      body: data.violations.slice(0, 20).map(v => [
        v.severity.toUpperCase(),
        v.summary.slice(0, 80),
        v.createdAt.split('T')[0] ?? '',
      ]),
      theme: 'grid',
      styles: { fillColor: [26, 26, 26], textColor: [200, 200, 200], fontSize: 8 },
      headStyles: { fillColor: [40, 40, 40], textColor: [255, 255, 255] },
      columnStyles: { 1: { cellWidth: 100 } },
    });
  }

  // Footer on each page
  const pageCount = doc.getNumberOfPages();
  for (let i = 1; i <= pageCount; i++) {
    doc.setPage(i);
    doc.setFontSize(8);
    doc.setTextColor(100, 100, 100);
    doc.text('Generated by OpenSyber | opensyber.cloud', 20, 290);
    doc.text(`Page ${i} of ${pageCount}`, 170, 290);
  }

  return doc.output('arraybuffer');
}
```

#### Modified `agent-report-export.ts`

Add PDF generation alongside HTML:

```typescript
import { generatePdfReport } from './pdf-report-generator.js';

export async function generateAgentReport(
  db: Db,
  env: ReportEnv,
  orgId: string,
  orgName: string,
): Promise<ReportResult> {
  // ... existing data fetching ...

  const html = buildHtml(orgName, agentSummary, cspmSummary, score, violations);
  const pdfBuffer = generatePdfReport({
    orgName, score, agentSummary, cspmSummary, violations,
  });

  const reportId = crypto.randomUUID();

  // Store both HTML and PDF in R2
  await Promise.all([
    env.STORAGE.put(`reports/${orgId}/${reportId}.html`, html, {
      httpMetadata: { contentType: 'text/html' },
    }),
    env.STORAGE.put(`reports/${orgId}/${reportId}.pdf`, pdfBuffer, {
      httpMetadata: { contentType: 'application/pdf' },
    }),
  ]);

  return {
    reportId,
    downloadUrl: `/api/agents/reports/${reportId}/download`,
    pdfUrl: `/api/agents/reports/${reportId}/download?format=pdf`,
  };
}
```

The download endpoint in `agent-reports.ts` is updated to support `?format=pdf`:

```typescript
agentReportRoutes.get('/reports/:id/download', async (c) => {
  const format = c.req.query('format') === 'pdf' ? 'pdf' : 'html';
  const ext = format;
  const contentType = format === 'pdf' ? 'application/pdf' : 'text/html';
  const disposition = format === 'pdf' ? 'attachment' : 'inline';

  const key = `reports/${orgId}/${reportId}.${ext}`;
  const object = await c.env.STORAGE.get(key);
  if (!object) return c.json({ error: 'Not found' }, 404);

  const body = await object.arrayBuffer();
  return new Response(body, {
    headers: {
      'Content-Type': contentType,
      'Content-Disposition': `${disposition}; filename="opensyber-report-${reportId}.${ext}"`,
    },
  });
});
```

