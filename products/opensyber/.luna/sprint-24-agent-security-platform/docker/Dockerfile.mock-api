# Mock API Server - Simulates Cloudflare Workers APIs locally
# This allows the web apps to function during local development

FROM node:22-alpine

# Install pnpm and utilities
RUN npm install -g pnpm@10.6.2 && \
    apk add --no-cache git

WORKDIR /app

# Copy workspace files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY turbo.json ./

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Create mock server entry point
RUN mkdir -p /app/mock-api

# Expose port
EXPOSE 8787

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD wget --spider -q http://localhost:8787/health || exit 1

# Run mock API server
CMD ["node", "/app/mock-api/server.js"]
