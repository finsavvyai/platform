# TokenForge Web - Development Dockerfile
# Includes hot reload and Next.js dev server

FROM node:22-alpine
WORKDIR /app

# Install system dependencies
RUN apk add --no-cache libc6-compat git

# Install pnpm
RUN corepack enable && corepack prepare pnpm@10.6.2 --activate

# Create non-root user (with more permissions for development)
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 opensyber

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install all dependencies (including dev dependencies)
RUN pnpm install

# Set environment
ENV NODE_ENV=development
ENV PORT=3001

# Set permissions
RUN chown -R opensyber:nodejs /app
USER opensyber

# Expose port
EXPOSE 3001

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3001', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

# Run in development mode with hot reload
CMD ["pnpm", "dev", "--filter=@opensyber/tokenforge-web"]
