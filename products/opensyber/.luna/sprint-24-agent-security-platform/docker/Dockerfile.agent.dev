# OpenSyber Agent - Development Dockerfile
# Includes hot reload and development tools

FROM node:22-alpine
WORKDIR /app

# Install system dependencies for agent operations and development
RUN apk add --no-cache \
    libc6-compat \
    docker-cli \
    curl \
    bash \
    procps \
    git

# Install pnpm
RUN corepack enable && corepack prepare pnpm@10.6.2 --activate

# Create non-root user with docker group access
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 opensyber
RUN addgroup docker
RUN addgroup opensyber docker

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install all dependencies (including dev dependencies)
RUN pnpm install

# Set environment
ENV NODE_ENV=development
ENV AGENT_MODE=development

# Set permissions
RUN chown -R opensyber:nodejs /app
USER opensyber

# Expose metrics port
EXPOSE 9090

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:9090/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

# Run in development mode with hot reload
CMD ["pnpm", "dev", "--filter=@opensyber/agent"]
