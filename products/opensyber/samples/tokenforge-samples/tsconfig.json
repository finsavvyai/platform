{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDirs": [".", "../../packages/tokenforge/src"],
    "jsx": "react-jsx",
    "types": ["vitest/globals", "node"],
    "paths": {
      "@opensyber/tokenforge/*": ["../../packages/tokenforge/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "integration/**"]
}
