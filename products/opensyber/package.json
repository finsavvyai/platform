{
  "name": "opensyber",
  "version": "0.1.0",
  "private": true,
  "description": "OpenSyber — Secure, managed AI agent hosting with audited skills and security monitoring",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "deploy:api": "turbo run deploy --filter=@opensyber/api"
  },
  "packageManager": "pnpm@10.6.2",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "playwright": "^1.58.2",
    "prettier": "^3.8.3",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.60.2",
      "minimatch": ">=10.2.5",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.2",
      "brace-expansion": ">=5.0.5",
      "lodash": ">=4.18.1",
      "next-auth": ">=5.0.0-beta.31",
      "fast-uri": ">=3.1.2",
      "fast-xml-builder": ">=1.1.7"
    }
  }
}
