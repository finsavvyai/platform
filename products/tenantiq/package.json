{
  "name": "tenantiq",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:visual": "playwright test tests/e2e/visual-regression.spec.ts --update-snapshots",
    "test:visual:check": "playwright test tests/e2e/visual-regression.spec.ts",
    "test:load": "k6 run tests/load/api-load.js",
    "test:load:smoke": "k6 run --vus 5 --duration 30s tests/load/api-load.js",
    "check": "turbo check",
    "analyze": "cd apps/web && ANALYZE=true npm run build",
    "clean": "turbo clean",
    "onboard": "tsx scripts/onboard.ts",
    "changelog": "git-cliff -o CHANGELOG.md",
    "deploy": "bash scripts/deploy-all.sh auto",
    "deploy:landing": "bash scripts/deploy-all.sh landing",
    "deploy:api": "bash scripts/deploy-all.sh api",
    "deploy:web": "bash scripts/deploy-all.sh web",
    "deploy:all": "bash scripts/deploy-all.sh all"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.2",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@cloudflare/workers-types": "4.20260405.1"
    }
  }
}
