# ============================================================================
# TenantIQ Deployment Environment Variables
# ============================================================================
# Copy this file to .env and fill in all values before deployment
# WARNING: Never commit .env to version control
# ============================================================================

# ---- Environment ----
ENVIRONMENT=production
LOG_LEVEL=info
NODE_ENV=production

# ---- Microsoft Graph API (Azure AD App Registration) ----
# Create app at: https://portal.azure.com/#view/Microsoft_AAD_IAM/ActiveDirectoryMenuBlade
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_AUTHORITY_URL=https://login.microsoftonline.com

# ---- Claude AI / Anthropic API ----
# Get key at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Database (Neon PostgreSQL) ----
# Create cluster at: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-example-pool.us-west-2.aws.neon.tech/tenantiq?sslmode=require

# ---- Redis (optional, for session caching) ----
REDIS_URL=redis://localhost:6379

# ---- Authentication & Encryption ----
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=7d
ENCRYPTION_KEY=your-encryption-key-here

# ---- Cloudflare Configuration ----
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_WORKERS_ACCOUNT_ID=your-workers-account-id

# ---- Cloudflare Pages (if deploying landing page) ----
PAGES_DEPLOYMENT_HOOK=your-deployment-webhook-url

# ---- Application Configuration ----
APP_URL=https://app.tenantiq.io
API_URL=https://api.tenantiq.io
LANDING_PAGE_URL=https://tenantiq.io

# ---- Security & Compliance ----
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000
CORS_ORIGINS=https://app.tenantiq.io,https://tenantiq.io

# ---- Claw Gateway (centralized AI routing, caching, billing) ----
# Routes LLM calls through shared gateway for usage tracking and cost control
CLAW_API_KEY=your-claw-api-key
CLAW_PROJECT_ID=tenantiq

# ---- OpenClaw AI Skill Supply Chain ----
OPENCLAW_API_URL=https://openclaw.api.tenantiq.io
OPENCLAW_API_KEY=your-openclaw-key

# ---- Monitoring & Analytics ----
SENTRY_DSN=https://your-key@sentry.io/project-id
DATADOG_API_KEY=your-datadog-api-key
DATADOG_SITE=us5.datadoghq.com

# ---- Email Configuration (for alerts & reports) ----
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_FROM=noreply@tenantiq.io

# ---- Webhook Secrets ----
# Used to verify incoming webhooks from Microsoft Graph
WEBHOOK_VERIFICATION_TOKEN=your-webhook-verification-token
MS_GRAPH_WEBHOOK_SECRET=your-webhook-secret

# ---- Feature Flags ----
FEATURE_LICENSE_OPTIMIZATION=true
FEATURE_AUTOMATED_REMEDIATION=true
FEATURE_AI_SCORING=true
FEATURE_COMPLIANCE_REPORTS=true

# ---- Billing & Licensing ----
PRICING_PER_TENANT_STARTER=5
PRICING_PER_TENANT_PROFESSIONAL=10
PRICING_PER_TENANT_ENTERPRISE=15
TRIAL_DURATION_DAYS=14

# ---- Multi-Tenant Configuration ----
MAX_TENANTS_PER_MSP=1000
TENANT_ISOLATION_LEVEL=strict
CROSS_TENANT_ANALYTICS=disabled
