{
  "name": "@tenantiq/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:mobile": "BUILD_TARGET=mobile bash -c 'mv src/instrumentation.server.ts src/instrumentation.server.ts.bak 2>/dev/null; vite build; S=$?; mv src/instrumentation.server.ts.bak src/instrumentation.server.ts 2>/dev/null; exit $S'",
    "preview": "vite preview",
    "screenshots:setup": "tsx scripts/capture-store-screenshots.ts --setup",
    "screenshots": "tsx scripts/capture-store-screenshots.ts",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@capacitor/cli": "^8.3.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^20.0.0",
    "jsdom": "^26.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.55.1",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.7",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@opensyber/tokenforge": "^0.1.2",
    "@sentry/sveltekit": "^10.49.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@tenantiq/shared": "workspace:*",
    "lucide-svelte": "^1.0.1"
  },
  "type": "module"
}
