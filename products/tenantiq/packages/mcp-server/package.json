  },
  "keywords": [
    "mcp",
    "tenantiq",
    "json-rpc",
    "microsoft365"
  ],
  "author": "TenantIQ",
  "license": "MIT",
  "dependencies": {
    "@tenantiq/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.3",
    "vitest": "^4.0.18"
  }
