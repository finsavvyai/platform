{
  "name": "@tenantiq/mcp-server",
  "version": "1.0.0",
  "description": "MCP stdio server for TenantIQ — exposes 15 tools via JSON-RPC 2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tenantiq-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
