{
  "name": "@tenantiq/webhooks",
  "version": "1.0.0",
  "description": "Webhook delivery service for TenantIQ real-time alerts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@tenantiq/shared": "workspace:*",
    "@tenantiq/db": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
