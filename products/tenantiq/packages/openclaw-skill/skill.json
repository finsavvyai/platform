{
  "name": "tenantiq",
  "version": "1.0.0",
  "displayName": "TenantIQ - Microsoft 365 Intelligence",
  "description": "AI-powered Microsoft 365 tenant management with security monitoring, license optimization, and compliance automation",
  "author": "TenantIQ",
  "homepage": "https://tenantiq.app",
  "repository": "https://github.com/tenantiq/openclaw-skill",
  "license": "MIT",
  "keywords": [
    "microsoft365",
    "m365",
    "azure",
    "security",
    "compliance",
    "license-optimization",
    "tenant-management",
    "msp",
    "it-management"
  ],
  "category": "productivity",
  "icon": "🔐",
  "activationCommands": [
    "tenantiq",
    "tenantiq help",
    "tenantiq security status",
    "tenantiq license waste",
    "tenantiq check alerts"
  ],
  "permissions": [
    "network",
    "storage"
  ],
  "configuration": {
    "apiUrl": {
      "type": "string",
      "description": "TenantIQ API endpoint URL",
      "default": "https://api.tenantiq.app",
      "required": false
    },
    "accessToken": {
      "type": "string",
      "description": "OAuth2 access token (automatically managed)",
      "secret": true,
      "required": false
    },
    "refreshToken": {
      "type": "string",
      "description": "OAuth2 refresh token (automatically managed)",
      "secret": true,
      "required": false
    },
    "activeTenantId": {
      "type": "string",
      "description": "Currently active tenant ID",
      "required": false
    }
  },
  "commands": [
    {
      "name": "security status",
      "description": "Get security posture summary",
      "category": "security",
      "examples": ["tenantiq security status"]
    },
    {
      "name": "check alerts",
      "description": "List active alerts",
      "category": "security",
      "examples": ["tenantiq check alerts", "tenantiq alerts"]
    },
    {
      "name": "show critical alerts",
      "description": "Display critical alerts with details",
      "category": "security",
      "examples": ["tenantiq show critical alerts"]
    },
    {
      "name": "mfa status",
      "description": "Check MFA adoption rate",
      "category": "security",
      "examples": ["tenantiq mfa status"]
    },
    {
      "name": "risky users",
      "description": "List users with security issues",
      "category": "security",
      "examples": ["tenantiq risky users"]
    },
    {
      "name": "license waste",
      "description": "Calculate license waste and savings",
      "category": "licenses",
      "examples": ["tenantiq license waste", "tenantiq waste"]
    },
    {
      "name": "inactive users",
      "description": "Find users who haven't logged in",
      "category": "licenses",
      "examples": ["tenantiq inactive users", "tenantiq inactive users 90"]
    },
    {
      "name": "unused licenses",
      "description": "List unassigned licenses",
      "category": "licenses",
      "examples": ["tenantiq unused licenses"]
    },
    {
      "name": "downgrade",
      "description": "Downgrade a user's license",
      "category": "licenses",
      "examples": ["tenantiq downgrade john@contoso.com"]
    },
    {
      "name": "optimize licenses",
      "description": "Get AI optimization recommendations",
      "category": "licenses",
      "examples": ["tenantiq optimize licenses"]
    },
    {
      "name": "search user",
      "description": "Find users by name or email",
      "category": "users",
      "examples": ["tenantiq search user john"]
    },
    {
      "name": "user details",
      "description": "Get detailed user information",
      "category": "users",
      "examples": ["tenantiq user details john@contoso.com"]
    },
    {
      "name": "guest users",
      "description": "List all guest accounts",
      "category": "users",
      "examples": ["tenantiq guest users"]
    },
    {
      "name": "remove guest",
      "description": "Remove a guest user",
      "category": "users",
      "examples": ["tenantiq remove guest external@partner.com"]
    },
    {
      "name": "reset password",
      "description": "Force password reset for a user",
      "category": "users",
      "examples": ["tenantiq reset password john@contoso.com"]
    },
    {
      "name": "compliance status",
      "description": "Get compliance overview",
      "category": "compliance",
      "examples": ["tenantiq compliance status"]
    },
    {
      "name": "groups without owners",
      "description": "List orphaned groups",
      "category": "compliance",
      "examples": ["tenantiq groups without owners"]
    },
    {
      "name": "audit trail",
      "description": "Search audit logs",
      "category": "compliance",
      "examples": ["tenantiq audit trail", "tenantiq audit trail user_deleted"]
    },
    {
      "name": "switch tenant",
      "description": "Switch to a different tenant",
      "category": "tenants",
      "examples": ["tenantiq switch tenant Contoso"]
    },
    {
      "name": "list tenants",
      "description": "Show all accessible tenants",
      "category": "tenants",
      "examples": ["tenantiq list tenants"]
    },
    {
      "name": "dashboard",
      "description": "Get comprehensive metrics",
      "category": "tenants",
      "examples": ["tenantiq dashboard"]
    },
    {
      "name": "ask",
      "description": "Ask AI a question",
      "category": "ai",
      "examples": ["tenantiq ask how can I reduce costs?"]
    },
    {
      "name": "recommend",
      "description": "Get AI recommendations",
      "category": "ai",
      "examples": ["tenantiq recommend"]
    }
  ],
  "webhooks": {
    "enabled": true,
    "events": [
      "alert.created",
      "alert.updated",
      "tenant.synced",
      "remediation.completed"
    ]
  },
  "platforms": {
    "whatsapp": true,
    "slack": true,
    "teams": true,
    "discord": true,
    "telegram": true,
    "imessage": true
  },
  "screenshots": [
    "https://tenantiq.app/screenshots/openclaw-1.png",
    "https://tenantiq.app/screenshots/openclaw-2.png",
    "https://tenantiq.app/screenshots/openclaw-3.png"
  ],
  "documentation": "https://docs.tenantiq.app/openclaw",
  "support": {
    "url": "https://discord.gg/tenantiq",
    "email": "support@tenantiq.app"
  }
}
