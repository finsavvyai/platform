# ────────────────────────────────────────────────────────────
# TenantIQ development environment example
# Copy to .env and fill with real values. Never commit .env.
# All production secrets live in `wrangler secret put ...`.
# ────────────────────────────────────────────────────────────

# Azure AD App Registration (MSAL) — primary sign-in provider
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# LinkedIn OpenID Connect — secondary sign-in provider (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Neon PostgreSQL (dev schema)
DATABASE_URL=

# Anthropic AI
ANTHROPIC_API_KEY=

# Claw Gateway (centralized AI routing)
CLAW_GATEWAY_URL=
CLAW_API_KEY=
CLAW_PROJECT_ID=tenantiq

# Cloudflare (prefer `wrangler login` over tokens locally)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# LemonSqueezy billing
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_STARTER=
LEMONSQUEEZY_VARIANT_PROFESSIONAL=
LEMONSQUEEZY_VARIANT_ENTERPRISE=

# Outbound email
RESEND_API_KEY=

# Monitoring — API (Cloudflare Worker) DSN
SENTRY_DSN=

# Monitoring — Web (SvelteKit) — PUBLIC_ prefix makes it readable in the browser
PUBLIC_SENTRY_DSN=
PUBLIC_APP_VERSION=1.0.0

# Sentry source-map upload (set only in CI / deploy scripts, not locally)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# OpenClaw integration (optional)
OPENCLAW_URL=
OPENCLAW_API_KEY=
OPENCLAW_SERVICE_KEY=

# Graph refresh-token encryption KEK (32-byte hex) — openssl rand -hex 32
GRAPH_TOKEN_KEK=
