{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@tenantiq/shared": ["packages/shared/src/index.ts"],
      "@tenantiq/shared/*": ["packages/shared/src/*"],
      "@tenantiq/db": ["packages/db/src/index.ts"],
      "@tenantiq/db/*": ["packages/db/src/*"],
      "@tenantiq/intel": ["packages/intel/src/index.ts"],
      "@tenantiq/graph": ["packages/graph/src/index.ts"]
    },
    "types": []
  },
  "include": [
    "tests/samples/**/*.ts",
    "tests/e2e/user-behavior/pwa-validation.test.ts",
    "tests/e2e/user-behavior/deep-validation.test.ts",
    "tests/e2e/user-behavior/production-http.test.ts",
    "tests/e2e/user-behavior/landing-live.test.ts",
    "tests/e2e/user-behavior/landing-responsive.test.ts",
    "packages/shared/src/**/*.ts",
    "packages/intel/src/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    "**/dist/**",
    "**/.svelte-kit/**",
    "apps/api/**",
    "apps/web/**",
    "packages/mcp-server/**",
    "packages/webhooks/**",
    "packages/remediation/src/actions/remediation-actions.test.ts",
    "tests/integration/**",
    "tests/services/**",
    "tests/license-optimization.test.ts",
    "tests/security-scoring.test.ts",
    "tests/samples/health-monitoring.test.ts",
    "tests/e2e/user-behavior/api-behavior.test.ts",
    "**/*.svelte.ts"
  ]
}
