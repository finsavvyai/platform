FROM python:3.11-slim

# Install system dependencies for tkinter
RUN apt-get update && apt-get install -y --no-install-recommends     python3-tk     && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pg_gui.py /app/pg_gui.py
RUN pip install --no-cache-dir psycopg2-binary requests

# Run with X11 forwarding support
CMD ["python", "/app/pg_gui.py"]
