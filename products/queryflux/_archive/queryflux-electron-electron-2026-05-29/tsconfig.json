{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/renderer/src/*"
            ],
            "@shared/*": [
                "src/shared/*"
            ],
            "@components/*": [
                "src/renderer/src/components/*"
            ],
            "@hooks/*": [
                "src/renderer/src/hooks/*"
            ],
            "@utils/*": [
                "src/renderer/src/utils/*"
            ],
            "@services/*": [
                "src/renderer/src/services/*"
            ]
        }
    },
    "include": [
        "src/main/**/*.ts",
        "src/preload/**/*.ts",
        "src/renderer/**/*.ts",
        "src/renderer/**/*.tsx",
        "src/shared/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "out"
    ]
}