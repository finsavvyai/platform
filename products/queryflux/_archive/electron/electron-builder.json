{
  "appId": "com.queryflux.desktop",
  "productName": "QueryFlux",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "build/**/*",
    "node_modules/**/*",
    "public/**/*",
    "index.html",
    "main.js",
    "preload.js",
    "package.json"
  ],
  "extraMetadata": {
    "main": "main.js"
  },
  "mac": {
    "category": "public.app-category.developer-tools",
    "icon": "build/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.inherit.plist",
    "extendInfo": {
      "NSCameraUsageDescription": "This app needs camera access for video conferencing features.",
      "NSMicrophoneUsageDescription": "This app needs microphone access for voice commands.",
      "NSDocumentsFolderUsageDescription": "This app needs access to Documents folder to import/export SQL files."
    },
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "mas",
        "arch": ["x64", "arm64"]
      }
    ]
  },
  "dmg": {
    "title": "${productName} ${version}",
    "icon": "build/volume.icns",
    "background": "build/background.png",
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ],
    "window": {
      "width": 540,
      "height": 380
    }
  },
  "mas": {
    "entitlements": "build/entitlements.mas.plist",
    "entitlementsInherit": "build/entitlements.mas.inherit.plist",
    "hardenedRuntime": false,
    "provisioningProfile": "build/QueryFlux.provisionprofile"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "ia32"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      },
      {
        "target": "appx",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "requestedExecutionLevel": "asInvoker",
    "publisherName": "QueryFlux Inc."
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "installerIcon": "build/installer.ico",
    "uninstallerIcon": "build/uninstaller.ico",
    "installerHeaderIcon": "build/header.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "QueryFlux",
    "include": "build/installer.nsh"
  },
  "appx": {
    "displayName": "QueryFlux",
    "publisherDisplayName": "QueryFlux Inc.",
    "identityName": "QueryFluxInc.QueryFluxDesktop",
    "publisherId": "CN=QueryFlux Inc.",
    "backgroundColor": "#transparent",
    "showNameOnTiles": true,
    "artifactName": "${productName}-${version}.${ext}"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      },
      {
        "target": "rpm",
        "arch": ["x64"]
      },
      {
        "target": "snap",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.png",
    "category": "Development"
  },
  "snap": {
    "plugs": [
      "default",
      "desktop",
      "desktop-legacy",
      "home",
      "x11",
      "unity7",
      "browser-support",
      "network",
      "gsettings",
      "audio-playback",
      "pulseaudio",
      "opengl"
    ],
    "grade": "stable"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "queryflux",
      "repo": "queryflux-desktop",
      "private": false,
      "releaseType": "release"
    }
  ],
  "afterSign": "scripts/notarize.js",
  "afterAllArtifactBuild": "scripts/cleanup.js"
}