<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.PGDesk" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>

        <!-- Tertiary brand color -->
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>

        <!-- Error colors -->
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorSurfaceInverse">@color/md_theme_light_inverseSurface</item>
        <item name="colorOnSurfaceInverse">@color/md_theme_light_inverseOnSurface</item>

        <!-- Outline colors -->
        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_light_outlineVariant</item>

        <!-- System UI -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Window -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.PGDesk.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/md_theme_light_surface</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/md_theme_light_primary</item>
        <item name="windowSplashScreenBrandingImage">@drawable/pgdesk_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.PGDesk</item>
    </style>

    <!-- Dark theme -->
    <style name="Theme.PGDesk.Dark" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/md_theme_dark_primary</item>
        <item name="colorOnPrimary">@color/md_theme_dark_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_dark_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_dark_onPrimaryContainer</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_theme_dark_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_dark_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_dark_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_dark_onSecondaryContainer</item>

        <!-- Tertiary brand color -->
        <item name="colorTertiary">@color/md_theme_dark_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_dark_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_dark_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_dark_onTertiaryContainer</item>

        <!-- Error colors -->
        <item name="colorError">@color/md_theme_dark_error</item>
        <item name="colorErrorContainer">@color/md_theme_dark_errorContainer</item>
        <item name="colorOnError">@color/md_theme_dark_onError</item>
        <item name="colorOnErrorContainer">@color/md_theme_dark_onErrorContainer</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/md_theme_dark_background</item>
        <item name="colorOnBackground">@color/md_theme_dark_onBackground</item>
        <item name="colorSurface">@color/md_theme_dark_surface</item>
        <item name="colorOnSurface">@color/md_theme_dark_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_dark_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="colorSurfaceInverse">@color/md_theme_dark_inverseSurface</item>
        <item name="colorOnSurfaceInverse">@color/md_theme_dark_inverseOnSurface</item>

        <!-- Outline colors -->
        <item name="colorOutline">@color/md_theme_dark_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_dark_outlineVariant</item>

        <!-- System UI -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Window -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Custom component themes -->

    <!-- Code Editor Theme -->
    <style name="Theme.PGDesk.CodeEditor">
        <item name="android:background">@color/code_editor_background</item>
        <item name="android:textColor">@color/code_editor_text</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- Performance Card Theme -->
    <style name="Theme.PGDesk.PerformanceCard">
        <item name="android:background">@drawable/performance_card_background</item>
        <item name="android:elevation">4dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <!-- AI Chat Theme -->
    <style name="Theme.PGDesk.AIChat">
        <item name="android:background">@color/ai_chat_background</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Voice Input Button Theme -->
    <style name="Theme.PGDesk.VoiceButton">
        <item name="android:background">@drawable/voice_button_background</item>
        <item name="android:elevation">6dp</item>
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
    </style>

    <!-- Connection Status Theme -->
    <style name="Theme.PGDesk.ConnectionStatus">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">4dp</item>
        <item name="android:background">@drawable/status_badge_background</item>
    </style>

    <!-- Navigation Theme -->
    <style name="Theme.PGDesk.Navigation">
        <item name="colorSurface">@color/navigation_surface</item>
        <item name="colorOnSurface">@color/navigation_on_surface</item>
        <item name="colorPrimary">@color/navigation_selected</item>
    </style>

    <!-- Dialog Theme -->
    <style name="Theme.PGDesk.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="colorSurface">@color/dialog_surface</item>
        <item name="colorOnSurface">@color/dialog_on_surface</item>
        <item name="android:windowBackground">@drawable/dialog_background</item>
    </style>

    <!-- Bottom Sheet Theme -->
    <style name="Theme.PGDesk.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="colorSurface">@color/bottom_sheet_surface</item>
        <item name="colorOnSurface">@color/bottom_sheet_on_surface</item>
        <item name="android:windowBackground">@drawable/bottom_sheet_background</item>
    </style>

    <!-- Alert Dialog Theme -->
    <style name="Theme.PGDesk.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/alert_dialog_surface</item>
        <item name="colorOnSurface">@color/alert_dialog_on_surface</item>
        <item name="colorPrimary">@color/alert_dialog_primary</item>
    </style>

    <!-- Snackbar Theme -->
    <style name="Theme.PGDesk.Snackbar">
        <item name="colorSurface">@color/snackbar_surface</item>
        <item name="colorOnSurface">@color/snackbar_on_surface</item>
        <item name="colorPrimary">@color/snackbar_action</item>
    </style>

    <!-- Chart Theme -->
    <style name="Theme.PGDesk.Chart">
        <item name="android:background">@color/chart_background</item>
        <item name="android:padding">8dp</item>
    </style>

    <!-- Security Badge Theme -->
    <style name="Theme.PGDesk.SecurityBadge">
        <item name="android:background">@drawable/security_badge_background</item>
        <item name="android:textColor">@color/security_badge_text</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">4dp</item>
    </style>

    <!-- Loading Theme -->
    <style name="Theme.PGDesk.Loading">
        <item name="colorPrimary">@color/loading_primary</item>
        <item name="colorOnSurface">@color/loading_text</item>
    </style>

    <!-- Error Theme -->
    <style name="Theme.PGDesk.Error">
        <item name="colorError">@color/error_primary</item>
        <item name="colorOnError">@color/error_on_primary</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/error_on_container</item>
    </style>

    <!-- Success Theme -->
    <style name="Theme.PGDesk.Success">
        <item name="colorPrimary">@color/success_primary</item>
        <item name="colorOnPrimary">@color/success_on_primary</item>
        <item name="colorPrimaryContainer">@color/success_container</item>
        <item name="colorOnPrimaryContainer">@color/success_on_container</item>
    </style>

    <!-- Warning Theme -->
    <style name="Theme.PGDesk.Warning">
        <item name="colorPrimary">@color/warning_primary</item>
        <item name="colorOnPrimary">@color/warning_on_primary</item>
        <item name="colorPrimaryContainer">@color/warning_container</item>
        <item name="colorOnPrimaryContainer">@color/warning_on_container</item>
    </style>
</resources>