<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Internal storage -->
    <files-path name="internal_files" path="." />
    <cache-path name="internal_cache" path="." />

    <!-- External storage -->
    <external-files-path name="external_files" path="." />
    <external-cache-path name="external_cache" path="." />

    <!-- Application specific external storage -->
    <external-files-path name="documents" path="Documents/" />
    <external-files-path name="downloads" path="Download/" />
    <external-files-path name="shared" path="shared/" />

    <!-- Root external storage (requires permission) -->
    <external-path name="external" path="." />

    <!-- Temp files -->
    <cache-path name="temp" path="temp/" />

    <!-- Logs -->
    <files-path name="logs" path="logs/" />

    <!-- Database exports -->
    <files-path name="exports" path="exports/" />

    <!-- User generated content -->
    <external-files-path name="user_content" path="user_content/" />
</paths>