{
  "name": "queryflux-workspace",
  "version": "1.0.0",
  "description": "QueryFlux Cross-Platform Database Management System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "vite --config web/vite.config.ts",
    "dev:website": "npm run dev --prefix website",
    "dev:desktop": "npm run tauri dev --prefix desktop",
    "dev:backend": "make -C backend run",
    "dev:server": "tsx watch backend/server-ts/index.ts",
    "build:server": "tsc -p backend/server-ts/tsconfig.json",
    "test:server": "jest --config backend/server-ts/jest.config.cjs",
    "test:server:watch": "jest --config backend/server-ts/jest.config.cjs --watch",
    "test:server:coverage": "jest --config backend/server-ts/jest.config.cjs --coverage",
    "build:web": "vite build --config web/vite.config.ts",
    "build:website": "npm run build --prefix website",
    "build:desktop": "npm run tauri build --prefix desktop",
    "build:backend": "make -C backend build",
    "test": "vitest run",
    "lint": "eslint web/src backend/server-ts",
    "clean": "rimraf packages/*/dist apps/*/dist",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:coverage && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.35",
    "@types/pg": "^8.16.0",
    "@types/pino-http": "^5.8.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^3.2.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jest": "^30.3.0",
    "jsdom": "^26.1.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.2.7",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "database",
    "postgresql",
    "mysql",
    "mongodb",
    "redis",
    "sqlite",
    "ai",
    "cross-platform",
    "macos",
    "ios",
    "windows",
    "linux"
  ],
  "author": "QueryFlux Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/queryflux/queryflux.git"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.560.0",
    "mongodb": "^7.0.0",
    "mysql2": "^3.15.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.0.3",
    "react-dom": "^19.0.3",
    "react-router-dom": "^7.15.1",
    "redis": "^5.10.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  }
}
