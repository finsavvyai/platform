{
  "name": "unified-compliance-platform",
  "version": "1.0.0",
  "description": "Unified Compliance Platform - SDLC integration across Qestro, PipeWarden, and MCPOverflow",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "test": "node --test tests/**/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:adapters": "node --test tests/adapters/*.test.js",
    "lint": "eslint src/ adapters/ tests/",
    "lint:fix": "eslint src/ adapters/ tests/ --fix",
    "format": "prettier --write src/ adapters/ tests/",
    "build": "npm run lint && npm run test",
    "local": "wrangler dev --local",
    "tail": "wrangler tail",
    "secrets:list": "wrangler secret list",
    "kv:create": "wrangler kv:namespace create",
    "d1:create": "wrangler d1 create",
    "r2:create": "wrangler r2 bucket create"
  },
  "keywords": [
    "compliance",
    "ai",
    "security",
    "gdpr",
    "hipaa",
    "soc2",
    "lam",
    "autonomous",
    "qestro",
    "pipewarden",
    "mcpoverflow",
    "sdlc"
  ],
  "author": "SDLC Team <team@sdlc.finsavvyai.com>",
  "license": "UNIFIED-COMPLIANCE-ENTERPRISE",
  "repository": {
    "type": "git",
    "url": "https://github.com/sdlc-platform/unified-compliance-platform.git"
  },
  "bugs": {
    "url": "https://github.com/sdlc-platform/unified-compliance-platform/issues"
  },
  "homepage": "https://unified.sdlc.finsavvyai.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cloudflare-workers": "^0.0.1",
    "prettier": "^3.1.1",
    "wrangler": "^3.22.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.9.1",
    "@aws-sdk/client-bedrock-runtime": "^3.490.0",
    "@google-cloud/aiplatform": "^3.18.0",
    "openai": "^4.20.1",
    "crypto": "^1.0.1",
    "zod": "^3.22.4"
  },
  "workspaces": [
    "adapters",
    "src",
    "tests"
  ]
}