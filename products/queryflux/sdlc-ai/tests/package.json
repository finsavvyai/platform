{
  "name": "sdlc-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end integration tests for SDLC production system",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:landing": "playwright test tests/landing-page/",
    "test:infrastructure": "playwright test tests/infrastructure/",
    "test:api": "playwright test tests/api/",
    "test:database": "playwright test tests/database/",
    "test:e2e": "playwright test tests/e2e/",
    "test:performance": "playwright test tests/performance/",
    "setup": "playwright install",
    "clean": "rm -rf test-results reports"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.8.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "typescript": "^5.2.2",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "kafkajs": "^2.2.4",
    "ajv": "^8.12.0",
    "html-validate": "^8.14.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}