{
    "name": "queryflux-electron",
    "version": "1.0.0",
    "description": "QueryFlux - AI-Powered Database Management Platform",
    "main": "dist/main/index.js",
    "author": {
        "name": "FinsavvyAI",
        "email": "hello@finsavvy.ai"
    },
    "license": "MIT",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "start": "electron .",
        "postinstall": "electron-builder install-app-deps",
        "pack": "electron-builder --dir",
        "dist": "electron-builder",
        "dist:mac": "electron-builder --mac",
        "dist:win": "electron-builder --win",
        "dist:linux": "electron-builder --linux",
        "lint": "eslint . --ext .ts,.tsx",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist out node_modules/.cache"
    },
    "dependencies": {
        "@electron-toolkit/preload": "^3.0.1",
        "@electron-toolkit/utils": "^3.0.0",
        "@heroicons/react": "^2.2.0",
        "electron-log": "^5.1.7",
        "electron-store": "^10.0.0",
        "electron-updater": "^6.3.9",
        "keytar": "^7.9.0"
    },
    "devDependencies": {
        "@electron-toolkit/eslint-config-ts": "^2.0.0",
        "@types/node": "^22.10.5",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "electron": "^33.2.1",
        "electron-builder": "^25.1.8",
        "electron-vite": "^2.3.0",
        "eslint": "^9.17.0",
        "postcss": "^8.4.49",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.28.1",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.7.2",
        "vite": "^5.4.11"
    },
    "build": {
        "appId": "com.finsavvy.queryflux",
        "productName": "QueryFlux",
        "copyright": "Copyright © 2026 FinsavvyAI",
        "directories": {
            "output": "out",
            "buildResources": "resources"
        },
        "files": [
            "dist/**/*",
            "!node_modules/**/*"
        ],
        "extraResources": [
            {
                "from": "resources/",
                "to": "resources/",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "mac": {
            "category": "public.app-category.developer-tools",
            "icon": "resources/icon.icns",
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "entitlements": "resources/entitlements.mac.plist",
            "entitlementsInherit": "resources/entitlements.mac.plist",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ]
        },
        "dmg": {
            "contents": [
                {
                    "x": 130,
                    "y": 220
                },
                {
                    "x": 410,
                    "y": 220,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "win": {
            "icon": "resources/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "resources/icon.ico",
            "uninstallerIcon": "resources/icon.ico"
        },
        "linux": {
            "icon": "resources/icons",
            "category": "Development",
            "target": [
                "AppImage",
                "deb",
                "rpm"
            ],
            "maintainer": "FinsavvyAI <hello@finsavvy.ai>"
        },
        "publish": {
            "provider": "github",
            "owner": "shacharsol",
            "repo": "queryflux"
        }
    }
}