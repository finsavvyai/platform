{
  "name": "@queryflux/openai-app-full",
  "version": "1.0.0",
  "description": "QueryFlux Database AI Assistant - First database assistant in OpenAI GPT Store",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:manifest",
    "build:manifest": "node scripts/build-manifest.js",
    "submit": "npm run build && node scripts/automated-submission.js",
    "submit:openai": "node scripts/automated-submission.js",
    "submit:demo": "npm run build && node scripts/demo-submission.js",
    "validate": "node scripts/validate-submission.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "openai",
    "gpt",
    "database",
    "sql",
    "ai",
    "query",
    "postgresql",
    "mysql",
    "mongodb",
    "visualization",
    "enterprise",
    "security",
    "automated-submission"
  ],
  "author": "QueryFlux Team",
  "license": "MIT",
  "dependencies": {
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.24.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/queryflux/openai-app.git"
  },
  "bugs": {
    "url": "https://github.com/queryflux/openai-app/issues"
  },
  "homepage": "https://queryflux.com/openai-app"
}
