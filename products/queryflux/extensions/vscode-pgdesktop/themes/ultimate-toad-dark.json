{
  "name": "Ultimate DB — Toad (Dark)",
  "type": "dark",
  "colors": {
    "editor.background": "#1b1f23",
    "editor.foreground": "#e6edf3",
    "editorLineNumber.foreground": "#6e7681",
    "editorCursor.foreground": "#f0f6fc",
    "editor.selectionBackground": "#264f78",
    "editor.inactiveSelectionBackground": "#264f7840",
    "editorBracketMatch.border": "#8b949e",
    "sideBar.background": "#161b22"
  },
  "tokenColors": [
    { "scope": ["comment"], "settings": { "foreground": "#8b949e", "fontStyle": "italic" }},
    { "scope": ["string", "constant.other.string"], "settings": { "foreground": "#9ecbff" }},
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#d2a8ff" }},
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#ff7b72", "fontStyle": "bold" }},
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#a5d6ff" }},
    { "scope": ["entity.name.table", "meta.table", "entity.name.type"], "settings": { "foreground": "#79c0ff" }},
    { "scope": ["variable", "identifier"], "settings": { "foreground": "#e6edf3" }},
    { "scope": ["punctuation", "operator"], "settings": { "foreground": "#c9d1d9" }},
    { "scope": ["source.sql keyword.other.DML"], "settings": { "foreground": "#ff7b72", "fontStyle": "bold" }},
    { "scope": ["source.sql keyword.other.DDL"], "settings": { "foreground": "#ffa657", "fontStyle": "bold" }},
    { "scope": ["source.sql constant.other.table-name"], "settings": { "foreground": "#79c0ff" }},
    { "scope": ["source.sql entity.name.column"], "settings": { "foreground": "#c3d1ff" }}
  ]
}

