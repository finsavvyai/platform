{
  "name": "ultimate-db-manager-vscode",
  "displayName": "🚀 Ultimate Universal Database Manager",
  "description": "AI-Powered Multi-Database Management: PostgreSQL, MongoDB, Redis, Oracle & More",
  "version": "1.1.0",
  "publisher": "finsavvyai",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/finsavvyai/ultimate-db-manager"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Snippets",
    "Visualization",
    "Machine Learning",
    "Data Science"
  ],
  "keywords": [
    "database",
    "postgresql",
    "mongodb",
    "redis",
    "oracle",
    "ai",
    "ml",
    "query",
    "sql",
    "nosql"
  ],
  "galleryBanner": {
    "color": "#2563eb",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:ultimatedb.connectionManager",
    "onCommand:ultimatedb.connect",
    "onCommand:ultimatedb.addConnection",
    "onView:ultimatedbConnections",
    "onView:ultimatedbExplorer",
    "onLanguage:sql",
    "onLanguage:mongodb",
    "onLanguage:redis"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish",
    "build": "npm run compile",
    "build:full": "./build.sh",
    "version:patch": "./version-manager.sh patch",
    "version:minor": "./version-manager.sh minor",
    "version:major": "./version-manager.sh major",
    "version:prerelease": "./version-manager.sh prerelease",
    "version:patch-no-publish": "./version-manager.sh patch --no-publish",
    "version:minor-no-publish": "./version-manager.sh minor --no-publish",
    "version:dry-run": "./version-manager.sh patch --dry-run",
    "release:patch": "bash ./scripts/release-fast.sh patch",
    "release:minor": "bash ./scripts/release-fast.sh minor",
    "release:major": "bash ./scripts/release-fast.sh major"
  },
  "contributes": {
    "commands": [
      {
        "command": "ultimatedb.connectionManager",
        "title": "🔗 Connection Manager",
        "category": "Ultimate DB",
        "icon": "$(database)"
      },
      {
        "command": "ultimatedb.aiAssistant",
        "title": "🤖 AI Query Assistant",
        "category": "Ultimate DB",
        "icon": "$(sparkle)"
      },
      {
        "command": "ultimatedb.connect",
        "title": "🚀 Connect to Database",
        "category": "Ultimate DB",
        "icon": "$(plug)"
      },
      {
        "command": "ultimatedb.addConnection",
        "title": "➕ Add New Connection",
        "category": "Ultimate DB",
        "icon": "$(add)"
      },
      {
        "command": "ultimatedb.editConnection",
        "title": "✏️ Edit Connection",
        "category": "Ultimate DB",
        "icon": "$(edit)"
      },
      {
        "command": "ultimatedb.deleteConnection",
        "title": "🗑️ Delete Connection",
        "category": "Ultimate DB",
        "icon": "$(trash)"
      },
      {
        "command": "ultimatedb.testConnection",
        "title": "🔍 Test Connection",
        "category": "Ultimate DB",
        "icon": "$(pulse)"
      },
      {
        "command": "ultimatedb.refresh",
        "title": "🔄 Refresh",
        "category": "Ultimate DB",
        "icon": "$(refresh)"
      },
      {
        "command": "ultimatedb.executeQuery",
        "title": "▶️ Execute Query",
        "category": "Ultimate DB",
        "icon": "$(play)"
      },
      {
        "command": "ultimatedb.executeSelection",
        "title": "▶️ Execute Selection",
        "category": "Ultimate DB",
        "icon": "$(play-circle)"
      },
      {
        "command": "ultimatedb.explainQuery",
        "title": "📊 Explain Query",
        "category": "Ultimate DB",
        "icon": "$(graph)"
      },
      {
        "command": "ultimatedb.optimizeQuery",
        "title": "⚡ AI Optimize Query",
        "category": "Ultimate DB",
        "icon": "$(rocket)"
      },
      {
        "command": "ultimatedb.naturalLanguageQuery",
        "title": "💬 Natural Language Query",
        "category": "Ultimate DB",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "ultimatedb.newSqlQuery",
        "title": "📝 New SQL Query",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.newMongoQuery",
        "title": "🍃 New MongoDB Query",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.newRedisQuery",
        "title": "🔶 New Redis Query",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.viewTableData",
        "title": "👁️ View Data",
        "category": "Ultimate DB",
        "icon": "$(table)"
      },
      {
        "command": "ultimatedb.openSelectForTable",
        "title": "📝 Open SELECT in Editor",
        "category": "Ultimate DB",
        "icon": "$(go-to-file)"
      },
      {
        "command": "ultimatedb.copyCreateTable",
        "title": "📋 Copy CREATE TABLE",
        "category": "Ultimate DB",
        "icon": "$(clippy)"
      },
      {
        "command": "ultimatedb.exportData",
        "title": "📤 Export Data",
        "category": "Ultimate DB",
        "icon": "$(export)"
      },
      {
        "command": "ultimatedb.importData",
        "title": "📥 Import Data",
        "category": "Ultimate DB",
        "icon": "$(repo-pull)"
      },
      {
        "command": "ultimatedb.generateSchema",
        "title": "🗂️ Generate Schema Diagram",
        "category": "Ultimate DB",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "ultimatedb.performanceMonitor",
        "title": "📊 Performance Monitor",
        "category": "Ultimate DB",
        "icon": "$(pulse)"
      },
      {
        "command": "ultimatedb.healthCheck",
        "title": "❤️ Health Check",
        "category": "Ultimate DB",
        "icon": "$(heart)"
      },
      {
        "command": "ultimatedb.saveQuery",
        "title": "💾 Save Query",
        "category": "Ultimate DB",
        "icon": "$(save)"
      },
      {
        "command": "ultimatedb.loadQuery",
        "title": "📂 Load Query",
        "category": "Ultimate DB",
        "icon": "$(folder-opened)"
      },
      {
        "command": "ultimatedb.queryHistory",
        "title": "📚 Query History",
        "category": "Ultimate DB",
        "icon": "$(history)"
      },
      {
        "command": "ultimatedb.launchConnectionManager",
        "title": "🎨 Launch Connection Manager GUI",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.launchUniversalGUI",
        "title": "🌐 Launch Universal Database GUI",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.launchAIGUI",
        "title": "🤖 Launch AI-Enhanced PostgreSQL",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.runTests",
        "title": "🧪 Run Test Suite",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.forgetPassword",
        "title": "🔐 Forget Saved Password",
        "category": "Ultimate DB",
        "icon": "$(key)"
      },
      {
        "command": "ultimatedb.securityScan",
        "title": "🛡️ Security Scan (PostgreSQL)",
        "category": "Ultimate DB",
        "icon": "$(shield)"
      },
      {
        "command": "ultimatedb.indexAdvisor",
        "title": "🧭 Index Advisor (PostgreSQL)",
        "category": "Ultimate DB",
        "icon": "$(light-bulb)"
      },
      {
        "command": "ultimatedb.monitoring.start",
        "title": "🔍 Start Monitoring",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.monitoring.stop",
        "title": "⏹️ Stop Monitoring",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.monitoring.dashboard",
        "title": "📊 Monitoring Dashboard",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.history.show",
        "title": "📜 Query History",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.history.clear",
        "title": "🗑️ Clear History",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.history.favorites",
        "title": "⭐ Favorite Queries",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.schema.compare",
        "title": "🔍 Compare Schemas",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.schema.migration",
        "title": "🔄 Generate Migration",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.security.audit",
        "title": "🛡️ Security Audit",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.security.analyze",
        "title": "🔍 Analyze Query Security",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.queryBuilder.open",
        "title": "🔧 Advanced Query Builder",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.visualization.chart",
        "title": "📊 Create Data Chart",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.connections.advanced",
        "title": "🔗 Advanced Connections",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.export.advanced",
        "title": "📤 Advanced Export",
        "category": "Ultimate DB"
      },
      {
        "command": "ultimatedb.import.advanced",
        "title": "📥 Advanced Import",
        "category": "Ultimate DB"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ultimatedb-explorer",
          "title": "🚀 Ultimate DB Manager",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "ultimatedb-explorer": [
        {
          "id": "ultimatedbConnections",
          "name": "🔗 Connections",
          "icon": "$(database)",
          "contextualTitle": "Database Connections"
        },
        {
          "id": "ultimatedbExplorer",
          "name": "🗂️ Database Explorer",
          "icon": "$(folder-opened)",
          "contextualTitle": "Database Schema Explorer"
        },
        {
          "id": "ultimatedbAI",
          "name": "🤖 AI Assistant",
          "icon": "$(sparkle)",
          "contextualTitle": "AI Query Assistant"
        },
        {
          "id": "ultimatedbQueries",
          "name": "📚 Saved Queries",
          "icon": "$(history)",
          "contextualTitle": "Query Library"
        },
        {
          "id": "ultimatedbHealth",
          "name": "❤️ Health Monitor",
          "icon": "$(pulse)",
          "contextualTitle": "Database Health"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ultimatedb.addConnection",
          "when": "view == ultimatedbConnections",
          "group": "navigation@1"
        },
        {
          "command": "ultimatedb.connectionManager",
          "when": "view == ultimatedbConnections",
          "group": "navigation@2"
        },
        {
          "command": "ultimatedb.refresh",
          "when": "view == ultimatedbExplorer",
          "group": "navigation@1"
        },
        {
          "command": "ultimatedb.aiAssistant",
          "when": "view == ultimatedbAI",
          "group": "navigation@1"
        },
        {
          "command": "ultimatedb.naturalLanguageQuery",
          "when": "view == ultimatedbAI",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "ultimatedb.connect",
          "when": "viewItem == dbConnection",
          "group": "inline@1"
        },
        {
          "command": "ultimatedb.editConnection",
          "when": "viewItem == dbConnection",
          "group": "connection@1"
        },
        {
          "command": "ultimatedb.testConnection",
          "when": "viewItem == dbConnection",
          "group": "connection@2"
        },
        {
          "command": "ultimatedb.deleteConnection",
          "when": "viewItem == dbConnection",
          "group": "connection@3"
        },
        {
          "command": "ultimatedb.forgetPassword",
          "when": "viewItem == dbConnection",
          "group": "connection@4"
        },
        {
          "command": "ultimatedb.viewTableData",
          "when": "viewItem == dbTable || viewItem == mongoCollection",
          "group": "inline@1"
        },
        {
          "command": "ultimatedb.exportData",
          "when": "viewItem == dbTable || viewItem == mongoCollection || viewItem == redisKey",
          "group": "data@1"
        },
        {
          "command": "ultimatedb.openSelectForTable",
          "when": "viewItem == dbTable",
          "group": "data@2"
        },
        {
          "command": "ultimatedb.copyCreateTable",
          "when": "viewItem == dbTable",
          "group": "data@3"
        },
        {
          "command": "ultimatedb.newSqlQuery",
          "when": "viewItem == postgresDatabase || viewItem == oracleDatabase",
          "group": "query@1"
        },
        {
          "command": "ultimatedb.newMongoQuery",
          "when": "viewItem == mongoDatabase",
          "group": "query@1"
        },
        {
          "command": "ultimatedb.newRedisQuery",
          "when": "viewItem == redisDatabase",
          "group": "query@1"
        },
        {
          "command": "ultimatedb.generateSchema",
          "when": "viewItem == postgresDatabase || viewItem == oracleDatabase",
          "group": "tools@1"
        },
        {
          "command": "ultimatedb.performanceMonitor",
          "when": "viewItem == dbConnection",
          "group": "tools@2"
        }
      ],
      "editor/title": [
        {
          "command": "ultimatedb.executeQuery",
          "when": "resourceExtname == .sql || resourceExtname == .mongo || resourceExtname == .redis",
          "group": "navigation@1"
        },
        {
          "command": "ultimatedb.executeSelection",
          "when": "resourceExtname == .sql || resourceExtname == .mongo || resourceExtname == .redis",
          "group": "navigation@2"
        },
        {
          "command": "ultimatedb.explainQuery",
          "when": "resourceExtname == .sql",
          "group": "navigation@3"
        },
        {
          "command": "ultimatedb.optimizeQuery",
          "when": "resourceExtname == .sql",
          "group": "navigation@4"
        },
        {
          "command": "ultimatedb.saveQuery",
          "when": "resourceExtname == .sql || resourceExtname == .mongo || resourceExtname == .redis",
          "group": "file@1"
        }
      ],
      "commandPalette": [
        {
          "command": "ultimatedb.launchConnectionManager",
          "when": "true"
        },
        {
          "command": "ultimatedb.launchUniversalGUI",
          "when": "true"
        },
        {
          "command": "ultimatedb.launchAIGUI",
          "when": "true"
        },
        {
          "command": "ultimatedb.securityScan",
          "when": "true"
        },
        {
          "command": "ultimatedb.indexAdvisor",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "Ultimate Universal Database Manager",
      "properties": {
        "ultimatedb.connections": {
          "type": "array",
          "default": [],
          "description": "Universal database connection configurations",
          "items": {
            "type": "object",
            "required": [
              "name",
              "type",
              "host"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Connection name"
              },
              "type": {
                "type": "string",
                "enum": [
                  "PostgreSQL",
                  "MongoDB",
                  "Redis",
                  "Oracle",
                  "Elasticsearch",
                  "Cassandra"
                ],
                "description": "Database type"
              },
              "host": {
                "type": "string",
                "description": "Database server host"
              },
              "port": {
                "type": "number",
                "description": "Database server port"
              },
              "username": {
                "type": "string",
                "description": "Username"
              },
              "password": {
                "type": "string",
                "description": "Password (encrypted)"
              },
              "database": {
                "type": "string",
                "description": "Default database"
              },
              "ssl": {
                "type": "boolean",
                "default": false,
                "description": "Use SSL/TLS connection"
              },
              "favorite": {
                "type": "boolean",
                "default": false,
                "description": "Mark as favorite connection"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Connection tags for organization"
              }
            }
          }
        },
        "ultimatedb.ai.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered features"
        },
        "ultimatedb.ai.provider": {
          "type": "string",
          "enum": [
            "OpenAI",
            "Anthropic",
            "Local"
          ],
          "default": "OpenAI",
          "description": "AI provider for natural language queries"
        },
        "ultimatedb.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for AI provider (stored securely)"
        },
        "ultimatedb.autoComplete": {
          "type": "boolean",
          "default": true,
          "description": "Enable intelligent auto-completion"
        },
        "ultimatedb.healthMonitoring": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time health monitoring"
        },
        "ultimatedb.queryHistory": {
          "type": "boolean",
          "default": true,
          "description": "Save and track query history"
        },
        "ultimatedb.performanceMonitoring": {
          "type": "boolean",
          "default": true,
          "description": "Enable performance monitoring and optimization suggestions"
        },
        "ultimatedb.theme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "default": "auto",
          "description": "UI theme preference"
        },
        "ultimatedb.guiPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Ultimate Database Manager GUI applications"
        }
      }
    },
    "languages": [
      {
        "id": "sql",
        "extensions": [
          ".sql"
        ],
        "aliases": [
          "SQL",
          "sql"
        ],
        "configuration": "./syntaxes/sql-language-configuration.json"
      },
      {
        "id": "mongodb",
        "extensions": [
          ".mongo",
          ".mongodb"
        ],
        "aliases": [
          "MongoDB",
          "mongo"
        ],
        "configuration": "./syntaxes/mongodb-language-configuration.json"
      },
      {
        "id": "redis",
        "extensions": [
          ".redis"
        ],
        "aliases": [
          "Redis",
          "redis"
        ],
        "configuration": "./syntaxes/redis-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sql",
        "scopeName": "source.sql",
        "path": "./syntaxes/sql.tmLanguage.json"
      },
      {
        "language": "mongodb",
        "scopeName": "source.js.mongodb",
        "path": "./syntaxes/mongodb.tmLanguage.json"
      },
      {
        "language": "redis",
        "scopeName": "source.redis",
        "path": "./syntaxes/redis.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Ultimate DB — Toad (Dark)",
        "uiTheme": "vs-dark",
        "path": "./themes/ultimate-toad-dark.json"
      },
      {
        "label": "Ultimate DB — TablePlus (Light)",
        "uiTheme": "vs",
        "path": "./themes/ultimate-tableplus-light.json"
      },
      {
        "label": "Ultimate DB — SQLyog (Dark)",
        "uiTheme": "vs-dark",
        "path": "./themes/ultimate-sqlyog-dark.json"
      },
      {
        "label": "Ultimate DB — Sequel Pro (Light)",
        "uiTheme": "vs",
        "path": "./themes/ultimate-sequelpro-light.json"
      }
    ]
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^16.18.126",
    "@types/pg": "^8.6.6",
    "@types/redis": "^4.0.11",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@types/ssh2": "^1.15.5",
    "axios": "^1.5.0",
    "crypto-js": "^4.1.1",
    "mongodb": "^6.0.0",
    "pg": "^8.11.0",
    "pngjs": "^7.0.0",
    "redis": "^4.6.0",
    "ssh2": "^1.17.0",
    "uuid": "^9.0.0"
  },
  "optionalDependencies": {
    "oracledb": "^6.0.0"
  }
}
