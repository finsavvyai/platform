{
  "SELECT with LIMIT": {
    "prefix": "sel",
    "body": "SELECT ${1:*} FROM ${2:table_name} LIMIT ${3:10};",
    "description": "SELECT statement with LIMIT"
  },
  "SELECT WHERE": {
    "prefix": "selw",
    "body": "SELECT ${1:*} FROM ${2:table_name} WHERE ${3:condition};",
    "description": "SELECT statement with WHERE clause"
  },
  "SELECT JOIN": {
    "prefix": "selj",
    "body": "SELECT ${1:columns} FROM ${2:table1} JOIN ${3:table2} ON ${4:table1.column} = ${5:table2.column};",
    "description": "SELECT with JOIN"
  },
  "INSERT": {
    "prefix": "ins",
    "body": "INSERT INTO ${1:table_name} (${2:columns}) VALUES (${3:values});",
    "description": "INSERT statement"
  },
  "UPDATE": {
    "prefix": "upd",
    "body": "UPDATE ${1:table_name} SET ${2:column} = ${3:value} WHERE ${4:condition};",
    "description": "UPDATE statement"
  },
  "DELETE": {
    "prefix": "del",
    "body": "DELETE FROM ${1:table_name} WHERE ${2:condition};",
    "description": "DELETE statement"
  },
  "CREATE TABLE": {
    "prefix": "ct",
    "body": "CREATE TABLE ${1:table_name} (\n    ${2:id} SERIAL PRIMARY KEY,\n    ${3:name} VARCHAR(255) NOT NULL,\n    ${4:created_at} TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n);",
    "description": "CREATE TABLE statement"
  },
  "DROP TABLE": {
    "prefix": "dt",
    "body": "DROP TABLE IF EXISTS ${1:table_name};",
    "description": "DROP TABLE statement"
  },
  "CREATE INDEX": {
    "prefix": "ci",
    "body": "CREATE INDEX ${1:index_name} ON ${2:table_name} (${3:column});",
    "description": "CREATE INDEX statement"
  },
  "ALTER TABLE ADD COLUMN": {
    "prefix": "at",
    "body": "ALTER TABLE ${1:table_name} ADD COLUMN ${2:column_name} ${3:data_type};",
    "description": "ALTER TABLE ADD COLUMN"
  },
  "GROUP BY": {
    "prefix": "gb",
    "body": "SELECT ${1:column}, COUNT(*) as count\nFROM ${2:table_name}\nGROUP BY ${3:column};",
    "description": "SELECT with GROUP BY"
  },
  "ORDER BY": {
    "prefix": "ob",
    "body": "SELECT ${1:*} FROM ${2:table_name} ORDER BY ${3:column} ${4:ASC};",
    "description": "SELECT with ORDER BY"
  },
  "HAVING": {
    "prefix": "hav",
    "body": "SELECT ${1:column}, COUNT(*) as count\nFROM ${2:table_name}\nGROUP BY ${3:column}\nHAVING COUNT(*) > ${4:value};",
    "description": "SELECT with GROUP BY and HAVING"
  },
  "SUBQUERY": {
    "prefix": "sub",
    "body": "SELECT ${1:columns} FROM ${2:table_name}\nWHERE ${3:column} IN (SELECT ${4:column} FROM ${5:table_name} WHERE ${6:condition});",
    "description": "SELECT with subquery"
  },
  "UNION": {
    "prefix": "un",
    "body": "SELECT ${1:columns} FROM ${2:table1}\nUNION\nSELECT ${3:columns} FROM ${4:table2};",
    "description": "UNION of two SELECT statements"
  },
  "EXISTS": {
    "prefix": "ex",
    "body": "SELECT ${1:*} FROM ${2:table_name} t1\nWHERE EXISTS (\n    SELECT 1 FROM ${3:table_name} t2 WHERE ${4:condition}\n);",
    "description": "SELECT with EXISTS subquery"
  },
  "CASE WHEN": {
    "prefix": "case",
    "body": "CASE\n    WHEN ${1:condition1} THEN ${2:value1}\n    WHEN ${3:condition2} THEN ${4:value2}\n    ELSE ${5:default_value}\nEND AS ${6:alias}",
    "description": "CASE WHEN statement"
  },
  "Transaction": {
    "prefix": "txn",
    "body": "BEGIN TRANSACTION;\n\n${1:-- Your SQL statements here}\n\nCOMMIT;",
    "description": "Transaction block"
  },
  "ROLLBACK": {
    "prefix": "rb",
    "body": "ROLLBACK;",
    "description": "ROLLBACK statement"
  },
  "EXPLAIN": {
    "prefix": "exp",
    "body": "EXPLAIN ${1:ANALYZE} ${2:QUERY};",
    "description": "EXPLAIN query plan"
  },
  "CTE": {
    "prefix": "cte",
    "body": "WITH ${1:cte_name} AS (\n    SELECT ${2:columns} FROM ${3:table_name} WHERE ${4:condition}\n)\nSELECT ${5:*} FROM ${1:cte_name};",
    "description": "Common Table Expression"
  },
  "Window Function": {
    "prefix": "wf",
    "body": "${1:ROW_NUMBER()} OVER (${2:PARTITION BY} ${3:column} ORDER BY ${4:column}) AS ${5:alias}",
    "description": "Window function"
  },
  "INSERT SELECT": {
    "prefix": "insel",
    "body": "INSERT INTO ${1:table_name} (${2:columns})\nSELECT ${3:columns} FROM ${4:source_table} WHERE ${5:condition};",
    "description": "INSERT from SELECT"
  },
  "UPSERT": {
    "prefix": "upsert",
    "body": "INSERT INTO ${1:table_name} (${2:columns}) VALUES (${3:values})\nON CONFLICT (${4:unique_column})\nDO UPDATE SET ${5:column} = ${6:excluded.column};",
    "description": "UPSERT (PostgreSQL)"
  },
  "LEFT JOIN": {
    "prefix": "lj",
    "body": "SELECT ${1:columns}\nFROM ${2:table1}\nLEFT JOIN ${3:table2} ON ${4:table1.column} = ${5:table2.column};",
    "description": "LEFT JOIN"
  },
  "INNER JOIN": {
    "prefix": "ij",
    "body": "SELECT ${1:columns}\nFROM ${2:table1}\nINNER JOIN ${3:table2} ON ${4:table1.column} = ${5:table2.column};",
    "description": "INNER JOIN"
  },
  "RIGHT JOIN": {
    "prefix": "rj",
    "body": "SELECT ${1:columns}\nFROM ${2:table1}\nRIGHT JOIN ${3:table2} ON ${4:table1.column} = ${5:table2.column};",
    "description": "RIGHT JOIN"
  },
  "FULL OUTER JOIN": {
    "prefix": "fj",
    "body": "SELECT ${1:columns}\nFROM ${2:table1}\nFULL OUTER JOIN ${3:table2} ON ${4:table1.column} = ${5:table2.column};",
    "description": "FULL OUTER JOIN"
  }
}