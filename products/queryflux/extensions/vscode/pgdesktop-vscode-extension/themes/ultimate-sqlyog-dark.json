{
  "name": "Ultimate DB — SQLyog (Dark)",
  "type": "dark",
  "colors": {
    "editor.background": "#1a1b1e",
    "editor.foreground": "#e5e7eb",
    "editorLineNumber.foreground": "#9ca3af",
    "editorCursor.foreground": "#f3f4f6",
    "editor.selectionBackground": "#374151",
    "editor.inactiveSelectionBackground": "#37415166",
    "editorBracketMatch.border": "#9ca3af",
    "sideBar.background": "#141519"
  },
  "tokenColors": [
    { "scope": ["comment"], "settings": { "foreground": "#9ca3af", "fontStyle": "italic" }},
    { "scope": ["string"], "settings": { "foreground": "#60a5fa" }},
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#f472b6" }},
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#fb7185", "fontStyle": "bold" }},
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#34d399" }},
    { "scope": ["entity.name.table", "meta.table", "entity.name.type"], "settings": { "foreground": "#93c5fd" }},
    { "scope": ["variable", "identifier"], "settings": { "foreground": "#e5e7eb" }},
    { "scope": ["punctuation", "operator"], "settings": { "foreground": "#e5e7eb" }},
    { "scope": ["source.sql keyword.other.DML"], "settings": { "foreground": "#f59e0b", "fontStyle": "bold" }},
    { "scope": ["source.sql keyword.other.DDL"], "settings": { "foreground": "#fb7185", "fontStyle": "bold" }},
    { "scope": ["source.sql constant.other.table-name"], "settings": { "foreground": "#93c5fd" }},
    { "scope": ["source.sql entity.name.column"], "settings": { "foreground": "#c4b5fd" }}
  ]
}

