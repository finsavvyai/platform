{
  "name": "Ultimate DB — Sequel Pro (Light)",
  "type": "light",
  "colors": {
    "editor.background": "#fbfbfb",
    "editor.foreground": "#2c3e50",
    "editorLineNumber.foreground": "#9aa5b1",
    "editorCursor.foreground": "#2c3e50",
    "editor.selectionBackground": "#b3d4fc",
    "editor.inactiveSelectionBackground": "#b3d4fc66",
    "editorBracketMatch.border": "#95a5a6",
    "sideBar.background": "#f5f6f7"
  },
  "tokenColors": [
    { "scope": ["comment"], "settings": { "foreground": "#95a5a6", "fontStyle": "italic" }},
    { "scope": ["string"], "settings": { "foreground": "#2980b9" }},
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#8e44ad" }},
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#c0392b", "fontStyle": "bold" }},
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#16a085" }},
    { "scope": ["entity.name.table", "meta.table", "entity.name.type"], "settings": { "foreground": "#2980b9" }},
    { "scope": ["variable", "identifier"], "settings": { "foreground": "#2c3e50" }},
    { "scope": ["punctuation", "operator"], "settings": { "foreground": "#34495e" }},
    { "scope": ["source.sql keyword.other.DML"], "settings": { "foreground": "#c0392b", "fontStyle": "bold" }},
    { "scope": ["source.sql keyword.other.DDL"], "settings": { "foreground": "#2c3e50", "fontStyle": "bold" }},
    { "scope": ["source.sql constant.other.table-name"], "settings": { "foreground": "#2980b9" }},
    { "scope": ["source.sql entity.name.column"], "settings": { "foreground": "#2c3e50" }}
  ]
}

