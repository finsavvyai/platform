{
  "name": "Ultimate DB — TablePlus (Light)",
  "type": "light",
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#2b2d30",
    "editorLineNumber.foreground": "#8a8f98",
    "editorCursor.foreground": "#1f2328",
    "editor.selectionBackground": "#cce5ff",
    "editor.inactiveSelectionBackground": "#cce5ff66",
    "editorBracketMatch.border": "#a0a6ad",
    "sideBar.background": "#f7f8fa"
  },
  "tokenColors": [
    { "scope": ["comment"], "settings": { "foreground": "#94a3b8", "fontStyle": "italic" }},
    { "scope": ["string"], "settings": { "foreground": "#0ea5e9" }},
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#7c3aed" }},
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#2563eb", "fontStyle": "bold" }},
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#16a34a" }},
    { "scope": ["entity.name.table", "meta.table", "entity.name.type"], "settings": { "foreground": "#0ea5e9" }},
    { "scope": ["variable", "identifier"], "settings": { "foreground": "#111827" }},
    { "scope": ["punctuation", "operator"], "settings": { "foreground": "#334155" }},
    { "scope": ["source.sql keyword.other.DML"], "settings": { "foreground": "#dc2626", "fontStyle": "bold" }},
    { "scope": ["source.sql keyword.other.DDL"], "settings": { "foreground": "#2563eb", "fontStyle": "bold" }},
    { "scope": ["source.sql constant.other.table-name"], "settings": { "foreground": "#0ea5e9" }},
    { "scope": ["source.sql entity.name.column"], "settings": { "foreground": "#0369a1" }}
  ]
}

