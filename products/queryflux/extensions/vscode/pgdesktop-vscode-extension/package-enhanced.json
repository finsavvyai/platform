{
  "name": "enhanced-db-manager-vscode",
  "displayName": "🚀 Enhanced Database Manager",
  "description": "Enhanced Database Management with Inline Editing, Schema Selection, and Modern UI",
  "version": "2.0.0",
  "publisher": "finsavvyai",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/finsavvyai/ultimate-db-manager"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Snippets",
    "Visualization",
    "Machine Learning",
    "Data Science"
  ],
  "keywords": [
    "database",
    "postgresql",
    "mongodb",
    "redis",
    "oracle",
    "ai",
    "ml",
    "query",
    "sql",
    "nosql",
    "inline-editing",
    "schema-browser",
    "table-structure"
  ],
  "galleryBanner": {
    "color": "#3b82f6",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:enhanceddb.connectionManager",
    "onCommand:enhanceddb.connect",
    "onCommand:enhanceddb.addConnection",
    "onView:enhanceddbConnections",
    "onView:enhanceddbExplorer",
    "onView:enhanceddbSchemaBrowser",
    "onView:enhanceddbDataEditor",
    "onLanguage:sql",
    "onLanguage:mongodb",
    "onLanguage:redis"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish",
    "build": "npm run compile",
    "build:full": "./build.sh"
  },
  "contributes": {
    "commands": [
      {
        "command": "enhanceddb.connectionManager",
        "title": "🔗 Connection Manager",
        "category": "Enhanced DB",
        "icon": "$(database)"
      },
      {
        "command": "enhanceddb.connect",
        "title": "🚀 Connect to Database",
        "category": "Enhanced DB",
        "icon": "$(plug)"
      },
      {
        "command": "enhanceddb.addConnection",
        "title": "➕ Add New Connection",
        "category": "Enhanced DB",
        "icon": "$(add)"
      },
      {
        "command": "enhanceddb.editConnection",
        "title": "✏️ Edit Connection",
        "category": "Enhanced DB",
        "icon": "$(edit)"
      },
      {
        "command": "enhanceddb.deleteConnection",
        "title": "🗑️ Delete Connection",
        "category": "Enhanced DB",
        "icon": "$(trash)"
      },
      {
        "command": "enhanceddb.testConnection",
        "title": "🔍 Test Connection",
        "category": "Enhanced DB",
        "icon": "$(pulse)"
      },
      {
        "command": "enhanceddb.refresh",
        "title": "🔄 Refresh",
        "category": "Enhanced DB",
        "icon": "$(refresh)"
      },
      {
        "command": "enhanceddb.executeQuery",
        "title": "▶️ Execute Query",
        "category": "Enhanced DB",
        "icon": "$(play)"
      },
      {
        "command": "enhanceddb.executeSelection",
        "title": "▶️ Execute Selection",
        "category": "Enhanced DB",
        "icon": "$(play-circle)"
      },
      {
        "command": "enhanceddb.viewTableStructure",
        "title": "📋 View Table Structure",
        "category": "Enhanced DB",
        "icon": "$(list-unordered)"
      },
      {
        "command": "enhanceddb.viewTableData",
        "title": "👁️ View Table Data",
        "category": "Enhanced DB",
        "icon": "$(table)"
      },
      {
        "command": "enhanceddb.editTableData",
        "title": "✏️ Edit Table Data",
        "category": "Enhanced DB",
        "icon": "$(edit)"
      },
      {
        "command": "enhanceddb.saveDataChanges",
        "title": "💾 Save Data Changes",
        "category": "Enhanced DB",
        "icon": "$(save)"
      },
      {
        "command": "enhanceddb.discardDataChanges",
        "title": "🗑️ Discard Changes",
        "category": "Enhanced DB",
        "icon": "$(discard)"
      },
      {
        "command": "enhanceddb.toggleEditMode",
        "title": "🔄 Toggle Edit Mode",
        "category": "Enhanced DB",
        "icon": "$(edit)"
      },
      {
        "command": "enhanceddb.switchSchema",
        "title": "🗃️ Switch Schema",
        "category": "Enhanced DB",
        "icon": "$(folder-opened)"
      },
      {
        "command": "enhanceddb.copyCreateTable",
        "title": "📋 Copy CREATE TABLE",
        "category": "Enhanced DB",
        "icon": "$(clippy)"
      },
      {
        "command": "enhanceddb.exportData",
        "title": "📤 Export Data",
        "category": "Enhanced DB",
        "icon": "$(export)"
      },
      {
        "command": "enhanceddb.importData",
        "title": "📥 Import Data",
        "category": "Enhanced DB",
        "icon": "$(repo-pull)"
      },
      {
        "command": "enhanceddb.newSqlQuery",
        "title": "📝 New SQL Query",
        "category": "Enhanced DB"
      },
      {
        "command": "enhanceddb.saveQuery",
        "title": "💾 Save Query",
        "category": "Enhanced DB",
        "icon": "$(save)"
      },
      {
        "command": "enhanceddb.loadQuery",
        "title": "📂 Load Query",
        "category": "Enhanced DB",
        "icon": "$(folder-opened)"
      },
      {
        "command": "enhanceddb.queryHistory",
        "title": "📚 Query History",
        "category": "Enhanced DB",
        "icon": "$(history)"
      },
      {
        "command": "enhanceddb.launchEnhancedGUI",
        "title": "🎨 Launch Enhanced Database Manager",
        "category": "Enhanced DB"
      },
      {
        "command": "enhanceddb.showConstraints",
        "title": "🔗 Show Constraints & Indexes",
        "category": "Enhanced DB",
        "icon": "$(link)"
      },
      {
        "command": "enhanceddb.showPrimaryKeys",
        "title": "🔑 Show Primary Keys",
        "category": "Enhanced DB",
        "icon": "$(key)"
      },
      {
        "command": "enhanceddb.showForeignKeys",
        "title": "🔗 Show Foreign Keys",
        "category": "Enhanced DB",
        "icon": "$(link-external)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "enhanceddb-explorer",
          "title": "🚀 Enhanced DB Manager",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "enhanceddb-explorer": [
        {
          "id": "enhanceddbConnections",
          "name": "🔗 Connections",
          "icon": "$(database)",
          "contextualTitle": "Database Connections"
        },
        {
          "id": "enhanceddbSchemaBrowser",
          "name": "🗃️ Schema Browser",
          "icon": "$(folder-opened)",
          "contextualTitle": "Schema & Table Browser"
        },
        {
          "id": "enhanceddbDataEditor",
          "name": "📊 Data Editor",
          "icon": "$(table)",
          "contextualTitle": "Table Data Editor"
        },
        {
          "id": "enhanceddbQueries",
          "name": "📚 Query Editor",
          "icon": "$(edit)",
          "contextualTitle": "SQL Query Editor"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "enhanceddb.addConnection",
          "when": "view == enhanceddbConnections",
          "group": "navigation@1"
        },
        {
          "command": "enhanceddb.connectionManager",
          "when": "view == enhanceddbConnections",
          "group": "navigation@2"
        },
        {
          "command": "enhanceddb.switchSchema",
          "when": "view == enhanceddbSchemaBrowser",
          "group": "navigation@1"
        },
        {
          "command": "enhanceddb.refresh",
          "when": "view == enhanceddbSchemaBrowser",
          "group": "navigation@2"
        },
        {
          "command": "enhanceddb.toggleEditMode",
          "when": "view == enhanceddbDataEditor",
          "group": "navigation@1"
        },
        {
          "command": "enhanceddb.saveDataChanges",
          "when": "view == enhanceddbDataEditor",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "enhanceddb.connect",
          "when": "viewItem == dbConnection",
          "group": "inline@1"
        },
        {
          "command": "enhanceddb.editConnection",
          "when": "viewItem == dbConnection",
          "group": "connection@1"
        },
        {
          "command": "enhanceddb.testConnection",
          "when": "viewItem == dbConnection",
          "group": "connection@2"
        },
        {
          "command": "enhanceddb.deleteConnection",
          "when": "viewItem == dbConnection",
          "group": "connection@3"
        },
        {
          "command": "enhanceddb.viewTableStructure",
          "when": "viewItem == dbTable",
          "group": "inline@1"
        },
        {
          "command": "enhanceddb.viewTableData",
          "when": "viewItem == dbTable",
          "group": "data@1"
        },
        {
          "command": "enhanceddb.editTableData",
          "when": "viewItem == dbTable",
          "group": "data@2"
        },
        {
          "command": "enhanceddb.showConstraints",
          "when": "viewItem == dbTable",
          "group": "structure@1"
        },
        {
          "command": "enhanceddb.showPrimaryKeys",
          "when": "viewItem == dbTable",
          "group": "structure@2"
        },
        {
          "command": "enhanceddb.showForeignKeys",
          "when": "viewItem == dbTable",
          "group": "structure@3"
        },
        {
          "command": "enhanceddb.copyCreateTable",
          "when": "viewItem == dbTable",
          "group": "tools@1"
        },
        {
          "command": "enhanceddb.exportData",
          "when": "viewItem == dbTable",
          "group": "tools@2"
        },
        {
          "command": "enhanceddb.newSqlQuery",
          "when": "viewItem == postgresDatabase || viewItem == oracleDatabase",
          "group": "query@1"
        }
      ],
      "editor/title": [
        {
          "command": "enhanceddb.executeQuery",
          "when": "resourceExtname == .sql",
          "group": "navigation@1"
        },
        {
          "command": "enhanceddb.executeSelection",
          "when": "resourceExtname == .sql",
          "group": "navigation@2"
        },
        {
          "command": "enhanceddb.saveQuery",
          "when": "resourceExtname == .sql",
          "group": "file@1"
        }
      ],
      "commandPalette": [
        {
          "command": "enhanceddb.launchEnhancedGUI",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "Enhanced Database Manager",
      "properties": {
        "enhanceddb.connections": {
          "type": "array",
          "default": [],
          "description": "Enhanced database connection configurations",
          "items": {
            "type": "object",
            "required": [
              "name",
              "type",
              "host"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Connection name"
              },
              "type": {
                "type": "string",
                "enum": [
                  "PostgreSQL",
                  "MongoDB",
                  "Redis",
                  "Oracle"
                ],
                "description": "Database type"
              },
              "host": {
                "type": "string",
                "description": "Database server host"
              },
              "port": {
                "type": "number",
                "description": "Database server port"
              },
              "username": {
                "type": "string",
                "description": "Username"
              },
              "password": {
                "type": "string",
                "description": "Password (encrypted)"
              },
              "database": {
                "type": "string",
                "description": "Default database"
              },
              "schema": {
                "type": "string",
                "default": "public",
                "description": "Default schema"
              },
              "ssl": {
                "type": "boolean",
                "default": false,
                "description": "Use SSL/TLS connection"
              }
            }
          }
        },
        "enhanceddb.inlineEditing": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline data editing"
        },
        "enhanceddb.schemaBrowser": {
          "type": "boolean",
          "default": true,
          "description": "Enable enhanced schema browser"
        },
        "enhanceddb.tableStructure": {
          "type": "boolean",
          "default": true,
          "description": "Show detailed table structure information"
        },
        "enhanceddb.autoRefresh": {
          "type": "boolean",
          "default": false,
          "description": "Auto-refresh data views"
        },
        "enhanceddb.editMode": {
          "type": "boolean",
          "default": false,
          "description": "Default edit mode state"
        },
        "enhanceddb.maxRows": {
          "type": "number",
          "default": 1000,
          "description": "Maximum rows to display in data view"
        },
        "enhanceddb.theme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "default": "auto",
          "description": "UI theme preference"
        }
      }
    },
    "languages": [
      {
        "id": "sql",
        "extensions": [
          ".sql"
        ],
        "aliases": [
          "SQL",
          "sql"
        ],
        "configuration": "./syntaxes/sql-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sql",
        "scopeName": "source.sql",
        "path": "./syntaxes/sql.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Enhanced DB — Modern Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/enhanced-modern-dark.json"
      },
      {
        "label": "Enhanced DB — Modern Light",
        "uiTheme": "vs",
        "path": "./themes/enhanced-modern-light.json"
      }
    ]
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "^16.18.126",
    "@types/pg": "^8.6.6",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "crypto-js": "^4.1.1",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  }
}


