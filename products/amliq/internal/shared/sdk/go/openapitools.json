{
  "$schema": "node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.2.0",
    "generators": {
      "go-sdk": {
        "generatorName": "go",
        "inputSpec": "../openapi-merged.yaml",
        "output": "./generated",
        "additionalProperties": {
          "packageName": "finsavvy",
          "moduleName": "github.com/finsavvyai/sdk-go",
          "packageVersion": "1.0.0",
          "isGoSubmodule": true,
          "generateInterfaces": true,
          "structPrefix": true,
          "withGoMod": false,
          "enumClassPrefix": true
        }
      }
    }
  }
}
