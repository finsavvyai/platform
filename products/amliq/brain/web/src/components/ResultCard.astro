---
import CitationPill from './CitationPill.astro';
import { toSegments } from '../lib/highlight.ts';
import type { SearchResult } from '../lib/types.ts';

interface Props {
  result: SearchResult;
}
const { result } = Astro.props;
const segments = toSegments(result.snippet, result.citations);
const scorePct = Math.round(result.score * 100);
---

<article
  id={result.doc_id}
  class="rounded-2xl border border-ink-100 bg-white p-5
         shadow-[0_1px_2px_rgba(10,10,12,0.04)]
         dark:border-ink-700 dark:bg-ink-900"
>
  <header class="flex items-center justify-between gap-3">
    <h3 class="truncate text-sm font-semibold tracking-tightish">
      {result.doc_id}
    </h3>
    <span
      class="text-xs tabular-nums text-ink-500 dark:text-ink-400"
      aria-label={`Relevance ${scorePct} percent`}
    >
      {`${scorePct}%`}
    </span>
  </header>
  <p
    class="mt-2 text-pretty text-[15px] leading-relaxed text-ink-700
           dark:text-ink-50/85"
  >
    {segments.map((s) =>
      s.highlighted ? (
        <mark
          class="rounded bg-accent-50 px-0.5 text-ink-900
                 dark:bg-accent-500/20 dark:text-ink-50"
        >
          {s.text}
        </mark>
      ) : (
        <span>{s.text}</span>
      ),
    )}
  </p>
  {result.citations.length > 0 && (
    <footer class="mt-3 flex flex-wrap items-center gap-2">
      <span
        class="text-[11px] uppercase tracking-widest text-ink-400"
      >
        Citations
      </span>
      {result.citations.map((c) => (
        <CitationPill citation={c} />
      ))}
    </footer>
  )}
</article>
