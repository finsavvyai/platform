---
interface Props {
  value?: string;
  action?: string;
  autofocus?: boolean;
}
const { value = '', action = '/search', autofocus = false } = Astro.props;
---

<form
  method="GET"
  action={action}
  role="search"
  class="mx-auto flex w-full max-w-2xl flex-col gap-3 sm:flex-row"
>
  <label for="q" class="sr-only">Search compliance documents</label>
  <input
    id="q"
    name="q"
    type="search"
    value={value}
    placeholder="Search FinCEN advisories, FFIEC guidance, sanctions notices…"
    autocomplete="off"
    spellcheck="false"
    autofocus={autofocus}
    class="flex-1 rounded-xl border border-ink-100 bg-white px-4 py-3
           text-base text-ink-900 placeholder:text-ink-400
           focus:border-accent-500 focus:outline-none focus:ring-2
           focus:ring-accent-500/40
           dark:border-ink-700 dark:bg-ink-900 dark:text-ink-50
           dark:placeholder:text-ink-500"
  />
  <button
    type="submit"
    class="rounded-xl bg-ink-900 px-5 py-3 text-sm font-medium text-ink-50
           transition-colors hover:bg-ink-700 focus:outline-none focus:ring-2
           focus:ring-accent-500/40
           dark:bg-ink-50 dark:text-ink-900 dark:hover:bg-ink-100"
  >
    Search
  </button>
</form>
