---
import Default from '../layouts/Default.astro';
import SearchInput from '../components/SearchInput.astro';

const examples = [
  'beneficial ownership',
  'wire transfer red flags',
  'sanctions screening',
  'PEP enhanced due diligence',
];

// Dev banner shows whenever the API URL isn't set in the build env.
const showAuthBanner =
  typeof process === 'undefined' || !process.env.BRAIN_API_URL;
---

<Default
  title="AMLIQ Brain — Search"
  showAuthBanner={showAuthBanner}
>
  <section class="mx-auto max-w-2xl">
    <p
      class="mb-3 text-xs font-medium uppercase tracking-widest
             text-ink-500 dark:text-ink-400"
    >
      AMLIQ Brain
    </p>
    <h1
      class="mb-3 text-balance text-3xl font-semibold leading-tight
             tracking-tightish sm:text-4xl"
    >
      Search regulator-defensible compliance corpus.
    </h1>
    <p
      class="mb-8 text-pretty text-[15px] leading-relaxed text-ink-500
             dark:text-ink-400"
    >
      Every result carries inline citations back to the source document.
      Designed for AML analysts and compliance officers.
    </p>
    <SearchInput autofocus />
    <div class="mt-8">
      <p
        class="mb-2 text-xs uppercase tracking-widest text-ink-400"
      >
        Try
      </p>
      <ul class="flex flex-wrap gap-2">
        {examples.map((e) => (
          <li>
            <a
              href={`/search?q=${encodeURIComponent(e)}`}
              class="inline-flex rounded-full border border-ink-100
                     bg-white px-3 py-1 text-xs text-ink-700
                     hover:border-ink-400 hover:text-ink-900
                     focus:outline-none focus:ring-2
                     focus:ring-accent-500/40
                     dark:border-ink-700 dark:bg-ink-900
                     dark:text-ink-50/80 dark:hover:border-ink-400"
            >
              {e}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Default>
