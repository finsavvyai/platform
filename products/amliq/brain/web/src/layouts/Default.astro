---
interface Props {
  title: string;
  description?: string;
  showAuthBanner?: boolean;
}

const {
  title,
  description = 'AMLIQ Brain — analyst search with regulator-defensible citations.',
  showAuthBanner = false,
} = Astro.props;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
    <style>
      /* A11Y: respect prefers-reduced-motion globally — disables non-
         essential transitions/animations only when the OS opts in. */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </head>
  <body
    class="min-h-screen bg-ink-50 text-ink-900 antialiased
           selection:bg-ink-900 selection:text-ink-50
           dark:bg-ink-900 dark:text-ink-50"
  >
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2
             focus:rounded focus:bg-ink-900 focus:px-3 focus:py-1.5
             focus:text-ink-50 focus:outline focus:outline-2
             focus:outline-offset-2 focus:outline-ink-900
             dark:focus:bg-ink-50 dark:focus:text-ink-900
             dark:focus:outline-ink-50"
    >
      Skip to content
    </a>
    {showAuthBanner && (
      <div
        role="status"
        aria-live="polite"
        class="border-b border-ink-100 bg-ink-50/95 px-6 py-2
               text-xs text-ink-500
               dark:border-ink-700 dark:bg-ink-900/95 dark:text-ink-400"
      >
        Dev mode — using fixture results. Set
        <code class="mx-1 rounded bg-ink-100 px-1 py-0.5
                     dark:bg-ink-700">BRAIN_API_URL</code>
        and
        <code class="mx-1 rounded bg-ink-100 px-1 py-0.5
                     dark:bg-ink-700">BRAIN_JWT</code>
        to call the real API.
      </div>
    )}
    <header class="border-b border-ink-100 dark:border-ink-700">
      <nav
        aria-label="Primary"
        class="mx-auto flex max-w-5xl items-center justify-between
               px-gutter py-4"
      >
        <a
          href="/"
          class="text-sm font-semibold tracking-tightish"
        >
          AMLIQ Brain
        </a>
        <a
          href="/search"
          class="text-sm text-ink-500 hover:text-ink-900
                 dark:text-ink-400 dark:hover:text-ink-50"
        >
          Search
        </a>
      </nav>
    </header>
    <main id="main" class="mx-auto max-w-5xl px-gutter py-12 sm:py-16">
      <slot />
    </main>
    <footer
      class="border-t border-ink-100 mt-12 dark:border-ink-700"
    >
      <div
        class="mx-auto flex max-w-5xl flex-col gap-2 px-gutter py-6
               text-xs text-ink-500 sm:flex-row sm:items-center
               sm:justify-between dark:text-ink-400"
      >
        <p>&copy; {year} FinsavvyAI — AMLIQ Brain (internal preview).</p>
        <p>Regulator-defensible citations · audit-chain enforced.</p>
      </div>
    </footer>
  </body>
</html>
