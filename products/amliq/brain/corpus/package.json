{
  "name": "@amliq/brain-corpus",
  "version": "0.1.0",
  "private": true,
  "description": "AMLIQ Brain — compliance corpus ingest pipeline (FinCEN RSS + FFIEC PDF). Producer for oss/finsavvy-rag indexer.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist coverage *.tsbuildinfo"
  },
  "files": [
    "dist",
    "README.md",
    "DESIGN.md"
  ],
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "1.6.1",
    "typescript": "^5.5.0",
    "vitest": "1.6.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
