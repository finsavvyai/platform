{
  "name": "@finsavvyai/amliq-brain",
  "version": "0.1.0",
  "private": true,
  "description": "AMLIQ Brain — agent-driven AML/CFT intelligence layer (Brain SKU). Sibling to AMLIQ Investigate (api/, web/, engines/).",
  "type": "module",
  "main": "./dist/services/api/src/index.js",
  "types": "./dist/services/api/src/index.d.ts",
  "exports": {
    "./api": {
      "types": "./dist/services/api/src/index.d.ts",
      "import": "./dist/services/api/src/index.js"
    },
    "./api/node": {
      "types": "./dist/services/api/src/node-server.d.ts",
      "import": "./dist/services/api/src/node-server.js"
    },
    "./retrieval": {
      "types": "./dist/services/retrieval/src/index.d.ts",
      "import": "./dist/services/retrieval/src/index.js"
    },
    "./sanctions": {
      "types": "./dist/services/sanctions/src/index.d.ts",
      "import": "./dist/services/sanctions/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/services/api/src/node-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf services/*/dist *.tsbuildinfo"
  },
  "dependencies": {
    "hono": "4.12.23",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "1.6.1",
    "typescript": "^5.5.0",
    "vitest": "1.6.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
