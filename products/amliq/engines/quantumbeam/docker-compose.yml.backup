version: "3.8"

services:
  # PostgreSQL Database
  postgres:
    image: postgres:16-alpine
    container_name: quantumbeam-postgres-dev
    restart: unless-stopped
    environment:
      POSTGRES_DB: quantumbeam_dev
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: password
      POSTGRES_MULTIPLE_DATABASES: quantumbeam_test,quantumbeam_staging
    ports:
      - "5432:5432"
    volumes:
      - postgres_data_dev:/var/lib/postgresql/data
      - ./scripts/init-databases.sh:/docker-entrypoint-initdb.d/init-databases.sh
      - ./migrations:/docker-entrypoint-initdb.d/migrations
      - ./seeds:/docker-entrypoint-initdb.d/seeds
    networks:
      - quantumbeam-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d quantumbeam_dev"]
      interval: 5s
      timeout: 5s
      retries: 5
      start_period: 30s

  # Redis Cache
  redis:
    image: redis:7-alpine
    container_name: quantumbeam-redis-dev
    restart: unless-stopped
    command: redis-server --appendonly yes --requirepass ""
    ports:
      - "6379:6379"
    volumes:
      - redis_data_dev:/data
      - ./config/redis.conf:/usr/local/etc/redis/redis.conf:ro
    networks:
      - quantumbeam-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
      start_period: 10s

  # InfluxDB Time-Series Database
  influxdb:
    image: influxdb:2.7-alpine
    container_name: quantumbeam-influxdb-dev
    restart: unless-stopped
    environment:
      DOCKER_INFLUXDB_INIT_MODE: setup
      DOCKER_INFLUXDB_INIT_USERNAME: admin
      DOCKER_INFLUXDB_INIT_PASSWORD: password123
      DOCKER_INFLUXDB_INIT_ORG: quantumbeam
      DOCKER_INFLUXDB_INIT_BUCKET: metrics
      DOCKER_INFLUXDB_INIT_ADMIN_TOKEN: quantumbeam-dev-token-123456789
    ports:
      - "8086:8086"
    volumes:
      - influxdb_data_dev:/var/lib/influxdb2
      - influxdb_config_dev:/etc/influxdb2
    networks:
      - quantumbeam-network
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8086/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

  # Elasticsearch Search and Analytics
  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:8.11.1
    container_name: quantumbeam-elasticsearch-dev
    restart: unless-stopped
    environment:
      - node.name=quantumbeam-es-node
      - cluster.name=quantumbeam-cluster
      - discovery.type=single-node
      - bootstrap.memory_lock=true
      - "ES_JAVA_OPTS=-Xms1g -Xmx1g"
      - xpack.security.enabled=false
      - xpack.security.enrollment.enabled=false
      - xpack.security.http.ssl.enabled=false
      - xpack.security.transport.ssl.enabled=false
      - xpack.monitoring.collection.enabled=true
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 65536
        hard: 65536
    ports:
      - "9200:9200"
      - "9300:9300"
    volumes:
      - elasticsearch_data_dev:/usr/share/elasticsearch/data
      - ./config/elasticsearch.yml:/usr/share/elasticsearch/config/elasticsearch.yml:ro
    networks:
      - quantumbeam-network
    healthcheck:
      test:
        ["CMD-SHELL", "curl -f http://localhost:9200/_cluster/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 60s

  # Kibana for Elasticsearch Visualization
  kibana:
    image: docker.elastic.co/kibana/kibana:8.11.1
    container_name: quantumbeam-kibana-dev
    restart: unless-stopped
    environment:
      ELASTICSEARCH_HOSTS: http://elasticsearch:9200
      XPACK_SECURITY_ENABLED: false
      XPACK_ENCRYPTIONKEY: quantumbeam-dev-key-32-chars
      XPACK_REPORTING_ENCRYPTIONKEY: quantumbeam-dev-reporting-key
    ports:
      - "5601:5601"
    volumes:
      - kibana_data_dev:/usr/share/kibana/data
    networks:
      - quantumbeam-network
    depends_on:
      elasticsearch:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:5601/api/status || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

  # Redis Commander (Redis GUI)
  redis-commander:
    image: rediscommander/redis-commander:latest
    container_name: quantumbeam-redis-commander-dev
    restart: unless-stopped
    environment:
      REDIS_HOSTS: local:redis:6379
      REDIS_PASSWORD: ""
      HTTP_USER: admin
      HTTP_PASSWORD: admin
    ports:
      - "8081:8081"
    networks:
      - quantumbeam-network
    depends_on:
      redis:
        condition: service_healthy

  # PgAdmin (PostgreSQL GUI)
  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: quantumbeam-pgadmin-dev
    restart: unless-stopped
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@quantumbeam.dev
      PGADMIN_DEFAULT_PASSWORD: admin
      PGADMIN_CONFIG_SERVER_MODE: "False"
      PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED: "False"
    ports:
      - "5050:80"
    volumes:
      - pgadmin_data_dev:/var/lib/pgadmin
      - ./config/pgadmin-servers.json:/pgadmin4/servers.json:ro
    networks:
      - quantumbeam-network
    depends_on:
      postgres:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      /entrypoint.sh
      "

  # Go API Service (with hot reload)
  api-service:
    build:
      context: .
      dockerfile: Dockerfile.dev
      target: development
    container_name: quantumbeam-api-dev
    restart: unless-stopped
    environment:
      APP_ENV: development
      CONFIG_PATH: /app/config/config.development.yaml
      DB_HOST: postgres
      DB_PORT: 5432
      DB_USER: postgres
      DB_PASSWORD: password
      DB_NAME: quantumbeam_dev
      REDIS_HOST: redis
      REDIS_PORT: 6379
      INFLUXDB_URL: http://influxdb:8086
      INFLUXDB_TOKEN: quantumbeam-dev-token-123456789
      INFLUXDB_ORG: quantumbeam
      INFLUXDB_BUCKET: metrics
      ELASTICSEARCH_URL: http://elasticsearch:9200
    ports:
      - "8080:8080"
      - "9090:9090" # Metrics
      - "6060:6060" # Profiling
      - "8082:8082" # Health check
    volumes:
      - .:/app
      - /app/vendor # Exclude vendor to avoid conflicts
      - go_modules:/go/pkg/mod
    networks:
      - quantumbeam-network
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      influxdb:
        condition: service_healthy
      elasticsearch:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8082/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

  # Python Quantum Service
  quantum-service:
    build:
      context: ./services/quantum
      dockerfile: Dockerfile.dev
    container_name: quantumbeam-quantum-dev
    restart: unless-stopped
    environment:
      PYTHONPATH: /app
      LOG_LEVEL: debug
      REDIS_HOST: redis
      REDIS_PORT: 6379
      INFLUXDB_URL: http://influxdb:8086
      INFLUXDB_TOKEN: quantumbeam-dev-token-123456789
      INFLUXDB_ORG: quantumbeam
      INFLUXDB_BUCKET: metrics
    ports:
      - "8001:8000"
    volumes:
      - ./services/quantum:/app
      - /app/__pycache__ # Exclude __pycache__
      - quantum_service_venv:/app/venv
    networks:
      - quantumbeam-network
    depends_on:
      redis:
        condition: service_healthy
      influxdb:
        condition: service_healthy
    command: uvicorn main:app --host 0.0.0.0 --port 8000 --reload --log-level debug

  # Python ML Service
  ml-service:
    build:
      context: ./services/ml
      dockerfile: Dockerfile.dev
    container_name: quantumbeam-ml-dev
    restart: unless-stopped
    environment:
      PYTHONPATH: /app
      LOG_LEVEL: debug
      MODEL_PATH: /app/models
      REDIS_HOST: redis
      REDIS_PORT: 6379
      INFLUXDB_URL: http://influxdb:8086
      INFLUXDB_TOKEN: quantumbeam-dev-token-123456789
      INFLUXDB_ORG: quantumbeam
      INFLUXDB_BUCKET: metrics
      ELASTICSEARCH_URL: http://elasticsearch:9200
    ports:
      - "8002:8000"
    volumes:
      - ./services/ml:/app
      - /app/__pycache__ # Exclude __pycache__
      - ml_service_venv:/app/venv
      - ml_models:/app/models
    networks:
      - quantumbeam-network
    depends_on:
      redis:
        condition: service_healthy
      influxdb:
        condition: service_healthy
      elasticsearch:
        condition: service_healthy
    command: uvicorn main:app --host 0.0.0.0 --port 8000 --reload --log-level debug

  # Jaeger Tracing
  jaeger:
    image: jaegertracing/all-in-one:latest
    container_name: quantumbeam-jaeger-dev
    restart: unless-stopped
    environment:
      COLLECTOR_OTLP_ENABLED: true
    ports:
      - "16686:16686" # Jaeger UI
      - "14268:14268" # HTTP collector
      - "14250:14250" # gRPC collector
    networks:
      - quantumbeam-network

  # Prometheus Monitoring
  prometheus:
    image: prom/prometheus:latest
    container_name: quantumbeam-prometheus-dev
    restart: unless-stopped
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--web.console.libraries=/etc/prometheus/console_libraries"
      - "--web.console.templates=/etc/prometheus/consoles"
      - "--storage.tsdb.retention.time=200h"
      - "--web.enable-lifecycle"
      - "--web.enable-admin-api"
    ports:
      - "9091:9090"
    volumes:
      - ./config/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data_dev:/prometheus
    networks:
      - quantumbeam-network
    depends_on:
      - api-service

  # Grafana Dashboards
  grafana:
    image: grafana/grafana:latest
    container_name: quantumbeam-grafana-dev
    restart: unless-stopped
    environment:
      GF_SECURITY_ADMIN_USER: admin
      GF_SECURITY_ADMIN_PASSWORD: admin
      GF_INSTALL_PLUGINS: grafana-clock-panel,grafana-simple-json-datasource
    ports:
      - "3000:3000"
    volumes:
      - grafana_data_dev:/var/lib/grafana
      - ./config/grafana/provisioning:/etc/grafana/provisioning:ro
      - ./config/grafana/dashboards:/var/lib/grafana/dashboards:ro
    networks:
      - quantumbeam-network
    depends_on:
      - prometheus
      - influxdb
      - elasticsearch

  # MinIO S3-compatible Storage
  minio:
    image: minio/minio:latest
    container_name: quantumbeam-minio-dev
    restart: unless-stopped
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: minioadmin123
    ports:
      - "9000:9000"
      - "9001:9001"
    volumes:
      - minio_data_dev:/data
    networks:
      - quantumbeam-network
    command: server /data --console-address ":9001"
    healthcheck:
      test:
        [
          "CMD-SHELL",
          "curl -f http://localhost:9000/minio/health/live || exit 1",
        ]
      interval: 30s
      timeout: 5s
      retries: 3

volumes:
  # Data volumes
  postgres_data_dev:
    driver: local
  redis_data_dev:
    driver: local
  influxdb_data_dev:
    driver: local
  influxdb_config_dev:
    driver: local
  elasticsearch_data_dev:
    driver: local
  kibana_data_dev:
    driver: local
  pgadmin_data_dev:
    driver: local
  grafana_data_dev:
    driver: local
  prometheus_data_dev:
    driver: local
  minio_data_dev:
    driver: local

  # Development cache volumes
  go_modules:
    driver: local
  quantum_service_venv:
    driver: local
  ml_service_venv:
    driver: local
  ml_models:
    driver: local

networks:
  quantumbeam-network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16
