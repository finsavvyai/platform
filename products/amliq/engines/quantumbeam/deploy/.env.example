# QuantumBeam Configuration
# Copy to .env and update with your values

# Database
DATABASE_URL=postgres://qb_user:qb_pass@localhost:5432/quantumbeam
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT_SECONDS=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# Server
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=debug
GRACEFUL_SHUTDOWN_TIMEOUT=30s

# Security
JWT_SECRET=your-secret-key-change-this
API_KEY_PREFIX=qb_

# Fraud Detection
SCORING_THRESHOLD=0.7
HIGH_RISK_THRESHOLD=0.85
RING_DETECTION_ENABLED=true
BEHAVIORAL_ANALYTICS_ENABLED=true

# Feature Flags
FEATURE_RING_DETECTION=true
FEATURE_GRAPH_ANALYSIS=true
FEATURE_ML_INFERENCE=true

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
SENTRY_DSN=

# Telemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Performance
MAX_CONCURRENT_TRANSACTIONS=1000
BATCH_SIZE=100
CACHE_TTL_SECONDS=3600

# Backup
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
