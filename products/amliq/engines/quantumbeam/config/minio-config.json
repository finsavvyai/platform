{
  "version": "1",
  "region": "us-east-1",
  "credential": {
    "accessKey": "minioadmin",
    "secretKey": "minioadmin123"
  },
  "logger": {
    "console": {
      "enable": true,
      "level": "info"
    },
    "file": {
      "enable": true,
      "fileName": "/var/log/minio.log",
      "level": "info"
    }
  },
  "notify": {
    "webhook": {
      "1": {
        "enable": true,
        "endpoint": "http://localhost:9000/api/v1/webhooks/minio"
      }
    },
    "amqp": {
      "1": {
        "enable": false,
        "url": "amqp://guest:guest@localhost:5672/",
        "exchange": "minio_events",
        "routingKey": "minio",
        "exchangeType": "fanout",
        "deliveryMode": 0,
        "mandatory": false,
        "immediate": false,
        "durable": true,
        "internal": false,
        "noWait": false,
        "autoDeleted": false
      }
    },
    "kafka": {
      "1": {
        "enable": false,
        "brokers": ["localhost:9092"],
        "topic": "minio-events"
      }
    },
    "elasticsearch": {
      "1": {
        "enable": false,
        "url": "http://localhost:9200",
        "index": "minio-events"
      }
    }
  },
  "storage": {
    "name": "fs",
    "fs": {
      "path": "/data"
    }
  },
  "compression": {
    "enable": true,
    "allow_encryption": true,
    "extensions": [".txt", ".log", ".csv", ".json", ".xml", ".yaml", ".yml"]
  },
  "cache": {
    "drives": ["/data/cache"],
    "expiry": 30,
    "maxuse": 80
  },
  "subnet": {
    "auto": true,
    "internal": [],
    "external": []
  },
  "api": {
    "corsAllowOrigin": ["*"],
    "secureCORS": false
  },
  "browser": {
    "redirect": true,
    "loginBanner": "QuantumBeam.io - Object Storage",
    "cancelWebhook": ""
  },
  "policy": {
    "default": [
      {
        "Statement": [
          {
            "Action": [
              "admin:ListGroupsForUser"
            ],
            "Effect": "Allow",
            "Principal": {
              "AWS": [
                "arn:aws:iam::minio:user:admin"
              ]
            },
            "Resource": [
              "arn:aws:s3:::admin:*"
            ]
          }
        ],
        "Version": "2012-10-17"
      }
    ]
  },
  "quota": {
    "enable": false
  },
  "lease": {
    "enable": true,
    "transient": true,
    "persistent": true
  },
  "site": {
    "name": "QuantumBeam MinIO",
    "region": "us-east-1",
    "domain": "",
    "comment": "QuantumBeam.io Object Storage"
  },
  "identity_openid": {
    "config": "",
    "client_id": "",
    "claim_name": "",
    "claim_prefix": "",
    "scopes": "",
    "redirect_url": "",
    "vendor_url": ""
  },
  "identity_ldap": {
    "server_addr": "",
    "server_insecure": false,
    "bind_dn": "",
    "bind_password": "",
    "user_dn_search_base": "",
    "user_dn_search_filter": "",
    "group_search_base": "",
    "group_search_filter": ""
  },
  "storage_class": {
    "standard": [
      {
        "pool": "default"
      }
    ],
    "rrs": [
      {
        "pool": "default"
      }
    ],
    "glacier": []
  },
  "retry": {
    "attempts": 3,
    "bucket": "failed-uploads",
    "expire": 1440
  },
  "ftp": {
    "enable": false,
    "address": ":2121"
  },
  "sftp": {
    "enable": false,
    "address": ":3022"
  },
  "monitoring": {
    "web": {
      "enable": true,
      "address": ":9000"
    },
    "prometheus": {
      "enable": true,
      "address": ":9000/metrics",
      "metrics_path": "/minio/v2/metrics/cluster",
      "auth_type": "public"
    }
  },
  "audit_webhook": {
    "enable": false,
    "endpoint": "http://localhost:9000/api/v1/webhooks/audit",
    "auth_token": ""
  },
  "logger_webhook": {
    "enable": false,
    "endpoint": "http://localhost:9000/api/v1/webhooks/logs",
    "auth_token": ""
  },
  "heal": {
    "max_drives": 0,
    "max_objects": 0,
    "max_io_errors": 0
  },
  "scanner": {
    "delay": 10,
    "cycle": 24,
    "unit": "h"
  },
  "usage": {
    "batch_size": 1000,
    "delay": 2,
    "cycle": 24,
    "unit": "h"
  },
  "encryption": {
    "key": {
      "keyId": "",
      "keySize": 256
    },
    "kms": {
      "endpoint": "",
      "secret": "",
      "token": ""
    }
  }
}