# QuantumBeam API Development Dockerfile
# Multi-stage build optimized for development with hot reload

# Base stage with dependencies
FROM golang:1.21-alpine AS base
WORKDIR /app

# Install build dependencies and tools
RUN apk add --no-cache \
    git \
    make \
    gcc \
    musl-dev \
    sqlite-dev \
    curl \
    bash \
    ca-certificates \
    tzdata \
    && rm -rf /var/cache/apk/*

# Install air for hot reload
RUN go install github.com/cosmtrek/air@latest

# Copy go mod files
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go mod download && \
    go mod verify

# Development stage
FROM base AS development
ENV GO111MODULE=on \
    CGO_ENABLED=1 \
    GOOS=linux \
    GOARCH=amd64

# Install additional development tools
RUN go install -a github.com/golangci/golangci-lint/cmd/golangci-lint@latest && \
    go install github.com/golang/mock/mockgen@latest && \
    go install github.com/pressly/goose/v3/cmd/goose@latest && \
    go install github.com/swaggo/swag/cmd/swag@latest

# Create non-root user
RUN addgroup -g 1001 -S quantumbeam && \
    adduser -u 1001 -S quantumbeam -G quantumbeam
USER quantumbeam

# Set up volume for source code
VOLUME ["/app"]

# Expose ports
EXPOSE 8080 9090 6060 8082

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8082/health || exit 1

# Default command - use air for hot reload
CMD ["air", "-c", ".air.toml"]
