# Database Configuration for QuantumBeam.io
# Copy this file to .env and update with your values

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=quantumbeam
POSTGRES_SSL_MODE=disable

# PgBouncer Configuration
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432
USE_PGBOUNCER=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=quantumbeam-token-123456789
INFLUXDB_ORG=quantumbeam
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=influxadmin123

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_PORT=9200

# ClickHouse Configuration
CLICKHOUSE_PORT=8123
CLICKHOUSE_PASSWORD=clickhouse123

# Kafka Configuration
KAFKA_PORT=9092

# MinIO Configuration
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Application Configuration
APP_ENV=development
APP_SECRET_KEY=your-secret-key-change-in-production
API_HOST=0.0.0.0
API_PORT=8080

# Migration Configuration
MIGRATIONS_PATH=./migrations
DB_SSL_MODE=disable

# Partition Maintenance
DEFAULT_RETENTION_MONTHS=12
AUTO_PARTITION_CREATE=true
AUTO_PARTITION_DROP=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=quantumbeam-backups

# Monitoring Configuration
METRICS_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces
LOG_LEVEL=info

# Security Configuration
CORS_ORIGINS=*
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Quantum Configuration
QUANTUM_SIMULATOR=true
QUANTUM_BACKEND=ibmq_quito
QUANTUM_SHOTS=8192
QUANTUM_NOISE_MODEL=true

# ML Configuration
MODEL_REGISTRY_PATH=./models
MODEL_CACHE_TTL=3600
MAX_BATCH_SIZE=1000
FEATURE_STORE_TYPE=redis
FEATURE_STORE_TTL=86400

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600
RATE_LIMIT_BURST=100

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# External APIs
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Logging
LOG_FORMAT=json
LOG_LEVEL=info
LOG_FILE=./logs/quantumbeam.log
LOG_MAX_SIZE=100M
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30
