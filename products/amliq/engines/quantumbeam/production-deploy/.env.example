# QuantumBeam Production Environment Variables

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/quantumbeam
POSTGRES_DB=quantumbeam
POSTGRES_USER=quantumbeam_user
POSTGRES_PASSWORD=your_secure_password

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters
API_SECRET_KEY=your_api_secret_key

# Application Settings
ENVIRONMENT=production
PORT=8080
LOG_LEVEL=info

# SSL Configuration (if using custom SSL)
SSL_CERT_PATH=/app/ssl/cert.pem
SSL_KEY_PATH=/app/ssl/key.pem

# Monitoring
GRAFANA_PASSWORD=your_grafana_password

# External Services (optional)
SENTRY_DSN=your_sentry_dsn
CLOUDFLARE_API_TOKEN=your_cloudflare_token

# Email (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# Feature Flags
ENABLE_METRICS=true
ENABLE_LOGGING=true
ENABLE_PROFILING=false

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=quantumbeam-backups
BACKUP_AWS_ACCESS_KEY=your_aws_access_key
BACKUP_AWS_SECRET_KEY=your_aws_secret_key