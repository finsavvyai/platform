# QuantumBeam Production Environment Configuration
# Copy this file to .env.production and fill in your actual values

# ============================================================================
# CORE SERVICE CONFIGURATION
# ============================================================================
ENVIRONMENT=production
SERVICE_NAME=quantumbeam-fraud-detection
SERVICE_VERSION=1.0.0
LOG_LEVEL=info
PORT=8080

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL Main Database
DATABASE_URL=postgres://quantumbeam:CHANGEME@postgres:5432/quantumbeam?sslmode=require
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=quantumbeam
POSTGRES_USER=quantumbeam
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD_HERE
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_IDLE_CONNECTIONS=10
POSTGRES_CONNECTION_TIMEOUT=30s

# Database Connection Pool
DB_POOL_MAX_OPEN_CONNS=100
DB_POOL_MAX_IDLE_CONNS=25
DB_POOL_CONN_MAX_LIFETIME=1h
DB_POOL_CONN_MAX_IDLE_TIME=10m

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_POOL_TIMEOUT=4s
REDIS_IDLE_TIMEOUT=5m

# ============================================================================
# QUANTUM BACKEND CONFIGURATION
# ============================================================================
# IBM Quantum
IBM_QUANTUM_TOKEN=YOUR_IBM_QUANTUM_TOKEN_HERE
IBM_QUANTUM_URL=https://auth.quantum-computing.ibm.com/api
IBM_QUANTUM_BACKEND_PREFERENCE=ibm_quantum_simulator,ibm_quantum_hardware

# AWS Braket
AWS_BRAKET_ACCESS_KEY=YOUR_AWS_ACCESS_KEY_HERE
AWS_BRAKET_SECRET_KEY=YOUR_AWS_SECRET_KEY_HERE
AWS_BRAKET_REGION=us-east-1
AWS_BRAKET_BACKEND_PREFERENCE=aws_braket_simulator,aws_braket_hardware

# Google Quantum AI
GOOGLE_QUANTUM_PROJECT_ID=YOUR_GOOGLE_PROJECT_ID
GOOGLE_QUANTUM_CREDENTIALS_JSON=/secrets/google-quantum-credentials.json

# Quantum Service Configuration
QUANTUM_SERVICE_URL=http://quantum:8001
QUANTUM_TIMEOUT=30s
QUANTUM_MAX_RETRIES=3
QUANTUM_RETRY_DELAY=100ms
QUANTUM_ENABLE_FALLBACK=true
QUANTUM_CIRCUIT_CACHE_TTL=5m

# ============================================================================
# AI/ML SERVICE CONFIGURATION
# ============================================================================
AI_SERVICE_URL=http://ai-ml:8001
AI_SERVICE_TIMEOUT=15s
AI_SERVICE_MAX_RETRIES=2

# OpenAI Configuration
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Anthropic Claude Configuration
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_MAX_TOKENS=1000

# HuggingFace Configuration
HUGGINGFACE_TOKEN=YOUR_HUGGINGFACE_TOKEN_HERE
HUGGINGFACE_MODEL=bert-base-uncased

# ============================================================================
# JWT AND AUTHENTICATION
# ============================================================================
JWT_SECRET=CHANGEME_LONG_RANDOM_STRING_64_CHARS_MIN_USE_OPENSSL_RAND_HEX
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h
JWT_ISSUER=quantumbeam.io
JWT_AUDIENCE=quantumbeam-api

# API Key Configuration
API_KEY_HEADER=X-API-Key
API_KEY_ENCRYPTION_KEY=CHANGEME_32_CHAR_ENCRYPTION_KEY_HERE

# Session Configuration
SESSION_SECRET=CHANGEME_SESSION_SECRET_KEY_HERE
SESSION_DURATION=24h

# ============================================================================
# BILLING AND PAYMENTS
# ============================================================================
# LemonSqueezy
LEMONSQUEEZY_API_KEY=YOUR_LEMONSQUEEZY_API_KEY_HERE
LEMONSQUEEZY_STORE_ID=YOUR_STORE_ID
LEMONSQUEEZY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE
LEMONSQUEEZY_WEBHOOK_URL=https://yourdomain.com/webhooks/lemonsqueezy

# Stripe (Alternative)
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE

# ============================================================================
# FRAUD DETECTION CONFIGURATION
# ============================================================================
# Production Features
FRAUD_DETECTION_MAX_CONCURRENT=100
FRAUD_DETECTION_TIMEOUT=30s
FRAUD_DETECTION_RATE_LIMIT=100
FRAUD_DETECTION_RATE_BURST=200
FRAUD_DETECTION_CACHE_TTL=5m

# Circuit Breaker
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_MAX_FAILURES=5
CIRCUIT_BREAKER_TIMEOUT=60s
CIRCUIT_BREAKER_RESET_TIMEOUT=30s

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=100ms
ENABLE_EXPONENTIAL_BACKOFF=true

# Thresholds
FRAUD_THRESHOLD_LOW=0.3
FRAUD_THRESHOLD_MEDIUM=0.6
FRAUD_THRESHOLD_HIGH=0.8
FRAUD_THRESHOLD_CRITICAL=0.9

# ============================================================================
# MONITORING AND OBSERVABILITY
# ============================================================================
# Prometheus
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana
GRAFANA_URL=http://grafana:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGEME_GRAFANA_PASSWORD

# AlertManager
ALERTMANAGER_URL=http://alertmanager:9093
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Jaeger Tracing
JAEGER_ENABLED=true
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=probabilistic
JAEGER_SAMPLER_PARAM=0.1

# Logging
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE_PATH=/var/log/quantumbeam/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30
LOG_COMPRESS=true

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# TLS/SSL
TLS_ENABLED=true
TLS_CERT_FILE=/etc/ssl/certs/quantumbeam.crt
TLS_KEY_FILE=/etc/ssl/private/quantumbeam.key
TLS_MIN_VERSION=1.2

# CORS
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key
CORS_MAX_AGE=86400

# Security Headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# Rate Limiting (Global)
GLOBAL_RATE_LIMIT_ENABLED=true
GLOBAL_RATE_LIMIT_PER_SECOND=1000
GLOBAL_RATE_LIMIT_BURST=2000

# IP Whitelist/Blacklist
IP_WHITELIST_ENABLED=false
IP_WHITELIST=
IP_BLACKLIST_ENABLED=true
IP_BLACKLIST=

# ============================================================================
# SECRETS MANAGEMENT
# ============================================================================
# Vault Configuration (Optional)
VAULT_ENABLED=false
VAULT_ADDR=https://vault.yourdomain.com:8200
VAULT_TOKEN=YOUR_VAULT_TOKEN_HERE
VAULT_NAMESPACE=quantumbeam
VAULT_MOUNT_PATH=secret

# AWS Secrets Manager (Optional)
AWS_SECRETS_ENABLED=false
AWS_SECRETS_REGION=us-east-1
AWS_SECRETS_PREFIX=quantumbeam/production

# ============================================================================
# BACKUP AND DISASTER RECOVERY
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=quantumbeam-backups-prod
BACKUP_S3_PREFIX=production/

# Point-in-Time Recovery
PITR_ENABLED=true
PITR_RETENTION_HOURS=168

# ============================================================================
# SCALING AND PERFORMANCE
# ============================================================================
# Auto-scaling
AUTOSCALING_ENABLED=true
AUTOSCALING_MIN_REPLICAS=3
AUTOSCALING_MAX_REPLICAS=10
AUTOSCALING_TARGET_CPU=70
AUTOSCALING_TARGET_MEMORY=80

# Performance Tuning
MAX_REQUEST_SIZE=10MB
READ_TIMEOUT=30s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=30s

# Caching
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=5m
CACHE_MAX_SIZE=1GB

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Email Service
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY_HERE
EMAIL_FROM=noreply@quantumbeam.io
EMAIL_FROM_NAME=QuantumBeam

# SMS Service
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1234567890

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#alerts

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_QUANTUM_ENABLED=true
FEATURE_AI_ENHANCED=true
FEATURE_FRAUD_RINGS=true
FEATURE_REAL_TIME_ALERTS=true
FEATURE_BATCH_PROCESSING=true
FEATURE_WEBHOOK_NOTIFICATIONS=true

# ============================================================================
# COMPLIANCE AND AUDIT
# ============================================================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=info
AUDIT_LOG_DESTINATION=elasticsearch
AUDIT_RETENTION_DAYS=365

# Compliance
PCI_DSS_COMPLIANT=true
GDPR_COMPLIANT=true
SOC2_COMPLIANT=true

# Data Retention
DATA_RETENTION_DAYS=2555
PURGE_OLD_DATA_SCHEDULE=0 3 * * 0

# ============================================================================
# DEVELOPMENT AND DEBUGGING (Disable in production!)
# ============================================================================
DEBUG_MODE=false
PROFILING_ENABLED=false
PPROF_ENABLED=false
PPROF_PORT=6060

# Gin Mode
GIN_MODE=release

# ============================================================================
# CONTAINER AND ORCHESTRATION
# ============================================================================
# Docker
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_TAG=latest
DOCKER_PULL_POLICY=Always

# Kubernetes
K8S_NAMESPACE=quantumbeam-production
K8S_SERVICE_ACCOUNT=quantumbeam-sa
K8S_CONFIG_MAP=quantumbeam-config
K8S_SECRET=quantumbeam-secrets

# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=5s
LIVENESS_PROBE_PATH=/health/live
READINESS_PROBE_PATH=/health/ready

# ============================================================================
# NOTES
# ============================================================================
# - Replace all CHANGEME values with strong, randomly generated values
# - Use secrets management service in production (Vault, AWS Secrets Manager, etc.)
# - Never commit this file with real credentials to version control
# - Rotate secrets regularly (recommended: quarterly)
# - Use different encryption keys for each environment
# - Enable all security features in production
# - Monitor and review logs regularly
# - Keep backups in a separate region/account
# - Test disaster recovery procedures regularly
