"on":
    - push
    - pull_request
stages:
    - name: test-go
      checks:
        - name: test-go-1
          run: go test -cover -race ./...
    - name: test-web
      checks:
        - name: test-web-1
          run: cd web && npm ci && npm test
    - name: test-e2e
      checks:
        - name: test-e2e-1
          run: cd web && npm ci
        - name: test-e2e-2
          run: npx playwright install --with-deps chromium
        - name: test-e2e-3
          run: cd web && npm run test:e2e
    - name: build
      checks:
        - name: build-1
          run: go build -o bin/api ./cmd/api
        - name: build-2
          run: go build -o bin/worker ./cmd/worker
      depends_on:
        - test-go
        - test-web
        - test-e2e
deploy:
    - name: cloudflare-pages
      trigger: push
      run: cd web && npm run build && npx wrangler pages deploy dist --project-name=amliq --branch=main
      only_on:
        - main
        - master
    - name: render
      trigger: push
      run: echo 'Render deploys via Git push'
      only_on:
        - main
        - master
