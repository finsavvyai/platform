#!/bin/bash
set -e
echo "pre-commit: checking..."
BAD=$(cd "." && gofmt -l . 2>/dev/null | grep -v vendor | head -5)
if [ -n "$BAD" ]; then
  echo "FAIL [.]: unformatted Go files:"; echo "$BAD"
  echo "Run: (cd . && go fmt ./...)"; exit 1
fi
if ! (cd "." && go build ./... 2>/dev/null); then
  echo "FAIL [.]: go build"; exit 1
fi
OVER=$(find .  -not -path './.git/*' -not -path '*/.git/*' -not -path './vendor/*' -not -path '*/vendor/*' -not -path './node_modules/*' -not -path '*/node_modules/*' -not -path './target/*' -not -path '*/target/*' -not -path './dist/*' -not -path '*/dist/*' -not -path './build/*' -not -path '*/build/*' -not -path './.claude/*' -not -path '*/.claude/*' -not -path './cmd/schedulers-stage/*' -not -path '*/cmd/schedulers-stage/*' -not -path './.claude/skills/*' -not -path '*/.claude/skills/*' \
  \( -name "*.go" -o -name "*.ts" -o -name "*.tsx" \
     -o -name "*.py" -o -name "*.rs" -o -name "*.java" \) \
  -exec sh -c 'l=$(wc -l < "$1"); [ "$l" -gt 100 ] && echo "$l $1"' _ {} \;)
if [ -n "$OVER" ]; then
  echo "FAIL: files over 100 lines:"; echo "$OVER"; exit 1
fi
echo "pre-commit: OK"
