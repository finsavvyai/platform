# ── Local dev only — do NOT commit real values ────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=devpassword

# Go service
INTERNAL_SECRET=change-this-to-a-random-string

# Cloudflare (get from dash.cloudflare.com)
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=

# Render (for make deploy / make logs)
RENDER_API_KEY=
RENDER_SERVICE_ID=

# ── Production (set in Render dashboard, not here) ────────────────────────────
# DATABASE_URL        — injected automatically by Render from fromDatabase ref
# WATCHMAN_ENDPOINT   — injected automatically as http://amliq-watchman:8084
# INTERNAL_SECRET     — generateValue: true in render.yaml
