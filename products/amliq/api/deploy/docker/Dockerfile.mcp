# Build stage
FROM golang:1.22-alpine AS builder

RUN apk add --no-cache git

WORKDIR /build

COPY go.mod go.sum* ./
COPY cmd ./cmd
COPY internal ./internal
COPY api ./api
COPY pkg ./pkg

RUN CGO_ENABLED=0 GOOS=linux go build -o mcp ./cmd/mcp

# Runtime stage
FROM alpine:3.19

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=builder /build/mcp .

CMD ["./mcp"]
