---
import { formatTimestamp } from '../lib/format.ts';
import type { ChainStatus } from '../lib/types.ts';

interface Props {
  chain: ChainStatus;
}

const { chain } = Astro.props;
const verified = chain.verified;
const ts = formatTimestamp(chain.last_verified_ts);

const stateClass = verified
  ? 'border-risk-low/40 bg-risk-low/10 text-risk-low'
  : 'border-risk-high/40 bg-risk-high/10 text-risk-high';

const statusLabel = verified ? 'Chain verified' : 'Chain broken';
const dotClass = verified ? 'bg-risk-low' : 'bg-risk-high';
---

<div
  role="status"
  aria-live="polite"
  class:list={[
    'flex flex-col gap-2 rounded-2xl border p-4 sm:flex-row sm:items-center sm:justify-between',
    stateClass,
  ]}
>
  <div class="flex items-center gap-2">
    <span
      aria-hidden="true"
      class:list={['inline-block h-2 w-2 rounded-full', dotClass]}
    ></span>
    <p class="text-sm font-medium">
      {statusLabel}
    </p>
  </div>
  <dl class="grid grid-cols-2 gap-x-4 gap-y-1 text-xs text-ink-500 dark:text-ink-400 sm:text-right">
    <dt class="font-medium">Last verified</dt>
    <dd class="tabular-nums">{ts}</dd>
    <dt class="font-medium">Head hash</dt>
    <dd class="truncate font-mono">{chain.head_hash}</dd>
    {!verified && chain.broken_at_index !== undefined && (
      <>
        <dt class="font-medium">Broken at index</dt>
        <dd class="tabular-nums">{chain.broken_at_index}</dd>
      </>
    )}
  </dl>
</div>
