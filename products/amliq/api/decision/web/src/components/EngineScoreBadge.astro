---
import { scoreColor } from '../lib/format.ts';

interface Props {
  score: number;
  label?: string;
}

const { score, label } = Astro.props;
const tier = scoreColor(score);
const rounded = Math.round(score);
const display = `${rounded}/100`;
const aria = label ? `${label}: ${display}` : `Risk score ${display}`;

const tierClasses = {
  low: 'bg-risk-low/15 text-risk-low border-risk-low/40',
  medium: 'bg-risk-medium/15 text-risk-medium border-risk-medium/40',
  high: 'bg-risk-high/15 text-risk-high border-risk-high/40',
} as const;
---

<span
  class:list={[
    'inline-flex items-center gap-1 rounded-full border px-2 py-0.5',
    'text-[11px] font-medium tabular-nums tracking-tightish',
    tierClasses[tier],
  ]}
  aria-label={aria}
>
  <span aria-hidden="true" class="font-semibold uppercase">
    {tier}
  </span>
  <span class="text-ink-700 dark:text-ink-50/80">{display}</span>
</span>
