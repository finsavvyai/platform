{
  "_meta": {
    "description": "Daily Digest samples for all channels",
    "whatsapp_template": {
      "friendly_name": "amliq_daily_digest",
      "category": "Utility",
      "body": "📊 AMLIQ Daily Summary — {{1}}\n\nScreenings run: {{2}}\nAlerts created: {{3}}\nHigh-risk matches: {{4}}\nOpen cases: {{5}}\nSLA breaches: {{6}}\n\nDashboard: {{7}}",
      "variables_order": ["date", "screenings_count", "alerts_count", "high_risk_count", "open_cases", "sla_breaches", "dashboard_url"]
    }
  },

  "quiet_day": {
    "description": "Low activity (weekend / small tenant)",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "whatsapp",
      "to": "+972501234567",
      "content_sid": "HX_DAILY_DIGEST_SID",
      "variables": {
        "1": "Apr 13, 2026",
        "2": "87",
        "3": "2",
        "4": "0",
        "5": "5",
        "6": "0",
        "7": "https://app.amliq.finance/dashboard"
      }
    }
  },

  "normal_day": {
    "description": "Typical business day",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "whatsapp",
      "to": "+972501234567",
      "content_sid": "HX_DAILY_DIGEST_SID",
      "variables": {
        "1": "Apr 14, 2026",
        "2": "1247",
        "3": "47",
        "4": "3",
        "5": "12",
        "6": "0",
        "7": "https://app.amliq.finance/dashboard"
      }
    }
  },

  "busy_day": {
    "description": "High-volume day with issues requiring attention",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "whatsapp",
      "to": "+972501234567",
      "content_sid": "HX_DAILY_DIGEST_SID",
      "variables": {
        "1": "Apr 14, 2026",
        "2": "8,423",
        "3": "182",
        "4": "17",
        "5": "34",
        "6": "3",
        "7": "https://app.amliq.finance/dashboard"
      }
    }
  },

  "email_version_template": {
    "description": "Daily digest via email using built-in template",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "email",
      "to": "compliance-team@yourbank.com",
      "template": "daily_digest",
      "vars": {
        "tenant_name": "Acme Bank",
        "timestamp": "2026-04-14T18:00:00Z",
        "notes": "Screenings run today: 1,247\nAlerts created: 47\nHigh-risk matches: 3\nOpen cases: 12\nSLA breaches: 0\n\nTop matched lists:\n  1. OFAC SDN (18)\n  2. UN Consolidated (12)\n  3. EU Sanctions (9)",
        "dashboard_url": "https://app.amliq.finance/dashboard"
      }
    }
  },

  "email_raw_html": {
    "description": "Full-HTML daily digest email",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "email",
      "to": "compliance-team@yourbank.com",
      "subject": "AMLIQ Daily Summary — Apr 14, 2026",
      "body": "<div style='font-family:Inter,system-ui,sans-serif;max-width:560px;padding:24px'><h2 style='color:#0f172a;margin:0 0 20px'>📊 Daily Summary</h2><table style='width:100%;border-collapse:collapse'><tr><td style='padding:10px 0;color:#475569'>Screenings run</td><td style='padding:10px 0;text-align:right;font-weight:600;color:#0f172a'>1,247</td></tr><tr><td style='padding:10px 0;color:#475569'>Alerts created</td><td style='padding:10px 0;text-align:right;font-weight:600;color:#0f172a'>47</td></tr><tr><td style='padding:10px 0;color:#475569'>High-risk matches</td><td style='padding:10px 0;text-align:right;font-weight:600;color:#dc2626'>3</td></tr><tr><td style='padding:10px 0;color:#475569'>Open cases</td><td style='padding:10px 0;text-align:right;font-weight:600;color:#0f172a'>12</td></tr><tr><td style='padding:10px 0;color:#475569'>SLA breaches</td><td style='padding:10px 0;text-align:right;font-weight:600;color:#059669'>0</td></tr></table><a href='https://app.amliq.finance/dashboard' style='display:inline-block;margin-top:24px;padding:12px 24px;background:#2563eb;color:#fff;text-decoration:none;border-radius:8px;font-weight:600'>View Dashboard</a></div>"
    }
  },

  "sms_version": {
    "description": "Daily digest via SMS (compact)",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "sms",
      "to": "+972501234567",
      "body": "AMLIQ Apr 14: 1247 screenings, 47 alerts, 3 high-risk, 12 open cases. https://app.amliq.finance/dashboard"
    }
  }
}
