{
  "email_raw": {
    "description": "Simple email with custom body",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "email",
      "to": "compliance@yourbank.com",
      "subject": "High-Risk Sanctions Match",
      "body": "<h2>Alert</h2><p>A high-confidence OFAC match was detected for <b>Hassan Ali Mohammad</b>.</p><p>Confidence: 94%</p><p><a href='https://app.amliq.finance/alerts/alrt_abc123'>Review</a></p>"
    }
  },

  "email_template": {
    "description": "Email rendered from built-in template",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "email",
      "to": "compliance@yourbank.com",
      "template": "high_risk_email",
      "vars": {
        "severity": "critical",
        "entity_name": "Hassan Ali Mohammad",
        "entity_type": "individual",
        "entity_country": "SY",
        "score": 0.94,
        "list_source": "OFAC SDN",
        "list_count": 3,
        "match_reason": "Exact + phonetic match",
        "alert_id": "alrt_abc123",
        "dashboard_url": "https://app.amliq.finance/alerts/alrt_abc123",
        "tenant_name": "Acme Bank"
      }
    }
  },

  "sms_raw": {
    "description": "Simple SMS alert",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "sms",
      "to": "+972501234567",
      "body": "AMLIQ: High-risk match — Hassan Ali Mohammad (94% on OFAC SDN). Review: https://app.amliq.finance/alerts/alrt_abc123"
    }
  },

  "sms_template": {
    "description": "SMS rendered from template",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "sms",
      "to": "+972501234567",
      "template": "high_risk_sms",
      "vars": {
        "entity_name": "Ivan Petrov",
        "score": 0.87,
        "list_source": "EU Consolidated",
        "dashboard_url": "https://app.amliq.finance/alerts/alrt_xyz"
      }
    }
  },

  "whatsapp_freeform": {
    "description": "WhatsApp freeform (sandbox or within 24h window)",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "whatsapp",
      "to": "+972501234567",
      "body": "🔴 AMLIQ: High-risk match\n\nEntity: Hassan Ali Mohammad\nList: OFAC SDN\nConfidence: 94%"
    }
  },

  "whatsapp_template_high_risk": {
    "description": "Production WhatsApp via pre-approved Content Template",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "whatsapp",
      "to": "+972501234567",
      "content_sid": "HXREPLACE_WITH_APPROVED_SID",
      "variables": {
        "1": "Hassan Ali Mohammad",
        "2": "OFAC SDN",
        "3": "94%",
        "4": "Exact + phonetic match",
        "5": "https://app.amliq.finance/alerts/alrt_abc123"
      }
    }
  },

  "whatsapp_template_case_escalated": {
    "description": "Case escalation via WhatsApp template",
    "endpoint": "POST /api/v1/alerts/send",
    "body": {
      "channel": "whatsapp",
      "to": "+972501234567",
      "content_sid": "HXREPLACE_WITH_APPROVED_SID",
      "variables": {
        "1": "CASE-1234",
        "2": "Acme Corp",
        "3": "Sarah K.",
        "4": "https://app.amliq.finance/cases/CASE-1234"
      }
    }
  }
