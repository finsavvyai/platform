{
  "send_sms": {
    "description": "Send OTP via SMS",
    "endpoint": "POST /api/v1/verify/send",
    "body": {
      "to": "+972501234567",
      "channel": "sms"
    }
  },

  "send_whatsapp": {
    "description": "Send OTP via WhatsApp",
    "endpoint": "POST /api/v1/verify/send",
    "body": {
      "to": "+972501234567",
      "channel": "whatsapp"
    }
  },

  "send_email": {
    "description": "Send OTP via email",
    "endpoint": "POST /api/v1/verify/send",
    "body": {
      "to": "user@example.com",
      "channel": "email"
    }
  },

  "send_call": {
    "description": "Send OTP via voice call",
    "endpoint": "POST /api/v1/verify/send",
    "body": {
      "to": "+972501234567",
      "channel": "call"
    }
  },

  "check_code": {
    "description": "Verify submitted code",
    "endpoint": "POST /api/v1/verify/check",
    "body": {
      "to": "+972501234567",
      "code": "123456"
    }
  }
}
