go 1.26

// Note: engines/quantumbeam and engines/ml-fraud both declare
// `module quantumbeam` in their go.mod files. Go workspaces forbid
// duplicate module paths, so only engines/quantumbeam is listed here.
// engines/ml-fraud still builds standalone via its own go.mod; a future
// consolidation PR will rename one of them to remove the collision.
//
// engines/quantumbeam/services/monitoring is a nested orphan module
// (its cmd/ entrypoint was removed) and has stale go.sum checksums;
// excluded from the workspace until it is either revived or deleted.

use (
	./api
	./api/runlocal
	./engines/quantumbeam
	./internal/shared/sdk/go
	./internal/shared/workers
)
