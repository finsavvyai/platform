{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Luna",
  "scopeName": "source.luna",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#operators" },
    { "include": "#decorators" },
    { "include": "#variables" },
    { "include": "#numbers" },
    { "include": "#control-keywords" },
    { "include": "#pipe-keywords" },
    { "include": "#repeat-operator" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.luna",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.luna",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.luna",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.luna",
          "match": ">>|\\?>>|!>>"
        },
        {
          "name": "keyword.operator.tilde.luna",
          "match": "~~"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "entity.name.function.decorator.luna",
          "match": "@(before|after|each):"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.luna",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.luna",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "repeat-operator": {
      "patterns": [
        {
          "name": "constant.numeric.repeat.luna",
          "match": "\\*\\d+"
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.luna",
          "match": "\\b(if|else|try|catch|finally|match|assert|approve|def|run|import|with|in|map|reduce|watch|on|timeout|retry|snapshot|diff|log)\\b"
        }
      ]
    },
    "pipe-keywords": {
      "patterns": [
        {
          "name": "keyword.other.pipe.luna",
          "match": "\\b(req|des|plan|go|rev|test|ship|watch|retro|feature|fix|debug|refactor|pr|rules|perf|a11y|deps|mock|auth|brand|docs|sec|nexa|search|vision|hig|ui|dock|cf|env|rollback|ci|changelog|migrate|storybook|i18n|lam|oh|chain|q|cfg|parallel)\\b"
        }
      ]
    }
  }
}
