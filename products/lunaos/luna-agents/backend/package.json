{
  "name": "luna-rag-backend",
  "version": "1.0.0",
  "description": "Luna RAG Backend - Cloudflare Workers deployment",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "db:migrate": "wrangler d1 migrations apply luna-rag-db",
    "db:local": "wrangler d1 migrations apply luna-rag-db --local",
    "secret:put": "wrangler secret put",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --testMatch='**/*.test.js'",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "~0.1.0",
    "@sendgrid/mail": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.6",
    "vitest": "^1.6.0",
    "wrangler": "^3.60.3"
  },
  "keywords": [
    "luna-rag",
    "cloudflare-workers",
    "serverless",
    "api",
    "search",
    "ai"
  ],
  "author": "Luna OS",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
