{
    "name": "lunaos-vscode",
    "displayName": "LunaOS Agents",
    "description": "Run LunaOS AI coding agents directly from VS Code",
    "version": "0.1.0",
    "publisher": "lunaos-ai",
    "engines": {
        "vscode": "^1.109.0"
    },
    "categories": [
        "AI",
        "Programming Languages",
        "Productivity"
    ],
    "activationEvents": [
        "onCommand:luna.runAgent"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "luna.runAgent",
                "title": "Luna: Run Agent"
            },
            {
                "command": "luna.runCodeReview",
                "title": "Luna: Run Code Review"
            }
        ],
        "keybindings": [
            {
                "command": "luna.runAgent",
                "key": "ctrl+shift+l",
                "mac": "cmd+shift+l"
            },
            {
                "command": "luna.runCodeReview",
                "key": "ctrl+shift+r",
                "mac": "cmd+shift+r",
                "when": "editorTextFocus"
            }
        ],
        "configuration": {
            "title": "LunaOS Agents",
            "properties": {
                "lunaos.cliPath": {
                    "type": "string",
                    "default": "luna",
                    "description": "Path to the Luna CLI executable"
                },
                "lunaos.defaultProvider": {
                    "type": "string",
                    "enum": ["anthropic", "openai", "deepseek"],
                    "default": "anthropic",
                    "description": "Default LLM provider for agent execution"
                },
                "lunaos.defaultModel": {
                    "type": "string",
                    "default": "",
                    "description": "Default model (leave empty to use provider default)"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.6",
        "@types/node": "^20.19.33",
        "@types/vscode": "^1.109.0",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "@vscode/test-electron": "^2.3.8",
        "eslint": "^8.56.0",
        "mocha": "^10.2.0",
        "ts-loader": "^9.5.1",
        "typescript": "^5.3.3",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "glob": "^10.3.10"
    }
}