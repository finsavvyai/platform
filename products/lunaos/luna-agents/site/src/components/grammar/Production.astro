---
interface Props { name: string; rule: string; note?: string; }
const { name, rule, note } = Astro.props;
---

<div class="prod" id={`p-${name}`}>
  <div class="row">
    <span class="lhs">&lt;{name}&gt;</span>
    <span class="arrow" aria-hidden="true">::=</span>
    <code class="rhs">{rule}</code>
  </div>
  {note && <p class="note"><small>{note}</small></p>}
</div>

<style>
  .prod {
    padding: var(--t-2) 0;
    border-bottom: 1px dotted var(--rule);
  }
  .row {
    display: grid;
    grid-template-columns: minmax(140px, max-content) auto 1fr;
    gap: 1ch;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    overflow-x: auto;
  }
  .lhs { color: var(--saffron-deep); font-weight: 500; }
  .arrow { color: var(--muted); }
  .rhs {
    color: var(--ink);
    white-space: pre-wrap;
    word-break: break-word;
    background: none;
    border: 0;
    padding: 0;
  }
  .note {
    margin: var(--t-1) 0 0 calc(140px + 1ch);
    color: var(--muted);
    max-width: var(--measure);
  }
  @media (max-width: 700px) {
    .row { grid-template-columns: 1fr; }
    .note { margin-left: 0; }
  }
</style>
