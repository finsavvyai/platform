---
import PipeBlock from "../PipeBlock.astro";

interface Props {
  glyph: string;
  name: string;
  arity: string;
  semantics: string;
  example: string;
  output: string[];
}
const { glyph, name, arity, semantics, example, output } = Astro.props;
const slug = name.toLowerCase().replace(/\s+/g, "-");
---

<article class="op-entry" id={`op-${slug}`}>
  <header class="op-head">
    <span class="op-glyph" aria-hidden="true">{glyph}</span>
    <div class="op-meta">
      <h3 class="op-name">{name}</h3>
      <p class="op-arity"><small>{arity}</small></p>
    </div>
  </header>
  <p class="op-sem">{semantics}</p>
  <PipeBlock code={example} output={output} />
</article>

<style>
  .op-entry {
    padding: var(--t-6) 0;
    border-bottom: 1px solid var(--rule);
    scroll-margin-top: 2rem;
  }
  .op-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--t-3);
    align-items: baseline;
    margin-bottom: var(--t-2);
  }
  .op-glyph {
    font-family: var(--font-mono);
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
    color: var(--saffron-deep);
    font-weight: 500;
    letter-spacing: -0.06em;
  }
  .op-meta { display: flex; flex-direction: column; gap: var(--t-1); }
  .op-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-3);
    margin: 0;
  }
  .op-arity { margin: 0; color: var(--muted); font-family: var(--font-mono); }
  .op-sem { max-width: var(--measure); }
</style>
