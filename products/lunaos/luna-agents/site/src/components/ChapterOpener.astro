---
interface Props {
  /** chapter number, padded, "01", "02" */
  num: string;
  /** display word */
  word: string;
  /** short subtitle, optional */
  subtitle?: string;
  /** an example pipe expression rendered below, mono */
  example?: string;
}
const { num, word, subtitle, example } = Astro.props;
---

<section class="opener" aria-label={`Chapter ${num}, ${word}`}>
  <div class="bleed">
    <div class="grid">
      <span class="num" aria-hidden="true">Ch.&nbsp;{num}</span>
      <h1 class="word">{word}</h1>
      {subtitle && <p class="sub">{subtitle}</p>}
      {example && (
        <pre class="ex"><code>{example}</code></pre>
      )}
    </div>
  </div>
</section>

<style>
  .opener {
    margin: var(--t-12) 0 var(--t-8);
  }
  .bleed {
    background: var(--saffron);
    color: var(--saffron-on);
    padding: clamp(2rem, 8vw, 6rem) clamp(1rem, 4vw, 3rem);
    border-top: 1px solid var(--saffron-deep);
    border-bottom: 1px solid var(--saffron-deep);
  }
  .grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--t-3);
  }
  .num {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--saffron-on);
    opacity: 0.75;
  }
  .word {
    font-size: clamp(4rem, 14vw, 12rem);
    line-height: 0.9;
    margin: 0;
    color: var(--saffron-on);
  }
  .sub {
    font-family: var(--font-body);
    font-size: var(--step-2);
    max-width: var(--measure);
    margin: var(--t-2) 0 0;
    color: var(--saffron-on);
  }
  .ex {
    margin-top: var(--t-3);
    font-family: var(--font-mono);
    font-size: var(--step-0);
    color: var(--saffron-on);
    background: none;
    padding: 0;
    overflow-x: auto;
    max-width: 100%;
  }
  .ex code { color: inherit; }
</style>
