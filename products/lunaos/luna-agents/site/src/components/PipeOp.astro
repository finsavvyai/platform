---
interface Props {
  /** glyph variant: pipe (>>), repeat (*), parallel (||), conditional (?), sink (!) */
  kind?: "pipe" | "repeat" | "parallel" | "conditional" | "sink";
}
const { kind = "pipe" } = Astro.props;
const glyph = {
  pipe: ">>",
  repeat: "*",
  parallel: "||",
  conditional: "?",
  sink: "!",
}[kind];
const label = {
  pipe: "pipe to",
  repeat: "repeat",
  parallel: "in parallel with",
  conditional: "if truthy then",
  sink: "discard output",
}[kind];
---

<span class={`op op-${kind}`} role="img" aria-label={label}>{glyph}</span>

<style>
  .op {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--saffron-deep);
    letter-spacing: -0.05em;
    padding: 0 0.15ch;
  }
  .op-pipe { color: var(--saffron-deep); }
  .op-repeat { color: var(--saffron-deep); }
  .op-parallel { color: var(--saffron-deep); }
  .op-conditional { color: var(--saffron-deep); }
  .op-sink { color: var(--saffron-deep); }
</style>
