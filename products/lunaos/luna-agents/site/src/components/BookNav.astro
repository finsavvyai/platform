---
interface Props {
  chapter?: string;
}
const { chapter } = Astro.props;

const entries = [
  { href: "/", label: "Frontispiece", id: "frontispiece" },
  { href: "/lexicon", label: "Lexicon", id: "lexicon" },
  { href: "/grammar", label: "Grammar", id: "grammar" },
  { href: "/etymology", label: "Etymology", id: "etymology" },
  { href: "/install", label: "Install", id: "install" },
  { href: "/play", label: "Playground", id: "play" },
  { href: "/manifesto", label: "Manifesto", id: "manifesto" },
];
const current = chapter ?? "frontispiece";
---

<header class="bn">
  <div class="wrap row">
    <a class="brand" href="/" aria-label="Luna Pipes, home">
      <span class="brand-mark">L<span class="op">»</span></span>
      <span class="brand-word">Luna Pipes</span>
    </a>
    <nav aria-label="Chapters">
      <ol class="chapters">
        {entries.map((e, i) => (
          <li>
            <span class="num" aria-hidden="true">{String(i).padStart(2, "0")}</span>
            <a href={e.href} aria-current={current === e.id ? "page" : undefined}>{e.label}</a>
          </li>
        ))}
      </ol>
    </nav>
  </div>
  <hr />
</header>

<style>
  .bn { padding-top: var(--t-3); }
  .bn hr { margin: var(--t-3) 0 0; }
  .row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--t-4);
    flex-wrap: wrap;
  }
  .brand {
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5ch;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    font-family: var(--font-mono);
    font-style: normal;
    font-weight: 500;
    font-size: 0.85em;
    letter-spacing: -0.06em;
  }
  .brand-mark .op { color: var(--saffron-deep); }
  .chapters {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--t-3);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .chapters li { display: inline-flex; gap: 0.75ch; align-items: baseline; margin: 0; }
  .num { color: var(--muted); }
  .chapters a {
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    padding-bottom: 2px;
    transition: border-color 240ms var(--ease), color 240ms var(--ease);
  }
  .chapters a:hover { border-bottom-color: var(--ink); }
  .chapters a[aria-current="page"] {
    color: var(--saffron-deep);
    border-bottom-color: var(--saffron-deep);
  }
</style>
