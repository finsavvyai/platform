---
interface Props {
  /** the pipe expression, e.g. `/persona generate >> ghost blog "topic" >> publish notion` */
  code: string;
  /** simulated output lines, shown in the terminal half */
  output?: string[];
  /** caption shown above the block, italic */
  caption?: string;
  /** auto-type the code on view (respects reduced motion) */
  typeIn?: boolean;
}
const { code, output = [], caption, typeIn = false } = Astro.props;

// Tokenize for highlighting: pipe operators (>>, *, ||, ?), strings ("..."), commands (/word, word), flags (--word).
function tokenize(src: string) {
  const tokens: { t: string; v: string }[] = [];
  const re = /(\/[a-z0-9-]+)|("(?:[^"\\]|\\.)*")|(>>|\|\||\*|\?)|(--[a-z0-9-]+)|(\s+)|([^\s]+)/gi;
  for (const m of src.matchAll(re)) {
    if (m[1]) tokens.push({ t: "cmd", v: m[1] });
    else if (m[2]) tokens.push({ t: "str", v: m[2] });
    else if (m[3]) tokens.push({ t: "op", v: m[3] });
    else if (m[4]) tokens.push({ t: "flag", v: m[4] });
    else if (m[5]) tokens.push({ t: "ws", v: m[5] });
    else if (m[6]) tokens.push({ t: "id", v: m[6] });
  }
  return tokens;
}
const tokens = tokenize(code);
const id = `pb-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class="pb" data-pb data-typein={typeIn ? "1" : "0"} aria-labelledby={`${id}-cap`}>
  {caption && <figcaption id={`${id}-cap`} class="cap">{caption}</figcaption>}
  <div class="src">
    <span class="prompt" aria-hidden="true">$</span>
    <code class="line">
      {tokens.map(({ t, v }) => (
        <span class={`tok tok-${t}`}>{v}</span>
      ))}
    </code>
  </div>
  {output.length > 0 && (
    <div class="out" role="log" aria-live="polite">
      {output.map((line) => (
        <div class="oline">{line}</div>
      ))}
    </div>
  )}
</figure>

<style>
  .pb {
    margin: var(--t-4) 0;
    border: 1px solid var(--term-rule);
    background: var(--term-bg);
    color: var(--term-fg);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    border-radius: 2px;
    overflow: hidden;
  }
  .cap {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-0);
    color: var(--term-dim);
    padding: var(--t-2) var(--t-3) 0;
  }
  .src {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75ch;
    padding: var(--t-2) var(--t-3);
    overflow-x: auto;
  }
  .prompt {
    color: var(--saffron);
    user-select: none;
    font-weight: 500;
  }
  .line { color: var(--term-fg); white-space: pre; line-height: 1.6; }
  .tok-cmd { color: oklch(0.92 0.06 220); }
  .tok-str { color: oklch(0.88 0.12 90); }
  .tok-op { color: var(--term-pipe); font-weight: 600; letter-spacing: -0.05em; padding: 0 0.1ch; }
  .tok-flag { color: var(--term-dim); }
  .tok-id { color: var(--term-fg); }
  .tok-ws { white-space: pre; }
  .out {
    border-top: 1px dashed var(--term-rule);
    padding: var(--t-2) var(--t-3);
    color: var(--term-dim);
    line-height: 1.6;
    white-space: pre-wrap;
    overflow-x: auto;
  }
  .oline:first-child { color: var(--term-fg); }
</style>

<script>
  // Cursor-blink + optional type-in for the first pipe block in view.
  const blocks = document.querySelectorAll<HTMLElement>("[data-pb][data-typein='1']");
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduced) {
    for (const block of blocks) {
      const line = block.querySelector<HTMLElement>(".line");
      if (!line) continue;
      const tokens = Array.from(line.querySelectorAll<HTMLElement>(".tok"));
      const orig = tokens.map((t) => t.textContent ?? "");
      tokens.forEach((t) => (t.textContent = ""));
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          io.disconnect();
          let i = 0; let j = 0;
          const step = () => {
            if (i >= tokens.length) return;
            if (j > orig[i].length) { i++; j = 0; step(); return; }
            tokens[i].textContent = orig[i].slice(0, j);
            j++;
            setTimeout(step, 28);
          };
          step();
        }
      }, { threshold: 0.4 });
      io.observe(block);
    }
  }
</script>
