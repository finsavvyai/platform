---
// Client-side filter for the lexicon. Progressive enhancement:
// without JS, the form is a real GET (?q=) so anchors and screen readers
// still work; with JS, results filter live as you type.
---

<form class="lf wrap" role="search" action="" method="get">
  <label class="lf-label" for="lf-q">
    <span class="lf-label-text">Find a word</span>
  </label>
  <input
    id="lf-q"
    name="q"
    type="search"
    placeholder="type any verb or part of a definition"
    autocomplete="off"
    spellcheck="false"
    aria-describedby="lf-count"
  />
  <output id="lf-count" class="lf-count" aria-live="polite"></output>
  <button type="reset" class="lf-clear" aria-label="Clear filter">clear</button>
</form>

<style>
  .lf {
    padding-top: var(--t-3);
    padding-bottom: var(--t-3);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--t-6);
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: var(--t-3);
    align-items: baseline;
  }
  .lf-label-text {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--muted);
    font-size: var(--step-0);
  }
  #lf-q {
    background: none;
    border: 0;
    border-bottom: 1px solid var(--rule);
    padding: 0.4rem 0;
    font-family: var(--font-mono);
    font-size: var(--step-0);
    color: var(--ink);
    width: 100%;
  }
  #lf-q:focus { outline: 0; border-bottom-color: var(--saffron-deep); }
  .lf-count {
    font-family: var(--font-mono);
    color: var(--saffron-deep);
    font-size: var(--step--1);
    font-feature-settings: "tnum";
    min-width: 8ch;
    text-align: right;
  }
  .lf-clear {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--muted);
    padding: 0.25rem 0.7rem;
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    cursor: pointer;
  }
  .lf-clear:hover { border-color: var(--ink); color: var(--ink); }
  @media (max-width: 700px) {
    .lf { grid-template-columns: 1fr; }
    .lf-count { text-align: left; }
  }

  /* Filter visibility: managed by JS via [data-lf-hidden] on entries + cats.
     `:global()` is required because the entries + categories are rendered by
     other components (different astro CIDs), so a scoped selector would never
     match them. */
  :global([data-lf-hidden="1"]) { display: none !important; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".lf");
  const inputEl = document.getElementById("lf-q") as HTMLInputElement | null;
  const countEl = document.getElementById("lf-count") as HTMLOutputElement | null;
  if (form && inputEl && countEl) {
    const input: HTMLInputElement = inputEl;
    const countOut: HTMLOutputElement = countEl;
    const entries = Array.from(document.querySelectorAll<HTMLElement>(".entry"));
    const cats = Array.from(document.querySelectorAll<HTMLElement>(".cat"));
    const total = entries.length;

    const index = entries.map((el) => ({
      el,
      hay: (el.textContent ?? "").toLowerCase(),
    }));

    function apply(q: string): void {
      const needle = q.trim().toLowerCase();
      let visible = 0;
      for (const { el, hay } of index) {
        const hit = !needle || hay.includes(needle);
        el.dataset.lfHidden = hit ? "" : "1";
        if (hit) visible++;
      }
      for (const cat of cats) {
        const any = cat.querySelector('.entry:not([data-lf-hidden="1"])');
        cat.dataset.lfHidden = any ? "" : "1";
      }
      countOut.textContent = needle
        ? `${visible} / ${total}`
        : `${total} entries`;
    }

    const params = new URLSearchParams(window.location.search);
    const initial = params.get("q") ?? "";
    if (initial) input.value = initial;
    apply(initial);

    input.addEventListener("input", () => apply(input.value));
    form.addEventListener("reset", () => {
      requestAnimationFrame(() => apply(""));
    });
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      apply(input.value);
    });
  }
</script>
