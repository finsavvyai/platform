---
import data from "../../data/skills.json";

const topCats = Object.entries(data.byCategory)
  .filter(([cat]) => cat !== "shortcut")
  .sort((a, b) => b[1].length - a[1].length)
  .slice(0, 10);
const skillCount = data.count;
---

<section class="lexicon-teaser wrap">
  <h2>The standard library is {skillCount} words long.</h2>
  <p>
    Skills are the language's vocabulary. Each one is a callable verb with
    a strict signature, an etymology, and example sentences. You install
    one binary; you inherit the whole lexicon.
  </p>
  <ul class="cat-list">
    {topCats.map(([cat, list]) => (
      <li>
        <a href={`/lexicon#cat-${cat}`}>
          <span class="cat-name">{cat}</span>
          <span class="cat-count">{list.length}</span>
        </a>
      </li>
    ))}
  </ul>
  <p>
    <a href="/lexicon" class="more">Read the full lexicon →</a>
  </p>
</section>

<style>
  .lexicon-teaser { padding-top: var(--t-8); padding-bottom: var(--t-12); }
  .cat-list {
    list-style: none;
    padding: 0;
    margin: var(--t-4) 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule);
    max-width: var(--measure-wide);
  }
  .cat-list li { border-bottom: 1px solid var(--rule); margin: 0; }
  .cat-list a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: var(--t-2) var(--t-3) var(--t-2) 0;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .cat-list a:hover { background: var(--paper-deep); }
  .cat-name { letter-spacing: -0.01em; }
  .cat-count { color: var(--saffron-deep); font-feature-settings: "tnum"; }
  .more {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-1);
    color: var(--saffron-deep);
    text-decoration-color: currentColor;
  }
</style>
