---
import PipeBlock from "../PipeBlock.astro";

interface Props { skillCount: number; categoryCount: number; }
const { skillCount, categoryCount } = Astro.props;
---

<section class="frontispiece wrap">
  <div class="title-block">
    <p class="edition">First Edition · {new Date().getFullYear()}</p>
    <h1 class="title"><span>Luna</span><span class="amp"> </span><em>Pipes</em></h1>
    <p class="subtitle">
      A programmable shell for AI work. Compose engineering, security,
      content, and deployment workflows the way Unix composed software, one
      skill, one pipe at a time.
    </p>
    <p class="strapline">
      The pipe operator <code>&gt;&gt;</code> is the grammar. Skills are the
      lexicon. You compose; the runtime executes.
    </p>
    <dl class="masthead-meta">
      <div><dt>Lexicon</dt><dd>{skillCount} entries</dd></div>
      <div><dt>Categories</dt><dd>{categoryCount}</dd></div>
      <div><dt>Runtime</dt><dd>Node ≥ 18, Claude Code</dd></div>
      <div><dt>License</dt><dd>MIT</dd></div>
    </dl>
  </div>

  <PipeBlock
    caption="Hello, world."
    typeIn={true}
    code={'/persona generate >> ghost "launch post" >> publish notion'}
    output={[
      'parsed: 3 stages',
      '  [01] /persona generate     → drafts 4 personas from your codebase',
      '  [02] ghost "launch post"   → writes long-form post per persona',
      '  [03] publish notion        → posts to your workspace',
      'ok. composed in 14ms.',
    ]}
  />
</section>

<style>
  .frontispiece { padding-top: var(--t-12); padding-bottom: var(--t-12); }
  .title-block { margin-bottom: var(--t-8); }
  .edition {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin: 0 0 var(--t-3);
  }
  .title { font-size: var(--step-5); line-height: 0.88; letter-spacing: -0.03em; margin: 0; }
  .title em { color: var(--saffron-deep); font-style: italic; }
  .title .amp { display: inline-block; width: 0.2em; }
  .subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-3);
    line-height: 1.2;
    margin: var(--t-4) 0 var(--t-6);
    max-width: var(--measure-wide);
  }
  .subtitle code {
    font-family: var(--font-mono);
    font-style: normal;
    color: var(--saffron-deep);
    font-size: 0.85em;
    padding: 0 0.2ch;
  }
  .strapline {
    margin: 0 0 var(--t-4);
    max-width: var(--measure-wide);
    color: var(--muted);
    font-size: var(--step-0);
  }
  .strapline code {
    font-family: var(--font-mono);
    color: var(--saffron-deep);
  }
  .masthead-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--t-3) var(--t-4);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: var(--t-3) 0;
    margin-top: var(--t-4);
    max-width: 880px;
  }
  .masthead-meta dt {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--muted);
    font-size: var(--step--1);
    margin-bottom: var(--t-1);
  }
  .masthead-meta dd { margin: 0; font-family: var(--font-mono); font-size: var(--step-0); }
</style>
