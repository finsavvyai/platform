---
// Brand-wall: services that Luna Pipes verbs already touch. Editorial,
// mono wordmarks plus a one-line role tag. No corporate SVGs; the typography
// is the logo here.

interface Item { name: string; role: string }

const items: Item[] = [
  { name: "GitHub",       role: "issues, PRs, releases, commits" },
  { name: "Slack",        role: "channels, threads, alerts" },
  { name: "Notion",       role: "pages, databases, indexes" },
  { name: "Cloudflare",   role: "workers, pages, KV, R2, D1" },
  { name: "OpenAI",       role: "gpt, embeddings, vision" },
  { name: "Anthropic",    role: "claude, opus, sonnet, haiku" },
  { name: "Stripe",       role: "payments, subs, dunning" },
  { name: "LemonSqueezy", role: "subscriptions, licenses, refunds" },
  { name: "Linear",       role: "issues, projects, triage" },
  { name: "Postgres",     role: "queries, migrations, audit" },
  { name: "Docker",       role: "images, builds, manifests" },
  { name: "Figma",        role: "files, frames, design tokens" },
];
---

<section class="ir wrap">
  <header class="ir-head">
    <span class="ir-num" aria-hidden="true">§</span>
    <h2 class="ir-title">Skills already touch these.</h2>
  </header>
  <p class="ir-lede">
    Many of the lexicon entries call one of the services below. Each is
    accessed through a verb in the lexicon, not a bespoke integration page.
    The runtime carries credentials; the pipe carries intent.
  </p>
  <ul class="ir-grid">
    {items.map((it) => (
      <li>
        <span class="ir-name">{it.name}</span>
        <span class="ir-role">{it.role}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .ir { padding-top: var(--t-8); padding-bottom: var(--t-8); }
  .ir-head {
    display: flex;
    align-items: baseline;
    gap: 1ch;
    border-bottom: 2px solid var(--ink);
    padding-bottom: var(--t-1);
    margin-bottom: var(--t-3);
  }
  .ir-num {
    font-family: var(--font-mono);
    color: var(--saffron-deep);
    font-size: var(--step-2);
  }
  .ir-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-3);
    margin: 0;
  }
  .ir-lede {
    margin: 0 0 var(--t-4);
    max-width: var(--measure);
    color: var(--muted);
  }
  .ir-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule);
  }
  .ir-grid li {
    margin: 0;
    padding: var(--t-2) var(--t-3) var(--t-2) 0;
    border-bottom: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
    display: grid;
    gap: 0.1rem;
  }
  .ir-grid li:nth-child(4n) { border-right: 0; }
  @media (max-width: 760px) { .ir-grid li { border-right: 0; } }
  .ir-name {
    font-family: var(--font-mono);
    font-size: var(--step-1);
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .ir-role {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--muted);
    font-size: var(--step--1);
  }
</style>
