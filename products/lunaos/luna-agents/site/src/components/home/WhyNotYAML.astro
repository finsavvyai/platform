---
const yamlCode = `steps:
  - action: persona_generate
  - action: ghost_post
    params:
      title: "launch post"
    repeat: 4
  - action: publish_notion`;

const pipeCode = `persona generate >> ghost "launch post" * 4 >> publish notion`;

const points: { left: string; right: string }[] = [
  { left: "Three nested levels of YAML to express one chain.",
    right: "One line. Stage order is reading order." },
  { left: "Repeats and fan-outs are configuration fields.",
    right: "Repeats and fan-outs are operators (`*N`, `||`)." },
  { left: "Composition lives outside the executor (CI definitions, orchestrators).",
    right: "Composition is the language. The shell is the executor." },
  { left: "Renaming an action means a global find-and-replace across files.",
    right: "Renaming a verb is a one-line edit; pipes that used it break loudly." },
];
---

<section class="why wrap">
  <header class="why-head">
    <span class="why-num" aria-hidden="true">§</span>
    <h2 class="why-title">Why not YAML.</h2>
  </header>
  <p class="why-lede">
    Most AI workflow tools express composition as configuration. Luna Pipes
    expresses composition as code, the same trick Unix played in 1973. Side
    by side, on the same job, four personas writing a launch post each, then
    posting to Notion.
  </p>

  <div class="why-compare">
    <article class="side">
      <h3 class="side-title">YAML, the usual way.</h3>
      <pre class="side-code"><code>{yamlCode}</code></pre>
    </article>
    <article class="side">
      <h3 class="side-title">Luna Pipes.</h3>
      <pre class="side-code"><code>{pipeCode}</code></pre>
    </article>
  </div>

  <dl class="why-points">
    {points.map((p) => (
      <div class="why-row">
        <dt>{p.left}</dt>
        <dd>{p.right}</dd>
      </div>
    ))}
  </dl>
</section>

<style>
  .why { padding-top: var(--t-12); padding-bottom: var(--t-8); }
  .why-head {
    display: flex;
    align-items: baseline;
    gap: 1ch;
    border-bottom: 2px solid var(--ink);
    padding-bottom: var(--t-1);
    margin-bottom: var(--t-3);
  }
  .why-num {
    font-family: var(--font-mono);
    color: var(--saffron-deep);
    font-size: var(--step-2);
  }
  .why-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-3);
    margin: 0;
  }
  .why-lede { max-width: var(--measure); margin: 0 0 var(--t-6); }
  .why-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--t-4);
    align-items: start;
    margin-bottom: var(--t-6);
  }
  @media (max-width: 760px) { .why-compare { grid-template-columns: 1fr; } }
  .side {
    border-top: 1px solid var(--rule);
    padding-top: var(--t-2);
  }
  .side-title {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--muted);
    font-size: var(--step-0);
    margin: 0 0 var(--t-2);
  }
  .side-code {
    margin: 0;
    background: rgba(0, 0, 0, 0.04);
    padding: var(--t-2) var(--t-3);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    line-height: 1.5;
    overflow-x: auto;
    border-radius: 2px;
    white-space: pre;
  }
  .side-code code { background: none; border: 0; padding: 0; font-family: inherit; }

  .why-points {
    margin: 0;
    border-top: 1px solid var(--rule);
  }
  .why-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--t-4);
    padding: var(--t-3) 0;
    border-bottom: 1px solid var(--rule);
  }
  @media (max-width: 760px) { .why-row { grid-template-columns: 1fr; gap: var(--t-1); } }
  .why-row dt {
    margin: 0;
    color: var(--muted);
    font-style: italic;
    font-family: var(--font-display);
  }
  .why-row dd {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
</style>
