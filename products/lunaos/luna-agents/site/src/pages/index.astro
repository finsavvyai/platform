---
import Book from "../layouts/Book.astro";
import Frontispiece from "../components/home/Frontispiece.astro";
import Motivation from "../components/home/Motivation.astro";
import WhyNotYAML from "../components/home/WhyNotYAML.astro";
import IntegrationsRow from "../components/home/IntegrationsRow.astro";
import GrammarTeaser from "../components/home/GrammarTeaser.astro";
import LexiconTeaser from "../components/home/LexiconTeaser.astro";
import InstallTeaser from "../components/home/InstallTeaser.astro";
import data from "../data/skills.json";

const skillCount = data.count;
const categoryCount = Object.keys(data.byCategory).filter((c) => c !== "shortcut").length;
---

<Book title="Frontispiece" chapter="frontispiece">
  <Frontispiece skillCount={skillCount} categoryCount={categoryCount} />
  <Motivation />
  <WhyNotYAML />
  <IntegrationsRow />
  <GrammarTeaser />
  <LexiconTeaser />
  <InstallTeaser />
</Book>
