---
import Book from "../layouts/Book.astro";
import PipeBlock from "../components/PipeBlock.astro";
---

<Book title="Parse error" description="No such page.">
  <section class="wrap notfound">
    <p class="kicker">404</p>
    <h1 class="title">Parse error.</h1>
    <p class="lead">
      That URL is not in the lexicon. The grammar is strict; the parser
      is unforgiving. Try one of the chapters below.
    </p>

    <PipeBlock
      code={Astro.url.pathname.replace(/^\//, "") || "(empty pipe)"}
      output={[
        "error: no such verb",
        "  parser stopped after 0 stages",
        "  did you mean: /lexicon, /grammar, /install ?",
      ]}
    />

    <ul class="links">
      <li><a href="/">Frontispiece</a></li>
      <li><a href="/lexicon">Lexicon</a></li>
      <li><a href="/grammar">Grammar</a></li>
      <li><a href="/install">Install</a></li>
    </ul>
  </section>
</Book>

<style>
  .notfound { padding: var(--t-12) 0 var(--t-16); }
  .kicker {
    font-family: var(--font-mono);
    color: var(--saffron-deep);
    font-size: var(--step-2);
    margin: 0 0 var(--t-2);
  }
  .title {
    font-size: var(--step-5);
    line-height: 0.9;
    margin: 0 0 var(--t-3);
  }
  .lead {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-3);
    max-width: var(--measure-wide);
    margin-bottom: var(--t-6);
  }
  .links {
    list-style: none;
    padding: 0;
    margin: var(--t-4) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--t-3);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .links li { margin: 0; }
</style>
