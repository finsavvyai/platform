---
import Book from "../layouts/Book.astro";
import ChapterOpener from "../components/ChapterOpener.astro";
import PipeBlock from "../components/PipeBlock.astro";

const versions = [
  {
    v: "1.0.0",
    date: "2026",
    title: "First edition",
    body: "Five operators frozen. The lexicon ships at 277 entries. The grammar is closed for v1; only the lexicon grows from here.",
    pipe: 'luna pipe "persona generate >> ghost \\"post\\" >> publish notion"',
  },
  {
    v: "0.9.0",
    date: "2026",
    title: "Sink and conditional",
    body: "Added the sink (!) and conditional (?) operators. Both were originally separate verbs; demoted to grammar after pattern-matching them in user pipelines for two months.",
    pipe: '/persona generate >> ? premium >> longform : short',
  },
  {
    v: "0.7.0",
    date: "2025",
    title: "Fanout",
    body: "The parallel operator (||) joined the language. Previously emulated with shell ampersands; promoted once it became clear the join semantics were a runtime concern, not a user concern.",
    pipe: '/ghost "post" || /imagine "hero" >> publish',
  },
  {
    v: "0.5.0",
    date: "2025",
    title: "Repeat",
    body: "Added the postfix repeat operator (*N). Replaced a Python-style loop construct that nobody used. Concatenative purists nodded.",
    pipe: '/persona generate >> ghost "post" *4',
  },
  {
    v: "0.1.0",
    date: "2025",
    title: "Pipe and stage",
    body: "Two productions: <pipe> ::= <stage> (>> <stage>)*, <stage> ::= <verb> <arg>*. The whole language was 200 lines of parser and a single test fixture. Everything since then is gardening.",
    pipe: '/persona generate >> /ghost "post"',
  },
];
---

<Book title="Etymology" chapter="etymology" description="Version history of the Luna Pipes language.">
  <ChapterOpener
    num="03"
    word="Etymology"
    subtitle="A language's etymology is its changelog. Each version below introduced a piece of grammar that survives in v1."
  />

  <section class="wrap">
    <ol class="timeline">
      {versions.map((r) => (
        <li class="entry">
          <header>
            <span class="version">v{r.v}</span>
            <time class="date">{r.date}</time>
          </header>
          <h3 class="title">{r.title}</h3>
          <p class="body">{r.body}</p>
          <PipeBlock code={r.pipe} />
        </li>
      ))}
    </ol>

    <hr />

    <h2>Influences.</h2>
    <ul class="influences">
      <li>
        <strong>Unix pipes</strong>, McIlroy, Bell Labs, 1973. The original
        good idea: small tools, one operator, the value flows.
      </li>
      <li>
        <strong>Forth</strong>, Moore, 1970. Proved a programming language
        can fit in a postcard if you commit to concatenation.
      </li>
      <li>
        <strong>Joy</strong>, von Thun, 2001. Showed how to take Forth
        seriously as a functional language. Composition over application.
      </li>
      <li>
        <strong>Factor</strong>, Pestov, 2003. The proof that concatenative
        languages can have libraries, tooling, and an IDE.
      </li>
      <li>
        <strong>Make and shell</strong>, every Unix system, forever. The
        dependency graph is implicit; the value flow is explicit; you cannot
        have both at once and Luna Pipes picked value flow.
      </li>
    </ul>
  </section>
</Book>

<style>
  section { padding: var(--t-6) 0 var(--t-12); }
  .timeline {
    list-style: none;
    padding: 0;
    margin: var(--t-4) 0;
    border-left: 1px solid var(--rule);
  }
  .entry {
    margin: 0;
    padding: var(--t-3) var(--t-4) var(--t-4);
    position: relative;
    border-bottom: 1px solid var(--rule);
  }
  .entry::before {
    content: "";
    position: absolute;
    left: -5px;
    top: var(--t-4);
    width: 9px;
    height: 9px;
    background: var(--saffron);
    border-radius: 2px;
  }
  .entry header {
    display: flex;
    gap: 1ch;
    align-items: baseline;
    margin-bottom: var(--t-1);
  }
  .version {
    font-family: var(--font-mono);
    color: var(--saffron-deep);
    font-weight: 500;
  }
  .date {
    font-family: var(--font-mono);
    color: var(--muted);
    font-size: var(--step--1);
  }
  .title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-3);
    margin: 0 0 var(--t-1);
  }
  .body { max-width: var(--measure); }

  .influences {
    list-style: none;
    padding: 0;
    margin: var(--t-3) 0;
    display: grid;
    gap: var(--t-2);
    max-width: var(--measure-wide);
  }
  .influences li {
    margin: 0;
    padding: var(--t-2) 0;
    border-bottom: 1px dotted var(--rule);
  }
  .influences strong {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    color: var(--saffron-deep);
  }
</style>
