{
    "name": "luna-agents-cli",
    "version": "1.0.1",
    "description": "AI agent platform CLI — run 28+ specialized coding agents from your terminal",
    "type": "module",
    "main": "dist/index.cjs",
    "bin": {
        "luna": "dist/index.cjs"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "test": "vitest run",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "luna",
        "lunaos",
        "ai",
        "agents",
        "code-review",
        "testing",
        "deployment",
        "cli",
        "mcp",
        "sdlc"
    ],
    "author": "Shachar Solomon",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/lunaos-ai/luna-agents.git",
        "directory": "cli"
    },
    "homepage": "https://lunaos.ai",
    "bugs": {
        "url": "https://github.com/lunaos-ai/luna-agents/issues"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "dependencies": {
        "chalk": "^5.3.0",
        "commander": "^12.1.0",
        "glob": "^11.0.0",
        "inquirer": "^9.3.7",
        "marked": "^14.1.4",
        "marked-terminal": "^7.2.1",
        "ora": "^8.1.0",
        "playwright-core": "^1.41.2",
        "ws": "^8.21.0",
        "yaml": "^2.5.1"
    },
    "devDependencies": {
        "@types/node": "^22.9.0",
        "@types/ws": "^8.18.1",
        "playwright": "^1.58.2",
        "tsup": "^8.3.5",
        "typescript": "^5.6.3",
        "vitest": "^2.1.5"
    },
    "overrides": {
        "picomatch": "^4.0.4",
        "esbuild": "^0.28.1"
    }
}
