    "type": "workflow",
    "framework": "claude-code",
    "entryPoints": {
      "agents": "../agents",
      "commands": "../commands"
    },
    "configuration": {
      "supportsMultiProject": true,
      "supportsFeatureScoping": true,
      "automaticProjectDetection": true,
      "progressTracking": true
    }
