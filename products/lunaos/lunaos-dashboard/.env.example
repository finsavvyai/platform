# Runtime environment template
# Replace placeholder values before deployment.

APP_ENV=development
LOG_LEVEL=info

# API / service
PORT=3000
API_BASE_URL=http://localhost:3000

# Database / cache
DATABASE_URL=
REDIS_URL=

# Auth / secrets
JWT_SECRET=
API_KEY=

# Analytics (set to "true" to enable event tracking)
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_ENDPOINT=/api/analytics
