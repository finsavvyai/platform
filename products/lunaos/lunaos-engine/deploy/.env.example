# Luna OS Production Environment Variables
# Copy to .env and fill in actual values for deployment

# API Configuration
NODE_ENV=production
PORT=8040
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://luna:password@postgres:5432/luna
POSTGRES_DB=luna
POSTGRES_USER=luna
POSTGRES_PASSWORD=your_secure_password_here

# Redis
REDIS_URL=redis://redis:6379/0

# Authentication & Security
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://your-domain.com,https://app.your-domain.com

# Cloudflare Workers
CLOUDFLARE_API_TOKEN=your_cloudflare_token_here
CF_ACCOUNT_ID=your_cf_account_id
CF_NAMESPACE_ID=your_cf_namespace_id
WRANGLER_TOKEN=your_wrangler_token_here

# LemonSqueezy (Payments)
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_key_here
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Third-party Integrations
OPENAI_API_KEY=sk-your_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GITHUB_TOKEN=ghp_your_token_here

# Email Service
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your_sendgrid_key_here
MAIL_FROM=noreply@luna-os.com

# Monitoring & Analytics
SENTRY_DSN=https://your_sentry_url
POSTHOG_API_KEY=your_posthog_key_here

# Feature Flags
ENABLE_ENTERPRISE_FEATURES=false
ENABLE_CUSTOM_AGENTS=true
MAX_WORKFLOWS=unlimited
MAX_AGENTS=28
