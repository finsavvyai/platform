{
  "name": "@lunaos/engine-api",
  "version": "1.0.0",
  "description": "LunaOS Engine API — Cloudflare Worker for agent execution, auth, and billing",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "db:create": "wrangler d1 create lunaos-engine-db",
    "db:migrate": "wrangler d1 migrations apply lunaos-engine-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply lunaos-engine-db --remote",
    "kv:create": "wrangler kv:namespace create KV",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "@lunaos/rag": "file:../rag",
    "fast-xml-parser": "^4.5.2",
    "hono": "^4.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.90.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "LunaOS",
  "license": "MIT"
}
