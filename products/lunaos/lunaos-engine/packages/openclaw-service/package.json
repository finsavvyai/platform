{
    "name": "@lunaos/openclaw-service",
    "version": "1.0.0",
    "private": true,
    "description": "OpenClaw Backend Service — unified agent execution, tool API, and analytics gateway for LunaOS and OpenHands",
    "scripts": {
        "dev": "wrangler dev --port 8790",
        "deploy": "wrangler deploy",
        "deploy:prod": "wrangler deploy --env production",
        "build": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "hono": "^4.6.14",
        "@hono/zod-validator": "^0.7.6",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241230.0",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8",
        "wrangler": "^4.0.0"
    }
}