{
  "name": "@lunaos/tests-browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cross-surface Playwright test suite for LunaOS (Studio, Dashboard, Marketing, Extension, AI browser agent).",
  "scripts": {
    "test": "playwright test",
    "test:studio": "playwright test --project=studio",
    "test:dashboard": "playwright test --project=dashboard",
    "test:marketing": "playwright test --project=marketing",
    "test:visual": "playwright test --project=visual",
    "test:extension": "playwright test --project=extension",
    "test:ai-agent": "playwright test --project=ai-agent",
    "test:update-snapshots": "playwright test --project=visual --update-snapshots",
    "test:heal": "node scripts/browser-heal.mjs",
    "list": "playwright test --list"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "typescript": "^5.4.0"
  }
}
