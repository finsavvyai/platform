# Exclude TypeScript source files
**/*.ts
**/*.tsx
**/*.map
**/*.d.ts

# Exclude source directories
**/src/**
**/test/**
**/__tests__/**
**/.git/**
**/node_modules/**/*.ts
**/node_modules/**/*.d.ts
**/node_modules/**/src/**
**/node_modules/**/test/**

# Include only built files and essentials
!dist/**
!icon.png
!LICENSE
!package.json

# Exclude test and build artifacts
**/test-results/**
**/*.vsix
**/.vscode-test/**

# Exclude configuration files that shouldn't be in package
**/.eslintrc*
**/.prettierrc*
**/.editorconfig*
**/tsconfig*.json

# Exclude documentation that's not needed
**/*.md
!README.md
!CHANGELOG.md

# Exclude build scripts
**/build.js
**/esbuild.js
**/webpack.config.js