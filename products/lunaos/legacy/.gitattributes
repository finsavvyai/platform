# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Treat all TS/JS/JSON as UTF-8 LF-normalized text
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf

# Keep binaries untouched
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.vsix binary
*.wasm binary