{
  "name": "lunaforge-core",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p . --skipLibCheck",
    "clean": "rm -rf dist",
    "watch": "tsc -w -p . --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "20.19.26",
    "@vitest/coverage-v8": "^1.0.0",
    "vitest": "^1.0.0"
  },
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core.js"
  }
}