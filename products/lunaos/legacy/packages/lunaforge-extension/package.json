{
  "name": "lunaforge-extension",
  "displayName": "LunaForge",
  "description": "The ultimate AI-powered development environment for VS Code. Visualize your project, generate code, and automate workflows with LunaForge.",
  "version": "2.5.3",
  "publisher": "FinsavvyTechnologies",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lunaforge/lunaforge.git"
  },
  "keywords": [
    "ai",
    "agent",
    "visualization",
    "automation",
    "productivity"
  ],
  "categories": [
    "AI",
    "Visualization",
    "Other"
  ],
  "engines": {
    "vscode": "^1.84.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lunaforge",
          "title": "LunaForge",
          "icon": "resources/lunaforge-icon.svg"
        }
      ]
    },
    "views": {
      "lunaforge": [
        {
          "id": "lunaforge.dashboard",
          "name": "Dashboard",
          "type": "webview"
        },
        {
          "id": "lunaforge.modes",
          "name": "Modes"
        },
        {
          "id": "lunaforge.tools",
          "name": "Quick Actions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "lunaforge.modes",
        "contents": "Welcome to LunaForge! 🌙\n\nGet started by opening the Control Center.\n\n[Open Control Center](command:lunaforge.openControlCenter)\n\n[Build Project Graph](command:lunaforge.buildGraph)\n\n[Show Aura Metrics](command:lunaforge.showAuraMetrics)"
      },
      {
        "view": "lunaforge.tools",
        "contents": "[🎯 Analyze File](command:lunaforge.analyzeFile)\n\n[🔄 Refresh Graph](command:lunaforge.refreshGraph)\n\n[📈 Show Metrics](command:lunaforge.showGraphMetrics)\n\n[🧘 Start Zen Focus](command:lunaforge.startZenFocus)\n\n[📜 Check License](command:lunaforge.checkLicense)\n\n[⚙️ Settings](command:lunaforge.openSettings)\n\n[💎 Upgrade to Pro](command:lunaforge.upgradeLicense)"
      }
    ],
    "commands": [
      {
        "command": "lunaforge.openControlCenter",
        "title": "LunaForge: Open Control Center",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.buildGraph",
        "title": "LunaForge: Build Project Graph",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.refreshGraph",
        "title": "LunaForge: Refresh Graph",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.clearGraph",
        "title": "LunaForge: Clear Graph Cache",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.exportGraph",
        "title": "LunaForge: Export Graph",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.showGraphMetrics",
        "title": "LunaForge: Show Graph Metrics",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.showAuraMetrics",
        "title": "LunaForge: Show Aura Metrics",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.startZenFocus",
        "title": "LunaForge: Start Zen Focus",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.stopZenFocus",
        "title": "LunaForge: Stop Zen Focus",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.showZenSummary",
        "title": "LunaForge: Show Zen Summary",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.listModes",
        "title": "LunaForge: List Available Modes",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.activateMode",
        "title": "LunaForge: Activate Mode",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.deactivateMode",
        "title": "LunaForge: Deactivate Mode",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.toggleMode",
        "title": "LunaForge: Toggle Mode",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.analyzeFile",
        "title": "LunaForge: Analyze Current File",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.analyzeSelection",
        "title": "LunaForge: Analyze Selection",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.requestPlan",
        "title": "LunaForge: Request Analysis Plan",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.enterLicense",
        "title": "LunaForge: Enter License Key",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.checkLicense",
        "title": "LunaForge: Check License Status",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.upgradeLicense",
        "title": "LunaForge: Upgrade to Premium",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.openSettings",
        "title": "LunaForge: Open Settings",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.resetSettings",
        "title": "LunaForge: Reset Settings",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.showOutput",
        "title": "LunaForge: Show Output Channel",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.openDocumentation",
        "title": "LunaForge: Open Documentation",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.reportIssue",
        "title": "LunaForge: Report Issue",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.showWelcome",
        "title": "LunaForge: Show Welcome Guide",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.showCommandPalette",
        "title": "LunaForge: Show Command Palette",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.commandDocumentation",
        "title": "LunaForge: Command Documentation",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.commandStats",
        "title": "LunaForge: Show Command Statistics",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.upgradeSubscription",
        "title": "LunaForge: Upgrade Subscription",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.viewSubscription",
        "title": "LunaForge: View Subscription Status",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.manageBilling",
        "title": "LunaForge: Manage Billing",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.viewPricing",
        "title": "LunaForge: View Pricing Plans",
        "category": "LunaForge"
      },
      {
        "command": "lunaforge.dream.start",
        "title": "Dream: Start Session",
        "category": "LunaForge",
        "icon": "$(cloud)"
      }
    ],
    "keybindings": [
      {
        "command": "lunaforge.openControlCenter",
        "key": "ctrl+shift+l l",
        "mac": "cmd+shift+l l"
      },
      {
        "command": "lunaforge.buildGraph",
        "key": "ctrl+shift+l b",
        "mac": "cmd+shift+l b"
      },
      {
        "command": "lunaforge.refreshGraph",
        "key": "ctrl+shift+l r",
        "mac": "cmd+shift+l r"
      },
      {
        "command": "lunaforge.analyzeFile",
        "key": "ctrl+shift+l a",
        "mac": "cmd+shift+l a"
      },
      {
        "command": "lunaforge.showCommandPalette",
        "key": "ctrl+shift+l p",
        "mac": "cmd+shift+l p"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "lunaforge.analyzeFile",
          "group": "lunaforge@1",
          "when": "editorTextFocus"
        },
        {
          "command": "lunaforge.requestPlan",
          "group": "lunaforge@2",
          "when": "editorTextFocus"
        },
        {
          "command": "lunaforge.analyzeSelection",
          "group": "lunaforge@3",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "lunaforge.refreshGraph",
          "group": "navigation",
          "when": "view == lunaforge.dashboard"
        }
      ]
    },
    "configuration": {
      "title": "LunaForge",
      "properties": {
        "lunaforge.hasLicense": {
          "type": "boolean",
          "default": false,
          "description": "Whether the user has a valid license"
        },
        "lunaforge.apiBaseUrl": {
          "type": "string",
          "default": "https://lunaforge-mcp.broad-dew-49ad.workers.dev",
          "description": "URL of the LunaForge backend worker"
        },
        "lunaforge.licensePlan": {
          "type": "string",
          "enum": [
            "free",
            "pro",
            "enterprise"
          ],
          "default": "free",
          "description": "Current license plan"
        },
        "lunaforge.ui.theme": {
          "type": "string",
          "enum": [
            "auto",
            "dark",
            "light"
          ],
          "default": "auto",
          "description": "UI theme for LunaForge panels"
        },
        "lunaforge.ui.compactMode": {
          "type": "boolean",
          "default": false,
          "description": "Use compact mode for UI elements"
        },
        "lunaforge.realtimeUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time updates in the Control Center"
        },
        "lunaforge.updateInterval": {
          "type": "number",
          "default": 1000,
          "minimum": 500,
          "maximum": 10000,
          "description": "Update interval for real-time data (in milliseconds)"
        },
        "lunaforge.autoBuildGraph": {
          "type": "boolean",
          "default": true,
          "description": "Automatically build graph when workspace opens"
        },
        "lunaforge.enableEarlyAccess": {
          "type": "boolean",
          "default": false,
          "description": "Enable experimental or premium features (Dream, Mythic, etc.) that are still in development."
        },
        "lunaforge.guardian.rules": {
          "type": "array",
          "default": [],
          "description": "Architectural rules for Guardian. Format: { id, name, fromPattern, toPattern, effect: 'deny' }",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "fromPattern": {
                "type": "string"
              },
              "toPattern": {
                "type": "string"
              },
              "effect": {
                "type": "string",
                "enum": [
                  "deny"
                ]
              }
            },
            "required": [
              "id",
              "name",
              "fromPattern",
              "toPattern",
              "effect"
            ]
          }
        },
        "lunaforge.maxGraphSize": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "maximum": 50000,
          "description": "Maximum number of files to analyze for graph building"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build": "npm run compile",
    "clean": "rm -rf out dist",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "pretest": "tsc -p .",
    "test": "node ./out/test/runTest.js",
    "test:published": "node ./out/test/runPublishedTest.js",
    "vsce:package": "vsce package --no-dependencies",
    "vsce:publish": "vsce publish --no-dependencies",
    "vsce:ls": "vsce ls",
    "vsce:verify": "vsce verify-pat"
  },
  "devDependencies": {
    "@types/glob": "8.1.0",
    "@types/mocha": "10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.84.0",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "2.32.0",
    "esbuild": "0.27.0",
    "glob": "13.0.0",
    "mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
