{
  "expo": {
    "name": "LunaOS",
    "slug": "lunaos-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "lunaos",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.lunaos.mobile",
      "buildNumber": "1"
    },
    "android": {
      "package": "ai.lunaos.mobile"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}