{
  "name": "lunaos-studio",
  "version": "2.0.0",
  "description": "LunaOS - AI-native backend-as-a-service platform with visual workflow builder",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:studio": "vite --config vite.studio.config.ts",
    "build": "vite build",
    "build:studio": "vite build --config vite.studio.config.ts",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.studio.config.ts src/__tests__",
    "test:legacy": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit",
    "test:studio": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.studio.config.ts src/__tests__",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.studio.config.ts --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.studio.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test tests/e2e/visual-regression.spec.js",
    "test:visual:update": "playwright test tests/e2e/visual-regression.spec.js --update-snapshots",
    "test:performance": "lhci autorun",
    "lighthouse": "lhci autorun",
    "validate:prod": "bash scripts/validate-production.sh"
  },
  "keywords": [
    "ai",
    "workflow",
    "orchestration",
    "visual-editor"
  ],
  "author": "LunaOS Team",
  "license": "MIT",
  "dependencies": {
    "@sentry/browser": "^10.25.0",
    "@xyflow/react": "^12.4.0",
    "dompurify": "^3.3.0",
    "konva": "^9.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@jest/globals": "^30.2.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-legacy": "^5.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-jest": "^30.2.0",
    "eslint": "^8.56.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "terser": "^5.27.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0",
    "vite": "^5.0.11",
    "vite-plugin-compression": "^0.5.1"
  }
}
