# Environment Configuration
# Options: development, staging, production
VITE_NODE_ENV=development

# API Configuration
# Development: http://localhost:8000
# Staging: https://api-staging.lunaos.ai
# Production: https://api.lunaos.ai
VITE_API_URL=http://localhost:8000

# Monitoring and Analytics
# Sentry DSN for error tracking (get from https://sentry.io)
VITE_SENTRY_DSN=

# DataDog RUM for performance monitoring (get from https://datadoghq.com)
VITE_DATADOG_APP_ID=
VITE_DATADOG_CLIENT_TOKEN=

# Feature Flags
# Enable/disable features at runtime
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_COLLABORATION=true
VITE_ENABLE_GAMIFICATION=false

# Logging
# Options: debug, info, warn, error
# Use 'debug' for development, 'warn' for production
VITE_LOG_LEVEL=debug

# Analytics
# Enable usage analytics and tracking
VITE_ENABLE_ANALYTICS=false

# Deployment Configuration (for CI/CD and rollback scripts)
# Get these from Netlify: https://app.netlify.com
# Site settings → General → Site details → API ID
NETLIFY_SITE_ID=
NETLIFY_STAGING_SITE_ID=

# Get from Netlify: User settings → Applications → Personal access tokens
NETLIFY_AUTH_TOKEN=
