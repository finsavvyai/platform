{
  "name": "pushci-cursor",
  "displayName": "PushCI — CI/CD Status (Cursor)",
  "description": "See CI status, run pipelines, view logs from Cursor. Zero-config, AI-native CI/CD.",
  "version": "0.1.0",
  "publisher": "finsavvyai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/finsavvyai/pushci-cli"
  },
  "homepage": "https://pushci.dev",
  "bugs": {
    "url": "https://github.com/finsavvyai/pushci-cli/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Testing"],
  "keywords": ["ci", "cd", "pushci", "pipeline", "cursor", "ai"],
  "activationEvents": ["workspaceContains:pushci.yml"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "pushci.run", "title": "PushCI: Run Pipeline" },
      { "command": "pushci.status", "title": "PushCI: Show Status" },
      { "command": "pushci.logs", "title": "PushCI: View Logs" },
      { "command": "pushci.init", "title": "PushCI: Initialize Project" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "pushci", "title": "PushCI", "icon": "$(testing-run-icon)" }
      ]
    },
    "views": {
      "pushci": [{ "id": "pushci.runs", "name": "Pipeline Runs" }]
    },
    "configuration": {
      "title": "PushCI",
      "properties": {
        "pushci.autoCheckOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run pipeline on every file save"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish:ovsx": "ovsx publish",
    "publish:marketplace": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0",
    "ovsx": "^0.9.0"
  }
}
