{
  "name": "pushci",
  "displayName": "PushCI — CI/CD Status",
  "description": "See CI status, run pipelines, view logs from VS Code",
  "version": "0.1.0",
  "publisher": "finsavvyai",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Testing"],
  "activationEvents": ["workspaceContains:pushci.yml"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pushci.run",
        "title": "PushCI: Run Pipeline"
      },
      {
        "command": "pushci.status",
        "title": "PushCI: Show Status"
      },
      {
        "command": "pushci.logs",
        "title": "PushCI: View Logs"
      },
      {
        "command": "pushci.init",
        "title": "PushCI: Initialize Project"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pushci",
          "title": "PushCI",
          "icon": "$(testing-run-icon)"
        }
      ]
    },
    "views": {
      "pushci": [
        {
          "id": "pushci.runs",
          "name": "Pipeline Runs"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
