{
  "name": "PushCI",
  "url": "https://pushci.dev",
  "hook_attributes": {
    "url": "https://api.pushci.dev/webhook/github",
    "active": true
  },
  "redirect_url": "https://app.pushci.dev/auth/callback",
  "callback_urls": ["https://app.pushci.dev/auth/callback"],
  "public": true,
  "default_events": ["push", "pull_request", "check_run"],
  "default_permissions": {
    "checks": "write",
    "statuses": "write",
    "pull_requests": "write",
    "contents": "read"
  }
}
