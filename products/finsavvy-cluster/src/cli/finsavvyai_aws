def create_parser() -> argparse.ArgumentParser:
    """Create AWS-style argument parser"""
    parser = argparse.ArgumentParser(
        prog="aws finsavvyai",
        description="FinSavvyAI CLI - Professional AWS-style cluster management",
        add_help=False  # We'll handle help ourselves
    )

    # Global options
    parser.add_argument("--region", default="home-cluster-1", help="AWS-style region")
    parser.add_argument("--output", choices=["json", "table", "yaml", "text"], default="table", help="Output format")
    parser.add_argument("--profile", default="default", help="Profile name")
    parser.add_argument("--verbose", action="store_true", help="Verbose output")
    parser.add_argument("--no-color", action="store_true", help="Disable colored output")

    # Subcommands
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # describe command
    describe_parser = subparsers.add_parser("describe", help="Describe FinSavvyAI resources")
    describe_subparsers = describe_parser.add_subparsers(dest="resource", help="Resource to describe")

    # describe clusters
    describe_subparsers.add_parser("clusters", help="List all clusters")

    # describe nodes
    nodes_parser = describe_subparsers.add_parser("nodes", help="List nodes")
    nodes_parser.add_argument("--detailed", action="store_true", help="Show detailed information")

    # describe services
    describe_subparsers.add_parser("services", help="Show service status")

    # start command
    start_parser = subparsers.add_parser("start", help="Start services")
    start_subparsers = start_parser.add_subparsers(dest="target", help="Target to start")
    service_parser = start_subparsers.add_parser("service", help="Start specific service")
    service_parser.add_argument("service_type", choices=["all", "master", "worker"], default="all", nargs="?", help="Service type")
    service_parser.add_argument("--foreground", action="store_true", help="Run in foreground")

    # stop command
    stop_parser = subparsers.add_parser("stop", help="Stop services")
    stop_subparsers = stop_parser.add_subparsers(dest="target", help="Target to stop")
    stop_service_parser = stop_subparsers.add_parser("service", help="Stop specific service")
    stop_service_parser.add_argument("service_type", choices=["all", "master", "worker"], default="all", nargs="?", help="Service type")

    # other commands
    subparsers.add_parser("deploy", help="Deploy to global access")
    subparsers.add_parser("test", help="Test cluster performance")
    subparsers.add_parser("monitor", help="Monitor cluster")

    # help
    subparsers.add_parser("help", help="Show help")

    return parser


async def main():
    """Main CLI entry point"""
    parser = create_parser()

    if len(sys.argv) == 1:
        parser.print_help()
        return

    args = parser.parse_args()

    # Create CLI instance
    cli = FinSavvyAICLI()
    cli.region = args.region
    cli.output_format = OutputFormat(args.output)
    cli.profile = args.profile
    cli.verbose = args.verbose

    # Update formatter
    cli.formatter = AWSStyleFormatter(cli.output_format)

    # Disable colors if requested
    if args.no_color:
        for attr in dir(Color):
            if not attr.startswith('_'):
                setattr(Color, attr, "")

    try:
        # Route to appropriate command
        if args.command == "help" or not args.command:
            await cli.show_help()
        elif args.command == "describe":
            if args.resource == "clusters":
                await cli.describe_clusters()
            elif args.resource == "nodes":
                await cli.describe_nodes(getattr(args, 'detailed', False))
            elif args.resource == "services":
                await cli.get_service_status()
            else:
                print(f"Unknown resource: {args.resource}")
                await cli.show_help()
        elif args.command == "start":
            if args.target == "service":
                service_type = getattr(args, 'service_type', 'all')
                foreground = getattr(args, 'foreground', False)
                await cli.start_services(service_type, foreground)
            else:
                await cli.start_services("all")
        elif args.command == "stop":
            if args.target == "service":
                service_type = getattr(args, 'service_type', 'all')
                await cli.stop_services(service_type)
            else:
                await cli.stop_services("all")
        elif args.command == "deploy":
            print("Deploy command not yet implemented")
        elif args.command == "test":
            print("Test command not yet implemented")
        elif args.command == "monitor":
            print("Monitor command not yet implemented")
        else:
            print(f"Unknown command: {args.command}")
            await cli.show_help()

    except KeyboardInterrupt:
        print(f"\n{cli.formatter.format_error('Operation cancelled by user')}")
    except Exception as e:
        print(f"\n{cli.formatter.format_error(f'Unexpected error: {str(e)}')}")
        if cli.verbose:
            import traceback
            traceback.print_exc()
    finally:
        await cli._close_session()


if __name__ == "__main__":
    asyncio.run(main())
