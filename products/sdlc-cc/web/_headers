# Cloudflare Pages security headers. CSP allows the gateway endpoint
# and same-origin only. Adjust connect-src if you front the gateway
# with a different host.
/*
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.sdlc.cc https://*.sdlc.cc; frame-ancestors 'none'
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: clipboard-read=(self), clipboard-write=(self)
