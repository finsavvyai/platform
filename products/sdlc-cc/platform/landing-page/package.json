{
  "name": "sdlc-landing-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:integration:watch": "jest --config jest.integration.config.js --watch",
    "test:integration:coverage": "jest --config jest.integration.config.js --coverage",
    "test:e2e": "echo 'E2E tests would run here with Playwright or Cypress'",
    "test:all": "npm run test:run && npm run test:integration",
    "production:check": "npm run lint && npm run typecheck && npm run test:run && npm run build",
    "pages:build": "npm run build && npx @cloudflare/next-on-pages",
    "pages:dev": "npx wrangler pages dev .next",
    "pages:deploy": "npm run pages:build && npx wrangler pages deploy .vercel/output/static --no-bundle"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.36.5",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@hookform/resolvers": "^3.9.0",
    "framer-motion": "^11.11.7",
    "lucide-react": "^0.454.0",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^22.8.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^29.7.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jsdom": "^23.0.0",
    "node-mocks-http": "^1.14.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^2.0.0",
    "vitest-canvas-mock": "^0.3.0",
    "@finsavvyai/test-config": "file:../packages/test-config",
    "wrangler": "^4.73.0"
  }
}
