  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level pre-request script",
          "// Ensure all required variables are set",
          "const requiredVars = ['base_url', 'tenant_id', 'user_email', 'user_password'];",
          "const missingVars = requiredVars.filter(varName => !pm.collectionVariables.get(varName));",
          "",
          "if (missingVars.length > 0) {",
          "    console.log('Missing required environment variables:', missingVars.join(', '));",
          "    console.log('Please set these variables in the environment.');",
          "}",
          "",
          "// Log current environment",
          "console.log('Current environment:', {",
          "    base_url: pm.collectionVariables.get('base_url'),",
          "    tenant_id: pm.collectionVariables.get('tenant_id'),",
          "    has_token: !!pm.collectionVariables.get('jwt_token')",
          "    user_id: pm.collectionVariables.get('user_id')",
          "});"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level test script",
          "// Log test completion",
          "console.log('[' + pm.info.requestName + '] Test completed');",
          "",
          "// Check for deprecation warnings",
          "if (pm.response.headers.get('API-Version-Deprecated')) {",
          "    pm.test('API Version Deprecation Warning', function () {",
          "        const warning = pm.response.headers.get('API-Version-Deprecation-Warning');",
          "        console.warn('API VERSION DEPRECATED:', warning);",
          "    });",
          "}",
          "",
          "// Check for rate limit warnings",
          "const remaining = parseInt(pm.response.headers.get('X-RateLimit-Remaining') || '0');",
          "if (remaining < 10) {",
          "    pm.test('Rate Limit Warning', function () {",
          "        console.warn('Rate limit running low:', remaining + ' requests remaining');",
          "    });",
          "}"
        ]
      }
