# Secret template for Gateway Service
# NOTE: Do NOT commit actual secrets to version control
# Use sealed-secrets, external-secrets, or similar for production
apiVersion: v1
kind: Secret
metadata:
  name: gateway-secrets
  namespace: sdlc-platform
  labels:
    app: gateway
    component: api-gateway
type: Opaque
stringData:
  # Database credentials
  db-user: "sdlc_platform"
  db-password: "CHANGE_ME_SECURE_PASSWORD"

  # Redis credentials
  redis-password: "CHANGE_ME_SECURE_PASSWORD"

  # JWT signing secret (use a strong random string)
  jwt-secret: "CHANGE_ME_USE_KUBERNETES_SECRET_OR_VAULT"

  # Cloudflare API credentials
  cloudflare-account-id: "YOUR_ACCOUNT_ID"
  cloudflare-api-token: "YOUR_API_TOKEN"

  # External service credentials
  lemonsqueezy-api-key: "YOUR_LEMONSQUEEZY_API_KEY"
  openai-api-key: "YOUR_OPENAI_API_KEY"
