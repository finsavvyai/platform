# RAG service — environment configuration

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Database / cache ---
DATABASE_URL=postgres://user:password@localhost:5432/rag?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# --- Langfuse LLM observability (opt-in) ---
# Set LANGFUSE_ENABLED=true to stream traces/generations to Langfuse.
# When disabled or misconfigured, app.observability.trace_llm_call() is a
# no-op and the `langfuse` package import is lazy.
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- OpenLLMetry / OpenTelemetry GenAI tracing (opt-in) ---
# Set OTEL_ENABLED=true to auto-instrument OpenAI/Anthropic/etc. via
# traceloop-sdk (OpenLLMetry). Traces follow OTel GenAI semantic conventions
# and are exported via OTLP so the Go llm-gateway and the Python RAG service
# share a single distributed trace per user request.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Optional: point at Traceloop Cloud instead of a local collector.
TRACELOOP_BASE_URL=
TRACELOOP_API_KEY=
OTEL_SERVICE_VERSION=dev
