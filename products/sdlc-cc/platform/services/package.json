  "devDependencies": {
    "nodemon": "^3.0.0",
    "wrangler": "^3.0.0"
  },
  "dependencies": {
    "workerd": "^1.20260418.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sdlc/lam-system.git"
  },
  "bugs": {
