{
  "name": "sdlc-lam-system",
  "version": "1.0.0",
  "description": "LAM (Large Action Model) Augmented SDLC Compliance System",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "node test-lam-system.js",
    "test:watch": "nodemon test-lam-system.js",
    "validate": "wrangler validate",
    "tail": "wrangler tail",
    "secret:list": "wrangler secret list",
    "kv:list": "wrangler kv:namespace list",
    "d1:list": "wrangler d1 list"
  },
  "keywords": [
    "lam",
    "compliance",
    "ai",
    "security",
    "gdpr",
    "hipaa",
    "cloudflare-workers",
    "serverless"
  ],
