# LLM Gateway — environment configuration

# --- Core providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GATEWAY_API_KEY=
JWT_SECRET=

# --- Langfuse LLM observability (opt-in) ---
# Set LANGFUSE_ENABLED=true to stream traces/generations to Langfuse.
# When any of these are missing or LANGFUSE_ENABLED is false, the gateway
# emits no Langfuse events (zero runtime cost).
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- ReasoningBank prompt cache ---
REASONING_BANK_ENABLED=true

# --- OpenLLMetry / OpenTelemetry GenAI tracing (opt-in) ---
# Set OTEL_ENABLED=true to emit OTel GenAI spans (gen_ai.system,
# gen_ai.request.model, gen_ai.usage.input_tokens, gen_ai.usage.output_tokens)
# around every provider call. Traces are exported to any OTLP collector,
# making the gateway interoperable with Traceloop/OpenLLMetry, Jaeger,
# Grafana Tempo, Honeycomb, Datadog, etc.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_VERSION=dev
