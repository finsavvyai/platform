{
  "name": "@sdlc/dashboard",
  "version": "1.0.0",
  "description": "Dashboard for SDLC.ai platform management",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:worker": "wrangler dev --config wrangler.toml",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:worker\"",
    "build:frontend": "vite build",
    "build:worker": "tsc --project tsconfig.worker.json",
    "build": "npm run build:frontend && npm run build:worker",
    "preview": "vite preview",
    "serve": "wrangler dev --config wrangler.toml",
    "deploy:worker": "wrangler deploy --config wrangler.toml --env=production",
    "deploy:frontend": "wrangler pages deploy ./dist-frontend --project-name=unified-dashboard --branch=main",
    "deploy:frontend:preview": "wrangler pages deploy ./dist-frontend --project-name=unified-dashboard --branch=preview",
    "deploy": "npm run build && npm run deploy:worker && npm run deploy:frontend",
    "type-check": "tsc --noEmit",
    "lint:check": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:smoke": "node ./scripts/test-api.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:oauth": "playwright test oauth-setup.spec.ts",
    "setup:oauth": "bash ./scripts/setup-oauth.sh",
    "db:migrate": "bash ./scripts/migrate.sh",
    "db:migrate:dev": "bash ./scripts/migrate.sh development",
    "analyze": "bundlesize"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@finsavvyai/auth": "file:../../../packages/auth",
    "@sdlc/auth": "file:../shared-auth",
    "@sdlc/billing": "file:../shared-billing",
    "@tanstack/react-query": "^5.59.15",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.11",
    "hono": "^4.12.14",
    "jotai": "^2.6.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "^4.6.1",
    "react-router-dom": "^6.28.0",
    "react-use": "^17.5.1",
    "recharts": "^2.13.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@finsavvyai/test-config": "file:../test-config",
    "@hono/vite-dev-server": "^0.25.3",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "honox": "^0.1.55",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jotai-devtools": "^0.13.1",
    "playwright": "^1.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.3.0",
    "wrangler": "^4.51.0"
  },
  "keywords": [
    "dashboard",
    "enterprise",
    "unified",
    "react",
    "typescript"
  ],
  "author": "Finsavvy AI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/finsavvyai/enterprise-ai-stack"
  }
}
