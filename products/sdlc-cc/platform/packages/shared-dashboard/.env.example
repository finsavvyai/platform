# Unified Dashboard Environment Variables
# Copy this file to .env and fill in your values

# Environment
ENVIRONMENT=production
API_VERSION=v1

# Security
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-change-this-in-production
API_KEY_SECRET=your-api-key-secret-change-this-in-production

# Features
ENABLE_ANALYTICS=true
ENABLE_CACHING=true
CACHE_TTL=300

# Rate Limiting
RATE_LIMIT_PER_MINUTE=120

# CORS
CORS_ALLOWED_ORIGINS=https://dashboard.finsavvyai.com,https://app.finsavvyai.com

# Database (Cloudflare D1)
D1_DATABASE_ID=your-d1-database-id-here
D1_DATABASE_NAME=unified_dashboard

# KV Namespace
KV_NAMESPACE_ID=your-kv-namespace-id-here

# R2 Bucket
R2_BUCKET_NAME=dashboard-assets

# Service Bindings (Optional - configure in wrangler.toml)
# PIPEWARDEN_SERVICE=pipewarden-api-gateway
# QUANTUMBEAM_SERVICE=quantumbeam-worker
# MCPOVERFLOW_SERVICE=mcpoverflow-main
# QESTRO_SERVICE=questro-platform-worker
# SDLC_SERVICE=sdlc-gateway-worker
# QUERYFLUX_SERVICE=queryflux-main
# UPM_SERVICE=upm-worker
# YALLABYE_SERVICE=yallabye-worker

# Monitoring & Alerting (Optional)
# SENTRY_DSN=your-sentry-dsn
# DATADOG_API_KEY=your-datadog-api-key
# PAGERDUTY_KEY=your-pagerduty-integration-key

# External Services (Optional)
# SENDGRID_API_KEY=your-sendgrid-api-key
# SLACK_WEBHOOK_URL=your-slack-webhook-url
