{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "jsx": "react",
    "noEmit": false,
    "outDir": "./dist-worker",
    "rootDir": "./src/worker"
  },
  "include": [
    "src/worker/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-worker",
    "**/*.test.ts"
  ]
}
