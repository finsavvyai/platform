{
  "name": "@sdlc/integrations",
  "version": "1.0.0",
  "description": "Enterprise integration bridges (PipeWarden, compliance reports) for the SDLC platform",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pipewarden": {
      "types": "./dist/pipewarden.d.ts",
      "import": "./dist/pipewarden.js"
    },
    "./compliance": {
      "types": "./dist/compliance-report.d.ts",
      "import": "./dist/compliance-report.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@sdlc/dlp": "file:../dlp"
  },
  "devDependencies": {
    "@finsavvyai/test-config": "file:../test-config",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
