{
  "name": "@sdlc/billing",
  "version": "1.0.0",
  "description": "Billing system with Stripe integration for SDLC.ai platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "deploy:dev": "npm run build && wrangler deploy --env dev",
    "dev:worker": "wrangler dev",
    "dev:worker:staging": "wrangler dev --env staging",
    "dev:worker:local": "wrangler dev --local",
    "tail": "wrangler tail",
    "tail:staging": "wrangler tail --env staging",
    "secrets:list": "wrangler secret list",
    "secrets:set": "wrangler secret put",
    "kv:cache:create": "wrangler kv:namespace create BILLING_CACHE",
    "kv:cache:preview": "wrangler kv:namespace create BILLING_CACHE --preview",
    "d1:create": "wrangler d1 create billing-cache-db",
    "d1:migrate": "wrangler d1 execute billing-cache-db --file=database-schema.sql",
    "queue:create": "wrangler queues create billing-events-queue",
    "r2:bucket:create": "wrangler r2 bucket create unified-billing-storage",
    "analytics:create": "wrangler analytics-engine dataset create BILLING_ANALYTICS",
    "test:deployment": "curl -s https://api-billing.broad-dew-49ad.workers.dev/health | jq .",
    "test:custom-domain": "curl -s https://api.billing.finsavvyai.com/health | jq . || echo 'Custom domain not ready'",
    "logs:production": "wrangler tail --format json",
    "logs:staging": "wrangler tail --env staging --format json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@finsavvyai/pay": "file:../../../packages/pay",
    "@supabase/supabase-js": "^2.38.0",
    "hono": "^4.12.14",
    "stripe": "^14.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/stripe": "^8.0.417",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1",
    "@finsavvyai/test-config": "file:../test-config"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
