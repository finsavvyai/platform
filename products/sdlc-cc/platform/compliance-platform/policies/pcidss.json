{
  "name": "pci-dss-policy",
  "version": "4.0.0",
  "description": "PCI DSS compliance policy for payment card data protection",
  "framework": "PCI-DSS",
  "risk_level": "critical",
  "retention_years": 7,
  "rules": [
    {
      "name": "cardholder_data_protection",
      "description": "Protect stored cardholder data",
      "condition": {
        "type": "data_classification",
        "value": "cardholder_data"
      },
      "effect": "transform",
      "actions": {
        "encryption_required": true,
        "encryption_algorithm": "AES-256",
        "key_management": true,
        "audit_level": "critical",
        "transformations": ["encrypt_pan", "mask_display", "truncate_storage"]
      },
      "on_violation": {
        "block": true,
        "alert": true,
        "escalation": "immediate"
      }
    },
    {
      "name": "pan_masking",
      "description": "Mask Primary Account Number (PAN) in displays and logs",
      "condition": {
        "type": "content_contains",
        "patterns": [
          "\\b(?:\\d{4}[\\s-]?){3}\\d{4}\\b"
        ]
      },
      "effect": "transform",
      "actions": {
        "transformations": [
          {"type": "mask", "pattern": "pan", "replacement": "****-****-****-####"}
        ],
        "audit": true,
        "max_visible_digits": 6
      }
    },
    {
      "name": "access_control",
      "description": "Restrict access to cardholder data by business need-to-know",
      "condition": {
        "type": "data_classification",
        "value": "cardholder_data"
      },
      "effect": "allow",
      "actions": {
        "authorization_required": true,
        "allowed_roles": ["payment_processor", "finance_admin", "compliance_officer"],
        "mfa_required": true,
        "audit_level": "critical",
        "session_timeout_minutes": 15
      }
    },
    {
      "name": "transmission_encryption",
      "description": "Encrypt transmission of cardholder data across open networks",
      "condition": {
        "type": "data_classification",
        "value": "cardholder_data"
      },
      "effect": "enhance",
      "actions": {
        "tls_required": true,
        "min_tls_version": "1.3",
        "strong_cryptography": true,
        "audit_level": "critical"
      }
    },
    {
      "name": "vulnerability_management",
      "description": "Maintain vulnerability management program",
      "condition": {
        "type": "data_classification",
        "value": "cardholder_data"
      },
      "effect": "enhance",
      "actions": {
        "antivirus_required": true,
        "patch_management": true,
        "secure_development": true,
        "audit_level": "high"
      }
    },
    {
      "name": "audit_logging",
      "description": "Track and monitor all access to cardholder data",
      "condition": {
        "type": "data_classification",
        "value": "cardholder_data"
      },
      "effect": "audit",
      "actions": {
        "audit_level": "critical",
        "retention_years": 1,
        "log_user_id": true,
        "log_timestamp": true,
        "log_action": true,
        "log_result": true,
        "tamper_protection": true
      }
    },
    {
      "name": "sensitive_auth_data_prohibition",
      "description": "Do not store sensitive authentication data after authorization",
      "condition": {
        "type": "data_classification",
        "value": "sensitive_auth_data"
      },
      "effect": "deny",
      "actions": {
        "block_storage": true,
        "alert": true,
        "audit_level": "critical"
      },
      "on_violation": {
        "block": true,
        "alert": true,
        "escalation": "immediate"
      }
    }
  ],
  "pii_patterns": {
    "pan": {
      "pattern": "\\b(?:\\d{4}[\\s-]?){3}\\d{4}\\b",
      "confidence": "high",
      "action": "encrypt"
    },
    "cvv": {
      "pattern": "\\b\\d{3,4}\\b",
      "confidence": "medium",
      "action": "block_storage"
    },
    "expiry": {
      "pattern": "\\b(0[1-9]|1[0-2])\\/\\d{2,4}\\b",
      "confidence": "medium",
      "action": "encrypt"
    }
  },
  "compliance_requirements": {
    "secure_network": true,
    "protect_cardholder_data": true,
    "vulnerability_management": true,
    "access_control": true,
    "monitoring_testing": true,
    "information_security_policy": true
  },
  "penalties": {
    "fines_per_violation": true,
    "card_replacement_costs": true,
    "forensic_investigation_costs": true,
    "brand_damage": true
  },
  "created_at": "2025-11-19T12:00:00Z",
  "updated_at": "2025-11-19T12:00:00Z",
  "author": "SDLC Compliance Team",
  "approved_by": "Payment Security Officer"
}
