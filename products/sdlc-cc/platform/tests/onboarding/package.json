{
  "name": "sdlc-onboarding-tests",
  "version": "1.0.0",
  "description": "Comprehensive Playwright tests for SDLC Platform user onboarding flow",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:landing": "playwright test tests/landing-page.spec.ts",
    "test:signup": "playwright test tests/sign-up.spec.ts",
    "test:signin": "playwright test tests/sign-in.spec.ts",
    "test:dashboard": "playwright test tests/dashboard-access.spec.ts tests/api-keys.spec.ts",
    "test:settings": "playwright test tests/settings.spec.ts",
    "test:visual": "playwright test tests/visual.visual.spec.ts",
    "test:mobile": "playwright test tests/mobile.spec.ts",
    "test:a11y": "playwright test tests/accessibility.a11y.spec.ts",
    "test:all": "playwright test",
    "test:ci": "playwright test --reporter=json --reporter=junit",
    "test:smoke": "playwright test tests/landing-page.spec.ts tests/sign-up.spec.ts tests/sign-in.spec.ts",
    "update-snapshots": "playwright test tests/visual.visual.spec.ts --update-snapshots",
    "setup": "playwright install",
    "clean": "rm -rf test-results screenshots"
  },
  "keywords": [
    "e2e",
    "testing",
    "playwright",
    "onboarding",
    "authentication"
  ],
  "author": "SDLC Platform",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "dotenv": "^16.3.1",
    "typescript": "^5.3.3",
    "@finsavvyai/test-config": "file:../../packages/test-config"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
