# Environment variables for Playwright tests

# Base URL for the application under test
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Environment
NODE_ENV=test

# Test user credentials (for testing login flows)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPass123!

# Clerk test keys (if using Clerk for authentication)
# Get these from your Clerk dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# API endpoints
API_BASE_URL=http://localhost:8080

# Database connection (for database cleanup, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/sdlc_test

# Redis connection (for cache testing)
REDIS_URL=redis://localhost:6379

# Feature flags
ENABLE_VISUAL_TESTS=true
ENABLE_ACCESSIBILITY_TESTS=true
ENABLE_API_TESTS=true

# Screenshot options
SCREENSHOT_DIR=test-results/screenshots

# Test timeouts
DEFAULT_TIMEOUT=60000
NAVIGATION_TIMEOUT=30000

# Reporting
REPORTER_PORT=9323
