# =============================================================================
# SDLC.ai Platform - Environment Configuration Template
# =============================================================================
# Copy this file to .env and customize for your environment
# =============================================================================
# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info

# =============================================================================
# Service Configuration
# =============================================================================

# Gateway Service (Go)
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0

# RAG Service (Python)
RAG_PORT=8001
RAG_HOST=0.0.0.0

# Vector Core Service (Rust)
VECTOR_PORT=8002
VECTOR_HOST=0.0.0.0

# Admin UI (Next.js)
ADMIN_PORT=3000
ADMIN_HOST=0.0.0.0

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/sdlc_dev
POSTGRES_DB=sdlc_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Authentication & Security
# =============================================================================

# JWT Configuration
JWT_SIGNING_KEY=dev-jwt-signing-key-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# mTLS Configuration
MTLS_ENABLED=true
MTLS_CERT_PATH=/etc/ssl/certs/server.crt
MTLS_KEY_PATH=/etc/ssl/private/server.key

# OIDC Configuration
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_ISSUER_URL=https://your-oidc-provider.com
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# =============================================================================
# AI Service Configuration
# =============================================================================

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION=your-openai-org-id
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Cohere
COHERE_API_KEY=your-cohere-api-key
COHERE_MODEL=command

# =============================================================================
# Storage Configuration
# =============================================================================

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_NAME=sdlc-documents
MINIO_USE_SSL=false

# Cloudflare R2 (Production)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=sdlc-prod-documents

# =============================================================================
# Cloudflare Services
# =============================================================================

# Cloudflare API
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# D1 Database
D1_DATABASE_ID=your-d1-database-id

# KV Storage
KV_NAMESPACE_ID=your-kv-namespace-id

# Vectorize
VECTORIZE_INDEX_NAME=your-vectorize-index

# R2 Storage
R2_ACCOUNT_ID=your-cloudflare-account-id

# =============================================================================
# Monitoring & Observability
# =============================================================================

# Prometheus
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_ENABLED=true

# Grafana
GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_PASSWORD=admin

# Jaeger Tracing
JAEGER_ENDPOINT=http://localhost:14268/api/traces
JAEGER_ENABLED=true

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sdlc-platform
OTEL_RESOURCE_ATTRIBUTES=service.version=1.0.0

# =============================================================================
# Email Configuration
# =============================================================================

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@sdlc.cc

# SendGrid (Alternative)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@sdlc.cc

# =============================================================================
# Feature Flags
# =============================================================================

# Feature Toggles
FEATURE_DLP_ENABLED=true
FEATURE_MULTI_TENANCY=true
FEATURE_AUDIT_LOGGING=true
FEATURE_REAL_TIME_MONITORING=true
FEATURE_ADVANCED_ANALYTICS=true

# Development Features
DEV_FEATURE_RELOAD_ON_CHANGE=true
DEV_FEATURE_DEBUG_MODE=true
DEV_FEATURE_MOCK_EXTERNAL_APIS=false

# =============================================================================
# Performance Configuration
# =============================================================================

# Rate Limiting
RATE_LIMIT_DEFAULT=1000
RATE_LIMIT_BURST=100
RATE_LIMIT_WINDOW=3600

# Connection Pooling
DB_MAX_CONNECTIONS=50
DB_MAX_IDLE_CONNECTIONS=10
DB_CONNECTION_MAX_LIFETIME=3600

# Caching
CACHE_TTL_DEFAULT=300
CACHE_TTL_USER_SESSIONS=1800
CACHE_TTL_API_RESPONSES=60

# =============================================================================
# Security Configuration
# =============================================================================

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Tenant-ID

# Content Security Policy
CSP_ENABLED=true
CSP_DIRECTIVES=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'

# DLP Configuration
DLP_ENABLED=true
DLP_SENSITIVITY_THRESHOLD=0.7
DLP_REDACTION_ENABLED=true

# =============================================================================
# Business Configuration
# =============================================================================

# Tenant Limits
DEFAULT_TENANT_MAX_DOCUMENTS=1000
DEFAULT_TENANT_MAX_USERS=100
DEFAULT_TENANT_MAX_TOKENS_PER_MONTH=1000000

# Document Processing
MAX_DOCUMENT_SIZE=50MB
SUPPORTED_DOCUMENT_FORMATS=pdf,docx,txt,html,json,csv
CHUNK_SIZE=1024
CHUNK_OVERLAP=256

# Vector Configuration
EMBEDDING_DIMENSIONS=1536
VECTOR_INDEX_TYPE=hnsw
SIMILARITY_THRESHOLD=0.7
MAX_SEARCH_RESULTS=10

# =============================================================================
# Development Configuration
# =============================================================================

# Development Tools
DEV_TOOLS_ENABLED=true
DEV_API_DOCS_ENABLED=true
DEV_SWAGGER_UI_ENABLED=true
DEV_PROFILING_ENABLED=false

# Testing
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/sdlc_test
TEST_REDIS_URL=redis://localhost:6379/1

# Mock Services
MOCK_OPENAI=false
MOCK_ANTHROPIC=false
MOCK_EMAIL_SERVICE=true

# =============================================================================
# Logging Configuration
# =============================================================================

# Log Levels
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Structured Logging
STRUCTURED_LOGGING=true
LOG_CORRELATION_ID=true
LOG_REQUEST_ID=true

# Log Destinations
LOG_FILE_ENABLED=false
LOG_FILE_PATH=/var/log/sdlc/app.log
LOG_FILE_MAX_SIZE=100MB
LOG_FILE_MAX_BACKUPS=5

# =============================================================================
# Backup & Recovery
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# Database Backup
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE=0 3 * * *
DB_BACKUP_RETENTION_DAYS=90

# =============================================================================
# External Services
# =============================================================================

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30s
WEBHOOK_RETRY_ATTEMPTS=3

# Third-party Integrations
SLACK_WEBHOOK_URL=your-slack-webhook-url
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# =============================================================================
# Compliance & Audit
# =============================================================================

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
AUDIT_LOG_STORAGE_PATH=/var/log/audit

# GDPR Compliance
GDPR_DATA_RETENTION_DAYS=2555
GDPR_ANONYMIZATION_ENABLED=true

# HIPAA Compliance
HIPAA_AUDIT_MODE=true
HIPAA_ENCRYPTION_REQUIRED=true
