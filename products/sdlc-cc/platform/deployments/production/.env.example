# SDLC.ai Production Environment Variables
# Copy this file to .env.production and fill in your actual values

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Domain Configuration
DOMAIN_NAME=sdlc.cc
ENVIRONMENT=production

# Payment Processing (Stripe)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Security Configuration
ENCRYPTION_KEY=your_master_encryption_key_at_least_32_characters_long

# GitHub Configuration (for Cloudflare Pages)
GITHUB_OWNER=sdlc-ai
GITHUB_REPO=sdlc-platform

# AWS Configuration (for backup services)
AWS_REGION=us-west-2

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_REAL_TIME=true
ENABLE_ANALYTICS=true
ENABLE_MULTI_TENANT=true
ENABLE_API_V2=true

# Security Settings
ENABLE_WAF=true
ENABLE_BOT_FIGHT=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# PCI Compliance
PCI_LEVEL=1
SCAN_FREQUENCY=quarterly
ENABLE_AUDIT_LOGGING=true

# Monitoring
ENABLE_REAL_USER_MONITORING=true
ENABLE_ERROR_TRACKING=true
ENABLE_PERFORMANCE_MONITORING=true

# Backup Configuration
BACKUP_RETENTION_DAYS=90
BACKUP_FREQUENCY=daily
CROSS_REGION_BACKUP=true

# Scaling Configuration
MIN_INSTANCES=2
MAX_INSTANCES=100
TARGET_CPU_UTILIZATION=70
TARGET_MEMORY_UTILIZATION=80

# Log Retention
ACCESS_LOGS_DAYS=30
ERROR_LOGS_DAYS=90
AUDIT_LOGS_DAYS=2555
