# Patterns to ignore when packaging the chart.
# Mirrors the helm default ignores plus this chart's specific bloat sources.
.DS_Store
.git/
.gitignore
.bzr/
.hg/
.svn/
*.swp
*.bak
*.tmp
*.orig
*~

# Editor + IDE
.vscode/
.idea/

# Helm chart artifacts.
#
# Without this, the previous packaged .tgz (sitting next to Chart.yaml
# from the prior run) gets included in the next `helm package`, so the
# chart roughly doubles each rebuild. Only this chart's own root .tgz
# is excluded — dependency archives under charts/*.tgz are required.
sdlc-platform-*.tgz

# OWNERS file
OWNERS
