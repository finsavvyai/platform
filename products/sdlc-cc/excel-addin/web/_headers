# Cloudflare Pages headers for the Excel add-in static host.
# Office iframes the add-in in officeapps.live.com / excel.officeapps.live.com.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# CSP per-file: don't send X-Frame-Options here (would break Office),
# rely on frame-ancestors to restrict framing to legitimate Office origins.
/taskpane.html
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://appsforoffice.microsoft.com; img-src 'self' data:; connect-src 'self' https://api.sdlc.cc https://*.sdlc.cc http://localhost:8080; frame-ancestors https://excel.officeapps.live.com https://*.officeapps.live.com https://*.office.com
