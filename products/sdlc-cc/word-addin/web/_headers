# Cloudflare Pages headers for the Word add-in static host.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/taskpane.html
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://appsforoffice.microsoft.com; img-src 'self' data:; connect-src 'self' https://api.sdlc.cc https://*.sdlc.cc http://localhost:8080; frame-ancestors https://word.officeapps.live.com https://*.officeapps.live.com https://*.office.com
