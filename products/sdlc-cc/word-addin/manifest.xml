<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Word add-in manifest. Same TaskPaneApp shape as Excel, with
  Host Name="Document" instead of "Workbook".

  Sideload: Word → Insert → My Add-ins → Upload My Add-in.
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <Id>44444444-5555-6666-7777-888888888888</Id>
  <Version>0.1.0.0</Version>
  <ProviderName>sdlc.cc</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="sdlc.cc — Sanitize for AI" />
  <Description DefaultValue="Redact PII, credentials, and IDs from a Word document before sharing with AI tools." />
  <IconUrl DefaultValue="https://addin-word.sdlc.cc/icons/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://addin-word.sdlc.cc/icons/icon-128.png" />
  <SupportUrl DefaultValue="https://github.com/finsavvyai/sdlc-cc" />

  <AppDomains>
    <AppDomain>https://api.sdlc.cc</AppDomain>
    <AppDomain>https://*.sdlc.cc</AppDomain>
    <AppDomain>http://localhost:8080</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Document" />
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="WordApi" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://addin-word.sdlc.cc/taskpane.html" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
    xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="sdlcGroup">
                <Label resid="GroupLabel" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="openPaneBtn">
                  <Label resid="ScrubButton.Label" />
                  <Supertip>
                    <Title resid="ScrubButton.Label" />
                    <Description resid="ScrubButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>SdlcTaskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://addin-word.sdlc.cc/icons/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://addin-word.sdlc.cc/icons/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://addin-word.sdlc.cc/icons/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://addin-word.sdlc.cc/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="sdlc.cc" />
        <bt:String id="ScrubButton.Label" DefaultValue="Sanitize for AI" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ScrubButton.Tooltip"
          DefaultValue="Scrub PII, credentials, and identifiers from this document." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
