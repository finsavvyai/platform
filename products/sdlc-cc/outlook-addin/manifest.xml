<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Outlook add-in manifest (XML form). AppSource still requires this
  shape; the Unified manifest for M365 is preview-only as of Q2 2026.
  Replace the host URLs once the add-in is hosted at addin.sdlc.cc
  (or any HTTPS endpoint reachable by Outlook).

  Sideload for testing:
    File → Get Add-ins → My add-ins → Add a custom add-in →
      Add from file → pick this manifest.xml
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- Per-publisher GUID. Replace with one you mint via uuidgen
       before submitting to AppSource. The current value is dev-only. -->
  <Id>11111111-2222-3333-4444-555555555555</Id>
  <Version>0.1.0.0</Version>
  <ProviderName>sdlc.cc</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="sdlc.cc — Sanitize for AI" />
  <Description DefaultValue="Redacts PII, credentials, and IDs from email bodies before they reach AI tools (Cowork, Copilot, Claude, ChatGPT)." />

  <IconUrl DefaultValue="https://addin.sdlc.cc/icons/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://addin.sdlc.cc/icons/icon-128.png" />
  <SupportUrl DefaultValue="https://github.com/finsavvyai/sdlc-cc" />

  <AppDomains>
    <AppDomain>https://api.sdlc.cc</AppDomain>
    <AppDomain>https://*.sdlc.cc</AppDomain>
    <AppDomain>http://localhost:8080</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://addin.sdlc.cc/taskpane.html" />
        <RequestedHeight>360</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://addin.sdlc.cc/taskpane.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
    xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="msgReadOpenPaneBtn">
                  <Label resid="ScrubButton.Label" />
                  <Supertip>
                    <Title resid="ScrubButton.Label" />
                    <Description resid="ScrubButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="msgComposeOpenPaneBtn">
                  <Label resid="ScrubButton.Label" />
                  <Supertip>
                    <Title resid="ScrubButton.Label" />
                    <Description resid="ScrubButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://addin.sdlc.cc/icons/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://addin.sdlc.cc/icons/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://addin.sdlc.cc/icons/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://addin.sdlc.cc/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://addin.sdlc.cc/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="sdlc.cc" />
        <bt:String id="ScrubButton.Label" DefaultValue="Sanitize for AI" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ScrubButton.Tooltip"
          DefaultValue="Scrub PII, credentials, and identifiers from this email body before sending it to AI tools." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
