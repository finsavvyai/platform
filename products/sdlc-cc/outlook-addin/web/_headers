# Cloudflare Pages headers for the Outlook add-in static host.
# Office requires the iframe-able resources to allow framing from
# the outlook.office.com / *.officeapps.live.com origins.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: clipboard-write=(self)

# Office hosts the add-in inside its own iframe; we must NOT send
# X-Frame-Options: DENY here (would break the integration). The CSP
# frame-ancestors clause restricts framing to the legitimate Office
# origins instead.
/taskpane.html
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://appsforoffice.microsoft.com; img-src 'self' data:; connect-src 'self' https://api.sdlc.cc https://*.sdlc.cc http://localhost:8080; frame-ancestors https://outlook.office.com https://outlook.office365.com https://outlook.live.com https://*.officeapps.live.com

/commands.html
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://appsforoffice.microsoft.com; frame-ancestors https://outlook.office.com https://outlook.office365.com https://outlook.live.com https://*.officeapps.live.com
