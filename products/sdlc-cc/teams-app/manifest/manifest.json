{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "0.1.0",
  "id": "33333333-4444-5555-6666-777777777777",
  "packageName": "cc.sdlc.scrub",
  "developer": {
    "name": "sdlc.cc",
    "websiteUrl": "https://github.com/finsavvyai/sdlc-cc",
    "privacyUrl": "https://github.com/finsavvyai/sdlc-cc",
    "termsOfUseUrl": "https://github.com/finsavvyai/sdlc-cc"
  },
  "icons": { "color": "icons/icon-192.png", "outline": "icons/icon-32-outline.png" },
  "name": { "short": "sdlc.cc Scrub", "full": "sdlc.cc — Sanitize for AI" },
  "description": {
    "short": "Redact PII before pasting into AI chats / Copilot.",
    "full": "Adds a 'Sanitize for AI' message-action and a personal tab to Teams. Run any chat message or pasted text through your sdlc.cc gateway's DLP before sharing with Copilot, Cowork, or external AI tools. Same backend as the sdlc.cc web app, browser extension, and Outlook/Excel add-ins."
  },
  "accentColor": "#0066ff",
  "staticTabs": [
    {
      "entityId": "sdlc-scrub-tab",
      "name": "Scrub",
      "contentUrl": "https://sdlc-cc-teams.pages.dev/tab.html",
      "websiteUrl": "https://sdlc-cc-teams.pages.dev/tab.html",
      "scopes": ["personal"]
    }
  ],
  "composeExtensions": [
    {
      "botId": "00000000-0000-0000-0000-000000000000",
      "canUpdateConfiguration": false,
      "commands": [
        {
          "id": "scrubMessage",
          "type": "action",
          "title": "Sanitize for AI",
          "description": "Scrub PII / credentials from this message body before reusing or forwarding to AI.",
          "initialRun": false,
          "fetchTask": true,
          "context": ["message", "compose", "commandBox"]
        }
      ],
      "messageHandlers": [],
      "type": "composeExtension"
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["sdlc-cc-teams.pages.dev", "*.sdlc.cc", "api.sdlc.cc"],
  "webApplicationInfo": {
    "id": "00000000-0000-0000-0000-000000000000",
    "resource": "api://sdlc-cc-teams.pages.dev/00000000-0000-0000-0000-000000000000"
  }
}
