# Teams iframes the tab inside teams.microsoft.com / *.teams.microsoft.com.
# Don't set X-Frame-Options DENY (would break the integration). Use
# CSP frame-ancestors to restrict instead.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/tab.html
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://res.cdn.office.net; img-src 'self' data:; connect-src 'self' https://api.sdlc.cc https://*.sdlc.cc http://localhost:8080; frame-ancestors https://teams.microsoft.com https://*.teams.microsoft.com https://teams.cloud.microsoft https://*.cloud.microsoft
