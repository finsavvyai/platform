{
  "dashboard": {
    "id": null,
    "title": "SDLC Alerts Status",
    "tags": ["sdlc", "alerts"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Alert Status",
        "type": "stat",
        "targets": [
          {
            "expr": "ALERTS{}",
            "legendFormat": "{{alertstate}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": "firing"},
                {"color": "green", "value": "resolved"}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Active Alerts by Severity",
        "type": "stat",
        "targets": [
          {
            "expr": "ALERTS{alertstate=\"firing\"}",
            "legendFormat": "{{severity}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": "warning"},
                {"color": "red", "value": "critical"}
              ]
            },
            "unit": "count"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Alerts Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(ALERTS{})[1h]",
            "legendFormat": "Alerts per hour"
          }
        ],
        "yAxes": [
          {
            "label": "Alerts per hour"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      }
    ],
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "refresh": "30s"
  }
}