{
  "name": "@sdlc/platform-workers",
  "version": "1.0.0",
  "description": "SDLC.ai Cloudflare Workers",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "tail": "wrangler tail --env production",
    "build": "tsc",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src/**/*.{ts,tsx,json,md}",
    "local:start": "wrangler local --env production",
    "local:persist": "wrangler local --persist --env production",
    "secrets:list": "wrangler secret list --env production",
    "secrets:put": "wrangler secret put",
    "kv:preview": "wrangler kv:preview",
    "kv:key": "wrangler kv:key",
    "r2:ls": "wrangler r2 object list STORAGE",
    "r2:sync": "wrangler r2 object sync ./local-data r2://STORAGE",
    "analytics:query": "wrangler analytics query",
    "queue:consumer": "wrangler queues consumer",
    "metrics": "wrangler metrics",
    "rollback": "wrangler rollback --env production",
    "pages:publish": "wrangler pages publish",
    "d1:execute": "wrangler d1 execute DB --command",
    "d1:migrate": "wrangler d1 migrations apply DB --remote",
    "d1:export": "wrangler d1 export DB --remote",
    "vectorize:query": "wrangler vectorize query",
    "diagnose": "wrangler diagnose",
    "whoami": "wrangler whoami",
    "clean": "rm -rf dist node_modules .wrangler",
    "predeploy": "npm run type-check && npm run lint && npm run test"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "~0.3.1",
    "@cloudflare/workers-types": "^4.20240208.0",
    "@sentry/cloudflare": "^7.100.1",
    "itty-router": "^4.0.27",
    "zod": "^3.22.4",
    "nanoid": "^5.0.4",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "openai": "^4.20.1",
    "anthropic": "^0.10.0",
    "aws-sdk": "^2.1510.0",
    "google-auth-library": "^9.4.1",
    "node-jose": "^2.2.0",
    "pino": "^8.17.2",
    "pino-cloudflare": "^5.0.0",
    "undici": "^6.6.2",
    "ws": "^8.16.0",
    "graphql": "^16.8.1",
    "@graphql-yoga/common": "^3.0.0",
    "jose": "^5.1.3",
    "cookie": "^0.6.0",
    "ua-parser-js": "^1.0.35",
    "mime-types": "^2.1.35",
    "sharp": "^0.33.1",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.6.0",
    "xlsx": "^0.18.5",
    "csv-parser": "^3.0.0",
    "archiver": "^6.0.1",
    "unzipper": "^0.10.14",
    "crypto-js": "^4.2.0",
    "tldts": "^6.1.34"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.5.10",
    "@types/cookie": "^0.6.0",
    "@types/mime-types": "^2.1.4",
    "@types/crypto-js": "^4.2.1",
    "@types/ua-parser-js": "^0.7.39",
    "@types/archiver": "^6.0.2",
    "@types/unzipper": "^0.10.9",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2",
    "wrangler": "^3.26.0",
    "wrangler.toml": "^0.2.0",
    "@cloudflare/workers-types": "^4.20240208.0",
    "miniflare": "^3.20240208.0",
    "workerd": "^1.20240208.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SDLC-ai/platform.git",
    "directory": "infra/cloudflare/workers"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "serverless",
    "edge",
    "ai",
    "rag",
    "sdlc"
  ],
  "author": {
    "name": "SDLC.ai Team",
    "email": "team@sdlc.ai",
    "url": "https://sdlc.ai"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SDLC-ai/platform/issues"
  },
  "homepage": "https://sdlc.ai",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "volta": {
    "node": "20.11.0",
    "npm": "10.2.4"
  }
}
