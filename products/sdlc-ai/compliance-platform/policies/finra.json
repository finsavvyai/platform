{
  "name": "finra-policy",
  "version": "1.5.0",
  "description": "FINRA compliance policy for financial services and securities",
  "framework": "FINRA",
  "risk_level": "critical",
  "retention_years": 7,
  "rules": [
    {
      "name": "communication_supervision",
      "description": "Supervise all business-related communications",
      "condition": {
        "type": "data_classification",
        "value": "business_communication"
      },
      "effect": "audit",
      "actions": {
        "supervision_required": true,
        "retention_years": 3,
        "audit_level": "critical",
        "review_required": true,
        "compliance_reporting": true
      }
    },
    {
      "name": "customer_information_protection",
      "description": "Protect customer financial information",
      "condition": {
        "type": "data_classification",
        "value": "customer_financial_data"
      },
      "effect": "transform",
      "actions": {
        "encryption_required": true,
        "access_controls": true,
        "audit_level": "critical",
        "transformations": ["encrypt_at_rest", "encrypt_in_transit", "audit_access"]
      },
      "on_violation": {
        "block": true,
        "alert": true,
        "escalation": "immediate"
      }
    },
    {
      "name": "trade_surveillance",
      "description": "Monitor trading activity for suspicious patterns",
      "condition": {
        "type": "data_classification",
        "value": "trading_data"
      },
      "effect": "audit",
      "actions": {
        "pattern_detection": true,
        "anomaly_detection": true,
        "audit_level": "critical",
        "retention_years": 6,
        "alert_on_suspicious": true
      }
    },
    {
      "name": "anti_money_laundering",
      "description": "Implement AML controls and monitoring",
      "condition": {
        "type": "data_classification",
        "value": "transaction_data"
      },
      "effect": "enhance",
      "actions": {
        "kyc_verification": true,
        "transaction_monitoring": true,
        "suspicious_activity_reporting": true,
        "audit_level": "critical",
        "threshold_monitoring": true
      }
    },
    {
      "name": "recordkeeping",
      "description": "Maintain required books and records",
      "condition": {
        "type": "data_classification",
        "value": ["trading_data", "customer_data", "business_communication"]
      },
      "effect": "enhance",
      "actions": {
        "retention_years": 6,
        "immutable_storage": true,
        "audit_level": "high",
        "indexing_required": true,
        "retrieval_capability": true
      }
    },
    {
      "name": "best_execution",
      "description": "Ensure best execution of customer orders",
      "condition": {
        "type": "data_classification",
        "value": "order_data"
      },
      "effect": "audit",
      "actions": {
        "execution_quality_monitoring": true,
        "venue_analysis": true,
        "audit_level": "high",
        "periodic_review": true
      }
    },
    {
      "name": "insider_trading_prevention",
      "description": "Prevent insider trading and information barriers",
      "condition": {
        "type": "data_classification",
        "value": "material_nonpublic_information"
      },
      "effect": "deny",
      "actions": {
        "information_barriers": true,
        "restricted_lists": true,
        "audit_level": "critical",
        "alert": true
      },
      "on_violation": {
        "block": true,
        "alert": true,
        "escalation": "immediate",
        "regulatory_reporting": true
      }
    },
    {
      "name": "suitability_obligations",
      "description": "Ensure investment recommendations are suitable",
      "condition": {
        "type": "data_classification",
        "value": "investment_recommendation"
      },
      "effect": "enhance",
      "actions": {
        "customer_profile_verification": true,
        "risk_assessment": true,
        "documentation_required": true,
        "audit_level": "high"
      }
    }
  ],
  "pii_patterns": {
    "account_number": {
      "pattern": "\\b\\d{8,17}\\b",
      "confidence": "medium",
      "action": "protect"
    },
    "ssn": {
      "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "confidence": "high",
      "action": "encrypt"
    },
    "cusip": {
      "pattern": "\\b[0-9]{3}[0-9A-Z]{5}[0-9]\\b",
      "confidence": "high",
      "action": "protect"
    }
  },
  "compliance_requirements": {
    "supervision": true,
    "recordkeeping": true,
    "customer_protection": true,
    "market_integrity": true,
    "anti_money_laundering": true,
    "cybersecurity": true,
    "business_continuity": true
  },
  "penalties": {
    "fines": true,
    "suspension": true,
    "expulsion": true,
    "censure": true,
    "restitution": true
  },
  "created_at": "2025-11-19T12:00:00Z",
  "updated_at": "2025-11-19T12:00:00Z",
  "author": "SDLC Compliance Team",
  "approved_by": "Chief Compliance Officer"
}
