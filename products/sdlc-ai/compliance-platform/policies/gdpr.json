{
  "name": "gdpr-policy",
  "version": "2.0.0",
  "description": "GDPR compliance policy for data protection and privacy",
  "framework": "GDPR",
  "risk_level": "critical",
  "retention_years": 7,
  "rules": [
    {
      "name": "data_subject_rights",
      "description": "Enforce data subject rights (access, rectification, erasure)",
      "condition": {
        "type": "data_classification",
        "value": "personal_data"
      },
      "effect": "enhance",
      "actions": {
        "enable_access_requests": true,
        "enable_rectification": true,
        "enable_erasure": true,
        "enable_portability": true,
        "audit_level": "high",
        "response_time_days": 30
      }
    },
    {
      "name": "consent_management",
      "description": "Require explicit consent for personal data processing",
      "condition": {
        "type": "data_classification",
        "value": "personal_data"
      },
      "effect": "allow",
      "actions": {
        "consent_required": true,
        "consent_granular": true,
        "consent_withdrawable": true,
        "audit_consent": true,
        "audit_level": "critical"
      }
    },
    {
      "name": "data_minimization",
      "description": "Collect only necessary personal data",
      "condition": {
        "type": "data_classification",
        "value": "personal_data"
      },
      "effect": "transform",
      "actions": {
        "minimize_collection": true,
        "purpose_limitation": true,
        "storage_limitation": true,
        "transformations": ["filter_unnecessary_fields", "anonymize_where_possible"]
      }
    },
    {
      "name": "cross_border_transfer",
      "description": "Restrict cross-border data transfers",
      "condition": {
        "type": "geographic_location",
        "value": ["non_eu", "non_adequate"]
      },
      "effect": "deny",
      "actions": {
        "require_adequacy_decision": true,
        "require_safeguards": true,
        "audit_level": "critical",
        "alert": true
      },
      "on_violation": {
        "block": true,
        "alert": true,
        "escalation": "immediate"
      }
    },
    {
      "name": "breach_notification",
      "description": "Notify authorities and subjects of data breaches",
      "condition": {
        "type": "data_classification",
        "value": "personal_data"
      },
      "effect": "enhance",
      "actions": {
        "breach_detection": true,
        "authority_notification_hours": 72,
        "subject_notification_required": true,
        "audit_level": "critical",
        "compliance_reporting": true
      }
    },
    {
      "name": "privacy_by_design",
      "description": "Implement privacy by design and default",
      "condition": {
        "type": "data_classification",
        "value": "personal_data"
      },
      "effect": "enhance",
      "actions": {
        "pseudonymization": true,
        "encryption": true,
        "access_controls": true,
        "audit_level": "high"
      }
    }
  ],
  "pii_patterns": {
    "email": {
      "pattern": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b",
      "confidence": "high",
      "action": "protect"
    },
    "phone": {
      "pattern": "\\b\\+?[1-9]\\d{1,14}\\b",
      "confidence": "medium",
      "action": "protect"
    },
    "ip_address": {
      "pattern": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
      "confidence": "medium",
      "action": "protect"
    }
  },
  "compliance_requirements": {
    "lawful_basis": true,
    "transparency": true,
    "data_subject_rights": true,
    "data_protection_officer": true,
    "impact_assessments": true,
    "security_measures": true
  },
  "penalties": {
    "administrative_fines": true,
    "max_fine_percentage": 4,
    "max_fine_amount": 20000000
  },
  "created_at": "2025-11-19T12:00:00Z",
  "updated_at": "2025-11-19T12:00:00Z",
  "author": "SDLC Compliance Team",
  "approved_by": "Data Protection Officer"
}
