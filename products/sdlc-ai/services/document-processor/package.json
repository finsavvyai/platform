{
  "name": "sdlc-document-processor",
  "version": "1.0.0",
  "description": "Advanced document processing service for SDLC.ai - PDF, Office docs, HTML extraction, chunking, and batch processing",
  "main": "app/index.js",
  "scripts": {
    "start": "node app/index.js",
    "dev": "nodemon app/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "lint": "eslint app/ --ext .js,.ts",
    "lint:fix": "eslint app/ --ext .js,.ts --fix",
    "build": "tsc",
    "docker:build": "docker build -t sdlc-document-processor .",
    "docker:run": "docker run -p 3005:3005 sdlc-document-processor"
  },
  "keywords": [
    "document-processing",
    "pdf-extraction",
    "ocr",
    "text-chunking",
    "office-documents",
    "html-parsing",
    "batch-processing",
    "sdlc-ai"
  ],
  "author": "SDLC.ai Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "bull": "^4.12.2",
    "ioredis": "^5.3.2",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^2.1.4",
    "tesseract.js": "^5.0.4",
    "mammoth": "^1.6.0",
    "xlsx": "^0.18.5",
    "pptxgenjs": "^3.12.0",
    "cheerio": "^1.0.0-rc.12",
    "turndown": "^7.1.2",
    "marked": "^9.1.6",
    "xml2js": "^0.6.2",
    "iconv-lite": "^0.6.3",
    "jschardet": "^3.0.0",
    "natural": "^6.9.0",
    "franc": "^6.1.0",
    "unidecode": "^0.1.8",
    "he": "^1.2.0",
    "sanitize-html": "^2.11.0",
    "sharp": "^0.32.6",
    "imagemagick": "^0.1.3",
    "fast-csv": "^4.3.6",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "winston-elasticsearch": "^0.17.4",
    "prom-client": "^15.0.0",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "aws-sdk": "^2.1499.0",
    "minio": "^7.1.3",
    "axios": "^1.6.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/multer": "^1.4.11",
    "@types/bull": "^4.10.0",
    "@types/xml2js": "^0.4.14",
    "@types/natural": "^5.1.5",
    "@types/uuid": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node-cron": "^3.0.11",
    "@types/lodash": "^4.14.202",
    "@types/mime-types": "^2.1.4",
    "typescript": "^5.2.2",
