{
  "name": "sdlc-realtime-service",
  "version": "1.0.0",
  "description": "Real-time collaboration service for SDLC.ai with WebSocket support and live features",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@types/ws": "^8.5.10",
    "ws": "^8.16.0",
    "fastify": "^4.24.3",
    "@fastify/cors": "^8.4.2",
    "@fastify/websocket": "^10.0.1",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.1",
    "joi": "^17.11.0",
    "lodash": "^4.17.21",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.7",
    "@types/lodash": "^4.14.202",
    "typescript": "^5.3.3",
    "tsx": "^4.6.2",
    "tsc-alias": "^1.8.8",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  },
  "keywords": [
    "websocket",
    "realtime",
    "collaboration",
    "sdlc",
    "ai",
    "live"
