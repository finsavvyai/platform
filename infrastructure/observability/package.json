{
  "name": "@finsavvyai/observability-adapters",
  "version": "0.1.0",
  "private": true,
  "description": "Concrete sink adapters (stdout, R2, Datadog), token-counter flush exporter, and health-check helper. Plugs into @finsavvyai/telemetry sink interfaces.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sinks/stdout": {
      "types": "./dist/sinks/stdout.d.ts",
      "import": "./dist/sinks/stdout.js"
    },
    "./sinks/r2": {
      "types": "./dist/sinks/r2.d.ts",
      "import": "./dist/sinks/r2.js"
    },
    "./sinks/datadog": {
      "types": "./dist/sinks/datadog.d.ts",
      "import": "./dist/sinks/datadog.js"
    },
    "./sinks/factory": {
      "types": "./dist/sinks/factory.d.ts",
      "import": "./dist/sinks/factory.js"
    },
    "./exporters/token-counter-flush": {
      "types": "./dist/exporters/token-counter-flush.d.ts",
      "import": "./dist/exporters/token-counter-flush.js"
    },
    "./health/health-check": {
      "types": "./dist/health/health-check.d.ts",
      "import": "./dist/health/health-check.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo coverage"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "peerDependencies": {
    "@finsavvyai/telemetry": "workspace:*"
  },
  "devDependencies": {
    "@finsavvyai/telemetry": "workspace:*",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "1.6.1",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
