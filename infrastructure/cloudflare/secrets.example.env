# Cloudflare Worker secrets manifest for @finsavvyai/ai-gateway.
#
# DO NOT commit real values. This file lists names and provenance ONLY.
# Set each via: wrangler secret put <NAME> --env <staging|production>
#
# After setting, verify with: wrangler secret list --env <env>

# ---------------------------------------------------------------------------
# Auth — JWT verification
# ---------------------------------------------------------------------------
# PEM-encoded RSA public key (or HS256 shared secret) used to verify Bearer
# tokens at the edge. Source: @finsavvyai/auth issuer key rotation procedure.
# Format: full PEM including BEGIN/END markers, newlines preserved.
JWT_PUBLIC_KEY=

# ---------------------------------------------------------------------------
# Billing — webhook signature verification
# ---------------------------------------------------------------------------
# Stripe webhook signing secret. Source: Stripe Dashboard ->
#   Developers -> Webhooks -> <endpoint> -> Signing secret (whsec_...).
# One per env; the staging value MUST be from a Stripe test-mode endpoint.
STRIPE_WEBHOOK_SECRET=

# LemonSqueezy webhook signing secret. Source: LemonSqueezy Dashboard ->
#   Settings -> Webhooks -> <endpoint> -> Signing secret.
# Used by @finsavvyai/billing's webhook verifier (round-1 hardened module).
LEMONSQUEEZY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Observability — audit sink
# ---------------------------------------------------------------------------
# Only required when FINSAVVY_AUDIT_SINK=datadog (default for production).
# Source: Datadog -> Organization Settings -> API Keys -> create key with
# scope 'logs_write'. Restrict by IP if your account plan allows.
FINSAVVY_AUDIT_DD_API_KEY=
