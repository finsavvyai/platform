---
interface Props {
  headline: string;
  subhead: string;
}

const { headline, subhead } = Astro.props;
---

<section class="max-w-3xl">
  <p
    class="mb-6 text-sm font-medium uppercase tracking-widest text-ink-900/60
           dark:text-ink-50/60"
  >
    FinsavvyAI
  </p>
  <h1
    class="text-balance text-4xl font-semibold leading-[1.05] tracking-tightish
           sm:text-5xl lg:text-6xl"
  >
    {headline}
  </h1>
  <p
    class="mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-ink-900/80
           sm:text-xl dark:text-ink-50/80"
  >
    {subhead}
  </p>
</section>
