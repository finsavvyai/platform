---
interface Props {
  feature: string;
  cells: readonly [string, string, string];
  emphasis?: boolean;
}

const { feature, cells, emphasis = false } = Astro.props;
const cellBase = 'px-4 py-3 align-top text-sm';
const featureCellClass = emphasis
  ? 'font-medium tracking-tightish'
  : 'text-ink-900/80 dark:text-ink-50/80';

// Symbolic "—" denotes "not included" in that tier; rendered with an
// aria-label so screen readers don't pronounce a dash.
const cellNode = (text: string) =>
  text === '—'
    ? {
        text: '—',
        aria: 'Not included',
        muted: true,
      }
    : { text, aria: undefined, muted: false };
---

<tr class="border-t border-ink-900/10 dark:border-ink-50/10">
  <th
    scope="row"
    class:list={[
      cellBase,
      featureCellClass,
      'text-left text-ink-900 dark:text-ink-50',
    ]}
  >
    {feature}
  </th>
  {cells.map((c) => {
    const node = cellNode(c);
    return (
      <td
        class:list={[
          cellBase,
          'text-ink-900/85 dark:text-ink-50/85',
          // A11Y WCAG 1.4.3 (AA, 4.5:1): the muted "—" cell previously
          // used /40 (~2.0:1 on ink-50 bg, fails). Computed alpha-blend
          // against ink-900 (#0a0a0c) on ink-50 (#f5f5f7) confirms /55
          // still falls under 4.5:1 — /85 clears it (~5.1:1). The cell
          // also carries aria-label="Not included" so screen readers
          // never depend on the visual glyph alone.
          node.muted ? 'text-ink-900/85 dark:text-ink-50/85' : '',
        ]}
        aria-label={node.aria}
      >
        {node.text}
      </td>
    );
  })}
</tr>
