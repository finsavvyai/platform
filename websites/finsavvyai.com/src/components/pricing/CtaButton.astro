---
interface Props {
  href: string;
  variant: 'primary' | 'secondary';
  label: string;
  ariaLabel?: string;
}

const { href, variant, label, ariaLabel } = Astro.props;

const styles = {
  primary:
    'bg-ink-900 text-ink-50 hover:bg-ink-900/90 ' +
    'dark:bg-ink-50 dark:text-ink-900 dark:hover:bg-ink-50/90',
  secondary:
    'border border-ink-900/15 bg-transparent text-ink-900 ' +
    'hover:border-ink-900/40 dark:border-ink-50/20 dark:text-ink-50 ' +
    'dark:hover:border-ink-50/50',
} as const;
---

<a
  href={href}
  aria-label={ariaLabel ?? label}
  class:list={[
    'inline-flex items-center justify-center rounded-full px-5 py-2.5',
    'text-sm font-medium tracking-tightish transition-colors',
    'focus:outline-none focus:ring-2 focus:ring-ink-900/30',
    'dark:focus:ring-ink-50/40',
    styles[variant],
  ]}
>
  {label}
</a>
