---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Infrastructure for autonomous AI software systems.',
} = Astro.props;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://finsavvyai.com" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <style>
      /* A11Y: respect prefers-reduced-motion across the site without
         requiring a per-element motion-safe: prefix. Disables non-essential
         transitions/animations only when the user has opted in via OS. */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </head>
  <body
    class="min-h-screen bg-ink-50 text-ink-900 antialiased
           selection:bg-ink-900 selection:text-ink-50
           dark:bg-ink-900 dark:text-ink-50"
  >
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2
             focus:rounded focus:bg-ink-900 focus:px-3 focus:py-1.5
             focus:text-ink-50 focus:outline focus:outline-2
             focus:outline-offset-2 focus:outline-ink-900
             dark:focus:bg-ink-50 dark:focus:text-ink-900
             dark:focus:outline-ink-50"
    >
      Skip to content
    </a>
    <header class="border-b border-ink-900/10 dark:border-ink-50/10">
      <nav
        aria-label="Primary"
        class="mx-auto flex max-w-6xl items-center justify-between
               px-6 py-4"
      >
        <a
          href="/"
          class="text-sm font-semibold tracking-tightish"
        >
          FinsavvyAI
        </a>
        <a
          href="/pricing"
          class="text-sm text-ink-900/70 hover:text-ink-900
                 dark:text-ink-50/70 dark:hover:text-ink-50"
        >
          Pricing
        </a>
      </nav>
    </header>
    <main id="main" class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
      <slot />
    </main>
    <footer
      class="border-t border-ink-900/10 mt-16 dark:border-ink-50/10"
    >
      <div
        class="mx-auto flex max-w-6xl flex-col gap-2 px-6 py-8 text-sm
               text-ink-900/70 sm:flex-row sm:items-center
               sm:justify-between dark:text-ink-50/70"
      >
        <p>&copy; {year} FinsavvyAI. All rights reserved.</p>
        <nav aria-label="Footer">
          <ul class="flex flex-wrap gap-4">
            <li>
              <a
                href="/privacy"
                class="hover:text-ink-900 dark:hover:text-ink-50"
              >
                Privacy
              </a>
            </li>
            <li>
              <a
                href="/pricing"
                class="hover:text-ink-900 dark:hover:text-ink-50"
              >
                Pricing
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </footer>
  </body>
</html>
