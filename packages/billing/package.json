{
  "name": "@finsavvyai/billing",
  "version": "0.1.0",
  "description": "Billing primitives: multi-gateway webhook verification (Stripe, LemonSqueezy), provider-agnostic charge/refund/subscription orchestration, invoicing, entitlements.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "1.6.1"
  }
}
