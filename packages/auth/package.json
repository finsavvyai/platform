{
  "name": "@finsavvyai/auth",
  "version": "0.1.0",
  "description": "Auth primitives: OAuth, JWT, MFA, SAML, SCIM, RBAC.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "jose": "5.10.0"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "restricted"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "1.6.1"
  }
}
