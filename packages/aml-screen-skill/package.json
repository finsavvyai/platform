{
  "name": "@finsavvyai/aml-screen-skill",
  "version": "0.1.0",
  "description": "Metered MCP skill exposing AMLIQ sanctions screening, gated by billing entitlements.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "amliq-screen-skill": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@finsavvyai/aml-screen-client": "workspace:*",
    "@finsavvyai/billing": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finsavvyai/platform.git",
    "directory": "packages/aml-screen-skill"
  }
}
