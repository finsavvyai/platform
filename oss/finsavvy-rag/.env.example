# ───────────────────────────────────────────────
# finsavvy-rag — .env (example, copy to .env)
# ───────────────────────────────────────────────
# All values below are PLACEHOLDERS. Replace with your own.
# Never commit a populated .env to source control.

# Optional Hugging Face token (only required for gated embedding models)
HF_TOKEN=REPLACE_WITH_YOUR_HF_TOKEN_OR_LEAVE_BLANK

# RAG Postgres + pgvector
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=finsavvy_rag
PGUSER=REPLACE_WITH_DB_USER
PGPASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# Embedding model (CPU-friendly default)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Gateway bind
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=9000

# Upstream selection: "local" | "lb"
GATEWAY_UPSTREAM=local
LLM_LOCAL_URL=http://127.0.0.1:8000
LLM_LB_URL=http://127.0.0.1:8100

# Caddy / Nginx load-balancer upstream pool (comma-separated host:port).
# Replace with the IPs/hostnames of your own OpenAI-compatible inference nodes.
LLM_UPSTREAMS=node-a.example.local:8000,node-b.example.local:8000,127.0.0.1:8000
