{
  auto_https off
}

:8100 {
  @api path /v1/*

  route {
    # Replace with the IPs/hostnames of your own OpenAI-compatible inference nodes.
    reverse_proxy @api {
      # Health-checking + LB
      to node-a.example.local:8000 node-b.example.local:8000 127.0.0.1:8000
      lb_policy least_conn
      lb_try_duration 5s
      lb_try_interval 250ms
      health_uri /v1/models
      health_timeout 2s
      fail_duration 5s
    }
  }

  # Basic CORS for dev
  header {
    Access-Control-Allow-Origin  *
    Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Access-Control-Allow-Headers "*"
  }
}
