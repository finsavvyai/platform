{
  "name": "@tokenforge/dashboard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold error",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler pages deploy .svelte-kit/cloudflare"
  },
  "dependencies": {
    "@tokenforge/db": "workspace:*",
    "@tokenforge/protocol": "workspace:*",
    "better-auth": "^1.0.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@sveltejs/adapter-cloudflare": "^4.0.0",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.71.0"
  }
}
