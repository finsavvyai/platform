{
  "name": "tokenforge-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "TokenForge — DBSC-aligned session security primitive. Customer + Workforce modes.",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "deploy:api": "pnpm --filter ./apps/api deploy",
    "deploy:dashboard": "pnpm --filter ./apps/dashboard deploy",
    "deploy:marketing": "pnpm --filter ./apps/marketing deploy"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "workspaces": ["apps/*", "packages/*"]
}
