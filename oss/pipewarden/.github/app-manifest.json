{
  "name": "PipeWarden",
  "url": "https://pipewarden.com",
  "hook_attributes": {
    "url": "https://app.pipewarden.com/webhooks/github",
    "active": true
  },
  "redirect_url": "https://app.pipewarden.com/auth/github/callback",
  "callback_urls": [
    "https://app.pipewarden.com/auth/github/callback"
  ],
  "setup_url": "https://app.pipewarden.com/setup",
  "setup_on_update": true,
  "description": "AI-powered CI/CD pipeline security scanner — detects secrets, vulnerable deps, and dangerous permissions in GitHub Actions workflows.",
  "public": true,
  "default_events": [
    "push",
    "pull_request",
    "workflow_run",
    "check_run",
    "check_suite"
  ],
  "default_permissions": {
    "actions": "read",
    "checks": "write",
    "contents": "read",
    "pull_requests": "write",
    "security_events": "write",
    "statuses": "write",
    "metadata": "read"
  }
}
