# PipeWarden Environment Configuration
# Copy to .env and fill in values

# Server
PIPEWARDEN_SERVER_PORT=8080
PIPEWARDEN_LOGGING_LEVEL=info

# Database — Postgres connection string (Neon or Supabase recommended)
# Example: postgres://user:pass@ep-xyz.us-east-2.aws.neon.tech/pipewarden?sslmode=require
PIPEWARDEN_DATABASE_URL=

# Credential vault key — 32 random bytes base64: openssl rand -base64 32
PIPEWARDEN_VAULT_KEY=

# Cloudflare Tunnel — obtain with: cloudflared tunnel token <tunnel-id>
CLOUDFLARE_TUNNEL_TOKEN=

# Claude AI analysis
CLAUDE_API_KEY=

# LemonSqueezy billing
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# GitHub App
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_BASE_URL=https://api.github.com

# SIEM integrations (optional)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#security-alerts
PAGERDUTY_INTEGRATION_KEY=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Dashboard URL
PIPEWARDEN_DASHBOARD_URL=https://app.pipewarden.dev
