{
  "framework": "PCI-DSS",
  "version": "4.0",
  "published": "2022-03-31",
  "effective": "2025-03-31",
  "source": "PCI Security Standards Council, Payment Card Industry Data Security Standard v4.0",
  "description": "PCI DSS v4.0 requirements relevant to CI/CD pipeline security, mapped to PipeWarden signals.",
  "controls": [
    {
      "id": "3.5.1",
      "name": "PAN is rendered unreadable anywhere it is stored",
      "pipewarden_signals": ["dlp.exposed_credentials", "policy.no_plaintext_secrets"],
      "evidence_type": ["scan_history"]
    },
    {
      "id": "6.2.3",
      "name": "Bespoke and custom software is reviewed prior to release",
      "pipewarden_signals": ["policy.require_review_count", "policy.require_sast"],
      "evidence_type": ["policy_evaluation_log"]
    },
    {
      "id": "6.3.1",
      "name": "Security vulnerabilities are identified and managed",
      "pipewarden_signals": ["policy.require_dependency_scan", "heuristic.vulnerability_scan"],
      "evidence_type": ["scan_history"]
    },
    {
      "id": "6.4.2",
      "name": "Web application attack protection",
      "pipewarden_signals": ["policy.require_sast", "claude.injection_analysis"],
      "evidence_type": ["policy_evaluation_log"]
    },
    {
      "id": "7.2.5",
      "name": "All application and system accounts limit access",
      "pipewarden_signals": ["policy.require_branch_protection", "policy.block_force_push_main"],
      "evidence_type": ["policy_evaluation_log"]
    },
    {
      "id": "10.2.1",
      "name": "Audit logs are enabled and capture required events",
      "pipewarden_signals": ["audit.hmac_chained", "siem.forwarded_events"],
      "evidence_type": ["audit_webhook", "siem_integration"]
    },
    {
      "id": "11.3.1",
      "name": "Internal vulnerability scans at least every three months",
      "pipewarden_signals": ["scan.scheduled"],
      "evidence_type": ["scheduled_scan_log"]
    }
  ]
}
