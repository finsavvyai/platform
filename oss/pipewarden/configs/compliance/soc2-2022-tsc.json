{
  "framework": "SOC2",
  "version": "2022-TSC",
  "published": "2022-01-01",
  "source": "AICPA Trust Services Criteria 2017 with 2022 points-of-focus revision",
  "description": "SOC 2 Trust Services Criteria mapped to PipeWarden finding categories. Use to demonstrate CI/CD control coverage during SOC 2 Type II audits.",
  "controls": [
    {
      "id": "CC6.1",
      "name": "Logical and physical access controls",
      "points_of_focus": ["Access review", "Credential management", "Privileged access"],
      "pipewarden_signals": ["dlp.exposed_credentials", "policy.no_plaintext_secrets", "policy.require_branch_protection"],
      "evidence_type": ["finding_export_sarif", "audit_webhook"]
    },
    {
      "id": "CC6.6",
      "name": "Protection against external and internal threats",
      "points_of_focus": ["Vulnerability identification", "Vulnerability remediation"],
      "pipewarden_signals": ["heuristic.vulnerability_scan", "claude.code_injection", "policy.require_sast"],
      "evidence_type": ["finding_export_sarif", "scan_history"]
    },
    {
      "id": "CC6.7",
      "name": "Restrict transmission, movement, and removal of information",
      "points_of_focus": ["Data in transit", "Data at rest"],
      "pipewarden_signals": ["policy.require_tls_env", "vault.aes256_encryption"],
      "evidence_type": ["config_audit"]
    },
    {
      "id": "CC6.8",
      "name": "Prevent or detect and act upon unauthorized software",
      "points_of_focus": ["Change management", "Unauthorized software"],
      "pipewarden_signals": ["policy.pin_action_shas", "policy.no_third_party_unpinned", "policy.require_signed_artifacts"],
      "evidence_type": ["policy_evaluation_log"]
    },
    {
      "id": "CC7.1",
      "name": "Detection of security events",
      "points_of_focus": ["Monitoring", "Detection"],
      "pipewarden_signals": ["siem.forwarded_events", "audit.hmac_chained"],
      "evidence_type": ["audit_webhook", "siem_integration"]
    },
    {
      "id": "CC7.2",
      "name": "Analyze security events",
      "points_of_focus": ["Event triage", "Root cause analysis"],
      "pipewarden_signals": ["claude.severity_analysis", "dashboard.finding_history"],
      "evidence_type": ["finding_history", "ai_analysis_log"]
    },
    {
      "id": "CC8.1",
      "name": "Change management",
      "points_of_focus": ["Change authorization", "Change testing"],
      "pipewarden_signals": ["policy.require_tests", "policy.require_approval_gate", "policy.require_review_count"],
      "evidence_type": ["policy_evaluation_log"]
    }
  ]
}
