{
  "framework": "HITRUST",
  "version": "11.3.0-CSF",
  "published": "2024-01-01",
  "source": "HITRUST Common Security Framework (CSF) v11.3.0",
  "description": "HITRUST CSF control references relevant to CI/CD security. HITRUST inherits from HIPAA, NIST CSF, ISO 27001. Use with HITRUST r2 assessments.",
  "controls": [
    {
      "id": "01.a",
      "name": "Access Control Policy",
      "pipewarden_signals": ["policy.require_branch_protection", "policy.require_approval_gate"],
      "evidence_type": ["policy_evaluation_log"]
    },
    {
      "id": "06.c",
      "name": "Protection of Organisational Records",
      "pipewarden_signals": ["vault.aes256_encryption", "audit.hmac_chained"],
      "evidence_type": ["config_audit", "audit_webhook"]
    },
    {
      "id": "06.d",
      "name": "Data Protection and Privacy of Personal Information",
      "pipewarden_signals": ["dlp.exposed_credentials", "policy.require_pii_scan"],
      "evidence_type": ["scan_history"]
    },
    {
      "id": "09.s",
      "name": "Information Exchange Policies and Procedures",
      "pipewarden_signals": ["policy.require_tls_env"],
      "evidence_type": ["policy_evaluation_log"]
    },
    {
      "id": "10.m",
      "name": "Control of Technical Vulnerabilities",
      "pipewarden_signals": ["policy.require_dependency_scan", "heuristic.vulnerability_scan"],
      "evidence_type": ["scan_history"]
    },
    {
      "id": "11.a",
      "name": "Reporting Information Security Events",
      "pipewarden_signals": ["siem.forwarded_events", "webhook.alert_dispatched"],
      "evidence_type": ["audit_webhook"]
    }
  ]
}
