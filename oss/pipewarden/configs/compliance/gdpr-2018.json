{
  "framework": "GDPR",
  "version": "2018",
  "published": "2018-05-25",
  "source": "Regulation (EU) 2016/679 General Data Protection Regulation",
  "description": "GDPR articles relevant to software supply chain and CI/CD security, mapped to PipeWarden signals.",
  "controls": [
    {
      "id": "Art.25",
      "name": "Data protection by design and by default",
      "pipewarden_signals": ["vault.aes256_encryption", "policy.no_plaintext_secrets"],
      "evidence_type": ["config_audit", "policy_evaluation_log"]
    },
    {
      "id": "Art.32(1)(a)",
      "name": "Pseudonymisation and encryption of personal data",
      "pipewarden_signals": ["vault.aes256_encryption", "policy.require_tls_env"],
      "evidence_type": ["config_audit"]
    },
    {
      "id": "Art.32(1)(b)",
      "name": "Ability to ensure confidentiality, integrity, availability",
      "pipewarden_signals": ["policy.require_signed_artifacts", "dlp.exposed_credentials"],
      "evidence_type": ["policy_evaluation_log", "scan_history"]
    },
    {
      "id": "Art.32(1)(d)",
      "name": "Regular testing and evaluation of technical measures",
      "pipewarden_signals": ["scan.scheduled", "scan.history_exported"],
      "evidence_type": ["scheduled_scan_log"]
    },
    {
      "id": "Art.33",
      "name": "Notification of a personal data breach",
      "pipewarden_signals": ["siem.forwarded_events", "webhook.alert_dispatched"],
      "evidence_type": ["audit_webhook", "alert_history"]
    }
  ]
}
