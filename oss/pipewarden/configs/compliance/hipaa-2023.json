{
  "framework": "HIPAA",
  "version": "2023",
  "published": "2023-01-01",
  "source": "HIPAA Security Rule 45 CFR §164.308-164.312",
  "description": "HIPAA Security Rule controls mapped to PipeWarden signals. Use for BAA attestations and Security Risk Analysis (SRA) evidence.",
  "controls": [
    {
      "id": "164.308(a)(1)(ii)(A)",
      "name": "Risk Analysis",
      "category": "Administrative Safeguards",
      "pipewarden_signals": ["heuristic.risk_score", "claude.severity_analysis"],
      "evidence_type": ["scan_history", "ai_analysis_log"]
    },
    {
      "id": "164.308(a)(3)(ii)(B)",
      "name": "Workforce Clearance Procedure",
      "category": "Administrative Safeguards",
      "pipewarden_signals": ["policy.require_review_count", "policy.require_approval_gate"],
      "evidence_type": ["policy_evaluation_log"]
    },
    {
      "id": "164.308(a)(5)(ii)(B)",
      "name": "Protection from malicious software",
      "category": "Administrative Safeguards",
      "pipewarden_signals": ["policy.no_curl_pipe_bash", "policy.pin_action_shas"],
      "evidence_type": ["policy_evaluation_log"]
    },
    {
      "id": "164.308(a)(8)",
      "name": "Evaluation (periodic technical evaluation)",
      "category": "Administrative Safeguards",
      "pipewarden_signals": ["scan.scheduled", "scan.history_exported"],
      "evidence_type": ["scan_history", "scheduled_scan_log"]
    },
    {
      "id": "164.312(a)(2)(iv)",
      "name": "Encryption and Decryption",
      "category": "Technical Safeguards",
      "pipewarden_signals": ["vault.aes256_encryption", "policy.require_tls_env"],
      "evidence_type": ["config_audit"]
    },
    {
      "id": "164.312(b)",
      "name": "Audit Controls",
      "category": "Technical Safeguards",
      "pipewarden_signals": ["audit.hmac_chained", "siem.forwarded_events"],
      "evidence_type": ["audit_webhook", "siem_integration"]
    },
    {
      "id": "164.312(c)(1)",
      "name": "Integrity",
      "category": "Technical Safeguards",
      "pipewarden_signals": ["policy.require_signed_commits", "policy.require_signed_artifacts"],
      "evidence_type": ["policy_evaluation_log"]
    },
    {
      "id": "164.312(e)(1)",
      "name": "Transmission Security",
      "category": "Technical Safeguards",
      "pipewarden_signals": ["policy.require_tls_env"],
      "evidence_type": ["policy_evaluation_log"]
    }
  ]
}
