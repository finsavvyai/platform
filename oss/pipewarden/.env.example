# PipeWarden environment variables
# Use this as a Docker Compose .env file or export the values in your shell.

# Server
PIPEWARDEN_SERVER_PORT=8080

# Database
PIPEWARDEN_DATABASE_DRIVER=sqlite
PIPEWARDEN_DATABASE_PATH=pipewarden.db
PIPEWARDEN_DATABASE_URL=

# Vault
# Required before you persist provider credentials.
PIPEWARDEN_VAULT_KEY=replace-with-a-long-random-secret

# Auth
PIPEWARDEN_AUTH_JWTSECRET=change-me-to-a-random-secret
PIPEWARDEN_AUTH_TOKENDURATION=24h

# Claude analysis
CLAUDE_API_KEY=
PIPEWARDEN_ANTHROPIC_MODEL=claude-sonnet-4-20250514
PIPEWARDEN_ANTHROPIC_BASEURL=https://api.anthropic.com

# Claw Gateway (AI gateway for security analysis)
CLAW_API_KEY=
CLAW_PROJECT_ID=

# GitHub App
GITHUB_APP_SLUG=
GITHUB_APP_ID=
# The Docker compose file mounts GITHUB_PRIVATE_KEY_DIR to /run/secrets inside the container.
GITHUB_PRIVATE_KEY_DIR=.
GITHUB_PRIVATE_KEY_PATH=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_BASE_URL=https://api.github.com

# LemonSqueezy billing
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Feature flags
PIPEWARDEN_HOSTED_MODE=false
PIPEWARDEN_EXPERIMENTAL_PROVIDERS=false

# Logging
PIPEWARDEN_LOGGING_LEVEL=info
PIPEWARDEN_LOGGING_JSON=false

# ─── Cloudflare deploy (scripts/deploy.sh) ──────────────────────────────
# Get token: https://dash.cloudflare.com/profile/api-tokens
#   Permissions: Account: Workers Scripts (Edit), Workers Tail (Read),
#                Account Settings (Read), Containers (Edit)
CLOUDFLARE_API_TOKEN=
# Get account ID: dash.cloudflare.com → top-right account menu
CLOUDFLARE_ACCOUNT_ID=
# Worker name (must match wrangler.toml `name` field)
CLOUDFLARE_WORKER_NAME=pipewarden
# Docker image name pushed to CF managed registry
PIPEWARDEN_IMAGE=pipewarden/pipewarden
PIPEWARDEN_TAG=latest
