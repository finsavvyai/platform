{
    "name": "udp/composer-plugin",
    "type": "composer-plugin",
    "description": "Composer plugin for Universal Dependency Platform (UDP) integration",
    "version": "1.0.0",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "UDP Team",
            "email": "team@universaldependency.com",
            "homepage": "https://universaldependency.com"
        }
    ],
    "homepage": "https://universaldependency.com",
    "keywords": ["udp", "dependency-management", "cross-language", "composer", "php"],
    "require": {
        "php": ">=8.0",
        "composer-plugin-api": "^2.0",
        "symfony/yaml": "^6.0",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/console": "^6.0",
        "symfony/filesystem": "^6.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Udp\\ComposerPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Udp\\ComposerPlugin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "class": "Udp\\ComposerPlugin\\UdpPlugin",
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "bin": [
        "bin/udp"
    ],
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src tests",
        "cs-check": "phpcs src tests",
        "cs-fix": "phpcbf src tests"
    }
}