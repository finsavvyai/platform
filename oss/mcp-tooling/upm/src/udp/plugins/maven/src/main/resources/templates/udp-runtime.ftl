    public static class PythonModule extends BridgeModule {
        private Object pythonModule;

        public PythonModule(String moduleName) {
            super(moduleName);
            loadPythonModule();
        }

        private void loadPythonModule() {
            String bridgeType = System.getProperty("udp.python.bridge", "jython");

            switch (bridgeType) {
                case "jython":
                    loadViaJython();
                    break;
                case "graalvm":
                    loadViaGraalVM();
                    break;
                default:
                    loadViaSubprocess();
            }
        }

        private void loadViaJython() {
            try {
                // Use Jython to load Python module
                Class<?> interpreterClass = Class.forName("org.python.util.PythonInterpreter");
                Object interpreter = interpreterClass.getDeclaredConstructor().newInstance();

                Method exec = interpreterClass.getMethod("exec", String.class);
                exec.invoke(interpreter, "import " + moduleName);

                Method get = interpreterClass.getMethod("get", String.class);
                this.pythonModule = get.invoke(interpreter, moduleName);

            } catch (Exception e) {
                throw new RuntimeException("Failed to load Python module via Jython: " + moduleName, e);
            }
        }

        private void loadViaGraalVM() {
            try {
                // Use GraalVM to load Python module
                Class<?> contextClass = Class.forName("org.graalvm.polyglot.Context");
                Method newBuilder = contextClass.getMethod("newBuilder", String[].class);
                Object builder = newBuilder.invoke(null, (Object) new String[]{"python"});

                Method build = builder.getClass().getMethod("build");
                Object context = build.invoke(builder);

                Method eval = contextClass.getMethod("eval", String.class, String.class);
                this.pythonModule = eval.invoke(context, "python", "import " + moduleName + "; " + moduleName);

            } catch (Exception e) {
                throw new RuntimeException("Failed to load Python module via GraalVM: " + moduleName, e);
            }
        }

