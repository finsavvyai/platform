        private void loadRustCrate() {
            // Load Rust library via JNI
            try {
                System.loadLibrary("udp_" + moduleName.replace("-", "_"));
                this.nativeHandle = initializeNative(moduleName);
            } catch (UnsatisfiedLinkError e) {
                throw new RuntimeException("Failed to load Rust crate: " + moduleName, e);
