{
  "name": "@udp/npm-plugin",
  "version": "1.0.0",
  "description": "NPM plugin for Universal Dependency Platform (UDP) integration",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "udp": "bin/udp.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "node lib/postinstall.js"
  },
  "keywords": [
    "udp",
    "dependency-management",
    "cross-language",
    "npm",
    "javascript",
    "typescript"
  ],
  "author": "UDP Team <team@universaldependency.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/universal-dependency-platform/udp-npm-plugin.git"
  },
  "homepage": "https://universaldependency.com",
  "bugs": {
    "url": "https://github.com/universal-dependency-platform/udp-npm-plugin/issues"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "yaml": "^2.3.4",
    "fs-extra": "^11.1.1",
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "semver": "^7.5.4",
    "tar": "^6.2.0",
    "cross-spawn": "^7.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/fs-extra": "^11.0.4",
    "@types/semver": "^7.5.4",
    "@types/tar": "^6.1.8",
    "@types/cross-spawn": "^6.0.6",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "files": [
    "lib/**/*",
    "bin/**/*",
    "templates/**/*"
  ]
}