{
  "name": "upm-api-gateway",
  "version": "1.0.0",
  "description": "UPM API Gateway - Cloudflare Worker for Universal Dependency Platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "kv:namespace:create": "wrangler kv:namespace create",
    "kv:namespace:preview": "wrangler kv:namespace create --preview",
    "d1:create": "wrangler d1 create",
    "d1:migrate": "wrangler d1 migrations apply",
    "r2:create": "wrangler r2 bucket create",
    "queue:create": "wrangler queues create",
    "secret:put": "wrangler secret put",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "build": "esbuild src/index.js --bundle --format=esm --outfile=dist/index.js --minify",
    "size": "wrangler tail --format=json"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "api-gateway",
    "dependency-management",
    "security",
    "upm"
  ],
  "author": "Universal Dependency Platform",
  "license": "MIT",
  "dependencies": {
    "itty-router": "^4.0.25",
    "jose": "^5.2.0",
    "cookie": "^0.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231025.0",
    "wrangler": "^3.22.1",
    "typescript": "^5.2.2",
    "esbuild": "^0.19.5",
    "vitest": "^0.34.6",
    "eslint": "^8.52.0",
    "prettier": "^3.0.3",
    "@types/cookie": "^0.5.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/universal-dependency-platform/upm-api-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/universal-dependency-platform/upm-api-gateway/issues"
  },
  "homepage": "https://upm.plus"
}
