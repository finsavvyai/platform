{
  "name": "@mcpoverflow/ai-engine",
  "version": "1.0.0",
  "description": "OpenHands AI integration engine for MCPoverflow",
  "main": "dist/server.js",
  "types": "dist/openhands-adapter.d.ts",
  "scripts": {
    "dev": "tsx watch server.ts",
    "dev:worker": "wrangler dev",
    "build": "tsc",
    "build:worker": "esbuild src/worker.ts --bundle --outfile=dist/worker.js --format=esm --platform=browser",
    "start": "node dist/server.js",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "jest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "cf:create-kv": "wrangler kv:namespace create AI_JOBS",
    "cf:tail": "wrangler tail"
  },
  "keywords": [
    "openhands",
    "ai",
    "mcp",
    "connector",
    "code-generation",
    "cloudflare",
    "workers"
  ],
  "author": "MCPoverflow",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "hono": "^3.11.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.22.1",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
