{
  "name": "@mcpoverflow/web-skills",
  "version": "0.1.0",
  "description": "Website-as-MCP skills. Site-specific browser actions generated as MCP tools with hardened mode + signed manifest.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./skills": {
      "import": "./dist/skills/index.js",
      "types": "./dist/skills/index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime/cf-browser.js",
      "types": "./dist/runtime/cf-browser.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@mcpoverflow/cli": "1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser-rendering",
    "cloudflare",
    "web-scraping",
    "ai-agents"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
