# AgentKit Configuration
# Generated by MCPoverflow for {{config.serviceName}}

# Agent metadata
name: "{{config.serviceName}}"
description: "{{config.description}}"
version: "{{config.serviceVersion}}"
author: "{{config.author}}"
homepage: "{{config.homepage}}"

# Runtime configuration
runtime:
  type: "cloudflare_worker"
  entry_point: "main.go"
  environment: "production"
  timeout: 30

# Agent permissions
permissions:
  # Network access for API calls
  - type: "network"
    scope: "outbound"
    description: "Allow outbound HTTP requests to external APIs"
    constraints:
      allowed_domains:
        {{#each config.allowedDomains}}
        - "{{this}}"
        {{/each}}

  # File system access (if needed)
  {{#if config.needsFileSystem}}
  - type: "filesystem"
    scope: "read_write"
    description: "Read/write access to temporary files"
    constraints:
      max_file_size: "10MB"
      allowed_paths:
        - "/tmp/"
  {{/if}}

  # API access permissions
  {{#each config.apiPermissions}}
  - type: "api"
    scope: "{{this.scope}}"
    description: "{{this.description}}"
    constraints:
      rate_limit:
        requests_per_minute: {{this.rateLimit}}
      allowed_methods:
        {{#each this.methods}}
        - "{{this}}"
        {{/each}}
  {{/each}}

# Tools configuration
tools:
  {{#each tools}}
  - name: "{{this.name}}"
    description: "{{this.description}}"
    input_schema:
      type: "object"
      properties:
        {{#each this.parameters}}
        "{{this.name}}":
          type: "{{this.type}}"
          description: "{{this.description}}"
          {{#if this.required}}
          required: true
          {{/if}}
        {{/each}}
      required:
        {{#each this.requiredParameters}}
        - "{{this}}"
        {{/each}}
  {{/each}}

# Deployment configuration
deployment:
  platform: "cloudflare"
  region: "auto"
  environment_variables:
    {{#each config.environment}}
    "{{this.key}}": "{{this.value}}"
    {{/each}}
  secrets:
    {{#each config.secrets}}
    "{{this.key}}": "${{this.key}}"
    {{/each}}

# Monitoring and observability
monitoring:
  enabled: true
  metrics:
    - "invocation_count"
    - "response_time"
    - "error_rate"
    - "memory_usage"
  logging:
    level: "info"
    format: "json"
  tracing:
    enabled: true
    sample_rate: 0.1

# Integration configuration
integrations:
  agentkit:
    enabled: true
    auto_register: true
    sync_interval: "5m"
    webhook_url: "${AGENTKIT_WEBHOOK_URL}"
    api_key: "${AGENTKIT_API_KEY}"

  # MCP protocol configuration
  mcp:
    protocol_version: "2024-11-05"
    capabilities:
      - "tools"
      - "resources"
      - "prompts"
    transport:
      - "websocket"
      - "http"

# Security configuration
security:
  authentication:
    type: "jwt"
    secret: "${JWT_SECRET}"
    token_expiry: "24h"

  authorization:
    enabled: true
    roles:
      - "admin"
      - "user"
      - "readonly"

  rate_limiting:
    enabled: true
    requests_per_minute: 100
    burst_size: 20

# Resource limits
limits:
  max_memory: "128MB"
  max_cpu_time: "50ms"
  max_concurrent_requests: 10
  max_request_size: "1MB"

# Health checks
health_checks:
  enabled: true
  endpoints:
    - "/health"
    - "/ready"
    - "/metrics"
  interval: "30s"
  timeout: "5s"
  retries: 3

# Backup and recovery
backup:
  enabled: false
  # Note: Backups are typically not needed for stateless workers

recovery:
  max_retries: 3
  retry_delay: "1s"
  backoff_factor: 2
  max_backoff: "10s"

# Documentation
documentation:
  api_doc_url: "https://{{config.domain}}/docs"
  repository_url: "{{config.repository}}"
  examples:
    - name: "Basic usage"
      description: "How to use this agent"
      code: |
        # Example code for using the agent
        print("Hello from {{config.serviceName}}")

# Tags and categories
tags:
  - "mcp"
  - "api"
  - "automation"
  {{#each config.tags}}
  - "{{this}}"
  {{/each}}

categories:
  - "api_integration"
  - "automation"
  - "developer_tools"