{
  "name": "@mcpoverflow/cli",
  "version": "1.0.0",
  "description": "Generate MCP servers from OpenAPI specifications",
  "type": "module",
  "bin": {
    "mcpoverflow": "./dist/cli.js",
    "mcp-gen": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "yaml": "^2.4.5",
    "ora": "^8.0.1",
    "inquirer": "^9.2.23",
    "handlebars": "^4.7.8",
    "@apidevtools/json-schema-ref-parser": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openapi",
    "code-generator",
    "cli",
    "ai",
    "claude"
  ],
  "author": "MCPOverflow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcpoverflow/mcpoverflow.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
