{
  "name": "mcpoverflow",
  "version": "0.1.4",
  "description": "Personal AI Operating System - MCP Connector Generation Platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*",
    "services/*"
  ],
  "scripts": {
    "vite-build": "vite build",
    "preview": "vite preview",
    "vite-typecheck": "tsc --noEmit -p tsconfig.app.json",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=@mcpoverflow/app-io",
    "dev:api": "npm run dev --workspace=@mcpoverflow/api-service",
    "build": "npm run build --workspaces",
    "build:apps": "npm run build --workspaces --if-present",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:workspaces": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "bootstrap": "npm install && npm run build --workspace=@mcpoverflow/config && npm run build --workspaces --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "i18next": "^25.5.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^7.9.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.7",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "husky": "^8.0.3",
    "i18next": "^25.5.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsdom": "^27.1.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vitest": "^4.0.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "mcp",
    "ai",
    "agents",
    "openapi",
    "cloudflare",
    "workers",
    "personal-ai-os"
  ],
  "author": "MCPOverflow Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcpoverflow/mcpoverflow.git"
  },
  "bugs": {
    "url": "https://github.com/mcpoverflow/mcpoverflow/issues"
  },
  "homepage": "https://mcpoverflow.com",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.go": [
      "go fmt",
      "go vet"
    ]
  },
  "overrides": {
    "@sentry/core": "^10.38.0"
  }
}
