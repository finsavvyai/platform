# FinSavvyAI Production Environment Variables

# Database Configuration
DATABASE_URL=postgresql://finsavvy:secure_password_here@postgres:5432/finsavvyai
DB_NAME=finsavvyai
DB_USER=finsavvy
DB_PASSWORD=secure_password_here

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# API Keys & Credentials
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234

# Service Configuration
ENVIRONMENT=production
FINSAVVYAI_LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8040
SECRET_KEY=your_super_secret_key_change_in_prod
FINSAVVYAI_AUTH_ENABLED=true
JWT_EXPIRY_MINUTES=60

# Monitoring & Observability
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=secure_grafana_password
SENTRY_DSN=https://xxxxxxxxxxxx@sentry.io/xxxx

# Cluster Configuration
CLUSTER_NAME=production-cluster
MASTER_NODE_ID=master-1
WORKER_NODES=worker-1,worker-2,worker-3
MDNS_ENABLED=true

# Governance & Security
RATE_LIMIT_PER_MINUTE=1000
MAX_CONCURRENT_REQUESTS=500
COST_LIMIT_USD_PER_DAY=10000
JWT_ALGORITHM=HS256
FINSAVVYAI_PAYMENT_WEBHOOK_SECRET=replace_with_real_webhook_secret

# CORS Configuration
FINSAVVYAI_CORS_ORIGINS=https://app.finsavvyai.com,https://dashboard.finsavvyai.com
ALLOW_CREDENTIALS=true
FINSAVVYAI_CHECKOUT_BASE_URL=https://checkout.finsavvyai.com/sessions

# Email Configuration (for alerts)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL=ops@finsavvyai.com

# SSL/TLS
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/finsavvyai.crt
SSL_KEY_PATH=/etc/ssl/private/finsavvyai.key

# Feature Flags
ENABLE_COST_OPTIMIZATION=true
ENABLE_MULTI_PROVIDER_ROUTING=true
ENABLE_AGENT_GOVERNANCE=true
ENABLE_AUTO_FAILOVER=true
