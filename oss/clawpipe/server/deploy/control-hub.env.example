# Control Hub production env example

# Published host port -> container 9090
CONTROL_HUB_PORT=9091

# Upstream service defaults for compose network
CONTROL_HUB_OPENCLAW_BASE_URL=http://openclaw:11434
CONTROL_HUB_GATEWAY_URL=http://gateway:8080
CONTROL_HUB_MASTER_URL=http://master:8000

# Security and hardening
CONTROL_HUB_BASIC_AUTH=admin:change-me
CONTROL_HUB_FETCH_TIMEOUT_MS=15000
CONTROL_HUB_ENABLE_DOCKER_HELPERS=false
CONTROL_HUB_PROXY_ALLOWLIST=openclaw,gateway,master,worker,localhost,127.0.0.1
CONTROL_HUB_TRUST_PROXY=false
CONTROL_HUB_RATE_LIMIT_ENABLED=true
CONTROL_HUB_RATE_LIMIT_WINDOW_MS=60000
CONTROL_HUB_RATE_LIMIT_MAX=120
CONTROL_HUB_AUDIT_LOG_ENABLED=true
CONTROL_HUB_AUDIT_LOG_HEALTHZ=false
# In-container path; persisted via control_hub_state volume.
CONTROL_HUB_AUDIT_LOG_FILE=/app/.control-hub/control-hub-audit.log

# Optional TLS reverse proxy profile ("edge")
# CONTROL_HUB_PROXY_HTTPS_PORT=9443

# Optional split credentials (instead of CONTROL_HUB_BASIC_AUTH)
# CONTROL_HUB_BASIC_USER=admin
# CONTROL_HUB_BASIC_PASS=change-me
