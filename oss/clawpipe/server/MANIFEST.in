include README.md
include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md
include SECURITY.md
include pyproject.toml
include .env.example

recursive-include src *.py
recursive-include src *.yaml
recursive-include src *.json

recursive-include docs *.md
recursive-include helm *.yaml *.tpl

exclude .github
exclude tests
exclude *.log
prune __pycache__
prune .pytest_cache
prune dist
prune build
