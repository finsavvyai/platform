# =============================================================================
# FinSavvyAI — Environment Configuration
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in at least ONE cloud provider key (or point to a local Ollama).
# 3. Run: finsavvyai quickstart   (or docker run -p 8080:8080 finsavvyai/finsavvyai)
# 4. Verify: curl http://localhost:8080/health?verbose=true
# =============================================================================

# -----------------------------------------------------------------------------
# Cloud LLM Providers — set at least one to enable cloud routing
# -----------------------------------------------------------------------------

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Local Models (Ollama) — no key required; runs automatically if Ollama is up
# -----------------------------------------------------------------------------

# Base URL of your local Ollama instance (default: localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Local Models (LM Studio) — no key required; runs automatically if LM Studio is up
# -----------------------------------------------------------------------------

# Base URL of your local LM Studio instance (default: localhost:1234)
# LM Studio provides an OpenAI-compatible API server
# Enable API Server in LM Studio: Settings → Developer → Enable API Server
LMSTUDIO_BASE_URL=http://localhost:1234

# -----------------------------------------------------------------------------
# OpenHands Bridge (optional) — LunaOS OpenHands fork bridge API
# -----------------------------------------------------------------------------

# Set to true to enable the OpenHands provider
OPENHANDS_ENABLED=false

# Base URL of your OpenHands instance
OPENHANDS_BASE_URL=http://localhost:8000

# API key for OpenHands (leave empty if unauthenticated)
OPENHANDS_API_KEY=

# Path used for code-execution tasks
OPENHANDS_EXECUTE_PATH=/api/execute

# Default model name passed to OpenHands
OPENHANDS_DEFAULT_MODEL=openhands/default

# -----------------------------------------------------------------------------
# API Gateway — network binding
# -----------------------------------------------------------------------------

# Host the gateway listens on (0.0.0.0 = all interfaces)
FINSAVVYAI_GATEWAY_HOST=0.0.0.0

# Port the gateway listens on — this is your base_url port for OpenAI SDK
FINSAVVYAI_GATEWAY_PORT=8080

# Request timeout in seconds (increase for slow model inference)
FINSAVVYAI_TIMEOUT=60

# Max incoming request body size in bytes (default 10 MB)
FINSAVVYAI_MAX_REQUEST_SIZE=10485760

# -----------------------------------------------------------------------------
# Cluster / Worker nodes — optional for multi-machine distributed inference
# -----------------------------------------------------------------------------

# Hostname of the master coordinator node
FINSAVVYAI_MASTER_HOST=localhost

# Port of the master coordinator node
FINSAVVYAI_MASTER_PORT=8000

# Worker node port (each worker increments from this base)
FINSAVVYAI_WORKER_PORT=8001

# -----------------------------------------------------------------------------
# Security — harden these for production deployments
# -----------------------------------------------------------------------------

# Set to true to require FINSAVVYAI_API_KEY on every request
FINSAVVYAI_AUTH_ENABLED=false

# Your gateway API key (required when AUTH_ENABLED=true)
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
FINSAVVYAI_API_KEY=

# Auth mode: none | dev | service | jwt
FINSAVVYAI_AUTH_MODE=none

# Comma-separated CORS allowed origins (use * only in development)
FINSAVVYAI_CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Maximum requests per window per client IP
FINSAVVYAI_RATE_LIMIT_REQUESTS=100

# Rate limit window in seconds
FINSAVVYAI_RATE_LIMIT_WINDOW=60

# Enable request queuing for traffic spikes (true/false)
FINSAVVYAI_QUEUE_ENABLED=false

# Maximum requests held in the queue
FINSAVVYAI_QUEUE_MAX_SIZE=1000

# Maximum concurrent requests processed from the queue
FINSAVVYAI_QUEUE_MAX_CONCURRENT=10

# -----------------------------------------------------------------------------
# Observability & Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
FINSAVVYAI_LOG_LEVEL=INFO

# Set to true to emit structured JSON logs (recommended in production)
FINSAVVYAI_LOG_JSON=false

# Prometheus metrics scrape port (0 = disabled, uses /metrics on gateway port)
FINSAVVYAI_METRICS_PORT=0

# Jaeger/OTLP trace export endpoint (leave empty to disable tracing)
FINSAVVYAI_TRACE_ENDPOINT=

# NotebookLM Features
FINSAVVYAI_NOTEBOOKLM_ENABLED=true
FINSAVVYAI_SOURCES_PATH=./sources
FINSAVVYAI_NOTEBOOKS_PATH=./notebooks

# Source Processing
SOURCE_CHUNK_SIZE=1000
SOURCE_CHUNK_OVERLAP=200
MAX_CONTEXT_LENGTH=10000

# -----------------------------------------------------------------------------
# Cluster Identity
# -----------------------------------------------------------------------------

# Unique identifier for this cluster (used in multi-cluster setups)
FINSAVVYAI_CLUSTER_ID=finsavvy-production-cluster

# Path to local model files (for worker nodes with on-device inference)
FINSAVVYAI_MODELS_DIR=./models

# -----------------------------------------------------------------------------
# Rate Limiting Toggle
# -----------------------------------------------------------------------------

# Enable or disable rate limiting globally (true/false)
FINSAVVYAI_RATE_LIMIT_ENABLED=true

# -----------------------------------------------------------------------------
# Docker Resource Limits (used in docker-compose.production.yml)
# -----------------------------------------------------------------------------

# Memory limit for the master coordinator container
MASTER_MEMORY_LIMIT=1G

# Memory limit for each worker container
WORKER_MEMORY_LIMIT=16G

# Memory limit for the API gateway container
GATEWAY_MEMORY_LIMIT=2G

# -----------------------------------------------------------------------------
# Observability Stack
# -----------------------------------------------------------------------------

# How many days Prometheus retains time-series data
PROMETHEUS_RETENTION_DAYS=30

# Grafana admin password (change in production!)
GRAFANA_ADMIN_PASSWORD=changeme
