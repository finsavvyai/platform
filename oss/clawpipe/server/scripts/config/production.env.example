# FinSavvyAI Production Environment Variables
# Copy this file to .env and configure for your environment
# IMPORTANT: Never commit the actual .env file to version control

# =============================================================================
# MASTER SERVER
# =============================================================================
FINSAVVYAI_MASTER_HOST=0.0.0.0
FINSAVVYAI_MASTER_PORT=8000
FINSAVVYAI_CLUSTER_ID=finsavvy-production-cluster

# =============================================================================
# API GATEWAY
# =============================================================================
FINSAVVYAI_GATEWAY_HOST=0.0.0.0
FINSAVVYAI_GATEWAY_PORT=8080

# =============================================================================
# WORKER NODES
# =============================================================================
FINSAVVYAI_WORKER_DEFAULT_PORT=8001
FINSAVVYAI_WORKER_HEARTBEAT_INTERVAL=30
FINSAVVYAI_MODELS_DIR=/opt/finsavvyai/models

# =============================================================================
# SECURITY (all REQUIRED for production)
# =============================================================================
FINSAVVYAI_AUTH_ENABLED=true
FINSAVVYAI_API_KEY=               # Generate with: python3 scripts/manage_api_keys.py generate --name production
FINSAVVYAI_RATE_LIMIT_ENABLED=true
FINSAVVYAI_RATE_LIMIT_REQUESTS=100
FINSAVVYAI_RATE_LIMIT_WINDOW=60
FINSAVVYAI_CORS_ORIGINS=https://llm.finsavvyai.com

# =============================================================================
# LOGGING & OBSERVABILITY
# =============================================================================
FINSAVVYAI_LOG_LEVEL=INFO
FINSAVVYAI_LOG_FILE=/var/log/finsavvyai/finsavvyai.log
FINSAVVYAI_LOG_FORMAT=json

# =============================================================================
# CLOUDFLARE TUNNEL (for secure remote access)
# =============================================================================
CLOUDFLARE_TUNNEL_TOKEN=           # From: cloudflared tunnel create finsavvyai
CLOUDFLARE_TUNNEL_ID=              # UUID from tunnel creation
CLOUDFLARE_DOMAIN=llm.finsavvyai.com

# =============================================================================
# CLOUDFLARE WORKER (proxy layer)
# =============================================================================
CLUSTER_MASTER_URL=https://master.llm.finsavvyai.com
GATEWAY_URL=https://gateway.llm.finsavvyai.com
AI_WORKER_URL=https://worker.llm.finsavvyai.com

# =============================================================================
# MONITORING
# =============================================================================
GRAFANA_ADMIN_PASSWORD=            # Change from default!
PROMETHEUS_RETENTION_DAYS=30
ALERTMANAGER_SLACK_WEBHOOK=        # Optional: Slack webhook for alerts
ALERTMANAGER_EMAIL=                # Optional: Email for alerts

# =============================================================================
# BACKUP
# =============================================================================
BACKUP_DIR=/opt/finsavvyai/backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *         # Daily at 2 AM

# =============================================================================
# RESOURCE LIMITS
# =============================================================================
MASTER_MEMORY_LIMIT=1G
GATEWAY_MEMORY_LIMIT=2G
WORKER_MEMORY_LIMIT=16G
WORKER_CPU_QUOTA=800%

# =============================================================================
# OPTIONAL: External LLM API Keys
# =============================================================================
# OPENAI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here
# HF_TOKEN=your-huggingface-token
