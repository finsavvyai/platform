# FinSavvyAI AWS-style CLI Configuration File
# Place in ~/.finsavvyai/config

[default]
region = home-cluster-1
output = table
profile = default

[development]
region = dev-cluster-1
output = json
profile = development

[production]
region = prod-cluster-1
output = table
profile = production
verbose = true

[staging]
region = staging-cluster-1
output = yaml
profile = staging

# Service endpoints
[api]
base_url = http://10.0.0.10:8000
timeout = 30
retry_count = 3

# Advanced settings
[advanced]
auto_discovery = true
load_balancing = round_robin
health_check_interval = 30
max_concurrent_requests = 10
