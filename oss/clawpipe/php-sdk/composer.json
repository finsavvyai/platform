{
  "name": "clawpipe/clawpipe-ai",
  "description": "ClawPipe SDK — apply pre-LLM optimization with one line of code; measured benchmark in progress",
  "type": "library",
  "license": "MIT",
  "keywords": ["llm", "ai", "openai", "anthropic", "cost-optimization", "prompt-caching"],
  "homepage": "https://clawpipe.ai",
  "require": {
    "php": ">=8.0",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  },
  "autoload": {
    "psr-4": {
      "ClawPipe\\": "src/ClawPipe/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ClawPipe\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
