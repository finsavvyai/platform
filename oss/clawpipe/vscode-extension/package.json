{
  "name": "clawpipe-vscode",
  "displayName": "ClawPipe",
  "description": "ClawPipe AI pipeline integration — cost tracking, prompt analysis, and booster checks in VS Code.",
  "version": "3.0.0",
  "publisher": "clawpipe",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "llm",
    "cost-optimization",
    "clawpipe",
    "pipeline"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clawpipe.analyzeCost",
        "title": "ClawPipe: Analyze Prompt Cost"
      },
      {
        "command": "clawpipe.checkBooster",
        "title": "ClawPipe: Check Booster"
      },
      {
        "command": "clawpipe.showStats",
        "title": "ClawPipe: Show Stats"
      }
    ],
    "configuration": {
      "title": "ClawPipe",
      "properties": {
        "clawpipe.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your ClawPipe API key"
        },
        "clawpipe.projectId": {
          "type": "string",
          "default": "vscode-default",
          "description": "ClawPipe project ID"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "tsc --noEmit",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "clawpipe-ai": "^3.0.0"
  }
}
