# ClawPipe Self-Hosted — Environment Variables
# Copy to .env and fill in values before running docker compose up

# ── Gateway ──────────────────────────────────────────────
AUTH_SECRET=replace-with-random-64-char-string
GATEWAY_PORT=8787

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgres://clawpipe:changeme@postgres:5432/clawpipe
POSTGRES_DB=clawpipe
POSTGRES_USER=clawpipe
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ── Redis (cache layer) ─────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ── LLM Provider API Keys ───────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ── Stripe Billing ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_TEAM=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
STRIPE_METERED_PRICE=price_xxx

# ── Dashboard ────────────────────────────────────────────
DASHBOARD_PORT=3000
