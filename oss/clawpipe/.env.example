CLAWPIPE_API_KEY=cp_xxx
CLAWPIPE_PROJECT_ID=my-app

# Optional gateway override for the pre-push smoke (pushci.yml smoke stage).
# Leave unset to hit https://api.clawpipe.ai. The smoke self-provisions a
# throwaway .test-TLD user per run and cleans up after itself.
# CLAWPIPE_API_URL=https://api.clawpipe.ai
