# Provider keys (required for benchmark runs, NOT for harness scaffolding)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# HuggingFace (required for LMSYS-Chat-1M; you must accept the dataset terms first)
HF_TOKEN=

# Cloudflare AI Gateway — needed for Baseline C
CF_ACCOUNT_ID=
CF_AI_GATEWAY_ID=
CF_API_TOKEN=

# ClawPipe gateway URL (Baseline D)
CLAWPIPE_GATEWAY_URL=https://api.clawpipe.ai
CLAWPIPE_API_KEY=
CLAWPIPE_PROJECT_ID=

# Spend cap — bench halts if total cost crosses this
BENCH_SPEND_CAP_USD=80

# Random seed (do not change between runs)
BENCH_SEED=2026-05-02-clawpipe-booster
