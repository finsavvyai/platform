{
  "name": "clawpipe-ai",
  "version": "3.7.0",
  "description": "The intelligent AI pipeline. Booster, Context Packing, Caching, Smart Routing, Multi-Provider Gateway, Budget Caps, Rate Limiting, Circuit Breaker, Audit Logging — all in one SDK.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./openai-compat": {
      "types": "./dist/openai-compat.d.ts",
      "import": "./dist/openai-compat.js",
      "require": "./dist/openai-compat.js",
      "default": "./dist/openai-compat.js"
    },
    "./anthropic-compat": {
      "types": "./dist/anthropic-compat.d.ts",
      "import": "./dist/anthropic-compat.js",
      "require": "./dist/anthropic-compat.js",
      "default": "./dist/anthropic-compat.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "clawpipe": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:stress": "for i in $(seq 1 50); do echo \"Run $i/50\"; vitest run --reporter=dot 2>&1 || exit 1; done && echo 'All 50 runs passed'",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "ai",
    "pipeline",
    "caching",
    "routing",
    "openai",
    "anthropic",
    "deepseek",
    "cost-optimization",
    "swarm",
    "rag",
    "semantic-cache",
    "voice",
    "tracing",
    "offline"
  ],
  "author": "ClawPipe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finsavvyai/clawpipe-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/finsavvyai/clawpipe-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  },
  "homepage": "https://clawpipe.ai",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
