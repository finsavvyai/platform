{
  "name": "@finsavvyai/auth",
  "version": "0.1.0",
  "description": "JWT, RBAC, and middleware for Express/Hono",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "peerDependencies": {
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "prettier": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "auth",
    "jwt",
    "rbac",
    "express",
    "hono",
    "typescript"
  ]
}
