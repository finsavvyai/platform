  "keywords": ["cloudflare", "workers", "templates", "scaffolding"],
  "author": "FinSavvy AI",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
