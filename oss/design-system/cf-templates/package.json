{
  "name": "@finsavvyai/cf-templates",
  "version": "1.0.0",
  "type": "module",
  "description": "Cloudflare Workers project templates and scaffolding",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
