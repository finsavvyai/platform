{
  "name": "upm-plus-cloudflare-workers",
  "version": "1.0.0",
  "description": "UPM.Plus AutomationHub Cloudflare Workers for edge computing and global distribution",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "eslint src --ext .js,.ts --fix",
    "type-check": "tsc --noEmit",
    "build": "webpack --mode=production",
    "db:migrate": "wrangler d1 migrations apply upm_plus_db --env production",
    "db:migrate:staging": "wrangler d1 migrations apply upm_plus_db --env staging"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "edge-computing",
    "automation",
    "upm-plus"
  ],
  "author": "UPM.Plus Team",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231025.0",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "typescript": "^5.2.2",
    "vitest": "^0.34.4",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "~0.3.0",
    "hono": "^3.4.0",
    "zod": "^3.22.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}