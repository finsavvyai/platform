{
  "name": "UPM.Plus Cloudflare Manager",
  "version": "1.0.0",
  "description": "Automated Cloudflare domain management for UPM.Plus multi-domain infrastructure",
  "author": "Shahar Solomon",
  "license": "MIT",
  "homepage": "https://github.com/shahar-solomon/upm.plus",
  "repository": {
    "type": "git",
    "url": "https://github.com/shahar-solomon/upm.plus.git"
  },
  "keywords": [
    "cloudflare",
    "domain-management",
    "upm-plus",
    "automation",
    "dns",
    "ssl",
    "cdn"
  ],
  "category": "Developer Tools",
  "main": "cloudflare-production-server.py",
  "scripts": {
    "start": "python3 cloudflare-production-server.py",
    "test": "python3 -m pytest tests/",
    "lint": "python3 -m flake8 *.py",
    "install": "pip3 install -r requirements.txt"
  },
  "dependencies": {
    "fastapi": "^0.108.0",
    "uvicorn": "^0.25.0",
    "pydantic": "^2.5.3",
    "python-dotenv": "^1.0.0",
    "httpx": "^0.26.0",
    "cloudflare": "^2.20.0"
  },
  "mcp": {
    "server": "cloudflare-production-server.py",
    "tools": [
      "get_domains",
      "create_dns_record",
      "update_dns_record",
      "delete_dns_record",
      "configure_ssl",
      "configure_security",
      "purge_cache",
      "get_analytics",
      "deploy_all_domains"
    ]
  },
  "engines": {
    "python": ">=3.9"
  },
  "files": [
    "cloudflare-production-server.py",
    "cloudflare-demo-server.py",
    "requirements.txt",
    "README.md",
    ".env.example"
  ]
}
