{
  "mcpServers": {
    "cloudflare-upm": {
      "command": "python",
      "args": ["mcp-servers/cloudflare-mcp-server/cloudflare-mcp-server.py"],
      "env": {
        "CLOUDFLARE_API_TOKEN": "${CLOUDFLARE_API_TOKEN}",
        "CLOUDFLARE_ACCOUNT_ID": "${CLOUDFLARE_ACCOUNT_ID}",
        "UPM_DOMAINS": "upm.plus,upmplus.dev,upmplus.io,upmplus.ai"
      }
    },
    "upm-plus-dev": {
      "command": "python",
      "args": ["-m", "uvicorn", "backend.app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "/Users/shaharsolomon/dev/projects/github/upm.plus",
      "env": {
        "PYTHONPATH": "/Users/shaharsolomon/dev/projects/github/upm.plus/backend",
        "DATABASE_URL": "${DATABASE_URL}",
        "REDIS_URL": "${REDIS_URL}",
        "SECRET_KEY": "${SECRET_KEY}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      }
    }
  },
  "tools": {
    "cloudflare": {
      "description": "Manage Cloudflare domains, DNS, SSL, and Workers for UPM.Plus deployment",
      "server": "cloudflare-upm"
    },
    "upm-dev": {
      "description": "Interact with UPM.Plus development backend",
      "server": "upm-plus-dev"
    }
  }
}