# Cloudflare API Configuration
# Get your API token from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:Zone:Read, Zone:DNS:Edit, Zone:Page Rules:Edit, Zone:Workers:Edit

CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Zone IDs for UPM.Plus domains
# Get these from your Cloudflare dashboard or using: cloudflare zone list
CLOUDFLARE_ZONE_ID_UPM_PLUS=zone_id_for_upm_plus
CLOUDFLARE_ZONE_ID_UPMPLUS_DEV=zone_id_for_upmplus_dev
CLOUDFLARE_ZONE_ID_UPMPLUS_IO=zone_id_for_upmplus_io
CLOUDFLARE_ZONE_ID_UPMPLUS_AI=zone_id_for_upmplus_ai

# UPM.Plus domains
PRIMARY_DOMAIN=upm.plus
DEVELOPMENT_DOMAIN=upmplus.dev
STAGING_DOMAIN=upmplus.io
PRODUCTION_DOMAIN=upmplus.ai