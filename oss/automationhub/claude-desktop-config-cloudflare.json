{
  "mcpServers": {
    "cloudflare-upm": {
      "command": "python",
      "args": [
        "/Users/shaharsolomon/dev/projects/github/upm.plus/mcp-servers/cloudflare-mcp-server.py"
      ],
      "env": {
        "CLOUDFLARE_API_TOKEN": "${CLOUDFLARE_API_TOKEN}",
        "CLOUDFLARE_ZONE_ID_UPM_PLUS": "${CLOUDFLARE_ZONE_ID_UPM_PLUS}",
        "CLOUDFLARE_ZONE_ID_UPMPLUS_DEV": "${CLOUDFLARE_ZONE_ID_UPMPLUS_DEV}",
        "CLOUDFLARE_ZONE_ID_UPMPLUS_IO": "${CLOUDFLARE_ZONE_ID_UPMPLUS_IO}",
        "CLOUDFLARE_ZONE_ID_UPMPLUS_AI": "${CLOUDFLARE_ZONE_ID_UPMPLUS_AI}",
        "PRIMARY_DOMAIN": "upm.plus",
        "DEVELOPMENT_DOMAIN": "upmplus.dev",
        "STAGING_DOMAIN": "upmplus.io",
        "PRODUCTION_DOMAIN": "upmplus.ai"
      }
    }
  }
