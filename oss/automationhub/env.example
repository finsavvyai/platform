# =====================================================
# UPM.Plus Enterprise Configuration
# Copy this file to .env and configure for your environment
# =====================================================

# -----------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------
ENVIRONMENT=production
DEBUG=false

# -----------------------------------------------------
# SECURITY (Required - Generate unique values!)
# -----------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-min-64-characters-long-change-this
MFA_ENCRYPTION_KEY=your-mfa-encryption-key-also-change-this

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------
# DATABASE
# -----------------------------------------------------
# PostgreSQL (Production)
DATABASE_URL=postgresql+asyncpg://upmplus:your-strong-password@postgres:5432/upmplus
POSTGRES_DB=upmplus
POSTGRES_USER=upmplus
POSTGRES_PASSWORD=your-strong-password

# SQLite (Development only)
# DATABASE_URL=sqlite+aiosqlite:///./test.db

# -----------------------------------------------------
# REDIS
# -----------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -----------------------------------------------------
# VECTOR DATABASE (ChromaDB)
# -----------------------------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# -----------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# -----------------------------------------------------
# FRONTEND
# -----------------------------------------------------
REACT_APP_API_URL=http://localhost:8001/api/v1
REACT_APP_WS_URL=ws://localhost:8001/ws

# -----------------------------------------------------
# AI SERVICES (Optional but recommended)
# -----------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# -----------------------------------------------------
# BILLING (Stripe - Required for paid features)
# -----------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# -----------------------------------------------------
# EMAIL NOTIFICATIONS (Optional)
# -----------------------------------------------------
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@your-domain.com

# -----------------------------------------------------
# EMBEDDED INTEGRATIONS (built-in, see docs/INTEGRATION_OPENCLAW_OPENHANDS.md)
# -----------------------------------------------------
# OpenClaw (embedded gateway - Slack, Discord, Telegram)
# OPENCLAW_ENABLED=true
# OPENCLAW_GATEWAY_TOKEN=  # from docker-setup or generate
# OPENCLAW_WEBHOOK_SECRET=  # for internal backend<->gateway

# OpenHands (embedded SDK - code gen, refactor, debug)
# OPENHANDS_ENABLED=true
# OPENHANDS_MODE=sdk  # sdk (embedded) | cloud
# LLM_API_KEY=  # or OPENAI_API_KEY / ANTHROPIC_API_KEY for SDK
# OPENHANDS_WORKSPACE_ROOT=  # optional sandbox path

