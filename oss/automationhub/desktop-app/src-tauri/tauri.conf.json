{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3030",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "UPM.Plus",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "createDir": true,
        "removeDir": true,
        "copyFile": true,
        "exists": true,
        "scope": ["$HOME/**", "$DESKTOP/**", "$DOCUMENT/**", "$DOWNLOAD/**"]
      },
      "path": {
        "all": true
      },
      "process": {
        "all": false,
        "relaunch": true,
        "exit": true
      },
      "shell": {
        "all": false,
        "open": true,
        "scope": [
          {
            "name": "https",
            "cmd": "open",
            "args": ["https://**"]
          },
          {
            "name": "localhost",
            "cmd": "open",
            "args": ["http://localhost:**"]
          }
        ]
      },
      "window": {
        "all": false,
        "center": true,
        "close": true,
        "create": true,
        "hide": true,
        "maximize": true,
        "minimize": true,
        "print": true,
        "requestUserAttention": true,
        "setAlwaysOnTop": true,
        "setClosable": true,
        "setCursorGrab": true,
        "setCursorVisible": true,
        "setDecorations": true,
        "setFocus": true,
        "setFullscreen": true,
        "setIcon": true,
        "setMaxSize": true,
        "setMinSize": true,
        "setPosition": true,
        "setResizable": true,
        "setSize": true,
        "setSkipTaskbar": true,
        "setTitle": true,
        "show": true,
        "startDragging": true,
        "unmaximize": true,
        "unminimize": true
      },
      "notification": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.upmplus.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "category": "DeveloperTool",
      "copyright": "Copyright © 2025 UPM.Plus Team",
      "longDescription": "UPM.Plus is an autonomous digital ecosystem orchestrator that combines browser automation, infrastructure management, conversational AI, workflow orchestration, and knowledge management into a single, self-evolving platform.",
      "shortDescription": "Autonomous Digital Ecosystem Orchestrator",
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": "10.15",
        "exceptionDomain": ""
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      },
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": true,
      "endpoints": ["https://api.upmplus.ai/updater/{{target}}/{{current_version}}"],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEMjU1MTkKUldRWEZjcU1rNDBCZWliQWZJZmIyWUt6V3IyQzMyVUwzS3FRRzZCZVZXQWlGSGlHeUF4MW5CUWI4UXBQM2pWagotPi0tZW5kIG9mIHB1YmxpYyBrZXktLT4K"
    },
    "windows": [
      {
        "label": "main",
        "url": "/",
        "fullscreen": false,
        "resizable": true,
        "title": "UPM.Plus",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ]
  }
}