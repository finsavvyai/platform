{
  "name": "upm-plus-desktop",
  "version": "0.1.0",
  "description": "UPM.Plus Desktop - Native macOS Application with Vue 3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "vitest",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write .",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@heroicons/vue": "^2.0.0",
    "@tauri-apps/api": "^1.5.0",
    "@vueuse/core": "^10.1.0",
    "chart.js": "^4.3.0",
    "date-fns": "^2.30.0",
    "pinia": "^2.1.0",
    "playwright": "^1.55.1",
    "vue": "^3.3.0",
    "vue-chartjs": "^5.2.0",
    "vue-router": "^4.2.0",
    "zod": "^3.21.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/typography": "^0.5.9",
    "@tauri-apps/cli": "^1.5.0",
    "@types/node": "^20.3.0",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "@vitejs/plugin-vue": "^4.2.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.38.0",
    "eslint-plugin-vue": "^9.14.0",
    "postcss": "^8.4.23",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "vite": "^4.3.0",
    "vue-tsc": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/upm-plus"
  },
